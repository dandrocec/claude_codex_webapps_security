# Verification-only placeholder secrets.
#
# These are THROWAWAY values supplied uniformly to EVERY container (identical for
# variant A and B, identical across all apps) so that apps which correctly read
# secrets from the environment can start during the build/stays-up check.
#
# This is runtime CONFIGURATION, not a security control: it adds no hardening,
# validation, or headers. It only provides *a* value for secrets the app demands.
# It is applied uniformly, so it advantages no app or variant. NOT for production.
#
# Var names cover the common conventions; an app reads whichever it expects and
# ignores the rest. Add a name here if a future app needs a differently-named one.

# --- session / app secrets ---
# 64 hex chars (decodes to 32 bytes) so apps that validate a 32-byte key derived
# from SECRET_KEY (e.g. S100-A AES key) accept it; still a valid arbitrary string
# for Flask/Express apps that only need a non-empty secret.
SECRET_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
APP_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
APP_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
FLASK_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
DJANGO_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
SESSION_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
COOKIE_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000

# --- tokens / JWT ---
JWT_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
JWT_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
TOKEN_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
ACCESS_TOKEN_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
REFRESH_TOKEN_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000

# --- misc keys / app bootstrap ---
APP_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
API_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
# App-specific secret names (an app reads whichever it expects; non-empty value
# satisfies a "must be set" guard). LEDGER_SECRET_KEY: S093-codex-B.
LEDGER_SECRET_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
# Demo/seed account password >=12 chars for apps that seed a demo user at first
# run (e.g. S092-codex-B requires DEMO_PASSWORD>=12). Reuses the strong-password value.
DEMO_PASSWORD=Csj-Verify-Placeholder-Pw1
# 64 hex chars (32 bytes) so apps that validate AES-256 key format (e.g. S090-B) accept it.
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
WEBHOOK_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
ADMIN_USERNAME=admin
# Strong throwaway admin password: satisfies len>=12 + lower + UPPER + digit +
# special (e.g. S072-codex-B's strong_password() check). Still a valid non-empty
# admin password for any app that only needs a non-empty value (backward-compatible).
ADMIN_PASSWORD=Csj-Verify-Placeholder-Pw1
# Valid email format so apps that bootstrap an admin from ADMIN_EMAIL +
# ADMIN_PASSWORD (e.g. S072-codex-B) pass their email validation.
ADMIN_EMAIL=admin@example.com

# --- OAuth provider client config (throwaway; lets OAuth apps construct their
#     strategy and serve the landing page. The OAuth round-trip itself is not exercised). ---
GITHUB_CLIENT_ID=csj_verify_placeholder_client_id
GITHUB_CLIENT_SECRET=csj_verify_placeholder_client_secret
OAUTH_CALLBACK_URL=http://localhost/auth/callback
BASE_URL=http://localhost
# Generic OAuth var names (some apps use OAUTH_* + APP_ORIGIN + explicit
# endpoint URLs instead of GITHUB_*; e.g. S090-codex-B). Throwaway placeholders +
# valid URLs so the app can construct its OAuth client and serve the landing
# page; the round-trip is not exercised.
APP_ORIGIN=http://localhost
OAUTH_CLIENT_ID=csj_verify_placeholder_client_id
OAUTH_CLIENT_SECRET=csj_verify_placeholder_client_secret
OAUTH_AUTHORIZATION_URL=https://provider.example.com/oauth/authorize
OAUTH_TOKEN_URL=https://provider.example.com/oauth/token
OAUTH_USERINFO_URL=https://provider.example.com/oauth/userinfo
