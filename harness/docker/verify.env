# Verification-only placeholder secrets.
#
# These are THROWAWAY values supplied uniformly to EVERY container (identical for
# variant A and B, identical across all apps) so that apps which correctly read
# secrets from the environment can start during the build/stays-up check.
#
# This is runtime CONFIGURATION, not a security control: it adds no hardening,
# validation, or headers. It only provides *a* value for secrets the app demands.
# It is applied uniformly, so it advantages no app or variant. NOT for production.
#
# Var names cover the common conventions; an app reads whichever it expects and
# ignores the rest. Add a name here if a future app needs a differently-named one.

# --- session / app secrets ---
SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
APP_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
FLASK_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
DJANGO_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
SESSION_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
COOKIE_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000

# --- tokens / JWT ---
JWT_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
JWT_SECRET_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
TOKEN_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
ACCESS_TOKEN_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000
REFRESH_TOKEN_SECRET=csj_verify_placeholder_0000000000000000000000000000000000000000000000

# --- misc keys / app bootstrap ---
APP_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
API_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
ENCRYPTION_KEY=csj_verify_placeholder_0000000000000000000000000000000000000000000000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=csj_verify_placeholder_admin_pw
