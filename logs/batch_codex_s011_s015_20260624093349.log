+:root {
+    color-scheme: light;
+    --bg: #f4f7fb;
+    --panel: #ffffff;
+    --text: #17202a;
+    --muted: #5d6978;
+    --line: #d8e0ea;
+    --accent: #2266cc;
+    --accent-dark: #174c99;
+    --danger: #b42318;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    min-height: 100vh;
+    font-family: Arial, Helvetica, sans-serif;
+    background: var(--bg);
+    color: var(--text);
+}
+
+a {
+    color: var(--accent);
+}
+
+.page {
+    width: min(680px, calc(100% - 32px));
+    margin: 48px auto;
+    padding: 28px;
+    background: var(--panel);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    box-shadow: 0 16px 40px rgba(23, 32, 42, 0.08);
+}
+
+.page.wide {
+    width: min(1100px, calc(100% - 32px));
+}
+
+.page.compact {
+    width: min(520px, calc(100% - 32px));
+}
+
+.header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 20px;
+    margin-bottom: 24px;
+}
+
+h1 {
+    margin: 0;
+    font-size: 32px;
+    line-height: 1.2;
+}
+
+p {
+    color: var(--muted);
+    line-height: 1.6;
+}
+
+.form {
+    display: grid;
+    gap: 18px;
+}
+
+label {
+    display: grid;
+    gap: 8px;
+    font-weight: 700;
+}
+
+input,
+textarea {
+    width: 100%;
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    padding: 12px;
+    font: inherit;
+    color: var(--text);
+    background: #fff;
+}
+
+input:focus,
+textarea:focus {
+    outline: 3px solid rgba(34, 102, 204, 0.18);
+    border-color: var(--accent);
+}
+
+textarea {
+    resize: vertical;
+}
+
+button {
+    justify-self: start;
+    border: 0;
+    border-radius: 6px;
+    padding: 12px 18px;
+    font: inherit;
+    font-weight: 700;
+    color: #fff;
+    background: var(--accent);
+    cursor: pointer;
+}
+
+button:hover {
+    background: var(--accent-dark);
+}
+
+.error {
+    color: var(--danger);
+    font-weight: 400;
+}
+
+.actions {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 16px;
+    margin-top: 22px;
+}
+
+.empty {
+    margin-bottom: 0;
+}
+
+.table-wrap {
+    overflow-x: auto;
+}
+
+table {
+    width: 100%;
+    border-collapse: collapse;
+}
+
+th,
+td {
+    padding: 12px;
+    border-bottom: 1px solid var(--line);
+    text-align: left;
+    vertical-align: top;
+}
+
+th {
+    color: var(--muted);
+    font-size: 13px;
+    text-transform: uppercase;
+}
+
+.message {
+    min-width: 280px;
+    white-space: normal;
+}
+
+@media (max-width: 620px) {
+    .page {
+        margin: 20px auto;
+        padding: 20px;
+    }
+
+    .header {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    h1 {
+        font-size: 26px;
+    }
+}
