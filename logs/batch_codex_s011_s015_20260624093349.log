diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..07928774e4f2caedea93714d19bb0b0da5568b85
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,190 @@
+:root {
+  color-scheme: light;
+  --bg: #f4f7f6;
+  --panel: #ffffff;
+  --text: #1d2528;
+  --muted: #5f6f75;
+  --accent: #0f766e;
+  --accent-dark: #115e59;
+  --border: #d7e0df;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent-dark);
+}
+
+.shell {
+  width: min(920px, calc(100% - 32px));
+  margin: 0 auto;
+  padding: 28px 0 48px;
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.25rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  margin-bottom: 20px;
+  padding: 24px;
+}
+
+.auth-panel {
+  max-width: 460px;
+}
+
+h1,
+h2 {
+  margin: 0 0 18px;
+}
+
+form {
+  display: grid;
+  gap: 16px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+input {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 10px 12px;
+  width: 100%;
+}
+
+button,
+.button-link {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 14px;
+  text-decoration: none;
+}
+
+button:hover,
+.button-link:hover {
+  background: var(--accent-dark);
+}
+
+.link-button {
+  background: transparent;
+  color: var(--accent-dark);
+  padding: 0;
+}
+
+.link-button:hover {
+  background: transparent;
+  text-decoration: underline;
+}
+
+.secondary-link {
+  display: inline-block;
+  margin-left: 12px;
+}
+
+.muted {
+  color: var(--muted);
+}
+
+.messages {
+  margin-bottom: 16px;
+}
+
+.message {
+  background: #eef8f6;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  margin: 0 0 8px;
+  padding: 10px 12px;
+}
+
+.message.error {
+  background: #fff1f0;
+  color: var(--danger);
+}
+
+.image-list {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.image-list li {
+  align-items: center;
+  border-top: 1px solid var(--border);
+  display: flex;
+  gap: 12px;
+  justify-content: space-between;
+  padding: 12px 0;
+}
+
+.image-list li:first-child {
+  border-top: 0;
+}
+
+.image-list span {
+  color: var(--muted);
+  font-size: 0.9rem;
+}
+
+.preview {
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  margin-bottom: 16px;
+  overflow: auto;
+  padding: 16px;
+}
+
+.preview img {
+  display: block;
+  height: auto;
+  max-width: 100%;
+}
+
+@media (max-width: 640px) {
+  .panel {
+    padding: 18px;
+  }
+
+  .image-list li {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..a5a49d7e9899ab9b41466f5451440a56629f70cf
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,34 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{{ title|default("Image Resizer") }}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <main class="shell">
+      <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Image Resizer</a>
+        {% if g.user %}
+          <form method="post" action="{{ url_for('logout') }}">
+            {{ csrf_token() }}
+            <button class="link-button" type="submit">Sign out</button>
+          </form>
+        {% endif %}
+      </header>
+
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <section class="messages" aria-live="polite">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </section>
+        {% endif %}
+      {% endwith %}
+
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/detail.html b/templates/detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..cd302d47032e251de2788f467be28adf4d3dfdd0
--- /dev/null
+++ b/templates/detail.html
@@ -0,0 +1,14 @@
+{% extends "base.html" %}
+{% block content %}
+  <section class="panel">
+    <h1>Thumbnail {{ image.id }}</h1>
+    <div class="preview">
+      <img src="{{ url_for('thumbnail', image_id=image.id) }}" alt="Resized thumbnail {{ image.id }}">
+    </div>
+    <p class="muted">Generated at {{ image.created_at }} with target width {{ image.target_width }} px.</p>
+    <p>
+      <a class="button-link" href="{{ url_for('download', image_id=image.id) }}">Download thumbnail</a>
+      <a class="secondary-link" href="{{ url_for('index') }}">Back</a>
+    </p>
+  </section>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
