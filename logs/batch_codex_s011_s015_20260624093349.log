diff --git a/static/app.js b/static/app.js
new file mode 100644
index 0000000000000000000000000000000000000000..8d186dc821b2df7764aa87643287bec27b203209
--- /dev/null
+++ b/static/app.js
@@ -0,0 +1,26 @@
+const quoteText = document.querySelector("#quote-text");
+const quoteAuthor = document.querySelector("#quote-author");
+const newQuoteButton = document.querySelector("#new-quote");
+
+async function showNewQuote() {
+  newQuoteButton.disabled = true;
+
+  try {
+    const response = await fetch("/api/quote");
+
+    if (!response.ok) {
+      throw new Error("Unable to load quote");
+    }
+
+    const quote = await response.json();
+    quoteText.textContent = quote.text;
+    quoteAuthor.textContent = `- ${quote.author}`;
+  } catch (error) {
+    quoteText.textContent = "Keep going. A fresh quote is only a reload away.";
+    quoteAuthor.textContent = "- Quote app";
+  } finally {
+    newQuoteButton.disabled = false;
+  }
+}
+
+newQuoteButton.addEventListener("click", showNewQuote);
diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..72a4230d45280122a111a7ed542d84b5c7c1fe32
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,116 @@
+:root {
+  color-scheme: light;
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+  background: #f5f7f2;
+  color: #1e2720;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  min-height: 100vh;
+  margin: 0;
+  background:
+    linear-gradient(135deg, rgba(37, 78, 112, 0.12), transparent 36%),
+    linear-gradient(315deg, rgba(218, 142, 77, 0.16), transparent 34%),
+    #f5f7f2;
+}
+
+.quote-shell {
+  min-height: 100vh;
+  display: grid;
+  place-items: center;
+  padding: 24px;
+}
+
+.quote-panel {
+  width: min(100%, 680px);
+  padding: clamp(28px, 6vw, 56px);
+  border: 1px solid rgba(30, 39, 32, 0.12);
+  border-radius: 8px;
+  background: rgba(255, 255, 255, 0.88);
+  box-shadow: 0 24px 80px rgba(30, 39, 32, 0.14);
+}
+
+.eyebrow {
+  margin: 0 0 20px;
+  color: #b45f35;
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+blockquote {
+  margin: 0;
+}
+
+blockquote p {
+  min-height: 132px;
+  margin: 0;
+  font-size: clamp(2rem, 4vw, 3.4rem);
+  font-weight: 750;
+  line-height: 1.08;
+  text-wrap: balance;
+}
+
+blockquote footer {
+  margin-top: 22px;
+  color: #4b5b50;
+  font-size: 1.05rem;
+  font-weight: 650;
+}
+
+button {
+  margin-top: 36px;
+  border: 0;
+  border-radius: 6px;
+  background: #254e70;
+  color: #ffffff;
+  cursor: pointer;
+  font: inherit;
+  font-weight: 800;
+  padding: 14px 18px;
+  transition:
+    background 160ms ease,
+    transform 160ms ease,
+    opacity 160ms ease;
+}
+
+button:hover {
+  background: #173a56;
+  transform: translateY(-1px);
+}
+
+button:focus-visible {
+  outline: 3px solid rgba(180, 95, 53, 0.45);
+  outline-offset: 3px;
+}
+
+button:disabled {
+  cursor: wait;
+  opacity: 0.68;
+  transform: none;
+}
+
+@media (max-width: 520px) {
+  .quote-shell {
+    padding: 16px;
+  }
+
+  .quote-panel {
+    padding: 26px;
+  }
+
+  blockquote p {
+    min-height: 184px;
+  }
+
+  button {
+    width: 100%;
+  }
+}
