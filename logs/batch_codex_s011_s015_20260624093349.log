@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+{% block content %}
+  <section class="panel auth-panel">
+    <h1>Sign in</h1>
+    <form method="post" novalidate>
+      {{ form.hidden_tag() }}
+      <label>
+        <span>Email</span>
+        {{ form.email(autocomplete="email") }}
+      </label>
+      <label>
+        <span>Password</span>
+        {{ form.password(autocomplete="current-password") }}
+      </label>
+      <button type="submit">Sign in</button>
+    </form>
+    <p class="muted">Need an account? <a href="{{ url_for('register') }}">Create one</a>.</p>
+  </section>
+{% endblock %}
diff --git a/templates/register.html b/templates/register.html
new file mode 100644
index 0000000000000000000000000000000000000000..55b3fb8c0e115031ce213a869bb2c772aacc1870
--- /dev/null
+++ b/templates/register.html
@@ -0,0 +1,19 @@
