+{% extends "base.html" %}
+{% block content %}
+  <section class="panel">
+    <h1>Thumbnail {{ image.id }}</h1>
+    <div class="preview">
+      <img src="{{ url_for('thumbnail', image_id=image.id) }}" alt="Resized thumbnail {{ image.id }}">
+    </div>
+    <p class="muted">Generated at {{ image.created_at }} with target width {{ image.target_width }} px.</p>
+    <p>
+      <a class="button-link" href="{{ url_for('download', image_id=image.id) }}">Download thumbnail</a>
+      <a class="secondary-link" href="{{ url_for('index') }}">Back</a>
+    </p>
+  </section>
+{% endblock %}
