diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..f4c6cb071161c4131f55aeb044ef1e28143412fd
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,217 @@
+:root {
+  color-scheme: light;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: #f5f7fb;
+  color: #172033;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+}
+
+.site-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 3rem);
+  background: #ffffff;
+  border-bottom: 1px solid #dde3ee;
+}
+
+.brand,
+nav a,
+.link-button {
+  color: #17324d;
+  text-decoration: none;
+  font-weight: 700;
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+  flex-wrap: wrap;
+}
+
+.inline {
+  display: inline;
+}
+
+.link-button {
+  appearance: none;
+  border: 0;
+  background: transparent;
+  padding: 0;
+  font: inherit;
+  cursor: pointer;
+}
+
+main {
+  width: min(920px, calc(100% - 2rem));
+  margin: 0 auto;
+  padding: clamp(2rem, 7vw, 5rem) 0;
+}
+
+.quote-panel,
+.form-panel,
+.list-panel {
+  background: #ffffff;
+  border: 1px solid #dbe3ef;
+  border-radius: 8px;
+  padding: clamp(1.5rem, 5vw, 3rem);
+  box-shadow: 0 18px 50px rgba(28, 43, 68, 0.08);
+}
+
+.eyebrow {
+  margin: 0 0 0.4rem;
+  color: #5b6f87;
+  font-weight: 800;
+  text-transform: uppercase;
+  font-size: 0.78rem;
+}
+
+h1 {
+  margin: 0 0 1.5rem;
+  font-size: clamp(2rem, 5vw, 3.5rem);
+  line-height: 1.05;
+}
+
+blockquote {
+  margin: 0;
+}
+
+blockquote p {
+  margin: 0;
+  font-size: clamp(1.6rem, 4vw, 2.5rem);
+  line-height: 1.22;
+  font-weight: 800;
+}
+
+blockquote footer {
+  margin-top: 1rem;
+  color: #60758b;
+  font-size: 1.05rem;
+}
+
+blockquote footer::before {
+  content: "- ";
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.75rem;
+  margin-top: 2rem;
+}
+
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 2.75rem;
+  padding: 0.7rem 1rem;
+  border: 1px solid #aeb9c8;
+  border-radius: 6px;
+  background: #ffffff;
+  color: #172033;
+  font: inherit;
+  font-weight: 800;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+.button.primary {
+  border-color: #1b5d8f;
+  background: #1b5d8f;
+  color: #ffffff;
+}
+
+.button.danger {
+  border-color: #9b2f2f;
+  color: #9b2f2f;
+}
+
+form {
+  display: grid;
+  gap: 0.75rem;
+}
+
+label {
+  font-weight: 800;
+}
+
+input {
+  width: 100%;
+  min-height: 2.75rem;
+  border: 1px solid #aeb9c8;
+  border-radius: 6px;
+  padding: 0.65rem 0.75rem;
+  font: inherit;
+}
+
+.messages {
+  display: grid;
+  gap: 0.5rem;
+  margin-bottom: 1rem;
+}
+
+.message {
+  margin: 0;
+  padding: 0.8rem 1rem;
+  border-radius: 6px;
+  border: 1px solid #ccd7e4;
+  background: #ffffff;
+}
+
+.message.error {
+  border-color: #dfaaaa;
+  color: #7c2424;
+}
+
+.message.success {
+  border-color: #a6cdb8;
+  color: #1f6840;
+}
+
+.favorites {
+  display: grid;
+  gap: 1rem;
+  padding: 0;
+  margin: 0;
+  list-style: none;
+}
+
+.favorites li {
+  display: grid;
+  gap: 1rem;
+  padding: 1rem;
+  border: 1px solid #dbe3ef;
+  border-radius: 8px;
+}
+
+.favorites blockquote p {
+  font-size: 1.2rem;
+}
+
+.empty {
+  margin: 0;
+  color: #60758b;
+}
+
+@media (max-width: 620px) {
+  .site-header {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .button,
+  .actions form {
+    width: 100%;
+  }
+}
