+{% extends "base.html" %}
+{% block title %}Error | Daily Spark{% endblock %}
+{% block content %}
+  <section class="form-panel" aria-labelledby="error-heading">
+    <h1 id="error-heading">Something went wrong</h1>
+    <p>{{ message }}</p>
+    <a class="button primary" href="{{ url_for('index') }}">Return home</a>
+  </section>
+{% endblock %}
diff --git a/templates/favorites.html b/templates/favorites.html
new file mode 100644
