+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Image Thumbnail Resizer</title>
+    <style>
+      :root {
+        color-scheme: light;
+        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+        background: #f5f7fb;
+        color: #172033;
+      }
+
+      * {
+        box-sizing: border-box;
+      }
+
+      body {
+        margin: 0;
+        min-height: 100vh;
+        display: grid;
+        place-items: center;
+        padding: 32px 16px;
+      }
+
+      main {
+        width: min(760px, 100%);
+        background: #ffffff;
+        border: 1px solid #dbe2ef;
+        border-radius: 8px;
+        box-shadow: 0 20px 45px rgba(23, 32, 51, 0.08);
+        padding: clamp(24px, 4vw, 42px);
+      }
+
+      h1 {
+        margin: 0 0 8px;
+        font-size: clamp(2rem, 5vw, 3.2rem);
+        line-height: 1.05;
+        letter-spacing: 0;
+      }
+
+      p {
+        margin: 0;
+        color: #58647a;
+        line-height: 1.6;
+      }
+
+      form {
+        display: grid;
+        gap: 20px;
+        margin-top: 32px;
+      }
+
+      label {
+        display: grid;
+        gap: 8px;
+        font-weight: 700;
+      }
+
+      input {
+        width: 100%;
+        border: 1px solid #c7d0df;
+        border-radius: 6px;
+        padding: 12px 14px;
+        color: #172033;
+        font: inherit;
+        background: #ffffff;
+      }
+
+      input:focus {
+        border-color: #1b76d1;
+        outline: 3px solid rgba(27, 118, 209, 0.18);
+      }
+
+      button,
+      .download {
+        display: inline-flex;
+        align-items: center;
+        justify-content: center;
+        min-height: 46px;
+        border: 0;
+        border-radius: 6px;
+        padding: 0 18px;
+        background: #1460aa;
+        color: #ffffff;
+        font: inherit;
+        font-weight: 700;
+        text-decoration: none;
+        cursor: pointer;
+      }
+
+      button:hover,
+      .download:hover {
+        background: #0f4f8d;
+      }
+
+      .messages {
+        margin-top: 22px;
+        padding: 14px 16px;
+        border: 1px solid #ffd2a3;
+        border-radius: 6px;
+        background: #fff7ed;
+        color: #8a3c00;
+      }
+
+      .result {
+        margin-top: 32px;
+        display: grid;
+        gap: 18px;
+        border-top: 1px solid #e3e8f1;
+        padding-top: 28px;
+      }
+
+      .preview {
+        width: 100%;
+        display: grid;
+        place-items: center;
+        min-height: 180px;
+        background: #eef2f7;
+        border: 1px solid #dbe2ef;
+        border-radius: 8px;
+        padding: 16px;
+      }
+
+      img {
+        max-width: 100%;
+        height: auto;
+        border-radius: 4px;
+        display: block;
+      }
+
+      .meta {
+        display: flex;
+        flex-wrap: wrap;
+        align-items: center;
+        justify-content: space-between;
+        gap: 14px;
+      }
+
+      @media (max-width: 520px) {
+        body {
+          padding: 16px;
+          place-items: start center;
+        }
+
+        main {
+          padding: 22px;
+        }
+
+        .meta {
+          align-items: stretch;
+        }
+
+        .download {
+          width: 100%;
+        }
+      }
+    </style>
+  </head>
+  <body>
+    <main>
+      <h1>Image Thumbnail Resizer</h1>
+      <p>Upload an image, choose a target width, then preview and download the resized thumbnail.</p>
+
+      {% with messages = get_flashed_messages() %}
+        {% if messages %}
+          <div class="messages">
+            {% for message in messages %}
+              <div>{{ message }}</div>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+
+      <form method="post" enctype="multipart/form-data">
+        <label>
+          Image file
+          <input type="file" name="image" accept="image/png,image/jpeg,image/gif,image/webp" required>
+        </label>
+
+        <label>
+          Target width in pixels
+          <input type="number" name="width" min="1" max="5000" value="320" required>
+        </label>
+
+        <button type="submit">Generate Thumbnail</button>
+      </form>
+
+      {% if result %}
+        <section class="result" aria-label="Generated thumbnail">
+          <div class="preview">
+            <img src="{{ result.preview_url }}" alt="Generated thumbnail preview">
+          </div>
+          <div class="meta">
+            <p>Generated size: {{ result.width }} x {{ result.height }} px</p>
+            <a class="download" href="{{ result.download_url }}">Download Thumbnail</a>
+          </div>
+        </section>
+      {% endif %}
+    </main>
+  </body>
+</html>

