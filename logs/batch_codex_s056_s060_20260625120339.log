index 0000000000000000000000000000000000000000..6c00064834d99d5e70e7e12c69333e4606384ae4
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,295 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #17202a;
+  --muted: #5d6975;
+  --line: #d9dee6;
+  --accent: #1967d2;
+  --accent-dark: #104a9a;
+  --danger: #b42318;
+  --success: #0f7b45;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 3rem);
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  font-size: 1.2rem;
+  font-weight: 700;
+  color: var(--text);
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 0.75rem;
+}
+
+.container {
+  width: min(1040px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.page-heading,
+.dashboard-head,
+.form-panel,
+.post-card,
+.post-detail,
+.error-page {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.page-heading,
+.dashboard-head,
+.form-panel,
+.post-detail,
+.error-page {
+  padding: 1.5rem;
+}
+
+.dashboard-head {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 1rem;
+  margin-bottom: 1.25rem;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+.meta {
+  color: var(--muted);
+  font-size: 0.93rem;
+}
+
+.post-list {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+  gap: 1rem;
+  margin-top: 1rem;
+}
+
+.post-card {
+  padding: 1.2rem;
+}
+
+.post-card h2,
+.post-card h3 {
+  margin-bottom: 0.4rem;
+}
+
+.form-panel {
+  max-width: 520px;
+  margin: 0 auto;
+}
+
+.form-panel.wide {
+  max-width: 780px;
+}
+
+label {
+  display: block;
+  font-weight: 700;
+  margin-top: 1rem;
+}
+
+input,
+select,
+textarea {
+  width: 100%;
+  margin-top: 0.35rem;
+  padding: 0.7rem 0.75rem;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  background: #fff;
+}
+
+textarea {
+  min-height: 220px;
+  resize: vertical;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  border: 0;
+  border-radius: 6px;
+  padding: 0.62rem 0.9rem;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+button.danger,
+.danger {
+  background: var(--danger);
+}
+
+.button.secondary {
+  background: #eef2f7;
+  color: var(--text);
+}
+
+.inline-form,
+.actions form {
+  display: inline-flex;
+  margin: 0;
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: 0.5rem;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  overflow: hidden;
+}
+
+th,
+td {
+  padding: 0.85rem;
+  border-bottom: 1px solid var(--line);
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  background: #eef2f7;
+}
+
+.status {
+  display: inline-block;
+  padding: 0.2rem 0.45rem;
+  border-radius: 999px;
+  background: #eef2f7;
+  color: var(--text);
+  font-size: 0.85rem;
+}
+
+.simple-list {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 1rem 1rem 1rem 2rem;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message,
+.notice,
+.empty {
+  border-radius: 8px;
+  padding: 0.8rem 1rem;
+  background: var(--panel);
+  border: 1px solid var(--line);
+}
+
+.message.success {
+  border-color: var(--success);
+}
+
+.message.danger,
+.errors {
+  color: var(--danger);
+}
+
+.message.warning,
+.message.info {
+  border-color: var(--accent);
+}
+
+.errors {
+  margin: 0.35rem 0 0;
+  padding-left: 1.2rem;
+}
+
+.body {
+  white-space: normal;
+  font-size: 1.05rem;
+}
+
+.error-page {
+  text-align: center;
+}
+
+@media (max-width: 720px) {
+  .site-header,
+  .dashboard-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  table,
+  thead,
+  tbody,
+  th,
+  td,
+  tr {
+    display: block;
+  }
+
+  thead {
+    display: none;
+  }
+
+  tr {
+    border-bottom: 1px solid var(--line);
+  }
+}
