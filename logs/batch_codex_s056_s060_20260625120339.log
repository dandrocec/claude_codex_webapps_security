--- /dev/null
+++ b/package.json
@@ -0,0 +1,20 @@
+{
+  "name": "room-reservation-system",
+  "version": "1.0.0",
+  "description": "Node.js/Express room reservation system with SQLite storage.",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js"
+  },
+  "dependencies": {
+    "bcryptjs": "^2.4.3",
+    "better-sqlite3": "^11.8.1",
+    "ejs": "^3.1.10",
+    "express": "^4.21.2",
+    "express-session": "^1.18.1",
+    "helmet": "^8.0.0"
+  },
+  "engines": {
+    "node": ">=18"
+  }
+}
diff --git a/public/styles.css b/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..6c9d89e6f6669f383e96574a6e6de988f1377b1f
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,376 @@
+:root {
+  --bg: #f6f7f9;
+  --surface: #ffffff;
+  --text: #1d2430;
+  --muted: #677386;
+  --line: #dce1e8;
