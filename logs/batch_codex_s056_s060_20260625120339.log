+        WHERE t.id = ?
+    SQL);
+    $stmt->execute([$threadId]);
+    $thread = $stmt->fetch();
+
+    if (!$thread || $thread['deleted_at']) {
+        echo '<div class="panel">Thread not found.</div>';
+        return;
