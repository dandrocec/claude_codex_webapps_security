diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..6c00064834d99d5e70e7e12c69333e4606384ae4
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,295 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #17202a;
+  --muted: #5d6975;
+  --line: #d9dee6;
+  --accent: #1967d2;
+  --accent-dark: #104a9a;
+  --danger: #b42318;
+  --success: #0f7b45;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 3rem);
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  font-size: 1.2rem;
+  font-weight: 700;
+  color: var(--text);
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 0.75rem;
+}
+
+.container {
+  width: min(1040px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.page-heading,
+.dashboard-head,
+.form-panel,
+.post-card,
+.post-detail,
+.error-page {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.page-heading,
+.dashboard-head,
+.form-panel,
+.post-detail,
+.error-page {
+  padding: 1.5rem;
+}
+
+.dashboard-head {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 1rem;
+  margin-bottom: 1.25rem;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+.meta {
+  color: var(--muted);
+  font-size: 0.93rem;
+}
+
+.post-list {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+  gap: 1rem;
+  margin-top: 1rem;
+}
+
+.post-card {
+  padding: 1.2rem;
+}
+
+.post-card h2,
+.post-card h3 {
+  margin-bottom: 0.4rem;
+}
+
+.form-panel {
+  max-width: 520px;
+  margin: 0 auto;
+}
+
+.form-panel.wide {
+  max-width: 780px;
+}
+
+label {
+  display: block;
+  font-weight: 700;
+  margin-top: 1rem;
+}
+
+input,
+select,
+textarea {
+  width: 100%;
+  margin-top: 0.35rem;
+  padding: 0.7rem 0.75rem;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  background: #fff;
+}
+
+textarea {
+  min-height: 220px;
+  resize: vertical;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  border: 0;
+  border-radius: 6px;
+  padding: 0.62rem 0.9rem;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+button.danger,
+.danger {
+  background: var(--danger);
+}
+
+.button.secondary {
+  background: #eef2f7;
+  color: var(--text);
+}
+
+.inline-form,
+.actions form {
+  display: inline-flex;
+  margin: 0;
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: 0.5rem;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  overflow: hidden;
+}
+
+th,
+td {
+  padding: 0.85rem;
+  border-bottom: 1px solid var(--line);
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  background: #eef2f7;
+}
+
+.status {
+  display: inline-block;
+  padding: 0.2rem 0.45rem;
+  border-radius: 999px;
+  background: #eef2f7;
+  color: var(--text);
+  font-size: 0.85rem;
+}
+
+.simple-list {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 1rem 1rem 1rem 2rem;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message,
+.notice,
+.empty {
+  border-radius: 8px;
+  padding: 0.8rem 1rem;
+  background: var(--panel);
+  border: 1px solid var(--line);
+}
+
+.message.success {
+  border-color: var(--success);
+}
+
+.message.danger,
+.errors {
+  color: var(--danger);
+}
+
+.message.warning,
+.message.info {
+  border-color: var(--accent);
+}
+
+.errors {
+  margin: 0.35rem 0 0;
+  padding-left: 1.2rem;
+}
+
+.body {
+  white-space: normal;
+  font-size: 1.05rem;
+}
+
+.error-page {
+  text-align: center;
+}
+
+@media (max-width: 720px) {
+  .site-header,
+  .dashboard-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  table,
+  thead,
+  tbody,
+  th,
+  td,
+  tr {
+    display: block;
+  }
+
+  thead {
+    display: none;
+  }
+
+  tr {
+    border-bottom: 1px solid var(--line);
+  }
+}
diff --git a/templates/_field.html b/templates/_field.html
new file mode 100644
index 0000000000000000000000000000000000000000..fa168f57e757ef2d101b5078f8521df689e81b4d
--- /dev/null
+++ b/templates/_field.html
@@ -0,0 +1,11 @@
+{% for field in form if field.type not in ("CSRFTokenField", "SubmitField", "HiddenField") %}
+  <label for="{{ field.id }}">{{ field.label.text }}</label>
+  {{ field }}
+  {% if field.errors %}
+    <ul class="errors">
+      {% for error in field.errors %}
+        <li>{{ error }}</li>
+      {% endfor %}
+    </ul>
+  {% endif %}
+{% endfor %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..075cd111f9de2450568b43e086abfd939a8b6fd9
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Role Blog{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">Role Blog</a>
+    <nav>
+      <a href="{{ url_for('index') }}">Public posts</a>
+      {% if g.user %}
+        <a href="{{ url_for('dashboard') }}">Dashboard</a>
+        <form class="inline-form" action="{{ url_for('logout') }}" method="post">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages">
+          {% for category, message in messages %}
+            <p class="message {{ category }}">{{ message }}</p>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/dashboard_author.html b/templates/dashboard_author.html
new file mode 100644
index 0000000000000000000000000000000000000000..6e1df4554053df4e5847f81b7f7f82ca9d72594c
--- /dev/null
+++ b/templates/dashboard_author.html
@@ -0,0 +1,46 @@
+{% extends "base.html" %}
+{% block title %}Author Dashboard{% endblock %}
+{% block content %}
+  <section class="dashboard-head">
+    <div>
+      <h1>Author dashboard</h1>
+      <p>Write drafts and submit posts for editor review.</p>
+    </div>
+    <a class="button" href="{{ url_for('new_post') }}">New post</a>
+  </section>
+  {% if posts %}
+    <table>
+      <thead>
+        <tr><th>Title</th><th>Status</th><th>Updated</th><th>Actions</th></tr>
+      </thead>
+      <tbody>
+        {% for post in posts %}
+          <tr>
+            <td><a href="{{ url_for('post_detail', post_id=post.id) }}">{{ post.title }}</a></td>
+            <td><span class="status">{{ post.status }}</span></td>
+            <td>{{ post.updated_at[:10] }}</td>
+            <td class="actions">
+              {% if post.status != "approved" %}
+                <a href="{{ url_for('edit_post', post_id=post.id) }}">Edit</a>
+              {% endif %}
+              {% if post.status in ("draft", "rejected") %}
+                <form method="post" action="{{ url_for('submit_post', post_id=post.id) }}">
+                  {{ submit_form.hidden_tag() }}
+                  <button type="submit">Submit</button>
+                </form>
+              {% endif %}
+              {% if post.status != "approved" %}
+                <form method="post" action="{{ url_for('delete_post', post_id=post.id) }}">
+                  {{ delete_form.hidden_tag() }}
+                  <button class="danger" type="submit">Delete</button>
+                </form>
+              {% endif %}
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p class="empty">No posts yet.</p>
+  {% endif %}
+{% endblock %}
diff --git a/templates/dashboard_editor.html b/templates/dashboard_editor.html
new file mode 100644
index 0000000000000000000000000000000000000000..75e4cec095da4bde3981def85fa7d33da0cb0172
--- /dev/null
+++ b/templates/dashboard_editor.html
@@ -0,0 +1,39 @@
+{% extends "base.html" %}
+{% block title %}Editor Dashboard{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <h1>Editor dashboard</h1>
+    <p>Review submitted posts and publish only approved content.</p>
+  </section>
+  <h2>Pending review</h2>
+  {% if submitted %}
+    <div class="post-list">
+      {% for post in submitted %}
+        <article class="post-card">
+          <h3><a href="{{ url_for('post_detail', post_id=post.id) }}">{{ post.title }}</a></h3>
+          <p class="meta">By {{ post.author }} · submitted {{ post.submitted_at[:10] }}</p>
+          <p>{{ post.body[:180] }}{% if post.body|length > 180 %}...{% endif %}</p>
+          <div class="actions">
+            <form method="post" action="{{ url_for('approve_post', post_id=post.id) }}">
+              {{ approve_form.hidden_tag() }}
+              <button type="submit">Approve</button>
+            </form>
+            <a class="button secondary" href="{{ url_for('reject_post', post_id=post.id) }}">Reject</a>
+          </div>
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty">No posts awaiting review.</p>
+  {% endif %}
+  <h2>Recently approved</h2>
+  {% if approved %}
+    <ul class="simple-list">
+      {% for post in approved %}
+        <li><a href="{{ url_for('post_detail', post_id=post.id) }}">{{ post.title }}</a> by {{ post.author }}</li>
+      {% endfor %}
+    </ul>
+  {% else %}
+    <p class="empty">No approved posts yet.</p>
+  {% endif %}
+{% endblock %}
diff --git a/templates/dashboard_reader.html b/templates/dashboard_reader.html
new file mode 100644
index 0000000000000000000000000000000000000000..ca56b6a2cc848abc95987b3e3419f4aacabdc007
--- /dev/null
+++ b/templates/dashboard_reader.html
@@ -0,0 +1,17 @@
+{% extends "base.html" %}
+{% block title %}Reader Dashboard{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <h1>Reader dashboard</h1>
+    <p>Browse approved posts.</p>
+  </section>
+  {% if posts %}
+    <ul class="simple-list">
+      {% for post in posts %}
+        <li><a href="{{ url_for('post_detail', post_id=post.id) }}">{{ post.title }}</a> by {{ post.author }}</li>
+      {% endfor %}
+    </ul>
+  {% else %}
+    <p class="empty">No approved posts yet.</p>
+  {% endif %}
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
