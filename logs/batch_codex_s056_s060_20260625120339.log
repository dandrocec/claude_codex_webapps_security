+  font-size: 14px;
+}
+
+.schedule thead span,
+.schedule tbody th span {
+  display: block;
+  color: var(--muted);
+  font-size: 12px;
+  font-weight: 400;
+}
+
+.slot-button {
+  width: 100%;
+  min-height: 34px;
+  padding: 7px 10px;
+  font-size: 14px;
+}
+
+.status {
+  display: inline-flex;
+  align-items: center;
+  min-height: 30px;
+  padding: 5px 9px;
+  border-radius: 6px;
+  font-size: 13px;
+  font-weight: 700;
+}
+
+.status.booked {
