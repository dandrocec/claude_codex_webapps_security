diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..6b2013dcadf50f15370155c53b647f888422689c
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+{% block title %}Sign in · Role Blog{% endblock %}
+{% block content %}
+  <section class="auth-panel">
+    <h1>Sign in</h1>
+    <form method="post">
+      <label for="username">Username</label>
+      <input id="username" name="username" autocomplete="username" required>
+
+      <label for="password">Password</label>
+      <input id="password" name="password" type="password" autocomplete="current-password" required>
+
+      <button type="submit">Sign in</button>
+    </form>
+    <div class="demo-logins">
+      <strong>Demo accounts</strong>
+      <span>reader / readerpass</span>
+      <span>author / authorpass</span>
+      <span>editor / editorpass</span>
+    </div>
+  </section>
+{% endblock %}
+
diff --git a/templates/post_detail.html b/templates/post_detail.html
new file mode 100644
