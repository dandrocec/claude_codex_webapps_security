+{% extends "base.html" %}
+{% block title %}Error | Secure Shop{% endblock %}
+{% block content %}
+  <section class="error-page">
+    <h1>{{ code }}</h1>
+    <p>{{ message }}</p>
+    <a href="{{ url_for('index') }}">Return to catalogue</a>
+  </section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..79fd79b93f8a34ea00cf4240d04e08320e37e28c
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+{% block title %}Sign in | Secure Shop{% endblock %}
+{% block content %}
+  <section class="auth-panel">
+    <h1>Sign in</h1>
+    <form method="post" action="{{ url_for('login', next=request.args.get('next', '')) }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label>
+        Username
+        <input name="username" minlength="3" maxlength="32" autocomplete="username" required>
+      </label>
+      <label>
+        Password
+        <input type="password" name="password" minlength="12" maxlength="128" autocomplete="current-password" required>
+      </label>
+      <button type="submit">Sign in</button>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/product.html b/templates/product.html
new file mode 100644
index 0000000000000000000000000000000000000000..e1adbcbe91b2ab98e4891f5e002d9bef6eab6c9d
--- /dev/null
+++ b/templates/product.html
@@ -0,0 +1,54 @@
+{% extends "base.html" %}
+{% block title %}{{ product.name }} | Secure Shop{% endblock %}
+{% block content %}
+  <article class="product-detail">
+    <a href="{{ url_for('index') }}">Back to catalogue</a>
+    <h1>{{ product.name }}</h1>
+    <p class="price">{{ product.price_cents | money }}</p>
+    <p>{{ product.description }}</p>
+    <form method="post" action="{{ url_for('add_to_cart', product_id=product.id) }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label>
+        Quantity
+        <input type="number" name="quantity" min="1" max="20" value="1" inputmode="numeric">
+      </label>
+      <button type="submit">Add to cart</button>
+    </form>
+  </article>
+
+  <section class="comments">
+    <h2>Comments</h2>
+    {% if current_user() %}
+      <form class="comment-form" method="post" action="{{ url_for('add_comment', product_id=product.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <label for="body">Post a comment</label>
+        <textarea id="body" name="body" rows="4" minlength="2" maxlength="800" required></textarea>
+        <button type="submit">Post comment</button>
+      </form>
+    {% else %}
+      <p><a href="{{ url_for('login', next=request.path) }}">Sign in</a> to post a comment.</p>
+    {% endif %}
+
+    {% if comments %}
+      <ol class="comment-list">
+        {% for comment in comments %}
+          <li>
+            <div class="comment-meta">
+              <strong>{{ comment.username }}</strong>
+              <time datetime="{{ comment.created_at }}">{{ comment.created_at }}</time>
+            </div>
+            <p>{{ comment.body }}</p>
+            {% if current_user() and current_user().id == comment.user_id %}
+              <form method="post" action="{{ url_for('delete_comment', comment_id=comment.id) }}">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <button class="secondary" type="submit">Delete</button>
+              </form>
+            {% endif %}
+          </li>
+        {% endfor %}
+      </ol>
+    {% else %}
+      <p>No comments yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/templates/register.html b/templates/register.html
new file mode 100644
index 0000000000000000000000000000000000000000..fb36bfda4e71a4258716716faa2faef329039b53
--- /dev/null
+++ b/templates/register.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+{% block title %}Register | Secure Shop{% endblock %}
