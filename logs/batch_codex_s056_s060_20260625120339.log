+  border-bottom: 1px solid #d9e0e4;
+}
+
+nav {
+  max-width: 920px;
+  margin: 0 auto;
+  padding: 14px 20px;
+  display: flex;
+  align-items: center;
+  gap: 16px;
+  flex-wrap: wrap;
+}
+
+nav span {
+  margin-left: auto;
+  color: #50606a;
+}
+
+a {
+  color: #0b5cad;
