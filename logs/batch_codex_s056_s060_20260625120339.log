diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..98667146c5764fa945fc4426b9f0eeeaf8158dcf
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Role Blog{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">Role Blog</a>
+    <nav>
+      <a href="{{ url_for('index') }}">Public Posts</a>
+      {% if g.user %}
+        <a href="{{ url_for('dashboard') }}">Dashboard</a>
+        <span class="user-chip">{{ g.user.username }} · {{ g.user.role }}</span>
+        <a class="button ghost" href="{{ url_for('logout') }}">Sign out</a>
+      {% else %}
+        <a class="button" href="{{ url_for('login') }}">Sign in</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="flash-stack">
+          {% for category, message in messages %}
+            <p class="flash {{ category }}">{{ message }}</p>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
+
diff --git a/templates/dashboard_author.html b/templates/dashboard_author.html
new file mode 100644
index 0000000000000000000000000000000000000000..8eb2bcfa1ff2bb4256bea8efc337198ae1380d08
--- /dev/null
+++ b/templates/dashboard_author.html
@@ -0,0 +1,51 @@
+{% extends "base.html" %}
+{% block title %}Author Dashboard · Role Blog{% endblock %}
+{% block content %}
+  <section class="page-heading split">
+    <div>
+      <h1>Author dashboard</h1>
+      <p>Draft posts, submit them for review, and track editorial decisions.</p>
+    </div>
+    <a class="button" href="{{ url_for('new_post') }}">New post</a>
+  </section>
+
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th>Title</th>
+          <th>Status</th>
+          <th>Updated</th>
+          <th>Notes</th>
+          <th>Actions</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for post in posts %}
+          <tr>
+            <td>{{ post.title }}</td>
+            <td><span class="status {{ post.status }}">{{ post.status }}</span></td>
+            <td>{{ post.updated_at }}</td>
+            <td>{{ post.rejection_reason or "" }}</td>
+            <td class="actions">
+              {% if post.status != "approved" %}
+                <a class="button small ghost" href="{{ url_for('edit_post', post_id=post.id) }}">Edit</a>
+              {% endif %}
+              {% if post.status in ["draft", "rejected"] %}
+                <form method="post" action="{{ url_for('submit_post', post_id=post.id) }}">
+                  <button class="small" type="submit">Submit</button>
+                </form>
+              {% endif %}
+              {% if post.status == "approved" %}
+                <a class="button small ghost" href="{{ url_for('public_post', post_id=post.id) }}">View</a>
+              {% endif %}
+            </td>
+          </tr>
+        {% else %}
+          <tr><td colspan="5" class="empty">You have not written any posts yet.</td></tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+{% endblock %}
+
diff --git a/templates/dashboard_editor.html b/templates/dashboard_editor.html
new file mode 100644
index 0000000000000000000000000000000000000000..37b0b89d6f3483f1d8237e9292bcf852357f7335
--- /dev/null
+++ b/templates/dashboard_editor.html
@@ -0,0 +1,57 @@
+{% extends "base.html" %}
+{% block title %}Editor Dashboard · Role Blog{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <h1>Editor dashboard</h1>
+    <p>Review submitted posts and publish approved work.</p>
+  </section>
+
+  <h2 class="section-title">Pending review</h2>
+  <div class="review-list">
+    {% for post in pending %}
+      <article class="review-card">
+        <div class="meta">By {{ post.author_name }} · submitted {{ post.created_at }}</div>
+        <h3>{{ post.title }}</h3>
+        <p>{{ post.body }}</p>
+        <div class="review-actions">
+          <form method="post" action="{{ url_for('approve_post', post_id=post.id) }}">
+            <button type="submit">Approve</button>
+          </form>
+          <form method="post" action="{{ url_for('reject_post', post_id=post.id) }}" class="reject-form">
+            <input name="reason" placeholder="Reason for rejection">
+            <button class="danger" type="submit">Reject</button>
+          </form>
+        </div>
+      </article>
+    {% else %}
+      <p class="empty">No posts are waiting for review.</p>
+    {% endfor %}
+  </div>
+
+  <h2 class="section-title">Recent decisions</h2>
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th>Title</th>
+          <th>Author</th>
+          <th>Status</th>
+          <th>Updated</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for post in recent %}
+          <tr>
+            <td>{{ post.title }}</td>
+            <td>{{ post.author_name }}</td>
+            <td><span class="status {{ post.status }}">{{ post.status }}</span></td>
+            <td>{{ post.updated_at }}</td>
+          </tr>
+        {% else %}
+          <tr><td colspan="4" class="empty">No editorial decisions yet.</td></tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+{% endblock %}
+
