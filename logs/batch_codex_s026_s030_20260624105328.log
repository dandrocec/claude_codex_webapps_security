+.toggle:hover {
+  background: #315631;
+}
+
+.link-button {
+  background: transparent;
+  color: #0f5f80;
+  min-height: auto;
+  padding: 0;
+}
+
+.link-button:hover {
+  background: transparent;
+  text-decoration: underline;
+}
+
+.inline-form {
+  display: inline;
+}
+
+.muted {
+  color: #647386;
+}
+
+.alert {
+  border: 1px solid #d92d20;
+  border-radius: 6px;
+  background: #fff4f2;
+  color: #7a271a;
+  margin-bottom: 16px;
+  padding: 10px 12px;
+}
+
+.alert p {
+  margin: 0;
+}
+
+.alert p + p {
+  margin-top: 6px;
+}
+
+.tasks-header {
+  display: flex;
+  align-items: end;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 18px;
+}
+
+.tasks-header p {
+  margin: 0;
+}
+
+.task-create {
+  grid-template-columns: 1fr auto;
+}
+
+.task-list {
+  display: grid;
+  gap: 12px;
+  margin-top: 18px;
+}
+
+.task {
+  display: grid;
+  grid-template-columns: auto 1fr auto;
+  align-items: center;
+  gap: 10px;
+  background: #ffffff;
+  border: 1px solid #d9e0e7;
+  border-radius: 8px;
+  padding: 12px;
+}
+
+.task-edit {
+  grid-template-columns: 1fr auto;
+}
+
+.task.is-complete input {
+  color: #647386;
+  text-decoration: line-through;
+}
+
+.empty {
+  color: #647386;
+  text-align: center;
+  padding: 32px;
+}
+
+.sr-only {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+@media (max-width: 680px) {
+  .topbar,
+  .task,
+  .task-create,
+  .task-edit {
+    grid-template-columns: 1fr;
+  }
+
+  .topbar,
+  nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
