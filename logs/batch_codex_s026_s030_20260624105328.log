+
+.tags a.active {
+  background: var(--primary);
+  border-color: var(--primary);
+  color: #ffffff;
+}
+
+.bookmark-list {
+  display: grid;
+  gap: 14px;
+}
+
+.bookmark {
+  align-items: flex-start;
+  display: flex;
+  gap: 20px;
+  justify-content: space-between;
+  padding: 20px;
+}
+
+.bookmark-actions {
+  flex: 0 0 auto;
+}
+
+.empty {
