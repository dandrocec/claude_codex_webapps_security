+:root {
+  color-scheme: light;
+  --bg: #f7f8fa;
+  --panel: #ffffff;
+  --text: #1c2430;
+  --muted: #667085;
+  --border: #d9dee7;
+  --primary: #1f6feb;
+  --danger: #c93c37;
+  --success-bg: #e9f7ef;
+  --error-bg: #fff0f0;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  line-height: 1.55;
+}
+
+a {
+  color: var(--primary);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+  justify-content: space-between;
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 1rem;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.1rem;
+  font-weight: 700;
+}
+
+.nav-actions {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: .75rem;
+  justify-content: flex-end;
+}
+
+.user,
+.meta {
+  color: var(--muted);
+  font-size: .92rem;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 2rem 1rem;
+}
+
+.page-head,
+.form-panel,
+.post-detail,
+.post-card {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+}
+
+.page-head {
+  margin-bottom: 1rem;
+  padding: 1rem 1.25rem;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 .5rem;
+}
+
+.post-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.post-card,
+.post-detail,
+.form-panel {
+  padding: 1.25rem;
+}
+
+.post-card p:last-child,
+.post-detail p:last-child {
+  margin-bottom: 0;
+}
+
+.post-detail .body {
+  border-top: 1px solid var(--border);
+  margin-top: 1rem;
+  padding-top: 1rem;
+  white-space: normal;
+}
+
+.form-panel {
+  max-width: 720px;
+}
+
+.form-panel.narrow {
+  max-width: 430px;
+}
+
+label {
+  display: block;
+  font-weight: 650;
+  margin: 1rem 0 .35rem;
+}
+
+input,
+textarea {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: .65rem .75rem;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button {
+  align-items: center;
+  background: var(--primary);
+  border: 0;
+  border-radius: 6px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 650;
+  min-height: 2.4rem;
+  padding: .5rem .85rem;
+}
+
+button:hover,
+.button:hover {
+  filter: brightness(.95);
+  text-decoration: none;
+}
+
+button.danger {
+  background: var(--danger);
+}
+
+.inline-form {
+  display: inline;
+}
+
+.owner-actions {
+  display: flex;
