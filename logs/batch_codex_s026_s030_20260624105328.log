+{% extends "base.html" %}
+{% block title %}Your notes - Notes{% endblock %}
+{% block content %}
+<div class="page-header">
+  <h1>Your notes</h1>
+  <a class="button" href="{{ url_for('create_note') }}">New note</a>
+</div>
+
+{% if notes %}
+  <section class="notes-list" aria-label="Notes">
+    {% for note in notes %}
+      <article class="note">
+        <div class="note-content">
+          <h2>{{ note["title"] }}</h2>
+          <p>{{ note["body"] }}</p>
+          <small>Updated {{ note["updated_at"] }}</small>
+        </div>
+        <div class="note-actions">
+          <a class="button secondary" href="{{ url_for('edit_note', note_id=note['id']) }}">Edit</a>
+          <form method="post" action="{{ url_for('delete_note', note_id=note['id']) }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button class="danger" type="submit">Delete</button>
+          </form>
+        </div>
+      </article>
+    {% endfor %}
+  </section>
+{% else %}
+  <section class="empty">
+    <h2>No notes yet</h2>
+    <p>Create your first note to get started.</p>
+  </section>
+{% endif %}
+{% endblock %}
