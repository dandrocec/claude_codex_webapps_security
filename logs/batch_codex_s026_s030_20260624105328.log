diff --git a/views/tasks.ejs b/views/tasks.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b804e78e9d7eaa6bf077121d9541b3f21914da72
--- /dev/null
+++ b/views/tasks.ejs
@@ -0,0 +1,46 @@
+<%- include("partials/page_start", { title: "Tasks" }) %>
+
+<section class="task-shell">
+  <div class="task-heading">
+    <h1>Your tasks</h1>
+    <span><%= tasks.length %> total</span>
+  </div>
+
+  <form action="/tasks" method="post" class="add-form">
+    <input name="title" maxlength="200" placeholder="Add a task" required autofocus>
+    <button type="submit">Add</button>
+  </form>
+
+  <% if (tasks.length === 0) { %>
+    <p class="empty">No tasks yet.</p>
+  <% } %>
+
+  <ul class="task-list">
+    <% tasks.forEach((task) => { %>
+      <li class="task-item <%= task.completed ? "is-complete" : "" %>">
+        <% if (editingTask && editingTask.id === task.id) { %>
+          <form action="/tasks/<%= task.id %>/edit" method="post" class="edit-form">
+            <input name="title" value="<%= task.title %>" maxlength="200" required>
+            <button type="submit">Save</button>
+            <a class="button secondary" href="/tasks">Cancel</a>
+          </form>
+        <% } else { %>
+          <form action="/tasks/<%= task.id %>/toggle" method="post">
+            <button class="check" type="submit" aria-label="<%= task.completed ? "Mark incomplete" : "Mark complete" %>">
+              <%= task.completed ? "✓" : "" %>
+            </button>
+          </form>
+          <span class="task-title"><%= task.title %></span>
+          <div class="task-actions">
+            <a class="button secondary" href="/tasks/<%= task.id %>/edit">Edit</a>
+            <form action="/tasks/<%= task.id %>/delete" method="post">
+              <button type="submit" class="danger">Delete</button>
+            </form>
+          </div>
+        <% } %>
+      </li>
+    <% }) %>
+  </ul>
+</section>
+
+<%- include("partials/page_end") %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..2ecc81c678a5e567791069c59a33b61cc395413a
--- /dev/null
+++ b/README.md
@@ -0,0 +1,14 @@
+# Express To-do App
+
+A Node.js/Express to-do application with registration, login, SQLite storage, and per-user task lists.
+
+## Run locally
+
+```bash
+npm install
+npm start
+```
+
+The app runs on `http://localhost:5027` by default. To use another port, set `PORT` before starting the app.
+
+SQLite database files are created automatically in the project directory on first start.
