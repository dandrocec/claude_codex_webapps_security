+{% extends "base.html" %}
+{% block title %}Log in - Notes{% endblock %}
+{% block content %}
+<section class="panel auth-panel">
+  <h1>Log in</h1>
+  <form method="post" novalidate>
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label for="username">Username</label>
+    <input id="username" name="username" autocomplete="username" minlength="3" maxlength="32" required>
+
+    <label for="password">Password</label>
+    <input id="password" name="password" type="password" autocomplete="current-password" minlength="12" required>
+
+    <button type="submit">Log in</button>
+  </form>
+  <p class="muted">No account? <a href="{{ url_for('register') }}">Register</a></p>
+</section>
+{% endblock %}
diff --git a/templates/note_form.html b/templates/note_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..4572a919dae8ed4551ed6950d35bc715e9c8f378
--- /dev/null
+++ b/templates/note_form.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block title %}{{ action }} note - Notes{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>{{ action }} note</h1>
+  <form method="post" novalidate>
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label for="title">Title</label>
+    <input id="title" name="title" maxlength="150" value="{{ note['title'] if note else '' }}" required>
+
+    <label for="body">Body</label>
+    <textarea id="body" name="body" maxlength="10000" rows="12" required>{{ note['body'] if note else '' }}</textarea>
+
+    <div class="form-actions">
+      <button type="submit">{{ action }} note</button>
+      <a class="button secondary" href="{{ url_for('index') }}">Cancel</a>
+    </div>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/notes.html b/templates/notes.html
new file mode 100644
index 0000000000000000000000000000000000000000..d7c209eb892732942b4e6713fd59292bd98ef1ed
--- /dev/null
+++ b/templates/notes.html
@@ -0,0 +1,34 @@
+{% extends "base.html" %}
+{% block title %}Your notes - Notes{% endblock %}
+{% block content %}
+<div class="page-header">
+  <h1>Your notes</h1>
+  <a class="button" href="{{ url_for('create_note') }}">New note</a>
+</div>
+
+{% if notes %}
+  <section class="notes-list" aria-label="Notes">
+    {% for note in notes %}
+      <article class="note">
+        <div class="note-content">
+          <h2>{{ note["title"] }}</h2>
+          <p>{{ note["body"] }}</p>
+          <small>Updated {{ note["updated_at"] }}</small>
+        </div>
+        <div class="note-actions">
+          <a class="button secondary" href="{{ url_for('edit_note', note_id=note['id']) }}">Edit</a>
+          <form method="post" action="{{ url_for('delete_note', note_id=note['id']) }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button class="danger" type="submit">Delete</button>
+          </form>
+        </div>
+      </article>
+    {% endfor %}
+  </section>
+{% else %}
+  <section class="empty">
+    <h2>No notes yet</h2>
+    <p>Create your first note to get started.</p>
+  </section>
+{% endif %}
+{% endblock %}
