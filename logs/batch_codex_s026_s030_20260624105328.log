+  <a class="button" href="{{ url_for('index') }}">Back to notes</a>
+</section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..f167fe70515fb224c963fb249a134ff8d83e24e5
--- /dev/null
