@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+
+{% block title %}{{ post.title }} - Flask Blog{% endblock %}
+
+{% block content %}
+<article class="post-detail">
+    <div class="post-heading">
+        <div>
+            <h1>{{ post.title }}</h1>
+            <p class="meta">By {{ post.author }} on {{ post.created_at }}</p>
+        </div>
+        {% if g.user and g.user.id == post.author_id %}
+            <div class="actions">
+                <a class="button secondary" href="{{ url_for('edit_post', post_id=post.id) }}">Edit</a>
+                <form action="{{ url_for('delete_post', post_id=post.id) }}" method="post">
+                    <button class="danger" type="submit">Delete</button>
+                </form>
+            </div>
+        {% endif %}
+    </div>
+    <div class="body-text">{{ post.body }}</div>
+</article>
+{% endblock %}
