+<%- include('partials/header') %>
+
+<section class="tasks-header">
+  <div>
+    <h1>My tasks</h1>
+    <p class="muted">Only tasks owned by your account are shown here.</p>
+  </div>
+</section>
+
+<section class="panel">
+  <%- include('partials/errors', { errors }) %>
+  <form method="post" action="/tasks" class="task-create" novalidate>
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label class="sr-only" for="title">New task</label>
+    <input id="title" name="title" value="<%= draftTitle %>" maxlength="200" placeholder="Add a task" required>
+    <button type="submit">Add</button>
+  </form>
+</section>
+
+<section class="task-list" aria-label="Tasks">
+  <% if (!tasks.length) { %>
+    <div class="empty">No tasks yet.</div>
+  <% } %>
+
+  <% tasks.forEach((task) => { %>
+    <article class="task <%= task.completed ? 'is-complete' : '' %>">
+      <form method="post" action="/tasks/<%= task.id %>/toggle">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <button type="submit" class="toggle" aria-label="<%= task.completed ? 'Mark incomplete' : 'Mark complete' %>">
+          <%= task.completed ? 'Done' : 'Open' %>
+        </button>
+      </form>
+
+      <form method="post" action="/tasks/<%= task.id %>" class="task-edit" novalidate>
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <label class="sr-only" for="task-<%= task.id %>">Task title</label>
+        <input id="task-<%= task.id %>" name="title" value="<%= task.title %>" maxlength="200" required>
+        <button type="submit">Save</button>
+      </form>
+
+      <form method="post" action="/tasks/<%= task.id %>/delete">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <button type="submit" class="danger">Delete</button>
+      </form>
+    </article>
+  <% }) %>
+</section>
+
+<%- include('partials/footer') %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..50b502c37788d8090b93a5176e450121b8af8e38
--- /dev/null
+++ b/README.md
@@ -0,0 +1,33 @@
+# Secure Express To-Do App
+
+A Node.js/Express to-do app with registration, login, per-user task access, SQLite storage, bcrypt password hashing, CSRF protection, secure headers, and server-rendered EJS templates.
+
+## Run locally on port 5027
+
+1. Install dependencies:
+
+   ```bash
+   npm install
+   ```
+
+2. Set a strong session secret:
+
+   ```bash
+   set SESSION_SECRET=replace-with-a-long-random-secret
+   ```
+
+   On macOS/Linux:
+
+   ```bash
+   export SESSION_SECRET=replace-with-a-long-random-secret
+   ```
+
+3. Start the app:
+
+   ```bash
+   npm start
+   ```
+
+4. Open `http://localhost:5027`.
+
+By default the app stores data in `data/todos.sqlite`. Override this with `DATABASE_FILE`. For local HTTP development, cookies use `HttpOnly` and `SameSite=Lax`; set `COOKIE_SECURE=true` when serving over HTTPS or behind a TLS-terminating proxy.
