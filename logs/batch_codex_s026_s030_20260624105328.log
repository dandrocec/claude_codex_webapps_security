@@ -0,0 +1,247 @@
+:root {
+    color-scheme: light;
+    --bg: #f6f7f9;
+    --panel: #ffffff;
+    --text: #17202a;
+    --muted: #667085;
+    --border: #d9dee7;
+    --primary: #2563eb;
+    --primary-dark: #1d4ed8;
+    --danger: #b42318;
+    --success-bg: #ecfdf3;
+    --success-text: #067647;
+    --error-bg: #fef3f2;
+    --error-text: #b42318;
+    --warning-bg: #fffaeb;
+    --warning-text: #b54708;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--bg);
+    color: var(--text);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.5;
+}
+
+a {
+    color: var(--primary);
+    text-decoration: none;
+}
+
+a:hover {
+    text-decoration: underline;
+}
+
+.site-header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 24px;
+    padding: 16px 32px;
+    background: var(--panel);
+    border-bottom: 1px solid var(--border);
+}
+
+.brand {
+    color: var(--text);
+    font-size: 1.25rem;
+    font-weight: 700;
+}
+
+.site-header nav {
+    display: flex;
+    align-items: center;
+    gap: 16px;
+}
+
+.site-header form,
+.note-actions form {
+    display: inline;
+}
+
+.user {
+    color: var(--muted);
+}
+
+.container {
+    width: min(980px, calc(100% - 32px));
+    margin: 32px auto;
+}
+
+.messages {
+    display: grid;
+    gap: 10px;
+    margin-bottom: 24px;
+}
+
+.message {
+    padding: 12px 14px;
+    border-radius: 6px;
+    border: 1px solid var(--border);
+}
+
+.message.success {
+    background: var(--success-bg);
+    color: var(--success-text);
+}
+
+.message.error {
+    background: var(--error-bg);
+    color: var(--error-text);
+}
+
+.message.warning {
+    background: var(--warning-bg);
+    color: var(--warning-text);
+}
+
+.auth-panel,
+.form-panel,
+.empty-state {
+    max-width: 560px;
+    margin: 0 auto;
+    padding: 28px;
+    background: var(--panel);
+    border: 1px solid var(--border);
+    border-radius: 8px;
