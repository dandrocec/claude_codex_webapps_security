+}
+
+label {
+    font-weight: 700;
+}
+
+input,
+textarea {
+    border: 1px solid var(--border);
+    border-radius: 6px;
+    font: inherit;
+    padding: 0.7rem;
+    width: 100%;
+}
+
+textarea {
+    resize: vertical;
+}
+
+button,
+.button {
+    background: var(--accent);
+    border: 1px solid var(--accent);
+    border-radius: 6px;
+    color: #ffffff;
+    cursor: pointer;
+    display: inline-block;
+    font: inherit;
+    font-weight: 700;
+    padding: 0.65rem 0.9rem;
+    text-align: center;
+}
+
+button:hover,
+.button:hover {
+    background: var(--accent-dark);
