+{% extends "base.html" %}
+{% block title %}Error {{ code }}{% endblock %}
+{% block content %}
+  <section class="form-panel narrow">
+    <h1>Error {{ code }}</h1>
+    <p>The request could not be completed.</p>
+    <a href="{{ url_for('index') }}">Return home</a>
+  </section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..87013cd3c20b9a669148ae5a7069bf69f1b0e148
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,21 @@
+{% extends "base.html" %}
+{% block title %}All Posts{% endblock %}
+{% block content %}
+  <section class="page-head">
+    <h1>All posts</h1>
+  </section>
+
+  {% if posts %}
+    <div class="post-list">
+      {% for post in posts %}
+        <article class="post-card">
+          <h2><a href="{{ url_for('post_detail', post_id=post.id) }}">{{ post.title }}</a></h2>
+          <p class="meta">By {{ post.username }} on {{ post.created_at[:10] }}</p>
+          <p>{{ post.body[:240] }}{% if post.body|length > 240 %}...{% endif %}</p>
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty">No posts have been published yet.</p>
+  {% endif %}
+{% endblock %}
