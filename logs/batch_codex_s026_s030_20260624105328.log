+    {% if mode == "register" %}
+        <p class="muted">Already have an account? <a href="{{ url_for('login') }}">Log in</a>.</p>
+    {% else %}
+        <p class="muted">Need an account? <a href="{{ url_for('register') }}">Register</a>.</p>
+    {% endif %}
+</section>
+{% endblock %}
