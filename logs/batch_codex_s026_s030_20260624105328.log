+++ b/templates/base.html
@@ -0,0 +1,35 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Flask Blog{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="site-header">
+        <nav class="nav">
+            <a class="brand" href="{{ url_for('index') }}">Flask Blog</a>
+            <div class="nav-links">
+                {% if g.user %}
+                    <a href="{{ url_for('create_post') }}">New Post</a>
+                    <span class="muted">{{ g.user.username }}</span>
+                    <form action="{{ url_for('logout') }}" method="post">
+                        <button class="link-button" type="submit">Log out</button>
+                    </form>
+                {% else %}
+                    <a href="{{ url_for('login') }}">Log in</a>
+                    <a href="{{ url_for('register') }}">Register</a>
+                {% endif %}
+            </div>
+        </nav>
+    </header>
+
+    <main class="container">
+        {% for message in get_flashed_messages() %}
+            <div class="flash">{{ message }}</div>
+        {% endfor %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/detail.html b/templates/detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..534ca5d54c3ec184b900a9787e6a9d0abb7af815
--- /dev/null
+++ b/templates/detail.html
@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+
+{% block title %}{{ post.title }} - Flask Blog{% endblock %}
+
+{% block content %}
+<article class="post-detail">
+    <div class="post-heading">
+        <div>
+            <h1>{{ post.title }}</h1>
+            <p class="meta">By {{ post.author }} on {{ post.created_at }}</p>
+        </div>
+        {% if g.user and g.user.id == post.author_id %}
+            <div class="actions">
+                <a class="button secondary" href="{{ url_for('edit_post', post_id=post.id) }}">Edit</a>
+                <form action="{{ url_for('delete_post', post_id=post.id) }}" method="post">
+                    <button class="danger" type="submit">Delete</button>
+                </form>
+            </div>
+        {% endif %}
+    </div>
+    <div class="body-text">{{ post.body }}</div>
+</article>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
