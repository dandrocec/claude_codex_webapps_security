+  margin-top: 1.5rem;
+}
+
+.messages {
+  display: grid;
+  gap: .5rem;
+  margin-bottom: 1rem;
+}
+
+.message {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  margin: 0;
+  padding: .7rem .85rem;
+}
+
+.message.success {
+  background: var(--success-bg);
+}
+
+.message.error {
+  background: var(--error-bg);
+}
+
+.empty {
+  color: var(--muted);
+}
+
+@media (max-width: 640px) {
+  .nav {
+    align-items: flex-start;
