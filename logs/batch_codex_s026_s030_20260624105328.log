+}
+
+.page-title,
+.post-heading {
+    align-items: flex-start;
+    display: flex;
+    gap: 1rem;
+    justify-content: space-between;
+}
+
+h1,
+h2 {
+    line-height: 1.2;
+    margin: 0 0 0.75rem;
+}
+
+.post-list {
+    display: grid;
+    gap: 1rem;
+}
+
+.post-card,
+.post-detail,
