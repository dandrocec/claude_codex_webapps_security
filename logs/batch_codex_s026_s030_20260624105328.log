+  gap: 10px;
+  background: #ffffff;
+  border: 1px solid #d9e0e7;
+  border-radius: 8px;
+  padding: 12px;
+}
+
+.task-edit {
+  grid-template-columns: 1fr auto;
+}
+
+.task.is-complete input {
+  color: #647386;
+  text-decoration: line-through;
+}
+
+.empty {
+  color: #647386;
+  text-align: center;
+  padding: 32px;
+}
+
+.sr-only {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+@media (max-width: 680px) {
+  .topbar,
+  .task,
+  .task-create,
+  .task-edit {
+    grid-template-columns: 1fr;
+  }
+
+  .topbar,
+  nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
