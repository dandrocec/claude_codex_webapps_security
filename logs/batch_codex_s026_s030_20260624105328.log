+:root {
+  color-scheme: light;
+  --bg: #f7f8fa;
+  --panel: #ffffff;
+  --text: #1c2430;
+  --muted: #667085;
+  --border: #d9dee7;
+  --primary: #1f6feb;
+  --danger: #c93c37;
+  --success-bg: #e9f7ef;
+  --error-bg: #fff0f0;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  line-height: 1.55;
+}
+
+a {
+  color: var(--primary);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+  justify-content: space-between;
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 1rem;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.1rem;
+  font-weight: 700;
+}
+
+.nav-actions {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: .75rem;
+  justify-content: flex-end;
+}
+
+.user,
+.meta {
+  color: var(--muted);
+  font-size: .92rem;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 2rem 1rem;
+}
+
+.page-head,
+.form-panel,
+.post-detail,
+.post-card {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+}
+
+.page-head {
+  margin-bottom: 1rem;
+  padding: 1rem 1.25rem;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 .5rem;
+}
+
+.post-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.post-card,
+.post-detail,
+.form-panel {
+  padding: 1.25rem;
+}
+
+.post-card p:last-child,
+.post-detail p:last-child {
+  margin-bottom: 0;
+}
+
+.post-detail .body {
+  border-top: 1px solid var(--border);
+  margin-top: 1rem;
+  padding-top: 1rem;
+  white-space: normal;
+}
+
+.form-panel {
+  max-width: 720px;
+}
+
+.form-panel.narrow {
+  max-width: 430px;
+}
+
+label {
+  display: block;
+  font-weight: 650;
+  margin: 1rem 0 .35rem;
+}
+
+input,
+textarea {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: .65rem .75rem;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button {
+  align-items: center;
+  background: var(--primary);
+  border: 0;
+  border-radius: 6px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 650;
+  min-height: 2.4rem;
+  padding: .5rem .85rem;
+}
+
+button:hover,
+.button:hover {
+  filter: brightness(.95);
+  text-decoration: none;
+}
+
+button.danger {
+  background: var(--danger);
+}
+
+.inline-form {
+  display: inline;
+}
+
+.owner-actions {
+  display: flex;
+  gap: .65rem;
+  margin-top: 1.5rem;
+}
+
+.messages {
+  display: grid;
+  gap: .5rem;
+  margin-bottom: 1rem;
+}
+
+.message {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  margin: 0;
+  padding: .7rem .85rem;
+}
+
+.message.success {
+  background: var(--success-bg);
+}
+
+.message.error {
+  background: var(--error-bg);
+}
+
+.empty {
+  color: var(--muted);
+}
+
+@media (max-width: 640px) {
+  .nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .nav-actions {
+    justify-content: flex-start;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..1cdf360ee358c2ad724af48efc245dae5290a494
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,42 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Flask Blog{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <nav class="nav">
+        <a class="brand" href="{{ url_for('index') }}">Flask Blog</a>
+        <div class="nav-actions">
+          {% if g.user %}
+            <a href="{{ url_for('create_post') }}">New post</a>
+            <span class="user">{{ g.user.username }}</span>
+            <form class="inline-form" method="post" action="{{ url_for('logout') }}">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button type="submit">Log out</button>
+            </form>
+          {% else %}
+            <a href="{{ url_for('login') }}">Log in</a>
+            <a href="{{ url_for('register') }}">Register</a>
+          {% endif %}
+        </div>
+      </nav>
+    </header>
+
+    <main class="container">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/detail.html b/templates/detail.html
