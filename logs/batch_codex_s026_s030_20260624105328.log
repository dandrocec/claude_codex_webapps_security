@@ -0,0 +1,26 @@
+<%- include('partials/header', { title }) %>
+
+<section class="panel narrow">
+  <h1><%= title %></h1>
+  <% if (typeof error !== 'undefined' && error) { %>
+    <p class="alert"><%= error %></p>
+  <% } %>
+  <form method="post" action="<%= action %>" class="stack">
+    <label>
+      Username
+      <input name="username" autocomplete="username" required>
+    </label>
+    <label>
+      Password
+      <input name="password" type="password" autocomplete="<%= mode === 'register' ? 'new-password' : 'current-password' %>" required>
+    </label>
+    <button type="submit"><%= mode === 'register' ? 'Create account' : 'Sign in' %></button>
+  </form>
+  <% if (mode === 'register') { %>
+    <p class="muted">Already have an account? <a href="/login">Sign in</a>.</p>
+  <% } else { %>
+    <p class="muted">Need an account? <a href="/register">Create one</a>.</p>
+  <% } %>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/bookmark-form.ejs b/views/bookmark-form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..9ef26ef9c36fbf9bcca148b3ce0a4e23f032dda3
--- /dev/null
+++ b/views/bookmark-form.ejs
@@ -0,0 +1,28 @@
+<%- include('partials/header', { title: heading }) %>
+
+<section class="panel narrow">
+  <h1><%= heading %></h1>
+  <% if (typeof error !== 'undefined' && error) { %>
+    <p class="alert"><%= error %></p>
+  <% } %>
+  <form method="post" action="<%= action %>" class="stack">
+    <label>
+      Title
+      <input name="title" value="<%= bookmark.title %>" required>
+    </label>
+    <label>
+      URL
+      <input name="url" type="url" value="<%= bookmark.url %>" placeholder="https://example.com" required>
+    </label>
+    <label>
+      Tags
+      <input name="tags" value="<%= bookmark.tags %>" placeholder="work, reference, reading">
+    </label>
+    <div class="actions">
+      <button type="submit">Save bookmark</button>
+      <a class="secondary" href="/bookmarks">Cancel</a>
+    </div>
+  </form>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/bookmarks.ejs b/views/bookmarks.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c191acd8b84bab77957cdbfa9b3cd79fae518580
--- /dev/null
+++ b/views/bookmarks.ejs
@@ -0,0 +1,51 @@
+<%- include('partials/header', { title: 'Your bookmarks' }) %>
+
+<section class="toolbar">
+  <div>
+    <h1>Your bookmarks</h1>
+    <p class="muted"><%= selectedTag ? `Filtered by "${selectedTag}"` : 'All saved links' %></p>
+  </div>
+  <a class="button" href="/bookmarks/new">Add bookmark</a>
+</section>
+
+<% if (tags.length) { %>
+  <nav class="tags" aria-label="Filter by tag">
+    <a class="<%= !selectedTag ? 'active' : '' %>" href="/bookmarks">All</a>
+    <% tags.forEach((tag) => { %>
+      <a class="<%= selectedTag === tag ? 'active' : '' %>" href="/bookmarks?tag=<%= encodeURIComponent(tag) %>"><%= tag %></a>
+    <% }) %>
+  </nav>
+<% } %>
+
+<section class="bookmark-list">
+  <% if (!bookmarks.length) { %>
+    <div class="empty">
+      <h2>No bookmarks found</h2>
+      <p class="muted">Add a bookmark or clear the current tag filter.</p>
+    </div>
+  <% } %>
+
+  <% bookmarks.forEach((bookmark) => { %>
+    <article class="bookmark">
+      <div>
+        <h2><a href="<%= bookmark.url %>" target="_blank" rel="noopener noreferrer"><%= bookmark.title %></a></h2>
+        <p class="url"><%= bookmark.url %></p>
+        <% if (bookmark.tagList.length) { %>
+          <div class="tag-row">
+            <% bookmark.tagList.forEach((tag) => { %>
+              <a href="/bookmarks?tag=<%= encodeURIComponent(tag) %>"><%= tag %></a>
+            <% }) %>
+          </div>
+        <% } %>
+      </div>
+      <div class="bookmark-actions">
+        <a class="secondary" href="/bookmarks/<%= bookmark.id %>/edit">Edit</a>
+        <form method="post" action="/bookmarks/<%= bookmark.id %>/delete">
+          <button type="submit" class="danger">Delete</button>
+        </form>
+      </div>
+    </article>
+  <% }) %>
+</section>
+
+<%- include('partials/footer') %>
