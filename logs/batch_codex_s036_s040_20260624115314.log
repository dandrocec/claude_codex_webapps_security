@@ -0,0 +1,18 @@
+{% extends "base.html" %}
+
+{% block title %}Log in{% endblock %}
+
+{% block content %}
+<section class="auth-panel">
+    <h1>Log in</h1>
+    <form method="post">
+        <label for="username">Username</label>
