+{
+  "name": "local/php-image-gallery",
+  "description": "A small PHP image gallery with user uploads, captions, and SQLite metadata storage.",
+  "type": "project",
+  "require": {
+    "php": ">=8.1",
+    "ext-pdo": "*",
+    "ext-pdo_sqlite": "*"
+  },
+  "suggest": {
+    "ext-gd": "Creates optimized thumbnail images. The app falls back to original images when GD is unavailable."
+  },
+  "scripts": {
+    "serve": "php -S localhost:5037 -t public"
+  }
+}
