new file mode 100644
index 0000000000000000000000000000000000000000..7b7d19a51064e9b9aa20cb3e2e5daeadab901770
--- /dev/null
+++ b/static/style.css
@@ -0,0 +1,284 @@
+:root {
+  color-scheme: light;
+  --bg: #f7f7f4;
+  --panel: #ffffff;
+  --text: #1f2933;
+  --muted: #65717f;
+  --border: #d9ded7;
+  --accent: #276b5d;
+  --accent-dark: #1f584d;
+  --danger: #a33b3b;
+  --success: #2d7651;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  line-height: 1.55;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+  display: grid;
+  gap: 16px;
+  grid-template-columns: auto minmax(220px, 1fr) auto;
+  padding: 14px clamp(16px, 4vw, 40px);
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.2rem;
+  font-weight: 800;
+}
+
+.search {
+  display: flex;
+  gap: 8px;
+  min-width: 0;
+}
+
+.search input {
+  width: 100%;
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  gap: 14px;
+  justify-content: flex-end;
+}
+
+.nav form {
+  margin: 0;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 34px 18px 56px;
+}
+
+.page-heading {
+  align-items: flex-start;
+  display: flex;
+  gap: 20px;
+  justify-content: space-between;
+  margin-bottom: 24px;
+}
+
+h1,
+h2 {
+  line-height: 1.15;
+  margin: 0 0 8px;
+}
+
+p {
+  color: var(--muted);
+  margin: 0;
+}
+
+input,
+textarea,
+button,
+.button {
+  border-radius: 6px;
+  font: inherit;
+}
+
+input,
+textarea {
+  background: #fff;
+  border: 1px solid var(--border);
+  color: var(--text);
+  padding: 10px 12px;
+}
+
+textarea {
+  min-height: 360px;
+  resize: vertical;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 1px solid var(--accent);
+  color: #fff;
+  cursor: pointer;
+  display: inline-flex;
+  font-weight: 700;
+  justify-content: center;
+  padding: 10px 14px;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.link-button {
+  background: transparent;
+  border: 0;
+  color: var(--accent);
+  padding: 0;
+}
+
+.link-button:hover {
+  background: transparent;
+  text-decoration: underline;
+}
+
+.messages {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 22px;
+}
+
+.message {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-left: 4px solid var(--accent);
+  border-radius: 6px;
+  padding: 10px 12px;
+}
+
+.message.error {
+  border-left-color: var(--danger);
+}
+
+.message.success {
+  border-left-color: var(--success);
+}
+
+.page-list {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.page-list li {
+  align-items: center;
+  display: flex;
+  gap: 14px;
+  justify-content: space-between;
+  padding: 16px 18px;
+}
+
+.page-list li + li {
+  border-top: 1px solid var(--border);
+}
+
+.page-list a {
+  font-size: 1.05rem;
+  font-weight: 800;
+}
+
+time {
+  color: var(--muted);
+  flex: 0 0 auto;
+  font-size: 0.9rem;
+}
+
+.empty,
+.form-panel,
+.markdown-body {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 24px;
+}
+
+.form-panel {
+  margin: 0 auto;
+  max-width: 820px;
+}
+
+.form-panel.narrow {
+  max-width: 460px;
+}
+
+.form-panel form {
+  display: grid;
+  gap: 12px;
+}
+
+label {
+  font-weight: 800;
+}
+
+.form-actions {
+  align-items: center;
+  display: flex;
+  gap: 14px;
+  margin-top: 10px;
+}
+
+.markdown-body {
+  overflow-wrap: anywhere;
+}
+
+.markdown-body > :first-child {
+  margin-top: 0;
+}
+
+.markdown-body > :last-child {
+  margin-bottom: 0;
+}
+
+.markdown-body pre {
+  background: #eef1ee;
+  border-radius: 6px;
+  overflow-x: auto;
+  padding: 14px;
+}
+
+.markdown-body code {
+  background: #eef1ee;
+  border-radius: 4px;
+  padding: 2px 4px;
+}
+
+.markdown-body pre code {
+  padding: 0;
+}
+
+@media (max-width: 760px) {
+  .site-header {
+    grid-template-columns: 1fr;
+  }
+
+  .nav,
+  .page-heading,
+  .page-list li {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .nav {
+    justify-content: flex-start;
+  }
+
+  .search {
+    width: 100%;
+  }
+}
diff --git a/templates/auth.html b/templates/auth.html
