diff --git a/views/partials/header.ejs b/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..0280b4ae876aa0822283219c942b881c59375733
--- /dev/null
+++ b/views/partials/header.ejs
@@ -0,0 +1,28 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Job Board</title>
+    <link rel="stylesheet" href="/styles.css">
+  </head>
+  <body>
+    <header class="site-header">
+      <a class="brand" href="/">Job Board</a>
+      <nav class="nav">
+        <% if (currentUser) { %>
+          <a href="/jobs/new">Post a Job</a>
+          <span class="muted">Signed in as <%= currentUser.username %></span>
+          <form method="post" action="/logout" class="inline-form">
+            <button type="submit" class="link-button">Log Out</button>
+          </form>
+        <% } else { %>
