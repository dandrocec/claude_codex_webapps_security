@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+
+{% block title %}{% if page %}Edit{% else %}Create{% endif %} Page - Wiki{% endblock %}
+
+{% block content %}
+  <section class="editor">
+    <h1>{% if page %}Edit page{% else %}Create page{% endif %}</h1>
+    <form method="post">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label for="title">Title</label>
+      <input id="title" name="title" type="text" required minlength="3" maxlength="120" value="{{ page.title if page else '' }}">
+
+      <label for="body">Markdown body</label>
+      <textarea id="body" name="body" rows="18" required maxlength="100000">{{ page.body if page else '' }}</textarea>
+
+      <button type="submit">{% if page %}Save changes{% else %}Create page{% endif %}</button>
+    </form>
+  </section>
+{% endblock %}
