+          <time datetime="{{ page.updated_at }}">Updated {{ page.updated_at }}</time>
+        </li>
+      {% endfor %}
+    </ul>
+  {% elif q %}
+    <div class="empty">
+      <h2>No matching pages</h2>
+      <p>Try a shorter or different title search.</p>
+    </div>
+  {% endif %}
+{% endblock %}

