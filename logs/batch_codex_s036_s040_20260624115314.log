@@ -0,0 +1,26 @@
+{% extends "base.html" %}
+
+{% set is_register = mode == 'register' %}
+{% block title %}{{ 'Register' if is_register else 'Log In' }} - Flask Wiki{% endblock %}
+
+{% block content %}
+  <section class="form-panel narrow">
+    <h1>{{ 'Create Account' if is_register else 'Log In' }}</h1>
+    <form method="post">
+      <label for="username">Username</label>
+      <input id="username" name="username" autocomplete="username" required value="{{ request.form.username or '' }}">
+
+      <label for="password">Password</label>
+      <input id="password" name="password" type="password" autocomplete="{{ 'new-password' if is_register else 'current-password' }}" required>
+
+      <div class="form-actions">
+        <button type="submit">{{ 'Register' if is_register else 'Log in' }}</button>
+        {% if is_register %}
+          <a href="{{ url_for('login') }}">Already have an account?</a>
+        {% else %}
+          <a href="{{ url_for('register') }}">Need an account?</a>
+        {% endif %}
+      </div>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
