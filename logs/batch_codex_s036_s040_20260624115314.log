+}
+
+.brand {
+    color: var(--ink);
+    font-size: 1.25rem;
+    font-weight: 700;
+}
+
+.nav,
+.actions,
+.inline {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 12px;
+}
+
+.nav form,
+.actions form {
+    margin: 0;
+}
+
+.container {
+    margin: 0 auto;
+    max-width: 1120px;
+    padding: 32px 20px 56px;
+}
+
+.button,
+button {
+    background: var(--accent);
+    border: 0;
+    border-radius: 6px;
+    color: #fff;
+    cursor: pointer;
+    display: inline-block;
+    font: inherit;
+    font-weight: 700;
+    padding: 10px 14px;
+}
+
+button:hover,
+.button:hover {
+    background: var(--accent-dark);
+}
+
+.nav button,
+.actions button {
+    background: transparent;
+    color: var(--danger);
+    padding: 0;
+}
+
+.toolbar {
+    align-items: end;
+    display: flex;
+    gap: 24px;
+    justify-content: space-between;
+    margin-bottom: 22px;
+}
+
+.toolbar h1,
+.auth-panel h1,
+.form-panel h1,
+.detail h1 {
+    line-height: 1.1;
+    margin: 0 0 8px;
+}
+
+.toolbar p {
+    color: var(--muted);
+    margin: 0;
+}
+
+.search-form {
+    display: grid;
+    gap: 10px;
+    grid-template-columns: minmax(180px, 1fr) 160px auto;
+}
+
+input,
+select,
+textarea {
+    background: #fff;
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    color: var(--ink);
+    font: inherit;
+    padding: 10px 12px;
+    width: 100%;
+}
+
+label {
+    display: grid;
+    font-weight: 700;
+    gap: 7px;
+}
+
+.category-row {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 8px;
+    margin-bottom: 24px;
+}
+
+.category-row a,
+.category {
+    background: #e8f3f0;
+    border-radius: 999px;
+    color: var(--accent-dark);
+    display: inline-block;
+    font-size: 0.85rem;
+    font-weight: 700;
+    padding: 5px 10px;
+}
+
+.category-row a.active {
+    background: var(--accent);
+    color: #fff;
+}
+
+.listing-grid {
+    display: grid;
+    gap: 18px;
+    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
+}
+
+.listing-card,
+.auth-panel,
+.form-panel,
+.manage-item,
+.seller-box,
+.empty,
+.notice,
+.errors {
+    background: var(--surface);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+}
+
+.listing-card {
+    overflow: hidden;
+}
+
+.listing-card img,
+.placeholder {
+    aspect-ratio: 4 / 3;
+    background: #dfe7ed;
+    object-fit: cover;
+    width: 100%;
+}
+
+.placeholder,
+.thumb-placeholder {
+    align-items: center;
+    color: var(--muted);
+    display: flex;
+    justify-content: center;
+}
+
+.listing-body {
+    padding: 14px;
+}
+
+.listing-body h2,
+.manage-item h2 {
+    color: var(--ink);
+    font-size: 1.05rem;
+    margin: 10px 0 6px;
+}
+
+.listing-body p {
+    color: var(--muted);
+    margin: 8px 0 0;
+}
+
+.auth-panel,
+.form-panel {
+    margin: 0 auto;
+    max-width: 560px;
+    padding: 24px;
+}
+
+.auth-panel form,
+.form-panel form {
+    display: grid;
+    gap: 16px;
+}
+
+.auth-panel p {
+    margin-bottom: 0;
+}
+
+.notice {
+    border-color: #9fd3c5;
+    margin-bottom: 18px;
+    padding: 12px 14px;
+}
+
+.errors {
+    border-color: #f2aaa4;
+    color: var(--danger);
+    margin-bottom: 16px;
+    padding: 10px 14px;
+}
+
+.errors p {
+    margin: 4px 0;
+}
+
+.empty {
+    padding: 28px;
+    text-align: center;
+}
+
+.manage-list {
+    display: grid;
+    gap: 14px;
+}
+
+.manage-item {
+    align-items: center;
+    display: grid;
+    gap: 16px;
+    grid-template-columns: 96px 1fr auto;
+    padding: 12px;
+}
+
+.manage-item img,
+.thumb-placeholder {
+    aspect-ratio: 1;
+    background: #dfe7ed;
+    border-radius: 6px;
+    object-fit: cover;
+    width: 96px;
+}
+
+.detail {
+    display: grid;
+    gap: 32px;
+    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
+}
+
+.detail-media img,
+.placeholder.large {
+    aspect-ratio: 4 / 3;
+    background: #dfe7ed;
+    border-radius: 8px;
+    object-fit: cover;
+    width: 100%;
+}
+
+.detail-copy {
+    min-width: 0;
+}
+
+.price {
+    display: block;
+    font-size: 1.8rem;
+    margin: 12px 0 18px;
+}
+
+.seller-box {
+    margin: 22px 0;
+    padding: 16px;
+}
+
+.seller-box h2 {
+    font-size: 1rem;
+    margin: 0 0 8px;
+}
+
+.seller-box p {
+    margin: 0 0 4px;
+}
+
+.current-photo {
+    border-radius: 6px;
+    max-height: 220px;
+    object-fit: cover;
+}
+
+@media (max-width: 760px) {
+    .site-header,
+    .toolbar,
+    .detail {
+        align-items: stretch;
+        display: grid;
+    }
+
+    .search-form,
+    .manage-item {
+        grid-template-columns: 1fr;
+    }
+
+    .manage-item img,
+    .thumb-placeholder {
+        width: 100%;
+    }
+}
diff --git a/src/bootstrap.php b/src/bootstrap.php
new file mode 100644
index 0000000000000000000000000000000000000000..e72b40ad4a9197a52eea2bfe91f4ceb180820815
--- /dev/null
+++ b/src/bootstrap.php
@@ -0,0 +1,181 @@
+<?php
+
+declare(strict_types=1);
+
+session_start();
+
+const BASE_PATH = __DIR__ . '/..';
+const DB_PATH = BASE_PATH . '/database/classifieds.sqlite';
+const UPLOAD_PATH = BASE_PATH . '/public/uploads';
+const UPLOAD_URL = '/uploads';
+
+if (!is_dir(BASE_PATH . '/database')) {
+    mkdir(BASE_PATH . '/database', 0775, true);
+}
+
+if (!is_dir(UPLOAD_PATH)) {
+    mkdir(UPLOAD_PATH, 0775, true);
+}
+
+$pdo = new PDO('sqlite:' . DB_PATH);
+$pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
+$pdo->setAttribute(PDO::ATTR_DEFAULT_FETCH_MODE, PDO::FETCH_ASSOC);
+
+$pdo->exec(
+    'CREATE TABLE IF NOT EXISTS users (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        name TEXT NOT NULL,
+        email TEXT NOT NULL UNIQUE,
+        password_hash TEXT NOT NULL,
+        created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
+    )'
+);
+
+$pdo->exec(
+    'CREATE TABLE IF NOT EXISTS listings (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        user_id INTEGER NOT NULL,
+        category TEXT NOT NULL,
+        title TEXT NOT NULL,
+        price INTEGER NOT NULL,
+        description TEXT NOT NULL,
+        photo_path TEXT,
+        created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+        updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+        FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
+    )'
+);
+
+$pdo->exec('CREATE INDEX IF NOT EXISTS idx_listings_category ON listings(category)');
+$pdo->exec('CREATE INDEX IF NOT EXISTS idx_listings_search ON listings(title, description)');
+
+function db(): PDO
+{
+    global $pdo;
+    return $pdo;
+}
+
+function current_user(): ?array
+{
+    if (empty($_SESSION['user_id'])) {
+        return null;
+    }
+
+    $stmt = db()->prepare('SELECT id, name, email FROM users WHERE id = ?');
+    $stmt->execute([$_SESSION['user_id']]);
+    $user = $stmt->fetch();
+
+    return $user ?: null;
+}
+
+function require_login(): array
+{
+    $user = current_user();
+    if (!$user) {
+        flash('Please log in to continue.');
+        redirect('/login');
+    }
+
+    return $user;
+}
+
+function categories(): array
+{
+    return ['Electronics', 'Home', 'Vehicles', 'Fashion', 'Sports', 'Books', 'Services', 'Other'];
+}
+
+function e(?string $value): string
+{
+    return htmlspecialchars($value ?? '', ENT_QUOTES, 'UTF-8');
+}
+
+function money(int $cents): string
+{
+    return '$' . number_format($cents / 100, 2);
+}
+
+function price_to_cents(string $price): int
+{
+    $normalized = preg_replace('/[^0-9.]/', '', $price);
+    if ($normalized === '' || !is_numeric($normalized)) {
+        return 0;
+    }
+
+    return (int) round(((float) $normalized) * 100);
+}
+
+function redirect(string $path): never
+{
+    header('Location: ' . $path);
+    exit;
+}
+
+function flash(?string $message = null): ?string
+{
+    if ($message !== null) {
+        $_SESSION['flash'] = $message;
+        return null;
+    }
+
+    $message = $_SESSION['flash'] ?? null;
+    unset($_SESSION['flash']);
+
+    return $message;
+}
+
+function old(array $source, string $key, string $default = ''): string
+{
+    return isset($source[$key]) ? (string) $source[$key] : $default;
+}
+
+function handle_photo_upload(?string $existingPath = null): ?string
+{
+    if (empty($_FILES['photo']) || $_FILES['photo']['error'] === UPLOAD_ERR_NO_FILE) {
+        return $existingPath;
+    }
+
+    if ($_FILES['photo']['error'] !== UPLOAD_ERR_OK) {
+        throw new RuntimeException('Photo upload failed.');
+    }
+
+    if ($_FILES['photo']['size'] > 3 * 1024 * 1024) {
+        throw new RuntimeException('Photo must be smaller than 3 MB.');
+    }
+
+    $finfo = new finfo(FILEINFO_MIME_TYPE);
+    $mime = $finfo->file($_FILES['photo']['tmp_name']);
+    $extensions = [
+        'image/jpeg' => 'jpg',
+        'image/png' => 'png',
+        'image/webp' => 'webp',
+        'image/gif' => 'gif',
+    ];
+
+    if (!isset($extensions[$mime])) {
+        throw new RuntimeException('Photo must be a JPG, PNG, WebP, or GIF image.');
+    }
+
+    $filename = bin2hex(random_bytes(16)) . '.' . $extensions[$mime];
+    $target = UPLOAD_PATH . '/' . $filename;
+
+    if (!move_uploaded_file($_FILES['photo']['tmp_name'], $target)) {
+        throw new RuntimeException('Could not save uploaded photo.');
+    }
+
+    if ($existingPath) {
+        $oldPath = UPLOAD_PATH . '/' . basename($existingPath);
+        if (is_file($oldPath)) {
+            unlink($oldPath);
+        }
+    }
+
+    return UPLOAD_URL . '/' . $filename;
+}
+
+function render(string $view, array $data = []): void
+{
+    extract($data, EXTR_SKIP);
+    $currentUser = current_user();
+    $flash = flash();
+    require BASE_PATH . '/views/layout.php';
+}
