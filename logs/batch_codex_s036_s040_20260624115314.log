@@ -0,0 +1,26 @@
+{% extends "base.html" %}
+
+{% set is_register = mode == 'register' %}
+{% block title %}{{ 'Register' if is_register else 'Log In' }} - Flask Wiki{% endblock %}
+
+{% block content %}
+  <section class="form-panel narrow">
+    <h1>{{ 'Create Account' if is_register else 'Log In' }}</h1>
+    <form method="post">
+      <label for="username">Username</label>
+      <input id="username" name="username" autocomplete="username" required value="{{ request.form.username or '' }}">
+
+      <label for="password">Password</label>
+      <input id="password" name="password" type="password" autocomplete="{{ 'new-password' if is_register else 'current-password' }}" required>
+
+      <div class="form-actions">
+        <button type="submit">{{ 'Register' if is_register else 'Log in' }}</button>
+        {% if is_register %}
+          <a href="{{ url_for('login') }}">Already have an account?</a>
+        {% else %}
+          <a href="{{ url_for('register') }}">Need an account?</a>
+        {% endif %}
+      </div>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..9440ec0c5f5c6781796a82d85cb52fe824de6565
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,44 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Flask Wiki{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <a class="brand" href="{{ url_for('index') }}">Flask Wiki</a>
+      <form class="search" action="{{ url_for('search') }}" method="get">
+        <input type="search" name="q" placeholder="Search titles" value="{{ q|default('') }}">
+        <button type="submit">Search</button>
+      </form>
+      <nav class="nav">
+        {% if g.user %}
+          <a href="{{ url_for('new_page') }}">New page</a>
+          <span>{{ g.user.username }}</span>
+          <form action="{{ url_for('logout') }}" method="post">
+            <button type="submit" class="link-button">Log out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Log in</a>
+          <a href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </nav>
+    </header>
+
+    <main class="container">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <div class="message {{ category }}">{{ message }}</div>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/edit.html b/templates/edit.html
