+}
+
+h1,
+h2,
+p {
+  margin-top: 0;
+}
+
+.event-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.event-card,
+.auth-panel,
+.form-panel {
+  background: #ffffff;
+  border: 1px solid #d9e0e8;
+  border-radius: 8px;
+  padding: 1.25rem;
+}
+
+.event-card h2 {
+  font-size: 1.25rem;
+  margin-bottom: 0.25rem;
+}
+
+.meta,
+.empty {
+  color: #5d6875;
+}
+
+form {
+  display: grid;
+  gap: 1rem;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  display: grid;
+  font-weight: 700;
+  gap: 0.35rem;
+}
+
+input,
+textarea {
+  border: 1px solid #aab5c2;
+  border-radius: 6px;
+  font: inherit;
+  padding: 0.65rem;
+  width: 100%;
+}
+
+textarea {
+  min-height: 9rem;
+  resize: vertical;
+}
+
+button,
+.button {
+  background: #1d4f91;
+  border: 1px solid #1d4f91;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 0.55rem 0.85rem;
+  text-align: center;
+}
+
+button:hover,
+.button:hover {
