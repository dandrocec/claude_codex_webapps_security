+      </section>
+    <?php else: ?>
+      <figure class="image-detail">
+        <img src="<?= h(public_image_path($image['file_path'])) ?>" alt="<?= h($image['caption']) ?>">
+        <figcaption>
+          <h1><?= h($image['caption']) ?></h1>
+          <p>Uploaded by <?= h($image['username']) ?> on <?= h(format_date($image['created_at'])) ?></p>
