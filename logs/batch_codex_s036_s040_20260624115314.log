diff --git a/static/style.css b/static/style.css
new file mode 100644
index 0000000000000000000000000000000000000000..8db9506b82fa71feb2be56f2ee7cfbff1a32a2d8
--- /dev/null
+++ b/static/style.css
@@ -0,0 +1,233 @@
+:root {
+  --bg: #f7f7f4;
+  --panel: #ffffff;
+  --text: #1e2528;
+  --muted: #5f6b70;
+  --line: #d8dddf;
+  --accent: #0b6b63;
+  --accent-dark: #084d47;
+  --danger: #9b1c31;
+  --success: #1d6b36;
+  --warning: #8a5a00;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.55;
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  gap: 1rem;
+  justify-content: space-between;
+  padding: 0.85rem 1.25rem;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.25rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.85rem;
+}
+
+nav a {
+  text-decoration: none;
+}
+
+.user {
+  color: var(--muted);
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 2rem 1rem 4rem;
+}
+
+.page-head {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+  justify-content: space-between;
+  margin-bottom: 1.4rem;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 0.35rem;
+}
+
+p {
+  margin: 0 0 1rem;
+}
+
+.button,
+button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 0.65rem 0.9rem;
+  text-decoration: none;
+}
+
+.button:hover,
+button:hover {
+  background: var(--accent-dark);
+}
+
+.inline {
+  display: inline;
+}
+
+.inline button {
+  padding: 0.45rem 0.65rem;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message {
+  background: var(--panel);
+  border-left: 4px solid var(--accent);
+  padding: 0.75rem 0.9rem;
+}
+
+.message.error {
+  border-color: var(--danger);
+}
+
+.message.success {
+  border-color: var(--success);
+}
+
+.message.warning {
+  border-color: var(--warning);
+}
+
+form label {
+  display: block;
+  font-weight: 700;
+  margin: 1rem 0 0.35rem;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 0.7rem;
+  width: 100%;
+}
+
+textarea {
+  min-height: 18rem;
+  resize: vertical;
+}
+
+.search {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  margin-bottom: 1.5rem;
+  padding: 1rem;
+}
+
+.search-row {
+  display: grid;
+  gap: 0.75rem;
+  grid-template-columns: 1fr auto;
+}
+
+.list {
+  display: grid;
+  gap: 0.75rem;
+}
+
+.list-item,
+.auth,
+.editor,
+.wiki-page,
+.error-page {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 1.25rem;
+}
+
+.list-item h2 {
+  font-size: 1.15rem;
+}
+
+.list-item p,
+.page-head p,
+.empty {
+  color: var(--muted);
+}
+
+.auth {
+  max-width: 440px;
+}
+
+.markdown {
+  overflow-wrap: anywhere;
+}
+
+.markdown pre {
+  background: #f0f2f2;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  overflow-x: auto;
+  padding: 1rem;
+}
+
+.markdown table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+.markdown th,
+.markdown td {
+  border: 1px solid var(--line);
+  padding: 0.5rem;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .page-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .search-row {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..d544cd5b0658ff11443c4d08bd9edde2b78f5d9c
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,42 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Wiki{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Wiki</a>
+    <nav>
+      <a href="{{ url_for('index') }}">Pages</a>
+      {% if g.user %}
+        <a href="{{ url_for('create_page') }}">New Page</a>
+        <span class="user">{{ g.user.username }}</span>
+        <form class="inline" method="post" action="{{ url_for('logout') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Log out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Log in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <section class="messages" aria-label="Messages">
+          {% for category, message in messages %}
+            <p class="message {{ category }}">{{ message }}</p>
+          {% endfor %}
+        </section>
+      {% endif %}
+    {% endwith %}
+
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..d87ae81a954840d98c3eecce4cf737a33d45d193
--- /dev/null
+++ b/templates/error.html
@@ -0,0 +1,11 @@
+{% extends "base.html" %}
+
+{% block title %}{{ code }} - Wiki{% endblock %}
+
+{% block content %}
+  <section class="error-page">
+    <h1>{{ code }} {{ title }}</h1>
+    <p>The request could not be completed.</p>
+    <a class="button" href="{{ url_for('index') }}">Back to pages</a>
+  </section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..b3bb4d4388826a145a7664d92212b4f16ff345e6
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,34 @@
+{% extends "base.html" %}
+
+{% block title %}Pages - Wiki{% endblock %}
+
+{% block content %}
+  <section class="page-head">
+    <div>
+      <h1>Pages</h1>
+      <p>Browse readable wiki pages or search by title.</p>
+    </div>
+    {% if g.user %}
+      <a class="button" href="{{ url_for('create_page') }}">Create page</a>
+    {% endif %}
+  </section>
+
+  <form class="search" method="get" action="{{ url_for('index') }}">
+    <label for="q">Search titles</label>
+    <div class="search-row">
+      <input id="q" name="q" type="search" maxlength="120" value="{{ q }}">
+      <button type="submit">Search</button>
+    </div>
+  </form>
+
+  <section class="list">
+    {% for page in pages %}
+      <article class="list-item">
+        <h2><a href="{{ url_for('show_page', page_id=page.id) }}">{{ page.title }}</a></h2>
+        <p>Updated {{ page.updated_at }} by {{ page.owner }}</p>
+      </article>
+    {% else %}
+      <p class="empty">No pages found.</p>
+    {% endfor %}
+  </section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..f1402422753378e031dbd087e24b205e72b9d5d2
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+
+{% block title %}Log in - Wiki{% endblock %}
+
+{% block content %}
+  <section class="auth">
+    <h1>Log in</h1>
+    <form method="post" action="{{ url_for('login', next=request.args.get('next')) }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label for="username">Username</label>
+      <input id="username" name="username" type="text" autocomplete="username" required minlength="3" maxlength="64">
+
+      <label for="password">Password</label>
+      <input id="password" name="password" type="password" autocomplete="current-password" required minlength="12" maxlength="128">
+
+      <button type="submit">Log in</button>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/page.html b/templates/page.html
new file mode 100644
index 0000000000000000000000000000000000000000..2c2ffc964d4b4e5a9509b93c2ecf5d43794b0eee
--- /dev/null
+++ b/templates/page.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+
+{% block title %}{{ page.title }} - Wiki{% endblock %}
+
+{% block content %}
+  <article class="wiki-page">
+    <header class="page-head">
+      <div>
+        <h1>{{ page.title }}</h1>
+        <p>Updated {{ page.updated_at }} by {{ page.owner }}</p>
+      </div>
+      {% if g.user and g.user.id == page.owner_id %}
+        <a class="button" href="{{ url_for('edit_page', page_id=page.id) }}">Edit</a>
+      {% endif %}
+    </header>
+    <div class="markdown">
+      {{ html_body|safe }}
+    </div>
+  </article>
+{% endblock %}
diff --git a/templates/page_form.html b/templates/page_form.html
new file mode 100644
