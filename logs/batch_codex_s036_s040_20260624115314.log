+:root {
+  color-scheme: light;
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+  color: #18202a;
+  background: #f5f7fa;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+}
+
+a {
+  color: #1d4f91;
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid #d9e0e8;
+  display: flex;
+  justify-content: space-between;
+  padding: 1rem max(1rem, calc((100vw - 960px) / 2));
+}
+
+.brand {
+  color: #18202a;
+  font-size: 1.4rem;
+  font-weight: 700;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 960px;
+  padding: 2rem 1rem;
+}
+
+.page-heading {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  margin-bottom: 1.5rem;
+}
+
+h1,
+h2,
+p {
+  margin-top: 0;
+}
+
+.event-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.event-card,
+.auth-panel,
+.form-panel {
+  background: #ffffff;
+  border: 1px solid #d9e0e8;
+  border-radius: 8px;
+  padding: 1.25rem;
+}
+
+.event-card h2 {
+  font-size: 1.25rem;
+  margin-bottom: 0.25rem;
+}
+
+.meta,
+.empty {
+  color: #5d6875;
+}
+
+form {
+  display: grid;
+  gap: 1rem;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  display: grid;
+  font-weight: 700;
+  gap: 0.35rem;
+}
+
+input,
+textarea {
+  border: 1px solid #aab5c2;
+  border-radius: 6px;
+  font: inherit;
+  padding: 0.65rem;
+  width: 100%;
+}
+
+textarea {
+  min-height: 9rem;
+  resize: vertical;
+}
+
+button,
+.button {
+  background: #1d4f91;
+  border: 1px solid #1d4f91;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 0.55rem 0.85rem;
+  text-align: center;
+}
+
+button:hover,
+.button:hover {
+  background: #163e72;
+  text-decoration: none;
+}
+
+.secondary {
+  background: #ffffff;
+  color: #1d4f91;
+}
+
+.danger {
+  background: #9d2431;
+  border-color: #9d2431;
+}
+
+.actions {
+  align-items: center;
+  display: flex;
+  gap: 0.75rem;
+  margin-top: 1rem;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message {
+  border-radius: 6px;
+  padding: 0.75rem;
+}
+
+.message.error {
+  background: #ffe8e9;
+  color: #7a1722;
+}
+
+.message.success {
+  background: #e7f5ed;
+  color: #155b32;
+}
+
+@media (max-width: 640px) {
+  .site-header,
+  .page-heading,
+  nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..14c1af457ae5d695eb33a89f9368c0e46ac7fbdd
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,40 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Events{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <a class="brand" href="{{ url_for('index') }}">Events</a>
+      <nav aria-label="Primary navigation">
+        <a href="{{ url_for('index') }}">Upcoming</a>
+        {% if g.user %}
+          <a href="{{ url_for('dashboard') }}">My events</a>
+          <form class="inline" method="post" action="{{ url_for('logout') }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit">Log out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Log in</a>
+          <a href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </nav>
+    </header>
+
+    <main class="container">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages" aria-live="polite">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..0a04c356a110d621d62ceeec3317c5d0050b8037
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,31 @@
+{% extends "base.html" %}
+{% block title %}My Events{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <h1>My Events</h1>
+    <a class="button" href="{{ url_for('new_event') }}">Create event</a>
+  </section>
+
+  {% if events %}
+    <div class="event-list">
+      {% for event in events %}
+        <article class="event-card">
+          <div>
+            <h2>{{ event.title }}</h2>
+            <p class="meta">{{ event.event_date }} · {{ event.location }}</p>
+          </div>
+          <p>{{ event.description }}</p>
+          <div class="actions">
+            <a class="button secondary" href="{{ url_for('edit_event', event_id=event.id) }}">Edit</a>
+            <form method="post" action="{{ url_for('delete_event', event_id=event.id) }}">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button class="danger" type="submit">Delete</button>
+            </form>
+          </div>
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty">You have not created any events yet.</p>
+  {% endif %}
+{% endblock %}
