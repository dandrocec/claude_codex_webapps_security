diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..d7041613a0a25a761dae917469a1df4692939771
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,290 @@
+:root {
+    color-scheme: light;
+    --bg: #f7f8fb;
+    --surface: #ffffff;
+    --text: #172033;
+    --muted: #687083;
+    --line: #dde2eb;
+    --primary: #2563eb;
+    --primary-dark: #1d4ed8;
+    --danger: #b42318;
+    --danger-dark: #8f1d14;
+    --success-bg: #ecfdf3;
+    --success-text: #067647;
+    --error-bg: #fef3f2;
+    --error-text: #b42318;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--bg);
+    color: var(--text);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.5;
+}
+
+a {
+    color: var(--primary);
+    text-decoration: none;
+}
+
+a:hover {
+    text-decoration: underline;
+}
+
+.site-header {
+    align-items: center;
+    background: var(--surface);
+    border-bottom: 1px solid var(--line);
+    display: flex;
+    justify-content: space-between;
+    padding: 16px max(24px, calc((100vw - 1040px) / 2));
+}
+
+.brand {
+    color: var(--text);
+    font-size: 20px;
+    font-weight: 700;
+}
+
+.nav {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 14px;
+}
+
+.user-label {
+    color: var(--muted);
+    font-size: 14px;
+}
+
+.container {
+    margin: 0 auto;
+    max-width: 1040px;
+    padding: 36px 24px;
+}
+
+.page-heading {
+    align-items: center;
+    display: flex;
+    gap: 24px;
+    justify-content: space-between;
+    margin-bottom: 24px;
+}
+
+h1,
+h2,
+p {
+    margin-top: 0;
+}
+
+h1 {
+    font-size: 32px;
+    margin-bottom: 6px;
+}
+
+h2 {
+    font-size: 22px;
+    margin-bottom: 6px;
+}
+
+.page-heading p,
+.event-meta,
+.empty-state {
+    color: var(--muted);
+}
+
+.button {
+    align-items: center;
+    background: var(--primary);
+    border: 0;
+    border-radius: 6px;
+    color: #ffffff;
+    cursor: pointer;
+    display: inline-flex;
+    font: inherit;
+    font-weight: 700;
+    justify-content: center;
+    min-height: 40px;
+    padding: 8px 14px;
+    text-decoration: none;
+    white-space: nowrap;
+}
+
+.button:hover {
+    background: var(--primary-dark);
+    text-decoration: none;
+}
+
+.button-secondary {
+    background: #edf2f7;
+    color: var(--text);
+}
+
+.button-secondary:hover {
+    background: #dce5f0;
+}
+
+.button-danger {
+    background: var(--danger);
+}
+
+.button-danger:hover {
+    background: var(--danger-dark);
+}
+
+.event-list {
+    display: grid;
+    gap: 16px;
+}
+
+.event-card {
+    background: var(--surface);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    display: grid;
+    gap: 18px;
+    grid-template-columns: 130px 1fr;
+    padding: 20px;
+}
+
+.event-date {
+    color: var(--primary);
+    font-weight: 700;
+}
+
+.event-body p:last-child {
+    margin-bottom: 0;
+}
+
+.table-wrap,
+.auth-panel,
+.form-panel {
+    background: var(--surface);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 24px;
+}
+
+table {
+    border-collapse: collapse;
+    width: 100%;
+}
+
+th,
+td {
+    border-bottom: 1px solid var(--line);
+    padding: 14px 10px;
+    text-align: left;
+    vertical-align: middle;
+}
+
+th {
+    color: var(--muted);
+    font-size: 13px;
+    text-transform: uppercase;
+}
+
+tr:last-child td {
+    border-bottom: 0;
+}
+
+.actions-col {
+    width: 190px;
+}
+
+.actions {
+    display: flex;
+    gap: 8px;
+}
+
+.actions form {
+    margin: 0;
+}
+
+.auth-panel,
+.form-panel {
+    max-width: 620px;
+}
+
+label {
+    display: block;
+    font-weight: 700;
+    margin: 16px 0 6px;
+}
+
+input,
+textarea {
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    color: var(--text);
+    font: inherit;
+    padding: 10px 12px;
+    width: 100%;
+}
+
+textarea {
+    resize: vertical;
+}
+
+.form-actions {
+    display: flex;
+    gap: 10px;
+    margin-top: 20px;
+}
+
+.messages {
+    display: grid;
+    gap: 10px;
+    margin-bottom: 20px;
+}
+
+.message {
+    border-radius: 6px;
+    padding: 12px 14px;
+}
+
+.message-success {
+    background: var(--success-bg);
+    color: var(--success-text);
+}
+
+.message-error {
+    background: var(--error-bg);
+    color: var(--error-text);
+}
+
+.empty-state {
+    background: var(--surface);
+    border: 1px dashed var(--line);
+    border-radius: 8px;
+    padding: 24px;
+}
+
+@media (max-width: 700px) {
+    .site-header,
+    .page-heading,
+    .event-card {
+        align-items: flex-start;
+        display: flex;
+        flex-direction: column;
+    }
+
+    .site-header {
+        gap: 14px;
+    }
+
+    .table-wrap {
+        overflow-x: auto;
+    }
+
+    .actions {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..3ab39752087e41473b8b0bb82b404fcad502c60d
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Events{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="site-header">
+        <a class="brand" href="{{ url_for('index') }}">Event Board</a>
+        <nav class="nav">
+            <a href="{{ url_for('index') }}">Upcoming</a>
+            {% if g.user %}
+                <a href="{{ url_for('dashboard') }}">My Events</a>
+                <span class="user-label">{{ g.user.username }}</span>
+                <a class="button button-secondary" href="{{ url_for('logout') }}">Log out</a>
+            {% else %}
+                <a href="{{ url_for('login') }}">Log in</a>
+                <a class="button" href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="container">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="messages">
+                    {% for category, message in messages %}
+                        <div class="message message-{{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..3f3dd9136ba819959b53fd522ae4af2e47791484
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,45 @@
+{% extends "base.html" %}
+
+{% block title %}My Events{% endblock %}
+
+{% block content %}
+<section class="page-heading">
+    <div>
+        <h1>My Events</h1>
+        <p>Create, edit, and remove the events you organise.</p>
+    </div>
+    <a class="button" href="{{ url_for('create_event') }}">Create event</a>
+</section>
+
+{% if events %}
+    <div class="table-wrap">
+        <table>
+            <thead>
+                <tr>
+                    <th>Title</th>
+                    <th>Date</th>
+                    <th>Location</th>
+                    <th class="actions-col">Actions</th>
+                </tr>
+            </thead>
+            <tbody>
+                {% for event in events %}
+                    <tr>
+                        <td>{{ event.title }}</td>
+                        <td>{{ event.event_date }}</td>
+                        <td>{{ event.location }}</td>
+                        <td class="actions">
+                            <a class="button button-secondary" href="{{ url_for('edit_event', event_id=event.id) }}">Edit</a>
+                            <form method="post" action="{{ url_for('delete_event', event_id=event.id) }}">
+                                <button class="button button-danger" type="submit">Delete</button>
+                            </form>
+                        </td>
+                    </tr>
+                {% endfor %}
+            </tbody>
+        </table>
+    </div>
+{% else %}
+    <p class="empty-state">You have not created any events.</p>
+{% endif %}
+{% endblock %}
diff --git a/templates/event_form.html b/templates/event_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..5dd676ebd21a5d3dca007efacfd17c003064f366
--- /dev/null
+++ b/templates/event_form.html
@@ -0,0 +1,27 @@
+{% extends "base.html" %}
+
+{% block title %}{{ heading }}{% endblock %}
+
+{% block content %}
+<section class="form-panel">
+    <h1>{{ heading }}</h1>
+    <form method="post">
+        <label for="title">Title</label>
+        <input id="title" name="title" value="{{ request.form.title or event.title if event else request.form.title }}" required>
+
+        <label for="event_date">Date</label>
+        <input id="event_date" name="event_date" type="date" value="{{ request.form.event_date or event.event_date if event else request.form.event_date }}" required>
+
+        <label for="location">Location</label>
+        <input id="location" name="location" value="{{ request.form.location or event.location if event else request.form.location }}" required>
+
+        <label for="description">Description</label>
+        <textarea id="description" name="description" rows="6" required>{{ request.form.description or event.description if event else request.form.description }}</textarea>
+
+        <div class="form-actions">
+            <button class="button" type="submit">Save event</button>
+            <a class="button button-secondary" href="{{ url_for('dashboard') }}">Cancel</a>
+        </div>
+    </form>
+</section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
