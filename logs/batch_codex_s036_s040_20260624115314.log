+                        <strong><?= money((int) $listing['price']) ?></strong>
+                        <p>Seller: <?= e($listing['seller_name']) ?></p>
+                    </div>
+                </a>
+            </article>
+        <?php endforeach; ?>
+    </div>
+<?php endif; ?>
