diff --git a/src/views/index.ejs b/src/views/index.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..63ccd11e05568bbfa1f7055d8b7e96aa875b0800
--- /dev/null
+++ b/src/views/index.ejs
@@ -0,0 +1,44 @@
+<%- include('partials/header') %>
+
+<section class="hero">
+  <h1>Open roles</h1>
+  <form class="search" method="get" action="/">
+    <input name="q" maxlength="100" value="<%= q || '' %>" placeholder="Search by title, company, keyword, or location">
+    <button type="submit">Search</button>
+  </form>
+</section>
+
+<% if (errors && errors.length) { %>
+  <div class="alert">
+    <% errors.forEach((error) => { %><p><%= error %></p><% }) %>
+  </div>
+<% } %>
+
+<section class="jobs">
+  <% if (!jobs.length) { %>
+    <p class="empty">No job listings found.</p>
+  <% } %>
+  <% jobs.forEach((job) => { %>
+    <article class="job">
+      <div>
+        <h2><%= job.title %></h2>
+        <p class="meta"><%= job.company %> · <%= job.location %></p>
+      </div>
+      <p><%= job.description %></p>
+      <div class="job-footer">
+        <small>Posted by <%= job.poster_email %> on <%= job.created_at %></small>
+        <% if (currentUser && currentUser.id === job.user_id) { %>
+          <div class="actions">
+            <a href="/jobs/<%= job.id %>/edit">Edit</a>
+            <form class="inline" method="post" action="/jobs/<%= job.id %>/delete">
+              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+              <button class="danger" type="submit">Delete</button>
+            </form>
+          </div>
+        <% } %>
+      </div>
+    </article>
+  <% }) %>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/src/views/job-form.ejs b/src/views/job-form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..4eec1a34828839ae7847a3262dba900a31e77d65
--- /dev/null
+++ b/src/views/job-form.ejs
@@ -0,0 +1,26 @@
+<%- include('partials/header') %>
+
+<section class="panel wide">
+  <h1><%= mode === 'edit' ? 'Edit job' : 'Post job' %></h1>
+  <% if (errors && errors.length) { %>
+    <div class="alert"><% errors.forEach((error) => { %><p><%= error %></p><% }) %></div>
+  <% } %>
+  <form method="post" action="<%= action %>">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Title
+      <input name="title" minlength="3" maxlength="120" required value="<%= values.title || '' %>">
+    </label>
+    <label>Company
+      <input name="company" minlength="2" maxlength="120" required value="<%= values.company || '' %>">
+    </label>
+    <label>Location
+      <input name="location" minlength="2" maxlength="120" required value="<%= values.location || '' %>">
+    </label>
+    <label>Description
+      <textarea name="description" minlength="20" maxlength="4000" required><%= values.description || '' %></textarea>
+    </label>
+    <button type="submit"><%= mode === 'edit' ? 'Save changes' : 'Post job' %></button>
+  </form>
+</section>
+
+<%- include('partials/footer') %>
