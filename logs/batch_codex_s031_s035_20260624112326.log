+    padding: 0;
+}
+
+.link-button:hover {
+    background: transparent;
+    text-decoration: underline;
+}
+
+.inline {
+    display: inline;
+}
+
+.wide {
+    grid-column: 1 / -1;
+}
+
+.actions,
+.card-actions,
+.search-row {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 10px;
+}
+
+.search-row {
+    margin-bottom: 20px;
+}
+
+.search-row input {
+    flex: 1 1 260px;
+}
+
+.contact-list {
+    display: grid;
+    gap: 14px;
+}
+
+.contact-card {
+    align-items: flex-start;
+    border: 1px solid var(--border);
+    border-radius: 8px;
+    display: grid;
+    gap: 18px;
+    grid-template-columns: 1fr auto;
+    padding: 18px;
+}
+
+.contact-card h2 {
+    margin-bottom: 8px;
+}
+
+.contact-card p {
+    margin-bottom: 6px;
+    overflow-wrap: anywhere;
+}
+
+.card-actions {
+    justify-content: flex-end;
+}
+
+.flash,
+.error {
+    border-radius: 6px;
+    margin-bottom: 16px;
