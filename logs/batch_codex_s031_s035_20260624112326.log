+  "description": "A simple PHP address book with user accounts and SQLite storage.",
+  "type": "project",
+  "require": {
+    "php": ">=8.1",
+    "ext-pdo": "*",
+    "ext-pdo_sqlite": "*"
+  },
+  "scripts": {
+    "serve": "php -S localhost:5033 -t public"
+  }
+}
