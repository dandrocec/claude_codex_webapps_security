+{% extends "base.html" %}
+{% block title %}{{ recipe.title }}{% endblock %}
+{% block content %}
+  <article class="detail">
+    {% if recipe.photo_filename %}
+      <img class="detail-photo" src="{{ url_for('uploaded_file', filename=recipe.photo_filename) }}" alt="{{ recipe.title }}">
+    {% endif %}
+    <div class="detail-header">
+      <div>
+        <h1>{{ recipe.title }}</h1>
+        <p class="meta">By {{ recipe.username }} · {{ recipe.created_at }}</p>
+      </div>
+      {% if g.user and g.user.id == recipe.user_id %}
+        <div class="actions">
+          <a class="secondary-button" href="{{ url_for('edit_recipe', recipe_id=recipe.id) }}">Edit</a>
+          <form method="post" action="{{ url_for('delete_recipe', recipe_id=recipe.id) }}" onsubmit="return confirm('Delete this recipe?');">
+            <button type="submit" class="danger-button">Delete</button>
+          </form>
+        </div>
+      {% endif %}
+    </div>
+
+    <section class="recipe-text">
+      <h2>Ingredients</h2>
+      <p>{{ recipe.ingredients }}</p>
+    </section>
+
+    <section class="recipe-text">
+      <h2>Steps</h2>
+      <p>{{ recipe.steps }}</p>
+    </section>
+  </article>
+{% endblock %}
diff --git a/templates/recipe_form.html b/templates/recipe_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..afd9c753b0f4bcaa56f4f1bb80e2b7795986719a
--- /dev/null
+++ b/templates/recipe_form.html
@@ -0,0 +1,28 @@
+{% extends "base.html" %}
+{% block title %}{% if recipe %}Edit{% else %}Add{% endif %} Recipe{% endblock %}
+{% block content %}
+  <section class="form-panel">
+    <h1>{% if recipe %}Edit recipe{% else %}Add recipe{% endif %}</h1>
+    <form method="post" enctype="multipart/form-data" class="form">
+      <label for="title">Title</label>
+      <input id="title" name="title" type="text" value="{{ recipe.title if recipe else '' }}" required>
+
+      <label for="ingredients">Ingredients</label>
+      <textarea id="ingredients" name="ingredients" rows="8" required>{{ recipe.ingredients if recipe else '' }}</textarea>
+
+      <label for="steps">Steps</label>
+      <textarea id="steps" name="steps" rows="10" required>{{ recipe.steps if recipe else '' }}</textarea>
+
+      <label for="photo">Photo</label>
+      <input id="photo" name="photo" type="file" accept="image/png,image/jpeg,image/gif,image/webp">
+      {% if recipe and recipe.photo_filename %}
+        <p class="helper">Uploading a new photo will replace the current one.</p>
+      {% endif %}
+
+      <div class="actions">
+        <button type="submit" class="primary-button">{% if recipe %}Save changes{% else %}Add recipe{% endif %}</button>
+        <a class="secondary-button" href="{{ url_for('index') }}">Cancel</a>
+      </div>
+    </form>
+  </section>
+{% endblock %}
