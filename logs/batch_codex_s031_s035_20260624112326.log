diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..cddf1cf975d4e8351b5b59534323073243a0223c
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,358 @@
+:root {
+    --bg: #f6f4ef;
+    --panel: #ffffff;
+    --ink: #1d2321;
+    --muted: #65706b;
+    --line: #d9ddd6;
+    --accent: #28665a;
+    --accent-dark: #17483f;
+    --warn: #a94032;
+    --success-bg: #e7f5ed;
+    --error-bg: #fdecea;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    min-height: 100vh;
+    background: var(--bg);
+    color: var(--ink);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.5;
+}
+
+a {
+    color: var(--accent-dark);
+}
+
+.topbar {
+    align-items: center;
+    background: var(--panel);
+    border-bottom: 1px solid var(--line);
+    display: flex;
+    gap: 24px;
+    justify-content: space-between;
+    padding: 16px clamp(18px, 4vw, 44px);
+}
+
+.brand {
+    color: var(--ink);
+    font-size: 20px;
+    font-weight: 800;
+    text-decoration: none;
+}
+
+.nav {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 14px;
+}
+
+.nav a {
+    text-decoration: none;
+}
+
+.user {
+    color: var(--muted);
+    font-weight: 700;
+}
+
+.page {
+    margin: 0 auto;
+    max-width: 1040px;
+    padding: 34px clamp(18px, 4vw, 44px);
+}
+
+.hero {
+    align-items: center;
+    display: grid;
+    min-height: 66vh;
+}
+
+.hero h1 {
+    font-size: clamp(38px, 7vw, 76px);
+    line-height: 1.02;
+    margin: 0;
+    max-width: 880px;
+}
+
+.eyebrow {
+    color: var(--accent);
+    font-size: 13px;
+    font-weight: 800;
+    letter-spacing: 0;
+    margin: 0 0 14px;
+    text-transform: uppercase;
+}
+
+.lede {
+    color: var(--muted);
+    font-size: 20px;
+    max-width: 650px;
+}
+
+.actions,
+.book-actions,
+.section-head {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 12px;
+}
+
+.section-head {
+    justify-content: space-between;
+    margin-bottom: 20px;
+}
+
+h1,
+h2,
+p {
+    margin-top: 0;
+}
+
+.button,
+button {
+    background: var(--accent);
+    border: 1px solid var(--accent);
+    border-radius: 7px;
+    color: #ffffff;
+    cursor: pointer;
+    display: inline-flex;
+    font: inherit;
+    font-weight: 700;
+    justify-content: center;
+    min-height: 42px;
+    padding: 9px 15px;
+    text-decoration: none;
+}
+
+.button:hover,
+button:hover {
+    background: var(--accent-dark);
+}
+
+.button.secondary {
+    background: #ffffff;
+    color: var(--accent-dark);
+}
+
+.button.secondary:hover {
+    background: #edf3f1;
+}
+
+.button.danger {
+    background: #ffffff;
+    border-color: #cdb3ad;
+    color: var(--warn);
+}
+
+.button.small {
+    min-height: 34px;
+    padding: 6px 11px;
+}
+
+.link-button {
+    background: transparent;
+    border: 0;
+    color: var(--accent-dark);
+    min-height: auto;
+    padding: 0;
+}
+
+.link-button:hover {
+    background: transparent;
+    text-decoration: underline;
+}
+
+.auth-panel,
+.empty {
+    background: var(--panel);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    margin: 0 auto;
+    max-width: 440px;
+    padding: 28px;
+}
+
+.auth-panel.wide {
+    max-width: 680px;
+}
+
+.form {
+    display: grid;
+    gap: 16px;
+}
+
+.form-row {
+    display: grid;
+    gap: 16px;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+}
+
+label {
+    color: var(--ink);
+    display: grid;
+    font-weight: 700;
+    gap: 7px;
+}
+
+input,
+select,
+textarea {
+    border: 1px solid var(--line);
+    border-radius: 7px;
+    color: var(--ink);
+    font: inherit;
+    padding: 10px 12px;
+    width: 100%;
+}
+
+textarea {
+    resize: vertical;
+}
+
+.muted {
+    color: var(--muted);
+}
+
+.flash-stack {
+    display: grid;
+    gap: 10px;
+    margin-bottom: 20px;
+}
+
+.flash {
+    border-radius: 7px;
+    padding: 12px 14px;
+}
+
+.flash.success {
+    background: var(--success-bg);
+}
+
+.flash.error {
+    background: var(--error-bg);
+}
+
+.filters {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 10px;
+    margin-bottom: 20px;
+}
+
+.filters a {
+    background: #ffffff;
+    border: 1px solid var(--line);
+    border-radius: 999px;
+    color: var(--ink);
+    padding: 8px 13px;
+    text-decoration: none;
+}
+
+.filters a.active {
+    background: var(--accent);
+    border-color: var(--accent);
+    color: #ffffff;
+}
+
+.filters span {
+    font-weight: 800;
+}
+
+.book-list {
+    display: grid;
+    gap: 14px;
+}
+
+.book-card {
+    background: var(--panel);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 20px;
+}
+
+.book-main {
+    align-items: start;
+    display: flex;
+    gap: 16px;
+    justify-content: space-between;
+}
+
+.book-main h2 {
+    margin-bottom: 4px;
+}
+
+.book-meta {
+    color: var(--muted);
+    display: flex;
+    flex-wrap: wrap;
+    gap: 14px;
+    margin: 12px 0;
+}
+
+.status {
+    border-radius: 999px;
+    font-size: 13px;
+    font-weight: 800;
+    padding: 5px 10px;
+    white-space: nowrap;
+}
+
+.status.to-read {
+    background: #ece7d7;
+}
+
+.status.reading {
+    background: #ddecf1;
+}
+
+.status.finished {
+    background: #dff0e6;
+}
+
+.notes {
+    border-left: 3px solid var(--line);
+    color: var(--muted);
+    padding-left: 12px;
+}
+
+.book-actions {
+    justify-content: flex-start;
+    margin-top: 14px;
+}
+
+.book-actions form {
+    align-items: center;
+    display: flex;
+    gap: 8px;
+}
+
+.empty {
+    text-align: center;
+}
+
+@media (max-width: 680px) {
+    .topbar,
+    .section-head,
+    .book-main {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    .form-row {
+        grid-template-columns: 1fr;
+    }
+
+    .book-actions,
+    .book-actions form {
+        align-items: stretch;
+        flex-direction: column;
+        width: 100%;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..446bf63dd164c467dcea63c4592758f0d91ec9b6
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,40 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Reading List{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Reading List</a>
+        <nav class="nav">
+            {% if g.user %}
+                <span class="user">{{ g.user["username"] }}</span>
+                <a href="{{ url_for('books') }}">My books</a>
+                <a href="{{ url_for('new_book') }}">Add book</a>
+                <form method="post" action="{{ url_for('logout') }}">
+                    <button class="link-button" type="submit">Log out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Log in</a>
+                <a class="button small" href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="page">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="flash-stack">
+                    {% for category, message in messages %}
+                        <div class="flash {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/book_form.html b/templates/book_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..b07317fa81c7b3e6b29bea63ce6059c713132ba9
--- /dev/null
+++ b/templates/book_form.html
@@ -0,0 +1,41 @@
+{% extends "base.html" %}
+
+{% block title %}{{ action }} Book - Reading List{% endblock %}
+
+{% block content %}
+<section class="auth-panel wide">
+    <h1>{{ action }} book</h1>
+    <form method="post" class="form">
+        <label>
+            Title
+            <input name="title" value="{{ book['title'] }}" required>
+        </label>
+        <label>
+            Author
+            <input name="author" value="{{ book['author'] }}" required>
+        </label>
+        <div class="form-row">
+            <label>
+                Status
+                <select name="status">
+                    {% for status in statuses %}
+                        <option value="{{ status }}" {{ "selected" if book["status"] == status else "" }}>{{ status|replace("-", " ")|title }}</option>
+                    {% endfor %}
+                </select>
+            </label>
+            <label>
+                Rating
+                <input name="rating" type="number" min="1" max="5" value="{{ book['rating'] or '' }}" placeholder="1-5">
+            </label>
+        </div>
+        <label>
+            Notes
+            <textarea name="notes" rows="5">{{ book['notes'] }}</textarea>
+        </label>
+        <div class="actions">
+            <button class="button" type="submit">{{ action }} book</button>
+            <a class="button secondary" href="{{ url_for('books') }}">Cancel</a>
+        </div>
+    </form>
+</section>
+{% endblock %}
diff --git a/templates/books.html b/templates/books.html
new file mode 100644
index 0000000000000000000000000000000000000000..48997cc7c5979d701512a39e41f6f599404f5d33
--- /dev/null
+++ b/templates/books.html
@@ -0,0 +1,65 @@
+{% extends "base.html" %}
+
+{% block title %}My Books - Reading List{% endblock %}
+
+{% block content %}
+<section class="section-head">
+    <div>
+        <h1>My books</h1>
+        <p class="muted">{{ total }} book{{ "" if total == 1 else "s" }} in your list</p>
+    </div>
+    <a class="button" href="{{ url_for('new_book') }}">Add book</a>
+</section>
+
+<nav class="filters" aria-label="Book filters">
+    <a class="{{ 'active' if selected_status == 'all' else '' }}" href="{{ url_for('books') }}">All <span>{{ total }}</span></a>
+    {% for status in statuses %}
+        <a class="{{ 'active' if selected_status == status else '' }}" href="{{ url_for('books', status=status) }}">
+            {{ status|replace("-", " ")|title }} <span>{{ counts.get(status, 0) }}</span>
+        </a>
+    {% endfor %}
+</nav>
+
+{% if books %}
+    <div class="book-list">
+        {% for book in books %}
+            <article class="book-card">
+                <div class="book-main">
+                    <div>
+                        <h2>{{ book["title"] }}</h2>
+                        <p class="muted">by {{ book["author"] }}</p>
+                    </div>
+                    <span class="status {{ book['status'] }}">{{ book["status"]|replace("-", " ")|title }}</span>
+                </div>
+                <div class="book-meta">
+                    <span>Rating: {{ book["rating"] or "Not rated" }}</span>
+                    <span>Updated: {{ book["updated_at"][:10] }}</span>
+                </div>
+                {% if book["notes"] %}
+                    <p class="notes">{{ book["notes"] }}</p>
+                {% endif %}
+                <div class="book-actions">
+                    <form method="post" action="{{ url_for('update_status', book_id=book['id']) }}">
+                        <select name="status" aria-label="Update status">
+                            {% for status in statuses %}
+                                <option value="{{ status }}" {{ "selected" if book["status"] == status else "" }}>{{ status|replace("-", " ")|title }}</option>
+                            {% endfor %}
+                        </select>
+                        <button class="button small secondary" type="submit">Mark</button>
+                    </form>
+                    <a class="button small secondary" href="{{ url_for('edit_book', book_id=book['id']) }}">Edit</a>
+                    <form method="post" action="{{ url_for('delete_book', book_id=book['id']) }}">
+                        <button class="button small danger" type="submit">Delete</button>
+                    </form>
+                </div>
+            </article>
+        {% endfor %}
+    </div>
+{% else %}
+    <section class="empty">
+        <h2>No books here yet</h2>
+        <p class="muted">Add a book to start tracking your reading progress.</p>
+        <a class="button" href="{{ url_for('new_book') }}">Add your first book</a>
+    </section>
+{% endif %}
+{% endblock %}
