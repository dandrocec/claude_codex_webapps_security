+        recipes = query_all(
+            """
+            SELECT recipes.id, recipes.title, recipes.ingredients, recipes.photo_filename,
+                   recipes.created_at, users.username
+            FROM recipes
+            JOIN users ON users.id = recipes.user_id
+            ORDER BY recipes.created_at DESC
+            """
