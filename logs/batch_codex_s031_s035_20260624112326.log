+{% extends "base.html" %}
+{% block title %}Edit Book{% endblock %}
+{% block content %}
+<section class="panel narrow">
+    <h1>Edit book</h1>
+    <form method="post" action="{{ url_for('edit_book', book_id=book.id) }}">
+        {{ csrf_field() }}
+        <label>Title
+            <input name="title" maxlength="120" value="{{ book.title }}" required>
+        </label>
+        <label>Author
+            <input name="author" maxlength="120" value="{{ book.author }}" required>
+        </label>
+        <label>Status
+            <select name="status" required>
+                {% for status in statuses %}
+                    <option value="{{ status }}" {% if book.status == status %}selected{% endif %}>{{ status }}</option>
+                {% endfor %}
+            </select>
+        </label>
+        <label>Rating
+            <select name="rating">
+                <option value="">Unrated</option>
+                {% for value in range(1, 6) %}
+                    <option value="{{ value }}" {% if book.rating == value %}selected{% endif %}>{{ value }}</option>
+                {% endfor %}
+            </select>
+        </label>
+        <button type="submit">Save</button>
+    </form>
+</section>
+{% endblock %}
