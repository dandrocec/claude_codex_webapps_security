+{% extends "base.html" %}
+{% block title %}{{ title }}{% endblock %}
+{% block content %}
+<section class="error-panel">
+  <h1>{{ title }}</h1>
+  <p>{{ message }}</p>
+  <a class="button" href="{{ url_for('index') }}">Back to recipes</a>
+</section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
