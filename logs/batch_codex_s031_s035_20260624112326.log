+{% extends "base.html" %}
+{% block title %}{{ recipe.title }}{% endblock %}
+{% block content %}
+  <article class="detail">
+    {% if recipe.photo_filename %}
+      <img class="detail-photo" src="{{ url_for('uploaded_file', filename=recipe.photo_filename) }}" alt="{{ recipe.title }}">
+    {% endif %}
+    <div class="detail-header">
+      <div>
+        <h1>{{ recipe.title }}</h1>
+        <p class="meta">By {{ recipe.username }} · {{ recipe.created_at }}</p>
+      </div>
+      {% if g.user and g.user.id == recipe.user_id %}
+        <div class="actions">
+          <a class="secondary-button" href="{{ url_for('edit_recipe', recipe_id=recipe.id) }}">Edit</a>
+          <form method="post" action="{{ url_for('delete_recipe', recipe_id=recipe.id) }}" onsubmit="return confirm('Delete this recipe?');">
+            <button type="submit" class="danger-button">Delete</button>
+          </form>
+        </div>
+      {% endif %}
+    </div>
+
+    <section class="recipe-text">
+      <h2>Ingredients</h2>
+      <p>{{ recipe.ingredients }}</p>
+    </section>
+
+    <section class="recipe-text">
+      <h2>Steps</h2>
+      <p>{{ recipe.steps }}</p>
+    </section>
+  </article>
+{% endblock %}
