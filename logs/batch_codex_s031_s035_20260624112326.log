diff --git a/static/style.css b/static/style.css
new file mode 100644
index 0000000000000000000000000000000000000000..f15a21fa2b3f8476ede736bea0f2edf9ee813e86
--- /dev/null
+++ b/static/style.css
@@ -0,0 +1,197 @@
+:root {
+    color-scheme: light;
+    --bg: #f5f7f9;
+    --panel: #ffffff;
+    --ink: #18212f;
+    --muted: #657285;
+    --line: #dce2e8;
+    --accent: #266a5d;
+    --accent-dark: #1e5248;
+    --danger: #a83232;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--bg);
+    color: var(--ink);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.5;
+}
+
+a {
+    color: var(--accent);
+    text-decoration: none;
+}
+
+.topbar {
+    align-items: center;
+    background: var(--panel);
+    border-bottom: 1px solid var(--line);
+    display: flex;
+    justify-content: space-between;
+    padding: 16px clamp(16px, 4vw, 48px);
+}
+
+.brand {
+    color: var(--ink);
+    font-size: 1.15rem;
+    font-weight: 700;
+}
+
+nav {
+    align-items: center;
+    display: flex;
+    gap: 14px;
+}
+
+.container {
+    margin: 0 auto;
+    max-width: 980px;
+    padding: 32px 16px;
+}
+
+.panel,
+.book {
+    background: var(--panel);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 24px;
+}
+
+.narrow {
+    margin: 0 auto;
+    max-width: 460px;
+}
+
+h1,
+h2,
+p {
+    margin-top: 0;
+}
+
+h1 {
+    font-size: 2rem;
+}
+
+h2 {
+    font-size: 1.15rem;
+    margin-bottom: 4px;
+}
+
+.meta,
+.book p {
+    color: var(--muted);
+}
+
+form {
+    display: grid;
+    gap: 14px;
+}
+
+.inline {
+    display: inline;
+}
+
+.grid-form {
+    align-items: end;
+    display: grid;
+    grid-template-columns: repeat(5, minmax(0, 1fr));
+}
+
+label {
+    color: var(--muted);
+    display: grid;
+    font-size: 0.9rem;
+    gap: 6px;
+}
+
+input,
+select {
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    color: var(--ink);
+    font: inherit;
+    min-height: 42px;
+    padding: 8px 10px;
+    width: 100%;
+}
+
+button,
+.button {
+    background: var(--accent);
+    border: 0;
+    border-radius: 6px;
+    color: #ffffff;
+    cursor: pointer;
+    display: inline-flex;
+    font: inherit;
+    justify-content: center;
+    min-height: 42px;
+    padding: 9px 14px;
+}
+
+button:hover,
+.button:hover {
+    background: var(--accent-dark);
+}
+
+.secondary {
+    background: #e6efec;
+    color: var(--accent-dark);
+}
+
+.secondary:hover {
+    background: #d5e4df;
+}
+
+.danger {
+    background: var(--danger);
+}
+
+.actions,
+.book-actions {
+    display: flex;
+    gap: 10px;
+}
+
+.book-list {
+    display: grid;
+    gap: 14px;
+    margin-top: 18px;
+}
+
+.book {
+    align-items: center;
+    display: flex;
+    justify-content: space-between;
+    gap: 16px;
+}
+
+.alerts {
+    background: #fff7df;
+    border: 1px solid #ead79d;
+    border-radius: 8px;
+    margin-bottom: 18px;
+    padding: 12px 16px;
+}
+
+.alerts p:last-child {
+    margin-bottom: 0;
+}
+
+@media (max-width: 760px) {
+    .grid-form,
+    .book {
+        display: grid;
+        grid-template-columns: 1fr;
+    }
+
+    .topbar {
+        align-items: flex-start;
+        gap: 12px;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..cae06662a386ac1f494cda22d8f2b8fb22bbfea2
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Reading List{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
+</head>
+<body>
+    <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Reading List</a>
+        <nav>
+            {% if g.user %}
+                <span>{{ g.user.username }}</span>
+                <form class="inline" method="post" action="{{ url_for('logout') }}">
+                    {{ csrf_field() }}
+                    <button type="submit">Log out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Log in</a>
+                <a href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+    <main class="container">
+        {% with messages = get_flashed_messages() %}
+            {% if messages %}
+                <div class="alerts">
+                    {% for message in messages %}
+                        <p>{{ message }}</p>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/books.html b/templates/books.html
new file mode 100644
index 0000000000000000000000000000000000000000..502b4406495f9eb606342f20bfd2853f9319e883
--- /dev/null
+++ b/templates/books.html
@@ -0,0 +1,55 @@
+{% extends "base.html" %}
+{% block title %}My Books{% endblock %}
+{% block content %}
+<section class="panel">
+    <h1>My books</h1>
+    <form class="grid-form" method="post" action="{{ url_for('add_book') }}">
+        {{ csrf_field() }}
+        <label>Title
+            <input name="title" maxlength="120" required>
+        </label>
+        <label>Author
+            <input name="author" maxlength="120" required>
+        </label>
+        <label>Status
+            <select name="status" required>
+                <option value="to-read">To-read</option>
+                <option value="reading">Reading</option>
+                <option value="finished">Finished</option>
+            </select>
+        </label>
+        <label>Rating
+            <select name="rating">
+                <option value="">Unrated</option>
+                {% for value in range(1, 6) %}
+                    <option value="{{ value }}">{{ value }}</option>
+                {% endfor %}
+            </select>
+        </label>
+        <button type="submit">Add</button>
+    </form>
+</section>
+
+<section class="book-list">
+    {% for book in books %}
+        <article class="book">
+            <div>
+                <h2>{{ book.title }}</h2>
+                <p>{{ book.author }}</p>
+                <p class="meta">{{ book.status }}{% if book.rating %} - {{ book.rating }}/5{% endif %}</p>
+            </div>
+            <div class="book-actions">
+                <a class="button secondary" href="{{ url_for('edit_book', book_id=book.id) }}">Edit</a>
+                <form method="post" action="{{ url_for('delete_book', book_id=book.id) }}">
+                    {{ csrf_field() }}
+                    <button class="danger" type="submit">Delete</button>
+                </form>
+            </div>
+        </article>
+    {% else %}
+        <section class="panel">
+            <p>No books yet.</p>
+        </section>
+    {% endfor %}
+</section>
+{% endblock %}
