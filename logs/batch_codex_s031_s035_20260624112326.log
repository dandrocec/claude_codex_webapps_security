+<%- include("partials/header", { title: "Habits" }) %>
+<div class="topbar">
+  <div>
+    <div class="brand">Habit Tracker</div>
+    <div class="muted">Signed in as <%= username %></div>
+  </div>
+  <form class="inline" method="post" action="/logout">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <button class="secondary" type="submit">Log out</button>
+  </form>
+</div>
+
+<section class="panel stack">
+  <h1>Daily habits</h1>
+  <form method="post" action="/habits">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label for="name">New habit</label>
+    <div class="row">
+      <input id="name" name="name" type="text" maxlength="80" required placeholder="Drink water">
+      <button type="submit">Add</button>
+    </div>
+  </form>
+
+  <div>
+    <% if (habits.length === 0) { %>
+      <p class="muted">No habits yet.</p>
+    <% } %>
+    <% habits.forEach((habit) => { %>
+      <div class="habit">
+        <div>
+          <div class="habit-name"><%= habit.name %></div>
+          <div class="muted">Created <%= habit.created_at %></div>
+        </div>
+        <form method="post" action="/habits/<%= habit.id %>/toggle">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <% if (!habit.completed_today) { %>
+            <input type="hidden" name="completed" value="on">
+            <button type="submit">Tick today</button>
+          <% } else { %>
+            <button class="secondary" type="submit">Untick today</button>
+          <% } %>
+        </form>
+        <div class="row">
+          <span class="streak"><%= habit.streak %> day streak</span>
+          <form method="post" action="/habits/<%= habit.id %>/delete">
+            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+            <button class="danger" type="submit">Delete</button>
+          </form>
+        </div>
+      </div>
+    <% }) %>
+  </div>
+</section>
+<%- include("partials/footer") %>
diff --git a/src/views/layout.ejs b/src/views/layout.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..f8b567092f3b44f3f62c3c2cd8cb7243884b4bff
--- /dev/null
+++ b/src/views/layout.ejs
@@ -0,0 +1,74 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title><%= title %> | Habit Tracker</title>
+    <style>
+      :root {
+        color-scheme: light;
+        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+        background: #f7f5ef;
+        color: #1f2933;
+      }
+      * { box-sizing: border-box; }
+      body { margin: 0; min-height: 100vh; }
+      main { width: min(920px, calc(100% - 32px)); margin: 0 auto; padding: 32px 0; }
+      a { color: #116466; }
+      .topbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 28px; }
+      .brand { font-weight: 800; font-size: 1.2rem; }
+      .panel { background: #ffffff; border: 1px solid #ddd8ca; border-radius: 8px; padding: 22px; box-shadow: 0 10px 25px rgba(31, 41, 51, 0.08); }
+      h1 { margin: 0 0 16px; font-size: clamp(1.6rem, 4vw, 2.2rem); letter-spacing: 0; }
+      h2 { margin: 0; font-size: 1.05rem; }
+      form { margin: 0; }
+      label { display: block; font-weight: 650; margin: 14px 0 6px; }
+      input[type="text"], input[type="password"] {
+        width: 100%;
+        border: 1px solid #b8b2a3;
+        border-radius: 6px;
+        min-height: 44px;
+        padding: 10px 12px;
+        font: inherit;
+        background: #fff;
+      }
+      button {
+        border: 0;
+        border-radius: 6px;
+        min-height: 40px;
+        padding: 9px 14px;
+        font: inherit;
+        font-weight: 700;
+        background: #116466;
+        color: white;
+        cursor: pointer;
+      }
+      button.secondary { background: #4b5563; }
+      button.danger { background: #a43d32; }
+      .row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
+      .stack { display: grid; gap: 14px; }
+      .errors { border-left: 4px solid #a43d32; background: #fff3f1; padding: 10px 12px; margin-bottom: 16px; }
+      .habit {
+        display: grid;
+        grid-template-columns: minmax(0, 1fr) auto auto;
+        gap: 12px;
+        align-items: center;
+        padding: 14px 0;
+        border-top: 1px solid #e7e1d3;
+      }
+      .habit-name { font-weight: 750; overflow-wrap: anywhere; }
+      .streak { color: #38424d; font-weight: 700; white-space: nowrap; }
+      .muted { color: #64707d; }
+      .auth { max-width: 460px; margin: 48px auto; }
+      .inline { display: inline; }
+      @media (max-width: 640px) {
+        .habit { grid-template-columns: 1fr; }
+        .topbar { align-items: flex-start; flex-direction: column; }
+      }
+    </style>
+  </head>
+  <body>
+    <main>
+      <%- body %>
+    </main>
+  </body>
+</html>
