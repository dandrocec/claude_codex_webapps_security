+  {% if recipe.photo_filename %}
+    <img class="hero-photo" src="{{ url_for('uploaded_file', filename=recipe.photo_filename) }}" alt="">
+  {% endif %}
+  <h1>{{ recipe.title }}</h1>
+  <p class="meta">By {{ recipe.username }} on {{ recipe.created_at[:10] }}</p>
+
+  {% if g.user and g.user.id == recipe.user_id %}
+    <div class="actions">
+      <a class="button" href="{{ url_for('edit_recipe', recipe_id=recipe.id) }}">Edit</a>
+      <form method="post" action="{{ url_for('delete_recipe', recipe_id=recipe.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <button class="danger" type="submit">Delete</button>
+      </form>
+    </div>
+  {% endif %}
+
+  <h2>Ingredients</h2>
+  <p class="preline">{{ recipe.ingredients }}</p>
+
+  <h2>Steps</h2>
+  <p class="preline">{{ recipe.steps }}</p>
+</article>
+{% endblock %}
