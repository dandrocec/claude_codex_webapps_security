--- /dev/null
+++ b/templates/books.html
@@ -0,0 +1,55 @@
+{% extends "base.html" %}
+{% block title %}My Books{% endblock %}
+{% block content %}
+<section class="panel">
+    <h1>My books</h1>
+    <form class="grid-form" method="post" action="{{ url_for('add_book') }}">
+        {{ csrf_field() }}
+        <label>Title
+            <input name="title" maxlength="120" required>
+        </label>
+        <label>Author
+            <input name="author" maxlength="120" required>
+        </label>
+        <label>Status
+            <select name="status" required>
+                <option value="to-read">To-read</option>
+                <option value="reading">Reading</option>
+                <option value="finished">Finished</option>
+            </select>
+        </label>
+        <label>Rating
+            <select name="rating">
+                <option value="">Unrated</option>
+                {% for value in range(1, 6) %}
+                    <option value="{{ value }}">{{ value }}</option>
+                {% endfor %}
+            </select>
+        </label>
+        <button type="submit">Add</button>
+    </form>
+</section>
+
+<section class="book-list">
+    {% for book in books %}
+        <article class="book">
+            <div>
+                <h2>{{ book.title }}</h2>
+                <p>{{ book.author }}</p>
+                <p class="meta">{{ book.status }}{% if book.rating %} · {{ book.rating }}/5{% endif %}</p>
+            </div>
+            <div class="book-actions">
+                <a class="button secondary" href="{{ url_for('edit_book', book_id=book.id) }}">Edit</a>
+                <form method="post" action="{{ url_for('delete_book', book_id=book.id) }}">
+                    {{ csrf_field() }}
+                    <button class="danger" type="submit">Delete</button>
+                </form>
+            </div>
+        </article>
+    {% else %}
+        <section class="panel">
+            <p>No books yet.</p>
+        </section>
+    {% endfor %}
+</section>
+{% endblock %}
