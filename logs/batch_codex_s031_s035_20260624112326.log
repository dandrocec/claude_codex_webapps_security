diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..91aa5db4f5130b8609ea94274dcc542be305dc7d
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,235 @@
+:root {
+  color-scheme: light;
+  --bg: #f7f4ee;
+  --panel: #ffffff;
+  --text: #22211f;
+  --muted: #6d6860;
+  --border: #ddd6c9;
+  --accent: #2f6f5e;
+  --accent-dark: #245849;
+  --danger: #a53935;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent-dark);
+}
+
+.site-header {
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  margin: 0 auto;
+  max-width: 1100px;
+  padding: 16px 20px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.2rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.nav-links {
+  align-items: center;
+  display: flex;
+  gap: 14px;
+}
+
+.user-label,
+.meta {
+  color: var(--muted);
+  font-size: 0.92rem;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1100px;
+  padding: 28px 20px 56px;
+}
+
+.section-heading {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  margin-bottom: 20px;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 14px;
+}
+
+.recipe-grid {
+  display: grid;
+  gap: 18px;
+  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
+}
+
+.recipe-card,
+.auth-panel,
+.form-panel,
+.recipe-detail,
+.error-panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+}
+
+.recipe-card {
+  overflow: hidden;
+}
+
+.recipe-card img {
+  aspect-ratio: 16 / 10;
+  display: block;
+  object-fit: cover;
+  width: 100%;
+}
+
+.card-body,
+.auth-panel,
+.form-panel,
+.recipe-detail,
+.error-panel {
+  padding: 22px;
+}
+
+.auth-panel,
+.form-panel,
+.recipe-detail,
+.error-panel {
+  margin: 0 auto;
+  max-width: 760px;
+}
+
+form {
+  display: grid;
+  gap: 16px;
+}
+
+.inline-form {
+  display: inline;
+}
+
+label {
+  display: grid;
+  font-weight: 700;
+  gap: 6px;
+}
+
+input,
+textarea {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  font: inherit;
+  padding: 10px 12px;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 14px;
+  text-decoration: none;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+}
+
+.danger {
+  background: var(--danger);
+}
+
+.messages {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 18px;
+}
+
+.message {
+  border-radius: 6px;
+  padding: 10px 12px;
+}
+
+.message.error {
+  background: #f8dfdd;
+  color: #6d211f;
+}
+
+.message.success {
+  background: #dff0e8;
+  color: #1f523f;
+}
+
+.actions {
+  align-items: center;
+  display: flex;
+  gap: 12px;
+  margin: 18px 0;
+}
+
+.hero-photo,
+.preview {
+  border-radius: 8px;
+  display: block;
+  max-height: 420px;
+  object-fit: cover;
+  width: 100%;
+}
+
+.preview {
+  max-height: 240px;
+}
+
+.preline {
+  white-space: pre-line;
+}
+
+.empty {
+  color: var(--muted);
+}
+
+@media (max-width: 640px) {
+  .nav,
+  .section-heading,
+  .nav-links {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .nav-links {
+    gap: 10px;
+  }
+}
