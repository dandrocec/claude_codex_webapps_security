diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..6f23580b382fb288a0821cc9e4ff301bd9dcab3e
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,322 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #16202a;
+  --muted: #637083;
+  --line: #dce1e8;
+  --primary: #176b5d;
+  --primary-dark: #105044;
+  --danger: #a33838;
+  --success: #1e7040;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--primary);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  min-height: 68px;
+  padding: 0 32px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.2rem;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 16px;
+}
+
+.nav-user {
+  color: var(--muted);
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1120px;
+  padding: 32px;
+}
+
+.hero {
+  align-items: center;
+  background: linear-gradient(135deg, #e8f4f1, #ffffff);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  display: flex;
+  min-height: 320px;
+  padding: 48px;
+}
+
+.hero h1 {
+  font-size: 2.6rem;
+  line-height: 1.1;
+  margin: 0 0 16px;
+  max-width: 720px;
+}
+
+.hero p {
+  color: var(--muted);
+  font-size: 1.1rem;
+  max-width: 680px;
+}
+
+.section-heading {
+  align-items: center;
+  display: flex;
+  gap: 20px;
+  justify-content: space-between;
+  margin: 0 0 20px;
+}
+
+.section-heading h1,
+.section-heading h2,
+.section-heading h3 {
+  margin: 0;
+}
+
+.section-heading.compact {
+  align-items: flex-start;
+  margin-bottom: 12px;
+}
+
+.grid {
+  display: grid;
+  gap: 18px;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+}
+
+.card,
+.panel,
+.application {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.card {
+  padding: 22px;
+}
+
+.panel {
+  padding: 28px;
+}
+
+.panel.narrow {
+  margin: 0 auto;
+  max-width: 520px;
+}
+
+.application {
+  padding: 20px;
+}
+
+.stack {
+  display: grid;
+  gap: 16px;
+}
+
+.muted {
+  color: var(--muted);
+}
+
+.empty {
+  color: var(--muted);
+  padding: 24px;
+  text-align: center;
+}
+
+.messages {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 20px;
+}
+
+.message {
+  border-radius: 8px;
+  padding: 12px 14px;
+}
+
+.message.error {
+  background: #f8e8e8;
+  color: var(--danger);
+}
+
+.message.success {
+  background: #e8f4ec;
+  color: var(--success);
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+  margin-top: 20px;
+}
+
+.button {
+  background: var(--primary);
+  border: 0;
+  border-radius: 6px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 11px 16px;
+}
+
+.button:hover {
+  background: var(--primary-dark);
+  text-decoration: none;
+}
+
+.button.secondary {
+  background: #dfe9e7;
+  color: var(--primary-dark);
+}
+
+.button-small {
+  padding: 7px 11px;
+}
+
+form {
+  display: grid;
+  gap: 16px;
+}
+
+label {
+  display: grid;
+  font-weight: 700;
+  gap: 6px;
+}
+
+input,
+textarea,
+select {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  padding: 10px 12px;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+fieldset {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  display: flex;
+  gap: 18px;
+  margin: 0;
+  padding: 14px;
+}
+
+.choice {
+  align-items: center;
+  display: flex;
+  font-weight: 400;
+  gap: 8px;
+}
+
+.choice input {
+  width: auto;
+}
+
+.table-wrap {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  overflow-x: auto;
+}
+
+table {
+  border-collapse: collapse;
+  min-width: 760px;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: 14px;
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  background: #eef2f5;
+}
+
+.status {
+  background: #eef2f5;
+  border-radius: 999px;
+  display: inline-block;
+  font-weight: 700;
+  padding: 4px 10px;
+}
+
+.inline-form {
+  align-items: end;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+}
+
+.job-description {
+  white-space: normal;
+}
+
+@media (max-width: 720px) {
+  .site-header,
+  .section-heading {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .site-header {
+    padding: 18px;
+  }
+
+  .page {
+    padding: 20px;
+  }
+
+  .hero,
+  .panel {
+    padding: 24px;
+  }
+
+  .hero h1 {
+    font-size: 2rem;
+  }
+}
diff --git a/templates/applicant_dashboard.html b/templates/applicant_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..0a767f45de39fd5bd768ec921ca7e03f8a4fa0ed
--- /dev/null
+++ b/templates/applicant_dashboard.html
@@ -0,0 +1,39 @@
+{% extends "base.html" %}
+
+{% block title %}My Applications{% endblock %}
+
+{% block content %}
+<div class="section-heading">
+  <h1>My applications</h1>
+  <a class="button" href="{{ url_for('jobs') }}">Find jobs</a>
+</div>
+
+<div class="table-wrap">
+  <table>
+    <thead>
+      <tr>
+        <th>Job</th>
+        <th>Employer</th>
+        <th>Location</th>
+        <th>Status</th>
+        <th>Submitted</th>
+        <th>Resume</th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for application in applications %}
+        <tr>
+          <td>{{ application.title }}</td>
+          <td>{{ application.employer_name }}</td>
+          <td>{{ application.location }}</td>
+          <td><span class="status">{{ application.status }}</span></td>
+          <td>{{ application.created_at }}</td>
+          <td><a href="{{ url_for('resume', filename=application.resume_filename) }}">{{ application.resume_original_name }}</a></td>
+        </tr>
+      {% else %}
+        <tr><td colspan="6" class="empty">You have not submitted any applications.</td></tr>
+      {% endfor %}
+    </tbody>
+  </table>
+</div>
+{% endblock %}
diff --git a/templates/apply.html b/templates/apply.html
new file mode 100644
index 0000000000000000000000000000000000000000..859372b915e15198137fe492e500410abc0d45cd
--- /dev/null
+++ b/templates/apply.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+
+{% block title %}Apply{% endblock %}
+
+{% block content %}
+<section class="panel">
+  <p class="muted">{{ job.location }}</p>
+  <h1>Apply for {{ job.title }}</h1>
+  <form method="post" enctype="multipart/form-data">
+    <label>Cover letter
+      <textarea name="cover_letter" rows="8" required></textarea>
+    </label>
+    <label>Resume
+      <input type="file" name="resume" accept=".pdf,.doc,.docx,.txt,.rtf" required>
+    </label>
+    <button class="button" type="submit">Submit application</button>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..7e37602edd6f9744b12b40796a063aee8b837f38
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,42 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Recruiting Portal{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <a class="brand" href="{{ url_for('index') }}">Recruiting Portal</a>
+      <nav>
+        <a href="{{ url_for('jobs') }}">Jobs</a>
+        {% if current_user %}
+          {% if current_user.role == "employer" %}
+            <a href="{{ url_for('employer_dashboard') }}">Employer Dashboard</a>
+          {% else %}
+            <a href="{{ url_for('applicant_dashboard') }}">My Applications</a>
+          {% endif %}
+          <span class="nav-user">{{ current_user.name }}</span>
+          <a href="{{ url_for('logout') }}">Logout</a>
+        {% else %}
+          <a href="{{ url_for('login') }}">Login</a>
+          <a class="button button-small" href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </nav>
+    </header>
+
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <div class="message {{ category }}">{{ message }}</div>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/employer_dashboard.html b/templates/employer_dashboard.html
new file mode 100644
