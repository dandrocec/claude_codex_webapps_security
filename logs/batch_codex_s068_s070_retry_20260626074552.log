+      {% for job in jobs %}
+        <tr>
+          <td>{{ job.title }}<br><span class="meta">{{ job.company }}</span></td>
+          <td>{{ job.location }}</td>
+          <td>{{ job.application_count }}</td>
+          <td><a href="{{ url_for('job_applications', job_id=job.id) }}">Review</a></td>
+        </tr>
+      {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p>You have not posted any jobs yet.</p>
+  {% endif %}
+{% endblock %}
