+{% extends "base.html" %}
+
+{% block title %}Employer Dashboard{% endblock %}
+
+{% block content %}
+<div class="section-heading">
+  <h1>Employer dashboard</h1>
+  <a class="button" href="{{ url_for('new_job') }}">Post job</a>
+</div>
+
+<div class="table-wrap">
+  <table>
+    <thead>
+      <tr>
+        <th>Job</th>
+        <th>Location</th>
+        <th>Applications</th>
+        <th>Posted</th>
+        <th></th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for job in jobs %}
+        <tr>
+          <td>{{ job.title }}</td>
+          <td>{{ job.location }}</td>
+          <td>{{ job.application_count }}</td>
+          <td>{{ job.created_at }}</td>
+          <td><a href="{{ url_for('review_applications', job_id=job.id) }}">Review</a></td>
+        </tr>
+      {% else %}
+        <tr><td colspan="5" class="empty">Post your first job to start receiving applications.</td></tr>
+      {% endfor %}
+    </tbody>
+  </table>
+</div>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..fb36f1e27ee8794dfd60f2f69f49efcff96a2ee5
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,35 @@
+{% extends "base.html" %}
+
+{% block title %}Recruiting Portal{% endblock %}
+
+{% block content %}
+<section class="hero">
+  <div>
+    <h1>Hiring and applications in one focused workspace.</h1>
+    <p>Employers can publish roles and review candidates. Applicants can apply with a resume and track each submission.</p>
+    <div class="actions">
+      <a class="button" href="{{ url_for('register') }}">Create account</a>
+      <a class="button secondary" href="{{ url_for('jobs') }}">Browse jobs</a>
+    </div>
+  </div>
+</section>
+
+<section>
+  <div class="section-heading">
+    <h2>Recent jobs</h2>
+    <a href="{{ url_for('jobs') }}">View all</a>
+  </div>
+  <div class="grid">
+    {% for job in jobs %}
+      <article class="card">
+        <h3>{{ job.title }}</h3>
+        <p class="muted">{{ job.employer_name }} · {{ job.location }}</p>
+        <p>{{ job.description[:160] }}{% if job.description|length > 160 %}...{% endif %}</p>
+        <a href="{{ url_for('job_detail', job_id=job.id) }}">View role</a>
+      </article>
+    {% else %}
+      <p class="empty">No jobs have been posted yet.</p>
+    {% endfor %}
+  </div>
+</section>
+{% endblock %}
