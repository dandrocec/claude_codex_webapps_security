@@ -0,0 +1,25 @@
+{
+  "name": "secure-crowdfunding-express",
+  "version": "1.0.0",
+  "description": "A secure Node.js/Express crowdfunding site with SQLite storage.",
+  "main": "app.js",
+  "scripts": {
+    "start": "node app.js"
+  },
+  "dependencies": {
+    "bcrypt": "^5.1.1",
+    "better-sqlite3": "^11.9.1",
+    "connect-sqlite3": "^0.9.15",
+    "csurf": "^1.11.0",
+    "ejs": "^3.1.10",
+    "express": "^4.21.2",
+    "express-rate-limit": "^7.5.0",
+    "express-session": "^1.18.1",
+    "express-validator": "^7.2.1",
+    "helmet": "^8.0.0",
+    "morgan": "^1.10.0"
+  },
+  "engines": {
+    "node": ">=18"
+  }
+}
diff --git a/public/styles.css b/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..c4a729683da84ae7c690f6f3d0c1024098639e11
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,204 @@
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  color: #1f2933;
+  background: #f6f8fb;
+}
+
+a {
+  color: #0b5cad;
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 16px 24px;
+  background: #ffffff;
+  border-bottom: 1px solid #d9e2ec;
+}
+
+.brand {
+  font-size: 20px;
+  font-weight: 700;
+  color: #102a43;
+  text-decoration: none;
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  flex-wrap: wrap;
+}
+
+.container {
+  width: min(1040px, calc(100% - 32px));
+  margin: 32px auto;
+}
+
+.page-head {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 24px;
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+  gap: 18px;
+}
+
+.card,
+.panel {
+  background: #ffffff;
+  border: 1px solid #d9e2ec;
+  border-radius: 8px;
+  padding: 20px;
+  box-shadow: 0 8px 22px rgba(16, 42, 67, 0.05);
+}
+
+.card h2,
+.panel h1 {
+  margin-top: 0;
+}
+
+.muted {
+  color: #627d98;
+}
+
+.description {
+  white-space: pre-wrap;
+  line-height: 1.5;
+}
+
+.progress {
+  height: 12px;
+  overflow: hidden;
+  border-radius: 999px;
+  background: #d9e2ec;
+  margin: 16px 0 8px;
+}
+
+.progress span {
+  display: block;
+  height: 100%;
+  background: #2f9e44;
+}
+
+.stats {
+  display: flex;
+  gap: 20px;
+  flex-wrap: wrap;
+  margin: 16px 0;
+}
+
+.stat strong {
+  display: block;
+  font-size: 22px;
+}
+
+label {
+  display: block;
+  font-weight: 700;
+  margin: 14px 0 6px;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid #bcccdc;
+  border-radius: 6px;
+  padding: 10px 12px;
+  font: inherit;
+  background: #ffffff;
+}
+
+textarea {
+  min-height: 150px;
+  resize: vertical;
+}
+
+.button,
+button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  border: 0;
+  border-radius: 6px;
+  padding: 10px 14px;
+  min-height: 40px;
+  background: #0b5cad;
+  color: #ffffff;
+  font: inherit;
+  font-weight: 700;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+.button.secondary,
+button.secondary {
+  background: #52606d;
+}
+
+.button.danger,
+button.danger {
+  background: #c92a2a;
+}
+
+.inline-form {
+  display: inline;
+}
+
+.errors,
+.flash {
+  border-radius: 6px;
+  padding: 12px 14px;
+  margin-bottom: 16px;
+}
+
+.errors {
+  border: 1px solid #ffa8a8;
+  background: #fff5f5;
+  color: #9b1c1c;
+}
+
+.flash.success {
+  border: 1px solid #b2f2bb;
+  background: #ebfbee;
+  color: #2b8a3e;
+}
+
+.flash.error {
+  border: 1px solid #ffa8a8;
+  background: #fff5f5;
+  color: #9b1c1c;
+}
+
+.pledges {
+  list-style: none;
+  padding: 0;
+}
+
+.pledges li {
+  display: flex;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 12px 0;
+  border-bottom: 1px solid #edf2f7;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .page-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
