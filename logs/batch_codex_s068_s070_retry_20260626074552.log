diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..894fa498d434db866c114556b3cb06c2644cb3d5
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,186 @@
+:root {
+  color-scheme: light;
+  --ink: #17202a;
+  --muted: #5d6d7e;
+  --line: #d5d8dc;
+  --panel: #ffffff;
+  --soft: #f4f6f7;
+  --accent: #146c94;
+  --accent-dark: #0f536f;
+  --danger: #a93226;
+  --ok: #1e8449;
+}
+
+* { box-sizing: border-box; }
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  color: var(--ink);
+  background: var(--soft);
+  line-height: 1.5;
+}
+
+header {
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+}
+
+.nav,
+main {
+  width: min(1080px, calc(100% - 32px));
+  margin: 0 auto;
+}
+
+.nav {
+  min-height: 64px;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  flex-wrap: wrap;
+}
+
+.brand {
+  color: var(--ink);
+  font-size: 1.25rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.links {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  flex-wrap: wrap;
+}
+
+main { padding: 28px 0 48px; }
+
+a { color: var(--accent); }
+
+.button,
+button {
+  border: 0;
+  border-radius: 6px;
+  background: var(--accent);
+  color: white;
+  cursor: pointer;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 40px;
+  padding: 0 14px;
+  text-decoration: none;
+  font: inherit;
+  font-weight: 700;
+}
+
+.button:hover,
+button:hover { background: var(--accent-dark); }
+
+.button.secondary {
+  background: #e8eef1;
+  color: var(--ink);
+}
+
+.button.secondary:hover { background: #d7e0e5; }
+
+.inline-form { display: inline; }
+
+.grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+  gap: 16px;
+}
+
+.card {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.meta {
+  color: var(--muted);
+  font-size: 0.95rem;
+}
+
+.flash {
+  border-radius: 6px;
+  margin-bottom: 14px;
+  padding: 10px 12px;
+  background: #eef7f0;
+  color: var(--ok);
+  border: 1px solid #bfe3c7;
+}
+
+.flash.error {
+  background: #fbebea;
+  color: var(--danger);
+  border-color: #efc2bd;
+}
+
+form.stack {
+  display: grid;
+  gap: 14px;
+  max-width: 680px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+input,
+select,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  padding: 10px 12px;
+  background: white;
+  color: var(--ink);
+}
+
+textarea {
+  min-height: 170px;
+  resize: vertical;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+  background: var(--panel);
+  border: 1px solid var(--line);
+}
+
+th,
+td {
+  padding: 12px;
+  border-bottom: 1px solid var(--line);
+  text-align: left;
+  vertical-align: top;
+}
+
+th { background: #eef2f3; }
+
+.prewrap {
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+}
+
+@media (max-width: 700px) {
+  th,
+  td {
+    display: block;
+    width: 100%;
+  }
+
+  tr {
+    display: block;
+    border-bottom: 1px solid var(--line);
+  }
+}
diff --git a/templates/applicant_dashboard.html b/templates/applicant_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..b0c2de5a08773456b7a5b23325992e7bf7244232
--- /dev/null
+++ b/templates/applicant_dashboard.html
@@ -0,0 +1,21 @@
+{% extends "base.html" %}
+{% block content %}
+  <h1>Applicant dashboard</h1>
+  {% if applications %}
+    <table>
+      <thead><tr><th>Job</th><th>Employer</th><th>Submitted</th><th>Resume</th></tr></thead>
+      <tbody>
+      {% for application in applications %}
+        <tr>
+          <td>{{ application.title }}<br><span class="meta">{{ application.location }}</span></td>
+          <td>{{ application.employer_name }}</td>
+          <td>{{ application.created_at }}</td>
+          <td><a href="{{ url_for('download_resume', application_id=application.id) }}">Download</a></td>
+        </tr>
+      {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p>You have not submitted any applications yet.</p>
+  {% endif %}
+{% endblock %}
diff --git a/templates/applications.html b/templates/applications.html
new file mode 100644
index 0000000000000000000000000000000000000000..e2bc18c9b01e3704fec7c6a664c3fc2e59006717
--- /dev/null
+++ b/templates/applications.html
@@ -0,0 +1,21 @@
+{% extends "base.html" %}
+{% block content %}
+  <h1>Applications for {{ job.title }}</h1>
+  {% if applications %}
+    <table>
+      <thead><tr><th>Applicant</th><th>Cover letter</th><th>Submitted</th><th>Resume</th></tr></thead>
+      <tbody>
+      {% for application in applications %}
+        <tr>
+          <td>{{ application.applicant_name }}<br><span class="meta">{{ application.applicant_email }}</span></td>
+          <td class="prewrap">{{ application.cover_letter }}</td>
+          <td>{{ application.created_at }}</td>
+          <td><a href="{{ url_for('download_resume', application_id=application.id) }}">Download</a></td>
+        </tr>
+      {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p>No applications have been submitted for this job.</p>
+  {% endif %}
+{% endblock %}
diff --git a/templates/apply.html b/templates/apply.html
new file mode 100644
index 0000000000000000000000000000000000000000..cd29ace3a9f99bc2d6d969e9afe67578cd960617
--- /dev/null
+++ b/templates/apply.html
@@ -0,0 +1,16 @@
+{% extends "base.html" %}
+{% block content %}
+  <h1>Apply for {{ job.title }}</h1>
+  <p class="meta">{{ job.company }} · {{ job.location }}</p>
+  <form class="stack" method="post" action="{{ url_for('apply', job_id=job.id) }}" enctype="multipart/form-data">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+    <label>Cover letter
+      <textarea name="cover_letter" maxlength="4000" required>{{ form.get('cover_letter', '') }}</textarea>
+    </label>
+    <label>Resume
+      <input name="resume" type="file" accept=".pdf,.docx,.txt" required>
+    </label>
+    <p class="meta">Accepted files: PDF, DOCX, or UTF-8 TXT. Maximum size: 2 MB.</p>
+    <button type="submit">Submit application</button>
+  </form>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..b8eb17ee0c785f2c7dd4f4d1bd318f533d1ee9ac
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{{ title or "Recruiting" }}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header>
+    <nav class="nav">
+      <a class="brand" href="{{ url_for('index') }}">Recruiting</a>
+      <div class="links">
+        {% if current_user %}
+          <a href="{{ url_for('dashboard') }}">Dashboard</a>
+          {% if current_user.role == "employer" %}
+            <a href="{{ url_for('new_job') }}">Post job</a>
+          {% endif %}
+          <span class="meta">{{ current_user.name }}</span>
+          <form class="inline-form" method="post" action="{{ url_for('logout') }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+            <button type="submit" class="button secondary">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Sign in</a>
+          <a class="button" href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </div>
+    </nav>
+  </header>
+  <main>
+    {% for category, message in get_flashed_messages(with_categories=true) %}
+      <div class="flash {{ category }}">{{ message }}</div>
+    {% endfor %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
