diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..df4b68ece86a5ed7ca3a30f47d2419b8e4736aa1
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,221 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #20242a;
+  --muted: #626c77;
+  --line: #d9dee5;
+  --primary: #1967d2;
+  --primary-dark: #1450a3;
+  --danger-bg: #feecec;
+  --danger: #8f1d1d;
+  --success-bg: #e9f7ef;
+  --success: #17633a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--primary);
+  text-decoration: none;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  min-height: 64px;
+  padding: 0 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.2rem;
+  font-weight: 700;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  gap: 16px;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 1180px;
+  padding: 32px 20px;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 24px;
+}
+
+.hero {
+  max-width: 720px;
+}
+
+.narrow {
+  max-width: 460px;
+}
+
+.grid {
+  display: grid;
+  gap: 24px;
+  grid-template-columns: minmax(300px, 0.85fr) minmax(0, 1.5fr);
+}
+
+h1 {
+  font-size: 1.6rem;
+  line-height: 1.2;
+  margin: 0 0 18px;
+}
+
+p {
+  color: var(--muted);
+}
+
+form {
+  display: grid;
+  gap: 16px;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  color: var(--muted);
+  display: grid;
+  font-size: 0.95rem;
+  gap: 6px;
+}
+
+input,
+select,
+button,
+.button {
+  border-radius: 6px;
+  font: inherit;
+}
+
+input,
+select {
+  border: 1px solid var(--line);
+  padding: 10px 12px;
+  width: 100%;
+}
+
+button,
+.button {
+  background: #fff;
+  border: 1px solid var(--line);
+  color: var(--text);
+  cursor: pointer;
+  display: inline-block;
+  padding: 9px 14px;
+}
+
+button.primary,
+.button.primary {
+  background: var(--primary);
+  border-color: var(--primary);
+  color: #fff;
+}
+
+button:hover,
+.button:hover {
+  border-color: var(--primary);
+}
+
+button.primary:hover,
+.button.primary:hover {
+  background: var(--primary-dark);
+}
+
+.actions {
+  display: flex;
+  gap: 12px;
+  margin-top: 24px;
+}
+
+.messages {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 20px;
+}
+
+.message {
+  border-radius: 6px;
+  padding: 10px 12px;
+}
+
+.message.error {
+  background: var(--danger-bg);
+  color: var(--danger);
+}
+
+.message.success {
+  background: var(--success-bg);
+  color: var(--success);
+}
+
+table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: 10px;
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  color: var(--muted);
+  font-size: 0.9rem;
+}
+
+code {
+  background: #eef1f5;
+  border-radius: 4px;
+  padding: 2px 5px;
+}
+
+@media (max-width: 800px) {
+  .topbar {
+    align-items: flex-start;
+    flex-direction: column;
+    gap: 10px;
+    padding: 16px 20px;
+  }
+
+  nav {
+    flex-wrap: wrap;
+  }
+
+  .grid {
+    grid-template-columns: 1fr;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..b8769c27abf2b890c1c41e58bdb612d402acd1e2
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Scheduler{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Scheduler</a>
+    <nav>
+      {% if g.user %}
+        <span>{{ g.user.display_name }}</span>
+        <form method="post" action="{{ url_for('logout') }}" class="inline">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages">
+          {% for category, message in messages %}
+            <div class="message {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/client_dashboard.html b/templates/client_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..54c6b476728ac8e7f57fbc98711575e2c150aaaf
--- /dev/null
+++ b/templates/client_dashboard.html
@@ -0,0 +1,55 @@
+{% extends "base.html" %}
+{% block title %}Client dashboard{% endblock %}
+{% block content %}
+<section class="grid">
+  <div class="panel">
+    <h1>Available slots</h1>
+    {% if open_slots %}
+      <table>
+        <thead>
+          <tr><th>Provider</th><th>Start</th><th>End</th><th></th></tr>
+        </thead>
+        <tbody>
+          {% for slot in open_slots %}
+            <tr>
+              <td>{{ slot.provider_name }}</td>
+              <td>{{ slot.starts_at }}</td>
+              <td>{{ slot.ends_at }}</td>
+              <td>
+                <form method="post" action="{{ url_for('book_slot', slot_id=slot.id) }}" class="inline">
+                  <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                  <button type="submit" class="primary">Book</button>
+                </form>
+              </td>
+            </tr>
+          {% endfor %}
+        </tbody>
+      </table>
+    {% else %}
+      <p>No open slots right now.</p>
+    {% endif %}
+  </div>
+  <div class="panel">
+    <h1>Your appointments</h1>
+    {% if appointments %}
+      <table>
+        <thead>
+          <tr><th>Provider</th><th>Start</th><th>End</th><th>Confirmation</th></tr>
+        </thead>
+        <tbody>
+          {% for appointment in appointments %}
+            <tr>
+              <td>{{ appointment.provider_name }}</td>
+              <td>{{ appointment.starts_at }}</td>
+              <td>{{ appointment.ends_at }}</td>
+              <td><code>{{ appointment.confirmation_code }}</code></td>
+            </tr>
+          {% endfor %}
+        </tbody>
+      </table>
+    {% else %}
+      <p>You have not booked any appointments.</p>
+    {% endif %}
+  </div>
+</section>
+{% endblock %}
