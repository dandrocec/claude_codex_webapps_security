diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..e517d1ba205b3d8e52c5c3248e10b53e680da3f5
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,259 @@
+:root {
+    color-scheme: light;
+    --bg: #f6f7f9;
+    --panel: #ffffff;
+    --text: #1d2430;
+    --muted: #667085;
+    --line: #d8dee8;
+    --primary: #176b87;
+    --primary-dark: #0f5268;
+    --success: #18794e;
+    --danger: #b42318;
+    --warning: #a15c07;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    min-height: 100vh;
+    background: var(--bg);
+    color: var(--text);
+    font-family: Arial, Helvetica, sans-serif;
+}
+
+a {
+    color: var(--primary);
+    text-decoration: none;
+}
+
+a:hover {
+    text-decoration: underline;
+}
+
+.topbar {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 1rem;
+    padding: 1rem 1.5rem;
+    background: var(--panel);
+    border-bottom: 1px solid var(--line);
+}
+
+.brand {
+    color: var(--text);
+    font-size: 1.25rem;
+    font-weight: 700;
+}
+
+nav {
+    display: flex;
+    align-items: center;
+    gap: 1rem;
+    flex-wrap: wrap;
+}
+
+.container {
+    width: min(1120px, calc(100% - 2rem));
+    margin: 2rem auto;
+}
+
+.hero,
+.panel {
+    background: var(--panel);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 1.5rem;
+}
+
+.hero {
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+    gap: 1.5rem;
+}
+
+h1 {
+    margin: 0 0 1rem;
+    font-size: 1.6rem;
+}
+
+p {
+    line-height: 1.45;
+}
+
+.grid {
+    display: grid;
+    grid-template-columns: minmax(280px, 0.8fr) minmax(320px, 1.2fr);
+    gap: 1.5rem;
+    align-items: start;
+}
+
+.narrow {
+    max-width: 480px;
+    margin: 0 auto;
+}
+
+form {
+    display: grid;
+    gap: 1rem;
+}
+
+label {
+    display: grid;
+    gap: 0.4rem;
+    color: var(--text);
+    font-weight: 700;
+}
+
+input,
+select,
+textarea {
+    width: 100%;
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    padding: 0.7rem 0.8rem;
+    color: var(--text);
+    font: inherit;
+    font-weight: 400;
+    background: #fff;
+}
+
+button,
+.button {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    border: 0;
+    border-radius: 6px;
+    padding: 0.75rem 1rem;
+    background: var(--primary);
+    color: #fff;
+    font: inherit;
+    font-weight: 700;
+    cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+    background: var(--primary-dark);
+    text-decoration: none;
+}
+
+.button.secondary {
+    background: #e8eef3;
+    color: var(--text);
+}
+
+.actions {
+    display: flex;
+    gap: 0.8rem;
+    flex-wrap: wrap;
+}
+
+.inline {
+    display: inline;
+}
+
+.link-button {
+    padding: 0;
+    background: transparent;
+    color: var(--primary);
+    font-weight: 400;
+}
+
+.link-button:hover {
+    background: transparent;
+    text-decoration: underline;
+}
+
+.messages {
+    display: grid;
+    gap: 0.75rem;
+    margin-bottom: 1rem;
+}
+
+.message {
+    border-radius: 6px;
+    padding: 0.8rem 1rem;
+    background: #eef4ff;
+    border: 1px solid #c7d7fe;
+}
+
+.message.success {
+    background: #ecfdf3;
+    border-color: #abefc6;
+    color: var(--success);
+}
+
+.message.danger {
+    background: #fef3f2;
+    border-color: #fecdca;
+    color: var(--danger);
+}
+
+.message.warning {
+    background: #fffaeb;
+    border-color: #fedf89;
+    color: var(--warning);
+}
+
+.stack {
+    display: grid;
+    gap: 1rem;
+}
+
+.appointment {
+    display: grid;
+    gap: 0.75rem;
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 1rem;
+}
+
+.appointment p {
+    margin: 0.35rem 0 0;
+}
+
+.badge {
+    width: max-content;
+    border-radius: 999px;
+    padding: 0.25rem 0.65rem;
+    font-size: 0.85rem;
+    font-weight: 700;
+}
+
+.badge.open {
+    background: #ecfdf3;
+    color: var(--success);
+}
+
+.badge.booked {
+    background: #eff8ff;
+    color: var(--primary);
+}
+
+.muted {
+    color: var(--muted);
+}
+
+code {
+    background: #eef2f6;
+    border-radius: 4px;
+    padding: 0.15rem 0.3rem;
+}
+
+@media (max-width: 760px) {
+    .topbar,
+    .hero {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    .grid {
+        grid-template-columns: 1fr;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..d19c11691ac704f70520350e09ae689005efe668
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Scheduler{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Scheduler</a>
+        <nav>
+            {% if g.user %}
+                <span class="muted">{{ g.user.name }} · {{ g.user.role }}</span>
+                <a href="{{ url_for('dashboard') }}">Dashboard</a>
+                <form class="inline" action="{{ url_for('logout') }}" method="post">
+                    <button type="submit" class="link-button">Sign out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Sign in</a>
+                <a href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="container">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="messages">
+                    {% for category, message in messages %}
+                        <div class="message {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/client.html b/templates/client.html
new file mode 100644
index 0000000000000000000000000000000000000000..ba83bf14bc993fc9fbae5e347b46ba9a98fb223d
--- /dev/null
+++ b/templates/client.html
@@ -0,0 +1,47 @@
+{% extends "base.html" %}
+{% block title %}Client Dashboard · Scheduler{% endblock %}
+{% block content %}
+<div class="grid">
+    <section class="panel">
+        <h1>Available slots</h1>
+        {% if available_slots %}
+            <div class="stack">
+                {% for slot in available_slots %}
+                    <article class="appointment">
+                        <div>
+                            <strong>{{ slot.starts_at }}</strong>
+                            <p>Provider: {{ slot.provider_name }}</p>
+                            {% if slot.notes %}<p>{{ slot.notes }}</p>{% endif %}
+                        </div>
+                        <form action="{{ url_for('book', slot_id=slot.id) }}" method="post">
+                            <button type="submit">Book</button>
+                        </form>
+                    </article>
+                {% endfor %}
+            </div>
+        {% else %}
+            <p class="muted">No open slots are available.</p>
+        {% endif %}
+    </section>
+
+    <section class="panel">
+        <h1>Your appointments</h1>
+        {% if appointments %}
+            <div class="stack">
+                {% for item in appointments %}
+                    <article class="appointment">
+                        <div>
+                            <strong>{{ item.starts_at }}</strong>
+                            <p>Provider: {{ item.provider_name }} ({{ item.provider_email }})</p>
+                            {% if item.notes %}<p>{{ item.notes }}</p>{% endif %}
+                            <p>Confirmation: <code>{{ item.confirmation_code }}</code></p>
+                        </div>
+                    </article>
+                {% endfor %}
+            </div>
+        {% else %}
+            <p class="muted">You have no booked appointments.</p>
+        {% endif %}
+    </section>
+</div>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..6d7e1c25c5866d623a2a52a0575c9838ed5e28a3
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,14 @@
+{% extends "base.html" %}
+{% block title %}Scheduler{% endblock %}
+{% block content %}
+<section class="hero">
+    <div>
+        <h1>Simple appointment scheduling</h1>
+        <p>Providers publish available times. Clients reserve open slots and receive confirmation codes.</p>
+    </div>
+    <div class="actions">
+        <a class="button" href="{{ url_for('register') }}">Create account</a>
+        <a class="button secondary" href="{{ url_for('login') }}">Sign in</a>
+    </div>
+</section>
