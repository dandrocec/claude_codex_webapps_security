@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Scheduler{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Scheduler</a>
+        <nav>
+            {% if g.user %}
+                <span class="muted">{{ g.user.name }} · {{ g.user.role }}</span>
+                <a href="{{ url_for('dashboard') }}">Dashboard</a>
+                <form class="inline" action="{{ url_for('logout') }}" method="post">
+                    <button type="submit" class="link-button">Sign out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Sign in</a>
+                <a href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="container">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="messages">
+                    {% for category, message in messages %}
+                        <div class="message {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/client.html b/templates/client.html
new file mode 100644
index 0000000000000000000000000000000000000000..ba83bf14bc993fc9fbae5e347b46ba9a98fb223d
--- /dev/null
+++ b/templates/client.html
@@ -0,0 +1,47 @@
+{% extends "base.html" %}
+{% block title %}Client Dashboard · Scheduler{% endblock %}
+{% block content %}
+<div class="grid">
+    <section class="panel">
+        <h1>Available slots</h1>
+        {% if available_slots %}
+            <div class="stack">
+                {% for slot in available_slots %}
+                    <article class="appointment">
+                        <div>
+                            <strong>{{ slot.starts_at }}</strong>
+                            <p>Provider: {{ slot.provider_name }}</p>
+                            {% if slot.notes %}<p>{{ slot.notes }}</p>{% endif %}
+                        </div>
+                        <form action="{{ url_for('book', slot_id=slot.id) }}" method="post">
+                            <button type="submit">Book</button>
+                        </form>
+                    </article>
+                {% endfor %}
+            </div>
+        {% else %}
+            <p class="muted">No open slots are available.</p>
+        {% endif %}
+    </section>
+
+    <section class="panel">
+        <h1>Your appointments</h1>
+        {% if appointments %}
+            <div class="stack">
+                {% for item in appointments %}
