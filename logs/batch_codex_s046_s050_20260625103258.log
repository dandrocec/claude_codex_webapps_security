+<%- include("partials/header") %>
+
+<section class="panel auth-panel">
+  <div class="section-head">
+    <h1>Reviewer login</h1>
+    <p>Use the reviewer account to view submitted feedback.</p>
+  </div>
+
+  <% if (error) { %>
+    <div class="notice error"><%= error %></div>
