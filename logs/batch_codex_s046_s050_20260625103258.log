diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..90f770686b46057bbb1cf7f456925dddc891c84a
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,413 @@
+:root {
+  color-scheme: light;
+  --bg: #f4f6f8;
+  --panel: #ffffff;
+  --text: #18212f;
+  --muted: #697386;
+  --line: #d8dee8;
+  --primary: #1864ab;
+  --primary-dark: #124d82;
+  --danger: #b42318;
+  --success-bg: #e8f6ee;
+  --success-text: #17613a;
+  --error-bg: #fff0ed;
+  --error-text: #9f2a1d;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+a {
+  color: var(--primary);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  min-height: 64px;
+  padding: 0 28px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 18px;
+  font-weight: 800;
+}
+
+.topbar nav {
+  align-items: center;
+  display: flex;
+  gap: 18px;
+}
+
+.topbar form {
+  margin: 0;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1120px;
+  padding: 32px 24px 56px;
+}
+
+.page-heading {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  margin-bottom: 24px;
+  gap: 20px;
+}
+
+.page-heading h1,
+.auth-panel h1 {
+  font-size: 34px;
+  line-height: 1.1;
+  margin: 0;
+}
+
+.eyebrow {
+  color: var(--muted);
+  font-size: 13px;
+  font-weight: 800;
+  letter-spacing: 0.08em;
+  margin: 0 0 8px;
+  text-transform: uppercase;
+}
+
+.auth-panel,
+.content-panel,
+.stat-card,
+.draft-card,
+.email-preview {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.auth-panel {
+  margin: 72px auto;
+  max-width: 420px;
+  padding: 28px;
+}
+
+.content-panel {
+  margin-bottom: 22px;
+  padding: 24px;
+}
+
+.content-panel h2,
+.draft-card h2 {
+  font-size: 20px;
+  margin: 0 0 16px;
+}
+
+.stats-grid {
+  display: grid;
+  gap: 18px;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  margin-bottom: 22px;
+}
+
+.stat-card {
+  padding: 24px;
+}
+
+.stat-card span,
+.draft-card span,
+.list span,
+.panel-title span,
+.muted {
+  color: var(--muted);
+}
+
+.stat-card strong {
+  display: block;
+  font-size: 40px;
+  line-height: 1;
+  margin-top: 8px;
+}
+
+.panel-title {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  margin-bottom: 16px;
+  gap: 16px;
+}
+
+.panel-title h2 {
+  margin: 0;
+}
+
+.stacked-form,
+.inline-form {
+  display: grid;
+  gap: 16px;
+}
+
+.inline-form {
+  align-items: end;
+  grid-template-columns: minmax(160px, 1fr) minmax(220px, 1.3fr) auto;
+}
+
+label {
+  color: var(--muted);
+  display: grid;
+  font-size: 14px;
+  font-weight: 700;
+  gap: 7px;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 11px 12px;
+  width: 100%;
+}
+
+textarea {
+  line-height: 1.5;
+  resize: vertical;
+}
+
+button,
+.button {
+  align-items: center;
+  background: #ffffff;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 800;
+  justify-content: center;
+  min-height: 40px;
+  padding: 9px 14px;
+}
+
+button:hover,
+.button:hover {
+  border-color: #aeb8c7;
+  text-decoration: none;
+}
+
+.primary {
+  background: var(--primary);
+  border-color: var(--primary);
+  color: #ffffff;
+}
+
+.primary:hover {
+  background: var(--primary-dark);
+  border-color: var(--primary-dark);
+}
+
+.danger {
+  color: var(--danger);
+}
+
+.button-row {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+}
+
+.alerts {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 20px;
+}
+
+.alert {
+  border-radius: 6px;
+  font-weight: 700;
+  padding: 12px 14px;
+}
+
+.alert.success {
+  background: var(--success-bg);
+  color: var(--success-text);
+}
+
+.alert.error {
+  background: var(--error-bg);
+  color: var(--error-text);
+}
+
+.list {
+  display: grid;
+  gap: 12px;
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.list li {
+  align-items: center;
+  border-top: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding-top: 12px;
+  gap: 16px;
+}
+
+.list li:first-child {
+  border-top: 0;
+  padding-top: 0;
+}
+
+.list span {
+  display: block;
+  font-size: 14px;
+  margin-top: 3px;
+}
+
+table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-top: 1px solid var(--line);
+  padding: 13px 10px;
+  text-align: left;
+}
+
+th {
+  color: var(--muted);
+  font-size: 13px;
+  text-transform: uppercase;
+}
+
+.actions {
+  text-align: right;
+}
+
+.actions form,
+.button-row form {
+  display: inline;
+  margin: 0;
+}
+
+.draft-grid {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+}
+
+.draft-card {
+  display: grid;
+  gap: 10px;
+  padding: 20px;
+}
+
+.draft-card p {
+  color: var(--muted);
+  line-height: 1.5;
+  margin: 0;
+}
+
+.preview-shell {
+  display: flex;
+  justify-content: center;
+}
+
+.email-preview {
+  max-width: 760px;
+  overflow: hidden;
+  width: 100%;
+}
+
+.email-preview header {
+  background: #12324d;
+  color: #ffffff;
+  padding: 32px;
+}
+
+.email-preview header span {
+  display: block;
+  font-size: 13px;
+  font-weight: 800;
+  letter-spacing: 0.1em;
+  margin-bottom: 12px;
+  text-transform: uppercase;
+}
+
+.email-preview header h2 {
+  font-size: 30px;
+  line-height: 1.2;
+  margin: 0;
+}
+
+.email-body {
+  line-height: 1.65;
+  padding: 32px;
+}
+
+.email-body p:first-child {
+  margin-top: 0;
+}
+
+.email-preview footer {
+  background: #eef2f6;
+  color: var(--muted);
+  font-size: 13px;
+  padding: 20px 32px;
+}
+
+.empty {
+  color: var(--muted);
+  margin: 0;
+}
+
+@media (max-width: 720px) {
+  .topbar,
+  .page-heading {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .topbar {
+    padding: 18px;
+  }
+
+  .topbar nav {
+    align-items: flex-start;
+    flex-wrap: wrap;
+  }
+
+  .page {
+    padding: 24px 16px 40px;
+  }
+
+  .inline-form {
+    grid-template-columns: 1fr;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..3611378128417374e828d29733acc739c5c583c7
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,37 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Newsletter Manager{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('dashboard') }}">Newsletter Manager</a>
+      {% if session.get("editor") %}
+        <nav>
+          <a href="{{ url_for('dashboard') }}">Dashboard</a>
+          <a href="{{ url_for('subscribers') }}">Subscribers</a>
+          <a href="{{ url_for('drafts') }}">Drafts</a>
+          <form method="post" action="{{ url_for('logout') }}">
+            <button type="submit">Sign out</button>
+          </form>
+        </nav>
+      {% endif %}
+    </header>
+
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="alerts">
+            {% for category, message in messages %}
+              <div class="alert {{ category }}">{{ message }}</div>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..788cd7c94e4e78d29aa5265dc6c266749312d17a
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,44 @@
+{% extends "base.html" %}
+{% block title %}Dashboard - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Editor workspace</p>
+      <h1>Dashboard</h1>
+    </div>
+    <a class="button primary" href="{{ url_for('new_draft') }}">New draft</a>
+  </section>
+
+  <section class="stats-grid">
+    <article class="stat-card">
+      <span>Subscribers</span>
+      <strong>{{ subscriber_count }}</strong>
+    </article>
+    <article class="stat-card">
+      <span>Drafts</span>
+      <strong>{{ draft_count }}</strong>
+    </article>
+  </section>
+
+  <section class="content-panel">
+    <div class="panel-title">
+      <h2>Recent drafts</h2>
+      <a href="{{ url_for('drafts') }}">View all</a>
+    </div>
+    {% if latest_drafts %}
+      <ul class="list">
+        {% for draft in latest_drafts %}
+          <li>
+            <div>
+              <strong>{{ draft.subject }}</strong>
+              <span>Updated {{ draft.updated_at }}</span>
+            </div>
+            <a class="button" href="{{ url_for('preview_draft', draft_id=draft.id) }}">Preview</a>
+          </li>
+        {% endfor %}
+      </ul>
+    {% else %}
+      <p class="empty">No drafts yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/templates/draft_form.html b/templates/draft_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..81e176db95d2c3a8514b3eeeeb8620f939a21b90
--- /dev/null
+++ b/templates/draft_form.html
@@ -0,0 +1,27 @@
+{% extends "base.html" %}
+{% block title %}{% if draft %}Edit draft{% else %}New draft{% endif %} - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Compose</p>
+      <h1>{% if draft %}Edit draft{% else %}New draft{% endif %}</h1>
+    </div>
+  </section>
+
+  <section class="content-panel">
+    <form method="post" class="stacked-form compose-form">
+      <label>
+        Subject
+        <input name="subject" value="{{ draft.subject if draft else '' }}" required>
+      </label>
+      <label>
+        Body
+        <textarea name="body" rows="14" required>{{ draft.body if draft else '' }}</textarea>
+      </label>
+      <div class="button-row">
+        <button class="primary" type="submit">Save draft</button>
+        <a class="button" href="{{ url_for('drafts') }}">Cancel</a>
+      </div>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/drafts.html b/templates/drafts.html
new file mode 100644
index 0000000000000000000000000000000000000000..a187f90d64c830b59a07a5da8c0bb7511f531a81
--- /dev/null
+++ b/templates/drafts.html
@@ -0,0 +1,34 @@
+{% extends "base.html" %}
+{% block title %}Drafts - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Newsletters</p>
+      <h1>Drafts</h1>
+    </div>
+    <a class="button primary" href="{{ url_for('new_draft') }}">New draft</a>
+  </section>
+
+  <section class="content-panel">
+    {% if drafts %}
+      <div class="draft-grid">
+        {% for draft in drafts %}
+          <article class="draft-card">
+            <h2>{{ draft.subject }}</h2>
+            <p>{{ draft.body[:150] }}{% if draft.body|length > 150 %}...{% endif %}</p>
+            <span>Updated {{ draft.updated_at }}</span>
+            <div class="button-row">
+              <a class="button" href="{{ url_for('preview_draft', draft_id=draft.id) }}">Preview</a>
+              <a class="button" href="{{ url_for('edit_draft', draft_id=draft.id) }}">Edit</a>
+              <form method="post" action="{{ url_for('delete_draft', draft_id=draft.id) }}">
+                <button class="danger" type="submit">Delete</button>
+              </form>
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty">No drafts yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
