--- /dev/null
+++ b/templates/drafts.html
@@ -0,0 +1,34 @@
+{% extends "base.html" %}
+{% block title %}Drafts - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Newsletters</p>
+      <h1>Drafts</h1>
+    </div>
+    <a class="button primary" href="{{ url_for('new_draft') }}">New draft</a>
+  </section>
+
+  <section class="content-panel">
+    {% if drafts %}
+      <div class="draft-grid">
+        {% for draft in drafts %}
+          <article class="draft-card">
+            <h2>{{ draft.subject }}</h2>
+            <p>{{ draft.body[:150] }}{% if draft.body|length > 150 %}...{% endif %}</p>
+            <span>Updated {{ draft.updated_at }}</span>
+            <div class="button-row">
+              <a class="button" href="{{ url_for('preview_draft', draft_id=draft.id) }}">Preview</a>
+              <a class="button" href="{{ url_for('edit_draft', draft_id=draft.id) }}">Edit</a>
+              <form method="post" action="{{ url_for('delete_draft', draft_id=draft.id) }}">
+                <button class="danger" type="submit">Delete</button>
+              </form>
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty">No drafts yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
