+
+h1 {
+  font-size: 1.5rem;
+  margin: 0 0 18px;
+}
+
+label {
+  display: block;
+  font-weight: 700;
+  margin: 14px 0 6px;
+}
+
+input {
+  border: 1px solid #b8c4cf;
+  border-radius: 6px;
+  font: inherit;
+  padding: 10px 12px;
