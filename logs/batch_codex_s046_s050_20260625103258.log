+{% extends "base.html" %}
+{% block title %}Error {{ code }} - Inventory Tracker{% endblock %}
+{% block content %}
+  <section class="panel narrow">
+    <h1>Error {{ code }}</h1>
+    <p>{{ message }}</p>
+    <a href="{{ url_for('index') if g.user else url_for('login') }}">Go back</a>
+  </section>
+{% endblock %}
