@@ -0,0 +1,185 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f3;
+  --panel: #ffffff;
+  --ink: #1c1f1d;
+  --muted: #667069;
+  --line: #d9ded6;
+  --accent: #1f7a65;
+  --danger: #a83333;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: var(--bg);
+  color: var(--ink);
+}
+
+a {
+  color: var(--accent);
+  font-weight: 650;
+  text-decoration: none;
+}
+
+button,
+input,
+textarea {
+  font: inherit;
+}
+
+button {
+  border: 0;
+  border-radius: 6px;
+  background: var(--accent);
+  color: #fff;
+  cursor: pointer;
+  font-weight: 700;
+  padding: 0.7rem 1rem;
+}
+
+.topbar {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding: 1rem max(1rem, calc((100vw - 980px) / 2));
+}
+
+.brand {
+  color: var(--ink);
+  font-size: 1.25rem;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+}
+
+.inline {
+  display: inline;
+}
+
+.inline button {
+  background: transparent;
+  color: var(--accent);
+  padding: 0;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 2rem 1rem 4rem;
+}
+
+.feed-header h1,
+.auth-panel h1,
+.editor h1 {
+  font-size: 2rem;
+  margin: 0 0 1.25rem;
+}
+
+.feed {
+  display: grid;
+  gap: 1.25rem;
+}
+
+.post,
+.auth-panel,
+.editor {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.post {
+  overflow: hidden;
+}
+
+.post img,
+.preview {
+  background: #e8ece6;
+  display: block;
+  height: auto;
+  max-height: 720px;
+  object-fit: contain;
+  width: 100%;
+}
+
+.post-body {
+  padding: 1rem;
+}
+
+.post-body p {
+  line-height: 1.5;
+  margin: 0 0 1rem;
+  white-space: normal;
+}
+
+.meta,
+.actions {
+  align-items: center;
+  color: var(--muted);
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.75rem;
+}
+
+.actions {
+  border-top: 1px solid var(--line);
+  margin-top: 1rem;
+  padding-top: 1rem;
+}
+
+.auth-panel,
+.editor {
+  margin: 0 auto;
+  max-width: 560px;
+  padding: 1.25rem;
+}
+
+form:not(.inline) {
+  display: grid;
+  gap: 1rem;
+}
+
+label {
+  display: grid;
+  gap: 0.4rem;
+  font-weight: 700;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 0.7rem;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+.error {
+  color: var(--danger);
+  font-weight: 700;
+}
+
+.empty {
+  color: var(--muted);
+}
+
+@media (max-width: 620px) {
+  .topbar {
+    align-items: flex-start;
+    flex-direction: column;
+    gap: 0.75rem;
