--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,37 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Newsletter Manager{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('dashboard') }}">Newsletter Manager</a>
+      {% if session.get("editor") %}
+        <nav>
+          <a href="{{ url_for('dashboard') }}">Dashboard</a>
+          <a href="{{ url_for('subscribers') }}">Subscribers</a>
+          <a href="{{ url_for('drafts') }}">Drafts</a>
+          <form method="post" action="{{ url_for('logout') }}">
+            <button type="submit">Sign out</button>
+          </form>
+        </nav>
+      {% endif %}
+    </header>
+
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="alerts">
+            {% for category, message in messages %}
+              <div class="alert {{ category }}">{{ message }}</div>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..788cd7c94e4e78d29aa5265dc6c266749312d17a
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,44 @@
+{% extends "base.html" %}
+{% block title %}Dashboard - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Editor workspace</p>
+      <h1>Dashboard</h1>
+    </div>
+    <a class="button primary" href="{{ url_for('new_draft') }}">New draft</a>
+  </section>
+
+  <section class="stats-grid">
+    <article class="stat-card">
+      <span>Subscribers</span>
+      <strong>{{ subscriber_count }}</strong>
+    </article>
+    <article class="stat-card">
+      <span>Drafts</span>
+      <strong>{{ draft_count }}</strong>
+    </article>
+  </section>
+
+  <section class="content-panel">
+    <div class="panel-title">
+      <h2>Recent drafts</h2>
+      <a href="{{ url_for('drafts') }}">View all</a>
+    </div>
+    {% if latest_drafts %}
+      <ul class="list">
+        {% for draft in latest_drafts %}
+          <li>
+            <div>
+              <strong>{{ draft.subject }}</strong>
+              <span>Updated {{ draft.updated_at }}</span>
+            </div>
+            <a class="button" href="{{ url_for('preview_draft', draft_id=draft.id) }}">Preview</a>
+          </li>
+        {% endfor %}
+      </ul>
+    {% else %}
+      <p class="empty">No drafts yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/templates/draft_form.html b/templates/draft_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..81e176db95d2c3a8514b3eeeeb8620f939a21b90
--- /dev/null
+++ b/templates/draft_form.html
@@ -0,0 +1,27 @@
+{% extends "base.html" %}
+{% block title %}{% if draft %}Edit draft{% else %}New draft{% endif %} - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Compose</p>
+      <h1>{% if draft %}Edit draft{% else %}New draft{% endif %}</h1>
+    </div>
+  </section>
+
+  <section class="content-panel">
+    <form method="post" class="stacked-form compose-form">
+      <label>
+        Subject
+        <input name="subject" value="{{ draft.subject if draft else '' }}" required>
+      </label>
+      <label>
+        Body
+        <textarea name="body" rows="14" required>{{ draft.body if draft else '' }}</textarea>
+      </label>
+      <div class="button-row">
+        <button class="primary" type="submit">Save draft</button>
+        <a class="button" href="{{ url_for('drafts') }}">Cancel</a>
+      </div>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/drafts.html b/templates/drafts.html
