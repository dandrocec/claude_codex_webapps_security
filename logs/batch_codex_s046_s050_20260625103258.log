+{% extends "base.html" %}
+{% block content %}
+  <section class="toolbar">
+    <form method="get" action="{{ url_for('index') }}" class="search">
+      <label for="q">Search</label>
+      <input id="q" name="q" value="{{ query }}" maxlength="80" placeholder="Name, SKU, or location">
+      <button type="submit">Search</button>
+      {% if query %}<a href="{{ url_for('index') }}">Clear</a>{% endif %}
+    </form>
+    <a class="button" href="{{ url_for('new_item') }}">Add item</a>
+  </section>
+
+  <section class="panel">
+    <div class="list-header">
+      <h1>Items</h1>
+      <p class="muted">Low stock: {{ low_stock_threshold }} or fewer</p>
+    </div>
+    {% if items %}
+      <div class="table-wrap">
+        <table>
+          <thead>
+            <tr>
+              <th>Name</th>
+              <th>SKU</th>
+              <th>Quantity</th>
+              <th>Location</th>
+              <th>Adjust</th>
+              <th>Actions</th>
+            </tr>
+          </thead>
+          <tbody>
+            {% for item in items %}
+              <tr class="{{ 'low-stock' if item.quantity <= low_stock_threshold else '' }}">
+                <td>{{ item.name }}</td>
+                <td>{{ item.sku }}</td>
+                <td>{{ item.quantity }}</td>
+                <td>{{ item.location or "Unassigned" }}</td>
+                <td>
+                  <form method="post" action="{{ url_for('adjust_item', item_id=item.id) }}" class="adjust">
+                    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                    <input name="delta" type="number" min="-1000000" max="1000000" required aria-label="Quantity adjustment for {{ item.name }}">
+                    <button type="submit">Apply</button>
+                  </form>
+                </td>
+                <td class="actions">
+                  <a href="{{ url_for('edit_item', item_id=item.id) }}">Edit</a>
+                  <form method="post" action="{{ url_for('delete_item', item_id=item.id) }}" class="inline">
+                    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                    <button type="submit">Delete</button>
+                  </form>
+                </td>
+              </tr>
+            {% endfor %}
+          </tbody>
+        </table>
+      </div>
+    {% else %}
+      <p class="empty">No items found.</p>
+    {% endif %}
+  </section>
+{% endblock %}
