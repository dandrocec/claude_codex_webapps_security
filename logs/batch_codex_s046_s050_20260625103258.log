diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..b84c06339e852a64ac064efc79fce3a8c1216660
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,250 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1f2933;
+  --muted: #667085;
+  --line: #d9dee7;
+  --accent: #1f7a5c;
+  --accent-dark: #155f47;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent-dark);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem 1.5rem;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.1rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav,
+.actions {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 0.65rem;
+}
+
+.container {
+  width: min(1120px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.auth,
+.panel-form,
+.row,
+.preview-meta,
+.newsletter-preview,
+.editor {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.auth {
+  max-width: 440px;
+  margin: 4rem auto;
+  padding: 1.5rem;
+}
+
+.page-heading {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 1rem;
+  margin-bottom: 1rem;
+}
+
+h1,
+h2 {
+  margin: 0 0 1rem;
+}
+
+form {
+  margin: 0;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  display: grid;
+  gap: 0.35rem;
+  margin-bottom: 1rem;
+  color: var(--muted);
+  font-weight: 700;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 0.75rem;
+  color: var(--text);
+  font: inherit;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 2.5rem;
+  border: 0;
+  border-radius: 6px;
+  padding: 0.6rem 0.9rem;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+}
+
+.secondary {
+  background: #eef4f1;
+  color: var(--accent-dark);
+}
+
+.secondary:hover {
+  background: #dcebe5;
+}
+
+.danger {
+  background: var(--danger);
+}
+
+.danger:hover {
+  background: #8f1d14;
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 1rem;
+}
+
+.panel-form,
+.editor,
+.preview-meta {
+  padding: 1rem;
+  margin-bottom: 1rem;
+}
+
+.list {
+  display: grid;
+  gap: 0.75rem;
+}
+
+.row {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem;
+}
+
+.row strong,
+.row span,
+.row small {
+  display: block;
+  overflow-wrap: anywhere;
+}
+
+.row small,
+.empty,
+.preview-meta {
+  color: var(--muted);
+}
+
+.messages {
+  display: grid;
+  gap: 0.5rem;
+  margin-bottom: 1rem;
+}
+
+.message {
+  padding: 0.75rem 1rem;
+  border-radius: 6px;
+  background: #edf7f2;
+  border: 1px solid #b8dfcd;
+}
+
+.message.error {
+  background: #fff0f0;
+  border-color: #f3b6b6;
+}
+
+.newsletter-preview {
+  max-width: 760px;
+  margin: 0 auto;
+  padding: 2rem;
+}
+
+.newsletter-preview header {
+  border-bottom: 1px solid var(--line);
+  margin-bottom: 1.5rem;
+  padding-bottom: 1rem;
+}
+
+.kicker {
+  color: var(--accent-dark);
+  font-weight: 700;
+  text-transform: uppercase;
+}
+
+.newsletter-body p {
+  margin: 0 0 1rem;
+  overflow-wrap: anywhere;
+}
+
+@media (max-width: 760px) {
+  .topbar,
+  .page-heading,
+  .row {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .grid {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..2f75a1c52c0fe6fbb070ad0f556da859c8e8c875
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{{ title or "Newsletter Manager" }}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('dashboard') if g.user else url_for('login') }}">Newsletter Manager</a>
+    <nav>
+      {% if g.user %}
+        <span>{{ g.user.email }}</span>
+        <form class="inline" method="post" action="{{ url_for('logout') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages">
+          {% for category, message in messages %}
+            <div class="message {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..63b2fab45300f54f6a087f0c741a7e0d4a3c9fa2
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,72 @@
+{% extends "base.html" %}
+{% set title = "Dashboard" %}
+{% block content %}
+<div class="page-heading">
+  <h1>Dashboard</h1>
+  <a class="button" href="{{ url_for('new_draft') }}">New draft</a>
+</div>
+
+<section class="grid">
+  <div>
+    <h2>Subscribers</h2>
+    <form class="panel-form" method="post" action="{{ url_for('create_subscriber') }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label>Email
+        <input name="email" type="email" maxlength="254" required>
+      </label>
+      <label>Name
+        <input name="name" maxlength="80">
+      </label>
+      <button type="submit">Add subscriber</button>
+    </form>
+
+    <div class="list">
+      {% for subscriber in subscribers %}
+        <article class="row">
+          <div>
+            <strong>{{ subscriber.email }}</strong>
+            {% if subscriber.name %}<span>{{ subscriber.name }}</span>{% endif %}
+            <small>{{ "Active" if subscriber.active else "Inactive" }}</small>
+          </div>
+          <div class="actions">
+            <form method="post" action="{{ url_for('toggle_subscriber', subscriber_id=subscriber.id) }}">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button type="submit">{{ "Disable" if subscriber.active else "Enable" }}</button>
+            </form>
+            <form method="post" action="{{ url_for('delete_subscriber', subscriber_id=subscriber.id) }}">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button class="danger" type="submit">Delete</button>
+            </form>
+          </div>
+        </article>
+      {% else %}
+        <p class="empty">No subscribers yet.</p>
+      {% endfor %}
+    </div>
+  </div>
+
+  <div>
+    <h2>Drafts</h2>
+    <div class="list">
+      {% for draft in drafts %}
+        <article class="row">
+          <div>
+            <strong>{{ draft.subject }}</strong>
+            <small>Updated {{ draft.updated_at }}</small>
+          </div>
+          <div class="actions">
+            <a class="button secondary" href="{{ url_for('edit_draft', draft_id=draft.id) }}">Edit</a>
+            <a class="button secondary" href="{{ url_for('preview_draft', draft_id=draft.id) }}">Preview</a>
+            <form method="post" action="{{ url_for('delete_draft', draft_id=draft.id) }}">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button class="danger" type="submit">Delete</button>
+            </form>
+          </div>
+        </article>
+      {% else %}
+        <p class="empty">No drafts yet.</p>
+      {% endfor %}
+    </div>
+  </div>
+</section>
+{% endblock %}
diff --git a/templates/draft_form.html b/templates/draft_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..147271a8a4dee76c1c6736a2d4b7b5b425623890
--- /dev/null
+++ b/templates/draft_form.html
@@ -0,0 +1,24 @@
+{% extends "base.html" %}
+{% set title = "Edit Draft" if draft else "New Draft" %}
+{% block content %}
+<div class="page-heading">
+  <h1>{{ "Edit Draft" if draft else "New Draft" }}</h1>
+  <a class="button secondary" href="{{ url_for('dashboard') }}">Dashboard</a>
+</div>
+
+<form class="editor" method="post" action="{{ url_for('edit_draft', draft_id=draft.id) if draft else url_for('new_draft') }}">
+  <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+  <label>Subject
+    <input name="subject" maxlength="140" value="{{ subject }}" required>
+  </label>
+  <label>Body
+    <textarea name="body" maxlength="10000" rows="16" required>{{ body }}</textarea>
+  </label>
+  <div class="actions">
+    <button type="submit">Save draft</button>
+    {% if draft %}
+      <a class="button secondary" href="{{ url_for('preview_draft', draft_id=draft.id) }}">Preview</a>
+    {% endif %}
+  </div>
+</form>
+{% endblock %}
