+
+.section-head h1 {
+  font-size: clamp(1.65rem, 3vw, 2.2rem);
+  line-height: 1.1;
+  margin: 0 0 8px;
+}
+
+.section-head p {
+  color: var(--muted);
+  margin: 0;
