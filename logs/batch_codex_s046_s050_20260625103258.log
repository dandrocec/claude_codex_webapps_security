+
+    @app.route("/dashboard")
+    @login_required
+    def dashboard():
+        subscribers = query_all(
+            "SELECT id, email, name, active, created_at FROM subscribers WHERE user_id = ? ORDER BY created_at DESC",
+            (g.user["id"],),
