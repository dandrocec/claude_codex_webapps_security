+{% extends "base.html" %}
+{% block title %}Subscribers - Newsletter Manager{% endblock %}
+{% block content %}
+  <section class="page-heading">
+    <div>
+      <p class="eyebrow">Audience</p>
+      <h1>Subscribers</h1>
+    </div>
+  </section>
+
+  <section class="content-panel">
+    <h2>Add subscriber</h2>
+    <form method="post" class="inline-form">
+      <label>
+        Name
+        <input name="name" placeholder="Ada Lovelace">
+      </label>
+      <label>
+        Email
+        <input name="email" type="email" placeholder="ada@example.com" required>
+      </label>
+      <button class="primary" type="submit">Add</button>
+    </form>
+  </section>
+
+  <section class="content-panel">
+    <div class="panel-title">
+      <h2>Subscriber list</h2>
+      <span>{{ subscribers|length }} total</span>
