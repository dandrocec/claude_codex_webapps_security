@@ -0,0 +1,20 @@
+{
+  "name": "codex/photo-blog",
+  "description": "A secure PHP photo blog with SQLite storage.",
+  "type": "project",
+  "require": {
+    "php": ">=8.2",
+    "ext-pdo": "*",
+    "ext-pdo_sqlite": "*",
+    "ext-fileinfo": "*",
+    "ext-mbstring": "*"
+  },
+  "autoload": {
+    "psr-4": {
+      "PhotoBlog\\": "src/"
+    }
+  },
+  "scripts": {
+    "serve": "php -S 127.0.0.1:5050 -t public"
+  }
+}
diff --git a/public/assets/style.css b/public/assets/style.css
new file mode 100644
index 0000000000000000000000000000000000000000..abf33c8b3d9b4bc9f9d201a6b6873d407f635c2f
--- /dev/null
