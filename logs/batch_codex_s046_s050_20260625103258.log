+  gap: 7px;
+  font-weight: 700;
+}
+
+label span {
+  color: #33424d;
+}
+
+input,
+select,
+textarea {
+  border: 1px solid #b8c6cf;
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 12px 13px;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button-link {
+  align-items: center;
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 700;
+  justify-content: center;
+  min-height: 44px;
+  padding: 11px 18px;
+  width: fit-content;
+}
+
+button:hover,
+.button-link:hover {
