@@ -0,0 +1,413 @@
+:root {
+  color-scheme: light;
+  --bg: #f4f6f8;
+  --panel: #ffffff;
+  --text: #18212f;
+  --muted: #697386;
+  --line: #d8dee8;
+  --primary: #1864ab;
+  --primary-dark: #124d82;
+  --danger: #b42318;
+  --success-bg: #e8f6ee;
+  --success-text: #17613a;
+  --error-bg: #fff0ed;
+  --error-text: #9f2a1d;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+a {
+  color: var(--primary);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  min-height: 64px;
+  padding: 0 28px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 18px;
+  font-weight: 800;
+}
+
+.topbar nav {
+  align-items: center;
+  display: flex;
+  gap: 18px;
+}
+
+.topbar form {
+  margin: 0;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1120px;
+  padding: 32px 24px 56px;
+}
+
+.page-heading {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  margin-bottom: 24px;
+  gap: 20px;
+}
+
+.page-heading h1,
+.auth-panel h1 {
+  font-size: 34px;
+  line-height: 1.1;
+  margin: 0;
+}
+
+.eyebrow {
+  color: var(--muted);
+  font-size: 13px;
+  font-weight: 800;
+  letter-spacing: 0.08em;
+  margin: 0 0 8px;
+  text-transform: uppercase;
+}
+
+.auth-panel,
+.content-panel,
+.stat-card,
+.draft-card,
+.email-preview {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.auth-panel {
+  margin: 72px auto;
+  max-width: 420px;
+  padding: 28px;
+}
+
+.content-panel {
+  margin-bottom: 22px;
+  padding: 24px;
+}
+
+.content-panel h2,
+.draft-card h2 {
+  font-size: 20px;
+  margin: 0 0 16px;
+}
+
+.stats-grid {
+  display: grid;
+  gap: 18px;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  margin-bottom: 22px;
+}
+
+.stat-card {
+  padding: 24px;
+}
+
+.stat-card span,
+.draft-card span,
+.list span,
+.panel-title span,
+.muted {
+  color: var(--muted);
+}
+
+.stat-card strong {
+  display: block;
+  font-size: 40px;
+  line-height: 1;
+  margin-top: 8px;
+}
+
+.panel-title {
+  align-items: center;
+  display: flex;
+  justify-content: space-between;
+  margin-bottom: 16px;
+  gap: 16px;
+}
+
+.panel-title h2 {
+  margin: 0;
+}
+
+.stacked-form,
+.inline-form {
+  display: grid;
+  gap: 16px;
+}
+
+.inline-form {
+  align-items: end;
+  grid-template-columns: minmax(160px, 1fr) minmax(220px, 1.3fr) auto;
+}
+
+label {
+  color: var(--muted);
+  display: grid;
+  font-size: 14px;
+  font-weight: 700;
+  gap: 7px;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 11px 12px;
+  width: 100%;
+}
+
+textarea {
+  line-height: 1.5;
+  resize: vertical;
+}
+
+button,
+.button {
+  align-items: center;
+  background: #ffffff;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 800;
+  justify-content: center;
+  min-height: 40px;
+  padding: 9px 14px;
+}
+
+button:hover,
+.button:hover {
+  border-color: #aeb8c7;
+  text-decoration: none;
+}
+
+.primary {
+  background: var(--primary);
+  border-color: var(--primary);
+  color: #ffffff;
+}
+
+.primary:hover {
+  background: var(--primary-dark);
+  border-color: var(--primary-dark);
+}
+
+.danger {
+  color: var(--danger);
+}
+
+.button-row {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+}
+
+.alerts {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 20px;
+}
+
+.alert {
+  border-radius: 6px;
+  font-weight: 700;
+  padding: 12px 14px;
+}
+
+.alert.success {
+  background: var(--success-bg);
+  color: var(--success-text);
+}
+
+.alert.error {
+  background: var(--error-bg);
+  color: var(--error-text);
+}
+
+.list {
+  display: grid;
+  gap: 12px;
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.list li {
+  align-items: center;
+  border-top: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding-top: 12px;
+  gap: 16px;
+}
+
+.list li:first-child {
+  border-top: 0;
+  padding-top: 0;
+}
+
+.list span {
+  display: block;
+  font-size: 14px;
+  margin-top: 3px;
+}
+
+table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-top: 1px solid var(--line);
+  padding: 13px 10px;
+  text-align: left;
+}
+
+th {
+  color: var(--muted);
+  font-size: 13px;
+  text-transform: uppercase;
+}
+
+.actions {
+  text-align: right;
+}
+
+.actions form,
+.button-row form {
+  display: inline;
+  margin: 0;
+}
+
+.draft-grid {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+}
+
+.draft-card {
+  display: grid;
+  gap: 10px;
+  padding: 20px;
+}
+
+.draft-card p {
+  color: var(--muted);
+  line-height: 1.5;
+  margin: 0;
+}
+
+.preview-shell {
+  display: flex;
+  justify-content: center;
+}
+
+.email-preview {
+  max-width: 760px;
+  overflow: hidden;
+  width: 100%;
+}
+
+.email-preview header {
+  background: #12324d;
+  color: #ffffff;
+  padding: 32px;
+}
+
+.email-preview header span {
+  display: block;
+  font-size: 13px;
+  font-weight: 800;
+  letter-spacing: 0.1em;
+  margin-bottom: 12px;
+  text-transform: uppercase;
+}
+
+.email-preview header h2 {
+  font-size: 30px;
+  line-height: 1.2;
+  margin: 0;
