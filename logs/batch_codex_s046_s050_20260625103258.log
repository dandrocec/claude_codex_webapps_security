+  <div class="section-head">
+    <h1>All feedback</h1>
+    <p><%= feedback.length %> total submission<%= feedback.length === 1 ? "" : "s" %></p>
+  </div>
+
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th><a href="/review?sort=created_at&order=<%= sort === "created_at" ? nextOrder : "desc" %>">Submitted</a></th>
+          <th><a href="/review?sort=category&order=<%= sort === "category" ? nextOrder : "asc" %>">Category</a></th>
+          <th><a href="/review?sort=rating&order=<%= sort === "rating" ? nextOrder : "desc" %>">Rating</a></th>
