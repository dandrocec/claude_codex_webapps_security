diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..0808c334b0efdf84ac3744ad7142b60cccde7a97
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,286 @@
+:root {
+    color-scheme: light;
+    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+    background: #f5f7fb;
+    color: #172033;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+}
+
+a {
+    color: #2456a6;
+}
+
+.site-header {
+    align-items: center;
+    background: #ffffff;
+    border-bottom: 1px solid #dce3ee;
+    display: flex;
+    justify-content: space-between;
+    padding: 16px clamp(18px, 4vw, 48px);
+}
+
+.brand {
+    color: #172033;
+    font-size: 20px;
+    font-weight: 700;
+    text-decoration: none;
+}
+
+.user-menu {
+    align-items: center;
+    display: flex;
+    gap: 16px;
+}
+
+.page {
+    margin: 0 auto;
+    max-width: 1180px;
+    padding: 32px clamp(18px, 4vw, 48px);
+}
+
+.auth-panel,
+.add-panel,
+.table-panel {
+    background: #ffffff;
+    border: 1px solid #dce3ee;
+    border-radius: 8px;
+    box-shadow: 0 16px 40px rgba(30, 42, 70, 0.08);
+}
+
+.auth-panel {
+    margin: 48px auto;
+    max-width: 420px;
+    padding: 28px;
+}
+
+h1,
+h2,
+p {
+    margin-top: 0;
+}
+
+h1 {
+    font-size: 32px;
+    margin-bottom: 8px;
+}
+
+h2 {
+    font-size: 20px;
+}
+
+.muted {
+    color: #5d6b82;
+}
+
+.form-stack,
+.add-grid,
+.search-form,
+.adjust-form {
+    display: grid;
+    gap: 14px;
+}
+
+label {
+    color: #33425f;
+    display: grid;
+    font-size: 14px;
+    font-weight: 650;
+    gap: 6px;
+}
+
+input {
+    border: 1px solid #c8d1df;
+    border-radius: 6px;
+    color: #172033;
+    font: inherit;
+    min-height: 42px;
+    padding: 9px 11px;
+}
+
+input:focus {
+    border-color: #2456a6;
+    box-shadow: 0 0 0 3px rgba(36, 86, 166, 0.14);
+    outline: none;
+}
+
+button,
+.secondary-action {
+    align-items: center;
+    background: #2456a6;
+    border: 1px solid #2456a6;
+    border-radius: 6px;
+    color: #ffffff;
+    cursor: pointer;
+    display: inline-flex;
+    font: inherit;
+    font-weight: 700;
+    justify-content: center;
+    min-height: 42px;
+    padding: 9px 14px;
+    text-decoration: none;
+}
+
+button:hover,
+.secondary-action:hover {
+    background: #1d478b;
+}
+
+.link-button {
+    background: transparent;
+    border: 0;
+    color: #2456a6;
+    min-height: auto;
+    padding: 0;
+}
+
+.link-button:hover {
+    background: transparent;
+    color: #1d478b;
+}
+
+.flash-stack {
+    display: grid;
+    gap: 10px;
+    margin-bottom: 18px;
+}
+
+.flash {
+    border-radius: 6px;
+    padding: 12px 14px;
+}
+
+.flash.error {
+    background: #fee8e6;
+    border: 1px solid #f6b8b3;
+    color: #8d221b;
+}
+
+.flash.success {
+    background: #e9f7ef;
+    border: 1px solid #abd9bd;
+    color: #176337;
+}
+
+.toolbar {
+    align-items: end;
+    display: flex;
+    gap: 18px;
+    justify-content: space-between;
+    margin-bottom: 22px;
+}
+
+.search-form {
+    align-items: end;
+    display: flex;
+    flex-wrap: wrap;
+}
+
+.search-form input {
+    min-width: min(420px, 70vw);
+}
+
+.secondary-action {
+    background: #ffffff;
+    color: #2456a6;
+}
+
+.secondary-action:hover {
+    background: #edf3fb;
+}
+
+.add-panel {
+    margin-bottom: 22px;
+    padding: 22px;
+}
+
+.add-grid {
+    align-items: end;
+    grid-template-columns: 1.3fr 1fr 0.7fr 1fr auto;
+}
+
+.table-panel {
+    overflow-x: auto;
+}
+
+table {
+    border-collapse: collapse;
+    min-width: 860px;
+    width: 100%;
+}
+
+th,
+td {
+    border-bottom: 1px solid #e4eaf2;
+    padding: 14px 16px;
+    text-align: left;
+    vertical-align: middle;
+}
+
+th {
+    background: #f9fbfe;
+    color: #42516b;
+    font-size: 13px;
+    text-transform: uppercase;
+}
+
+.low-stock {
+    background: #fff4e6;
+}
+
+.stock-badge {
+    background: #bf3d24;
+    border-radius: 999px;
+    color: #ffffff;
+    display: inline-block;
+    font-size: 12px;
+    font-weight: 700;
+    margin-left: 8px;
+    padding: 3px 8px;
+}
+
+.adjust-form {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 8px;
+}
+
+.adjust-form input {
+    min-height: 38px;
+    width: 88px;
+}
+
+.adjust-form button {
+    min-height: 38px;
+    padding-inline: 10px;
+}
+
+.empty-state {
+    color: #5d6b82;
+    padding: 34px;
+    text-align: center;
+}
+
+@media (max-width: 820px) {
+    .site-header,
+    .toolbar {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    .add-grid {
+        grid-template-columns: 1fr;
+    }
+
+    .search-form,
+    .search-form input {
+        width: 100%;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..179c3f3efcfcd5dd97eee76139ce78866e161e3c
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,37 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Inventory Tracker{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="site-header">
+        <div>
+            <a class="brand" href="{{ url_for('inventory') if g.user else url_for('login') }}">Inventory Tracker</a>
+        </div>
+        {% if g.user %}
+            <div class="user-menu">
+                <span>{{ g.user["username"] }}</span>
+                <form action="{{ url_for('logout') }}" method="post">
+                    <button class="link-button" type="submit">Sign out</button>
+                </form>
+            </div>
+        {% endif %}
+    </header>
+
+    <main class="page">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="flash-stack">
+                    {% for category, message in messages %}
+                        <div class="flash {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
