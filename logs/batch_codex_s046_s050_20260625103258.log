+{% extends "base.html" %}
+{% set title = "Preview" %}
+{% block content %}
+<div class="page-heading">
+  <h1>Newsletter Preview</h1>
+  <a class="button secondary" href="{{ url_for('edit_draft', draft_id=draft.id) }}">Edit</a>
+</div>
+
+<section class="preview-meta">
