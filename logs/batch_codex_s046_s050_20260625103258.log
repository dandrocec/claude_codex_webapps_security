+    color: #42516b;
+    font-size: 13px;
+    text-transform: uppercase;
+}
+
+.low-stock {
+    background: #fff4e6;
+}
+
+.stock-badge {
+    background: #bf3d24;
+    border-radius: 999px;
+    color: #ffffff;
+    display: inline-block;
+    font-size: 12px;
+    font-weight: 700;
+    margin-left: 8px;
+    padding: 3px 8px;
+}
+
+.adjust-form {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 8px;
+}
+
+.adjust-form input {
+    min-height: 38px;
+    width: 88px;
+}
+
+.adjust-form button {
+    min-height: 38px;
+    padding-inline: 10px;
+}
+
+.empty-state {
+    color: #5d6b82;
+    padding: 34px;
+    text-align: center;
+}
+
+@media (max-width: 820px) {
+    .site-header,
+    .toolbar {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    .add-grid {
+        grid-template-columns: 1fr;
+    }
+
+    .search-form,
+    .search-form input {
+        width: 100%;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..179c3f3efcfcd5dd97eee76139ce78866e161e3c
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,37 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Inventory Tracker{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="site-header">
+        <div>
+            <a class="brand" href="{{ url_for('inventory') if g.user else url_for('login') }}">Inventory Tracker</a>
+        </div>
+        {% if g.user %}
+            <div class="user-menu">
+                <span>{{ g.user["username"] }}</span>
+                <form action="{{ url_for('logout') }}" method="post">
+                    <button class="link-button" type="submit">Sign out</button>
+                </form>
+            </div>
+        {% endif %}
+    </header>
+
+    <main class="page">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="flash-stack">
+                    {% for category, message in messages %}
+                        <div class="flash {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/inventory.html b/templates/inventory.html
new file mode 100644
index 0000000000000000000000000000000000000000..134fa6bbab7d81c079cfc75eaf22a8e9c1ff34e2
--- /dev/null
+++ b/templates/inventory.html
@@ -0,0 +1,90 @@
+{% extends "base.html" %}
+
+{% block title %}Inventory - Inventory Tracker{% endblock %}
+
+{% block content %}
+<section class="toolbar">
+    <div>
+        <h1>Inventory</h1>
+        <p class="muted">Items at {{ low_stock_threshold }} units or fewer are highlighted.</p>
+    </div>
+    <form method="get" class="search-form">
+        <input name="q" value="{{ query }}" placeholder="Search name, SKU, or location">
+        <button type="submit">Search</button>
+        {% if query %}
+            <a class="secondary-action" href="{{ url_for('inventory') }}">Clear</a>
+        {% endif %}
+    </form>
+</section>
+
+<section class="add-panel">
+    <h2>Add item</h2>
+    <form method="post" class="add-grid">
+        <label>
+            Name
+            <input name="name" required>
+        </label>
+        <label>
+            SKU
+            <input name="sku" required>
+        </label>
+        <label>
+            Quantity
+            <input name="quantity" type="number" min="0" value="0" required>
+        </label>
+        <label>
+            Location
+            <input name="location" required>
+        </label>
+        <button type="submit">Add item</button>
+    </form>
+</section>
+
+<section class="table-panel">
+    {% if items %}
+        <table>
+            <thead>
+                <tr>
+                    <th>Name</th>
+                    <th>SKU</th>
+                    <th>Quantity</th>
+                    <th>Location</th>
+                    <th>Adjust</th>
+                </tr>
+            </thead>
+            <tbody>
+                {% for item in items %}
+                    <tr class="{{ 'low-stock' if item['quantity'] <= low_stock_threshold else '' }}">
+                        <td>
+                            <strong>{{ item["name"] }}</strong>
+                            {% if item["quantity"] <= low_stock_threshold %}
+                                <span class="stock-badge">Low stock</span>
+                            {% endif %}
+                        </td>
+                        <td>{{ item["sku"] }}</td>
+                        <td>{{ item["quantity"] }}</td>
+                        <td>{{ item["location"] }}</td>
+                        <td>
+                            <form action="{{ url_for('adjust_item', item_id=item['id']) }}" method="post" class="adjust-form">
+                                <input type="hidden" name="q" value="{{ query }}">
+                                <button name="delta" value="-1" type="submit">-1</button>
+                                <button name="delta" value="1" type="submit">+1</button>
+                                <input name="delta" type="number" placeholder="+/-">
+                                <button type="submit">Apply</button>
+                            </form>
+                        </td>
+                    </tr>
+                {% endfor %}
+            </tbody>
+        </table>
+    {% else %}
+        <div class="empty-state">
+            {% if query %}
+                No items match "{{ query }}".
+            {% else %}
+                No inventory items yet.
+            {% endif %}
+        </div>
+    {% endif %}
+</section>
+{% endblock %}
