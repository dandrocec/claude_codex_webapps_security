+      <table>
+        <thead>
+          <tr>
+            <th>Name</th>
+            <th>Email</th>
+            <th>Added</th>
+            <th></th>
+          </tr>
+        </thead>
+        <tbody>
+          {% for subscriber in subscribers %}
+            <tr>
+              <td>{{ subscriber.name or "Unnamed" }}</td>
+              <td>{{ subscriber.email }}</td>
+              <td>{{ subscriber.created_at }}</td>
+              <td class="actions">
+                <form method="post" action="{{ url_for('delete_subscriber', subscriber_id=subscriber.id) }}">
