+  <body>
+    <header class="topbar">
+      <a class="brand" href="/">OAuth Profile</a>
+      <form method="post" action="/logout">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <button type="submit">Sign out</button>
+      </form>
+    </header>
+    <main class="shell">
