diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..83d6295d6220096cc1938195fa98b3e958a6e585
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,42 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Flask Shop{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">Flask Shop</a>
+    <nav>
+      <a href="{{ url_for('cart') }}">Cart ({{ cart_count }})</a>
+      {% if g.user %}
+        <a href="{{ url_for('orders') }}">Orders</a>
+        {% if g.user.is_admin %}
+          <a href="{{ url_for('admin_orders') }}">Admin</a>
+        {% endif %}
+        <form class="inline" method="post" action="{{ url_for('logout') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages">
+          {% for category, message in messages %}
+            <div class="message {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
new file mode 100644
index 0000000000000000000000000000000000000000..15849c6ed4c4b5bfc70372db159beefd876b359e
--- /dev/null
+++ b/templates/cart.html
@@ -0,0 +1,30 @@
+{% extends "base.html" %}
+{% block title %}Cart - Flask Shop{% endblock %}
+{% block content %}
+<h1>Cart</h1>
+{% if items %}
+  <form method="post">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <table>
+      <thead><tr><th>Product</th><th>Quantity</th><th>Line total</th></tr></thead>
+      <tbody>
+        {% for item in items %}
+          <tr>
+            <td>{{ item.product.name }}</td>
+            <td><input type="number" name="qty_{{ item.product.id }}" min="0" max="20" value="{{ item.quantity }}"></td>
+            <td>{{ item.line_total|money }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+    <p class="total">Total: {{ total|money }}</p>
+    <button type="submit">Update cart</button>
+  </form>
+  <form method="post" action="{{ url_for('checkout') }}">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <button type="submit">Checkout</button>
+  </form>
+{% else %}
+  <p>Your cart is empty.</p>
+{% endif %}
+{% endblock %}
