diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..5131d193c7ca1cc9d2e10169e3ca3b58d181c83c
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,173 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1d2430;
+  --muted: #667085;
+  --line: #d9dee7;
+  --accent: #0f766e;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+}
+
+.site-header {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding: 1rem 1.5rem;
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 1040px;
+  padding: 2rem 1.5rem;
+}
+
+.product-grid {
+  display: grid;
+  gap: 1rem;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+}
+
+.card,
+.form,
+table {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.card,
+.form {
+  padding: 1rem;
+}
+
+.price,
+.total {
+  font-size: 1.1rem;
+  font-weight: 700;
+}
+
+.muted {
+  color: var(--muted);
+}
+
+label {
+  display: grid;
+  gap: 0.35rem;
+  margin-bottom: 0.75rem;
+}
+
+input {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  padding: 0.55rem;
+}
+
+button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: white;
+  cursor: pointer;
+  font: inherit;
+  font-weight: 650;
+  padding: 0.6rem 0.9rem;
+}
+
+button:disabled {
+  cursor: not-allowed;
+  opacity: 0.5;
+}
+
+.inline {
+  display: inline;
+}
+
+.inline button {
+  padding: 0.35rem 0.6rem;
+}
+
+table {
+  border-collapse: collapse;
+  margin: 1rem 0;
+  overflow: hidden;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: 0.75rem;
+  text-align: left;
+}
+
+tr:last-child td {
+  border-bottom: 0;
+}
+
+.message {
+  border-radius: 6px;
+  margin-bottom: 0.75rem;
+  padding: 0.75rem;
+}
+
+.message.success {
+  background: #dcfce7;
+}
+
+.message.danger {
+  background: #fee2e2;
+  color: var(--danger);
+}
+
+.message.warning {
+  background: #fef3c7;
+}
+
+.message.info {
+  background: #dbeafe;
+}
+
+@media (max-width: 700px) {
+  .site-header,
+  nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/admin_orders.html b/templates/admin_orders.html
new file mode 100644
index 0000000000000000000000000000000000000000..af5aea010132e9f34c3c824f5a865a3e63915f54
--- /dev/null
+++ b/templates/admin_orders.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block title %}Admin orders - Flask Shop{% endblock %}
+{% block content %}
+<h1>Admin orders</h1>
+<table>
+  <thead><tr><th>Order</th><th>User</th><th>Status</th><th>Total</th><th>Provider</th><th>Created</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+      <tr>
+        <td><a href="{{ url_for('order_detail', order_id=order.id) }}">#{{ order.id }}</a></td>
+        <td>{{ order.username }} &lt;{{ order.email }}&gt;</td>
+        <td>{{ order.status }}</td>
+        <td>{{ order.total_cents|money }}</td>
+        <td>{{ order.provider }}</td>
+        <td>{{ order.created_at }}</td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..83d6295d6220096cc1938195fa98b3e958a6e585
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,42 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Flask Shop{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">Flask Shop</a>
+    <nav>
+      <a href="{{ url_for('cart') }}">Cart ({{ cart_count }})</a>
+      {% if g.user %}
+        <a href="{{ url_for('orders') }}">Orders</a>
+        {% if g.user.is_admin %}
+          <a href="{{ url_for('admin_orders') }}">Admin</a>
+        {% endif %}
+        <form class="inline" method="post" action="{{ url_for('logout') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages">
+          {% for category, message in messages %}
+            <div class="message {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
new file mode 100644
index 0000000000000000000000000000000000000000..15849c6ed4c4b5bfc70372db159beefd876b359e
--- /dev/null
+++ b/templates/cart.html
@@ -0,0 +1,30 @@
+{% extends "base.html" %}
+{% block title %}Cart - Flask Shop{% endblock %}
+{% block content %}
+<h1>Cart</h1>
+{% if items %}
+  <form method="post">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <table>
+      <thead><tr><th>Product</th><th>Quantity</th><th>Line total</th></tr></thead>
+      <tbody>
+        {% for item in items %}
+          <tr>
+            <td>{{ item.product.name }}</td>
+            <td><input type="number" name="qty_{{ item.product.id }}" min="0" max="20" value="{{ item.quantity }}"></td>
+            <td>{{ item.line_total|money }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+    <p class="total">Total: {{ total|money }}</p>
+    <button type="submit">Update cart</button>
+  </form>
+  <form method="post" action="{{ url_for('checkout') }}">
