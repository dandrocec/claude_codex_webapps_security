@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+{% block title %}Products - Flask Shop{% endblock %}
+{% block content %}
+<h1>Products</h1>
+<div class="product-grid">
+  {% for product in products %}
+    <article class="card">
+      <h2>{{ product.name }}</h2>
+      <p>{{ product.description }}</p>
+      <p class="price">{{ product.price_cents|money }}</p>
+      <p class="muted">{{ product.inventory }} in stock</p>
+      <form method="post" action="{{ url_for('add_to_cart', product_id=product.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <label>
+          Quantity
+          <input type="number" name="quantity" min="1" max="20" value="1">
+        </label>
+        <button type="submit" {% if product.inventory <= 0 %}disabled{% endif %}>Add to cart</button>
+      </form>
+    </article>
+  {% endfor %}
+</div>
+{% endblock %}
