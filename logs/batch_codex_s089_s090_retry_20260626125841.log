+BASE_DIR = os.path.abspath(os.path.dirname(__file__))
+DATABASE = os.environ.get("DATABASE_URL", os.path.join(BASE_DIR, "shop.sqlite3"))
+USERNAME_RE = re.compile(r"^[A-Za-z0-9_.-]{3,32}$")
