+
+<section class="auth-panel">
+  <h1><%= title %></h1>
+  <p><%= message %></p>
+  <% if (typeof errors !== 'undefined' && errors.length) { %>
+    <ul class="errors"><% errors.forEach((error) => { %><li><%= error %></li><% }) %></ul>
+  <% } %>
+  <p><a href="/menu">Back to menu</a></p>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/login.ejs b/views/login.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..10091f55e7a80c65c0334eea65cc1ac37434c0c6
--- /dev/null
+++ b/views/login.ejs
@@ -0,0 +1,16 @@
+<%- include('partials/header') %>
+
+<section class="auth-panel">
+  <h1>Log In</h1>
+  <% if (errors.length) { %>
+    <ul class="errors"><% errors.forEach((error) => { %><li><%= error %></li><% }) %></ul>
+  <% } %>
+  <form method="post" action="/login">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Email <input type="email" name="email" maxlength="254" required autocomplete="email"></label>
+    <label>Password <input type="password" name="password" maxlength="128" required autocomplete="current-password"></label>
+    <button type="submit">Log in</button>
+  </form>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/menu.ejs b/views/menu.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..5d30a114cfe714090df8063b3af442ceb31a7e8a
--- /dev/null
+++ b/views/menu.ejs
@@ -0,0 +1,37 @@
+<%- include('partials/header') %>
+
+<section class="section-head">
+  <h1>Menu</h1>
+  <p>Choose fresh meals and desserts. Totals are calculated securely at checkout.</p>
+</section>
+
+<div class="grid">
+  <% menuItems.forEach((item) => { %>
+    <article class="card">
+      <div>
+        <h2><%= item.name %></h2>
+        <p><%= item.description %></p>
+      </div>
+      <div class="card-actions">
+        <strong><%= money(item.price_cents) %></strong>
+        <% if (currentUser && currentUser.role === 'customer') { %>
+          <form method="post" action="/cart/add">
+            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+            <input type="hidden" name="item_id" value="<%= item.id %>">
+            <label>
+              <span>Qty</span>
+              <input type="number" name="quantity" value="1" min="1" max="20" required>
+            </label>
+            <button type="submit">Add</button>
+          </form>
+        <% } %>
+      </div>
+    </article>
+  <% }) %>
+</div>
+
+<% if (!currentUser) { %>
+  <p class="notice"><a href="/login">Log in</a> or <a href="/register">register</a> to order.</p>
+<% } %>
+
+<%- include('partials/footer') %>
diff --git a/views/order-detail.ejs b/views/order-detail.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..5383213270ed05017cd2a39adf7c5c9a15881ef9
--- /dev/null
+++ b/views/order-detail.ejs
@@ -0,0 +1,44 @@
+<%- include('partials/header') %>
+
+<section class="section-head">
+  <h1>Order #<%= order.id %></h1>
+  <p>Status: <span class="status"><%= order.status %></span></p>
+</section>
+
+<% if (staffView) { %>
+  <p>Customer: <%= order.email %></p>
+  <form method="post" action="/staff/orders/<%= order.id %>/status" class="status-form detail-status">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <select name="status" required>
+      <% statuses.forEach((status) => { %>
+        <option value="<%= status %>" <%= status === order.status ? 'selected' : '' %>><%= status %></option>
+      <% }) %>
+    </select>
+    <button type="submit">Update Status</button>
+  </form>
+<% } %>
+
+<table>
+  <thead><tr><th>Item</th><th>Unit price</th><th>Quantity</th><th>Total</th></tr></thead>
+  <tbody>
+    <% items.forEach((item) => { %>
+      <tr>
+        <td><%= item.item_name %></td>
+        <td><%= money(item.unit_price_cents) %></td>
+        <td><%= item.quantity %></td>
+        <td><%= money(item.unit_price_cents * item.quantity) %></td>
+      </tr>
+    <% }) %>
+  </tbody>
+</table>
+
+<div class="total">Order total: <%= money(order.total_cents) %></div>
+
+<% if (order.customer_note) { %>
+  <section class="note">
+    <h2>Order Note</h2>
+    <p><%= order.customer_note %></p>
+  </section>
+<% } %>
+
+<%- include('partials/footer') %>
diff --git a/views/orders.ejs b/views/orders.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..f29cf0353a32886adc121feb0e9bff8ec27228fc
--- /dev/null
+++ b/views/orders.ejs
@@ -0,0 +1,25 @@
+<%- include('partials/header') %>
+
+<section class="section-head">
+  <h1>My Orders</h1>
+</section>
+
+<% if (orders.length === 0) { %>
+  <p class="notice">No orders yet.</p>
+<% } else { %>
+  <table>
+    <thead><tr><th>Order</th><th>Status</th><th>Total</th><th>Placed</th></tr></thead>
+    <tbody>
+      <% orders.forEach((order) => { %>
+        <tr>
+          <td><a href="/orders/<%= order.id %>">#<%= order.id %></a></td>
+          <td><span class="status"><%= order.status %></span></td>
+          <td><%= money(order.total_cents) %></td>
+          <td><%= order.created_at %></td>
+        </tr>
+      <% }) %>
+    </tbody>
+  </table>
+<% } %>
+
+<%- include('partials/footer') %>
diff --git a/views/partials/footer.ejs b/views/partials/footer.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..8f0b997cf27cd319fccfc51d64ea2ce6551cb675
--- /dev/null
+++ b/views/partials/footer.ejs
@@ -0,0 +1,3 @@
+  </main>
