+  margin: 0 auto;
+  padding: 28px 0 52px;
+}
+
+.site-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 18px;
+  padding: 16px max(16px, calc((100vw - 1180px) / 2));
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+  position: sticky;
+  top: 0;
+  z-index: 5;
+}
+
+.brand {
+  color: var(--ink);
+  font-size: 1.35rem;
+  font-weight: 800;
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 16px;
+  flex-wrap: wrap;
+}
+
+.inline {
+  display: inline;
+}
+
+.link-button {
+  border: 0;
+  background: transparent;
+  color: var(--brand);
+  cursor: pointer;
+  font: inherit;
+  padding: 0;
+}
+
+.hero {
+  display: grid;
+  grid-template-columns: 1fr;
+  gap: 22px;
+  padding: 36px;
+  background: linear-gradient(120deg, #ffffff 0%, #e4efec 60%, #f7e5dc 100%);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  font-size: clamp(2rem, 5vw, 4rem);
+  line-height: 1;
+  margin-bottom: 0;
+}
+
+h2 {
+  font-size: 1.45rem;
+}
+
+.eyebrow {
+  color: var(--accent);
+  font-weight: 800;
+  letter-spacing: 0;
+  text-transform: uppercase;
+  font-size: 0.78rem;
+  margin-bottom: 10px;
+}
+
+.search-bar,
+.form-grid {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 14px;
+  align-items: end;
+}
+
+.panel,
+.auth-panel {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 22px;
+}
+
+.auth-panel {
+  max-width: 460px;
+  margin: 44px auto;
+}
+
+label {
+  display: grid;
+  gap: 7px;
+  color: var(--muted);
+  font-size: 0.9rem;
+  font-weight: 700;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  background: var(--field);
+  color: var(--ink);
+  font: inherit;
+  padding: 11px 12px;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 42px;
+  border: 1px solid var(--brand);
+  border-radius: 6px;
+  background: var(--brand);
+  color: #ffffff;
+  font: inherit;
+  font-weight: 800;
+  padding: 10px 16px;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--brand-dark);
+  text-decoration: none;
+}
+
+.secondary {
+  background: #ffffff;
+  color: var(--brand);
+}
+
+.secondary:hover {
+  color: #ffffff;
+}
+
+.danger {
+  background: var(--danger);
+  border-color: var(--danger);
+}
+
+.compact {
+  min-height: 34px;
+  padding: 7px 11px;
+  font-size: 0.9rem;
+}
+
+.notice,
+.errors {
+  border-radius: 8px;
+  padding: 14px 16px;
+  margin-bottom: 18px;
+}
+
+.notice {
+  background: #dff3ea;
+  border: 1px solid #9fd7c2;
+}
+
+.errors {
+  background: #fff1f0;
+  border: 1px solid #ffb4aa;
+  color: #7a1f17;
+}
+
+.errors p:last-child {
+  margin-bottom: 0;
+}
+
+.section-head {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin: 30px 0 16px;
+}
+
+.listing-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 18px;
+}
+
+.listing-card {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  overflow: hidden;
+}
+
+.photo-link {
+  display: block;
+  height: 210px;
+  background: #d9e2e1;
+}
+
+.photo-link img,
+.detail-photo {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  display: block;
+}
+
+.placeholder {
+  display: grid;
+  place-items: center;
+  color: var(--muted);
+  min-height: 210px;
+  background: repeating-linear-gradient(45deg, #d8e0df, #d8e0df 12px, #edf2f1 12px, #edf2f1 24px);
+}
+
+.listing-body {
+  padding: 18px;
+}
+
+.price {
+  color: var(--accent);
+  font-size: 1.35rem;
+  font-weight: 900;
+  margin-bottom: 8px;
+}
+
+.muted {
+  color: var(--muted);
+}
+
+.empty {
+  color: var(--muted);
+  background: #ffffff;
+  border: 1px dashed var(--line);
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.detail-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 360px;
+  gap: 22px;
+}
+
+.detail-photo {
+  aspect-ratio: 16 / 9;
+  border-radius: 8px;
+  margin-bottom: 18px;
+  background: #d9e2e1;
+}
+
+.stats {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+  margin: 18px 0;
+}
+
+.stats span {
+  border: 1px solid var(--line);
+  border-radius: 999px;
+  padding: 7px 11px;
+  background: #f7f9fa;
+  font-weight: 700;
+}
+
+.stacked-form {
+  display: grid;
+  gap: 14px;
+}
+
+.wide {
+  grid-column: 1 / -1;
+}
+
+.actions {
+  display: flex;
+  gap: 10px;
+  align-items: center;
+}
+
+.dashboard-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
+  gap: 18px;
+}
+
+.manager-row,
+.inquiry {
+  border-top: 1px solid var(--line);
+  padding: 16px 0;
+}
+
+.manager-row {
+  display: flex;
+  justify-content: space-between;
+  gap: 14px;
+  align-items: center;
+}
+
+.row-actions {
+  display: flex;
+  gap: 8px;
+  align-items: center;
+}
+
+.manager-row p,
+.inquiry p:last-child {
+  margin-bottom: 0;
+}
+
+@media (max-width: 900px) {
+  .search-bar,
+  .form-grid,
+  .listing-grid,
+  .detail-layout,
+  .dashboard-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .site-header,
+  .section-head,
+  .manager-row {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .hero {
+    padding: 24px;
+  }
+}

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..cb951b4c5f1f520a305e4f5478733f51ba6fe9d0
--- /dev/null
+++ b/README.md
@@ -0,0 +1,24 @@
+# PHP Real Estate Site
+
+A dependency-free PHP real-estate application using SQLite. Agents can register, sign in, create listings with uploaded photos, edit or delete their own listings, and view contact messages. Visitors can search listings by location and filter by price, then contact the listing agent through a form.
+
+## Run Locally
+
+Requirements:
+
+- PHP 8.1 or newer
+- PHP SQLite extensions: `pdo` and `pdo_sqlite`
+
+Start the app on port 5066:
+
+```bash
+php -S 127.0.0.1:5066 -t public
+```
+
+Then open:
+
+```text
+http://127.0.0.1:5066
+```
+
+The app creates its SQLite database automatically at `data/app.sqlite` and stores uploaded listing photos in `public/uploads`.
