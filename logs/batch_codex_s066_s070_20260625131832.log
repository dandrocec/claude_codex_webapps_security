+:root {
+  color-scheme: light;
+  --ink: #202124;
+  --muted: #687076;
+  --line: #d9e0e4;
+  --panel: #ffffff;
+  --field: #f7f9fa;
+  --brand: #146c5f;
+  --brand-dark: #0f5148;
+  --accent: #c7522a;
+  --danger: #b42318;
+  --bg: #eef3f2;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--ink);
+}
+
+a {
+  color: var(--brand);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+main {
