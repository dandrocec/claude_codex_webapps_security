+}
+
+.section-head {
+  margin-bottom: 24px;
+}
+
+.section-head h1,
+.auth-panel h1 {
+  margin: 0 0 8px;
+  font-size: 32px;
+}
+
+.section-head p {
+  margin: 0;
+  color: var(--muted);
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
