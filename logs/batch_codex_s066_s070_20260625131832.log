+  background: #1f2933;
+  color: #fff;
+  display: flex;
+  gap: 1rem;
+  justify-content: space-between;
+  padding: 1.25rem clamp(1rem, 4vw, 3rem);
+}
+
+.topbar h1,
+.section-heading h2,
+.menu-card h3,
+.order-card h3 {
+  margin: 0;
+}
+
+.eyebrow {
+  color: var(--warm);
+  font-size: 0.76rem;
+  font-weight: 800;
+  letter-spacing: 0;
+  margin: 0 0 0.25rem;
