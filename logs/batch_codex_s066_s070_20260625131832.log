diff --git a/templates/provider_dashboard.html b/templates/provider_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..689a5080ecb111575c2963362d7d0111dcd36f77
--- /dev/null
+++ b/templates/provider_dashboard.html
@@ -0,0 +1,70 @@
+{% extends "base.html" %}
+{% block title %}Provider Dashboard{% endblock %}
+{% block content %}
+<div class="page-heading">
+    <div>
+        <p class="eyebrow">Provider</p>
+        <h1>Your availability</h1>
+    </div>
+</div>
+
+<section class="panel">
+    <h2>Publish a slot</h2>
+    <form class="slot-form" method="post" action="{{ url_for('create_slot') }}">
+        <label>
+            Starts
+            <input name="starts_at" type="datetime-local" required>
+        </label>
+        <label>
+            Ends
+            <input name="ends_at" type="datetime-local" required>
+        </label>
+        <button class="primary" type="submit">Publish</button>
+    </form>
+</section>
+
+<section class="panel">
+    <h2>Appointments and open slots</h2>
+    {% if slots %}
+        <div class="table-wrap">
+            <table>
+                <thead>
+                    <tr>
+                        <th>Starts</th>
+                        <th>Ends</th>
+                        <th>Status</th>
+                        <th>Client</th>
+                        <th>Confirmation</th>
+                    </tr>
+                </thead>
+                <tbody>
+                    {% for slot in slots %}
+                        <tr>
+                            <td>{{ slot.starts_at|format_dt }}</td>
+                            <td>{{ slot.ends_at|format_dt }}</td>
+                            <td>
+                                {% if slot.booked_by %}
+                                    <span class="badge booked">Booked</span>
+                                {% else %}
+                                    <span class="badge open">Open</span>
+                                {% endif %}
+                            </td>
+                            <td>
+                                {% if slot.client_name %}
+                                    {{ slot.client_name }}<br>
+                                    <small>{{ slot.client_email }}</small>
+                                {% else %}
+                                    -
+                                {% endif %}
+                            </td>
+                            <td>{{ slot.confirmation_code or "-" }}</td>
+                        </tr>
+                    {% endfor %}
+                </tbody>
+            </table>
+        </div>
+    {% else %}
+        <p class="empty">No slots published yet.</p>
+    {% endif %}
+</section>
+{% endblock %}
