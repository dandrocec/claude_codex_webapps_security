@@ -0,0 +1,16 @@
+# Flask Scheduling App
+
+A small scheduling app backed by SQLite. Providers can publish available time slots, clients can book open slots, and each user sees their own appointments. Booking uses an atomic update so a slot cannot be booked twice.
+
+## Run locally
+
+```bash
+python -m venv .venv
+.venv\Scripts\activate
+pip install -r requirements.txt
+python app.py
+```
+
+Open http://localhost:5068 in your browser.
+
+The SQLite database is created automatically at `instance/schedule.sqlite3` on first request.
diff --git a/app.py b/app.py
new file mode 100644
index 0000000000000000000000000000000000000000..5d390f5469b8ffd3a7b2a13e7672d595b1941ab7
--- /dev/null
+++ b/app.py
@@ -0,0 +1,303 @@
+from datetime import datetime
+import os
+import sqlite3
+from functools import wraps
+
+from flask import (
+    Flask,
+    flash,
+    g,
+    redirect,
+    render_template,
+    request,
+    session,
+    url_for,
+)
+from werkzeug.security import check_password_hash, generate_password_hash
+
+
+app = Flask(__name__)
+app.config["SECRET_KEY"] = os.environ.get("SECRET_KEY", "dev-secret-change-me")
+app.config["DATABASE"] = os.path.join(app.instance_path, "schedule.sqlite3")
+
+
+def get_db():
+    if "db" not in g:
+        os.makedirs(app.instance_path, exist_ok=True)
+        g.db = sqlite3.connect(app.config["DATABASE"])
+        g.db.row_factory = sqlite3.Row
+        g.db.execute("PRAGMA foreign_keys = ON")
+    return g.db
+
+
+@app.teardown_appcontext
+def close_db(error=None):
+    db = g.pop("db", None)
+    if db is not None:
+        db.close()
+
+
+def init_db():
+    db = get_db()
+    db.executescript(
+        """
+        CREATE TABLE IF NOT EXISTS users (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            name TEXT NOT NULL,
+            email TEXT NOT NULL UNIQUE,
+            password_hash TEXT NOT NULL,
+            role TEXT NOT NULL CHECK (role IN ('provider', 'client')),
+            created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
+        );
+
+        CREATE TABLE IF NOT EXISTS slots (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            provider_id INTEGER NOT NULL,
+            starts_at TEXT NOT NULL,
+            ends_at TEXT NOT NULL,
+            booked_by INTEGER,
+            booked_at TEXT,
+            confirmation_code TEXT,
+            created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+            FOREIGN KEY (provider_id) REFERENCES users(id) ON DELETE CASCADE,
+            FOREIGN KEY (booked_by) REFERENCES users(id) ON DELETE SET NULL,
+            UNIQUE (provider_id, starts_at, ends_at)
+        );
+
+        CREATE INDEX IF NOT EXISTS idx_slots_open_time
+            ON slots(booked_by, starts_at);
+        CREATE INDEX IF NOT EXISTS idx_slots_provider
+            ON slots(provider_id, starts_at);
+        """
+    )
+    db.commit()
+
+
+@app.before_request
+def load_current_user():
+    init_db()
+    user_id = session.get("user_id")
+    g.user = None
+    if user_id:
+        g.user = get_db().execute(
+            "SELECT id, name, email, role FROM users WHERE id = ?", (user_id,)
+        ).fetchone()
+
+
+def login_required(view):
+    @wraps(view)
+    def wrapped_view(**kwargs):
+        if g.user is None:
+            flash("Please sign in first.", "warning")
+            return redirect(url_for("login"))
+        return view(**kwargs)
+
+    return wrapped_view
+
+
+def role_required(role):
+    def decorator(view):
+        @wraps(view)
+        def wrapped_view(**kwargs):
+            if g.user is None:
+                flash("Please sign in first.", "warning")
+                return redirect(url_for("login"))
+            if g.user["role"] != role:
+                flash("That page is not available for your role.", "warning")
+                return redirect(url_for("dashboard"))
+            return view(**kwargs)
+
+        return wrapped_view
+
+    return decorator
+
+
+def parse_local_datetime(value):
+    try:
+        return datetime.strptime(value, "%Y-%m-%dT%H:%M")
+    except (TypeError, ValueError):
+        return None
+
+
+def format_dt(value):
+    try:
+        return datetime.fromisoformat(value).strftime("%b %d, %Y at %I:%M %p")
+    except (TypeError, ValueError):
+        return value
+
+
+app.jinja_env.filters["format_dt"] = format_dt
+
+
+@app.route("/")
+def index():
+    if g.user:
+        return redirect(url_for("dashboard"))
+    return render_template("index.html")
+
+
+@app.route("/register", methods=("GET", "POST"))
+def register():
+    if request.method == "POST":
+        name = request.form.get("name", "").strip()
+        email = request.form.get("email", "").strip().lower()
+        password = request.form.get("password", "")
+        role = request.form.get("role", "")
+
+        if not name or not email or not password:
+            flash("Name, email, and password are required.", "error")
+        elif role not in {"provider", "client"}:
+            flash("Choose whether this account is for a provider or client.", "error")
+        else:
+            try:
+                db = get_db()
+                db.execute(
+                    """
+                    INSERT INTO users (name, email, password_hash, role)
+                    VALUES (?, ?, ?, ?)
+                    """,
+                    (name, email, generate_password_hash(password), role),
+                )
+                db.commit()
+                flash("Account created. Sign in to continue.", "success")
+                return redirect(url_for("login"))
+            except sqlite3.IntegrityError:
+                flash("An account with that email already exists.", "error")
+
+    return render_template("register.html")
+
+
+@app.route("/login", methods=("GET", "POST"))
+def login():
+    if request.method == "POST":
+        email = request.form.get("email", "").strip().lower()
+        password = request.form.get("password", "")
+        user = get_db().execute(
+            "SELECT * FROM users WHERE email = ?", (email,)
+        ).fetchone()
+
+        if user is None or not check_password_hash(user["password_hash"], password):
+            flash("Invalid email or password.", "error")
+        else:
+            session.clear()
+            session["user_id"] = user["id"]
+            flash("Signed in successfully.", "success")
+            return redirect(url_for("dashboard"))
+
+    return render_template("login.html")
+
+
+@app.route("/logout", methods=("POST",))
+def logout():
+    session.clear()
+    flash("Signed out.", "success")
+    return redirect(url_for("index"))
+
+
+@app.route("/dashboard")
+@login_required
+def dashboard():
+    if g.user["role"] == "provider":
+        slots = get_db().execute(
+            """
+            SELECT slots.*, clients.name AS client_name, clients.email AS client_email
+            FROM slots
+            LEFT JOIN users AS clients ON clients.id = slots.booked_by
+            WHERE provider_id = ?
+            ORDER BY starts_at
+            """,
+            (g.user["id"],),
+        ).fetchall()
+        return render_template("provider_dashboard.html", slots=slots)
+
+    appointments = get_db().execute(
+        """
+        SELECT slots.*, providers.name AS provider_name, providers.email AS provider_email
+        FROM slots
+        JOIN users AS providers ON providers.id = slots.provider_id
+        WHERE booked_by = ?
+        ORDER BY starts_at
+        """,
+        (g.user["id"],),
+    ).fetchall()
+    open_slots = get_db().execute(
+        """
+        SELECT slots.*, providers.name AS provider_name
+        FROM slots
+        JOIN users AS providers ON providers.id = slots.provider_id
+        WHERE booked_by IS NULL AND starts_at >= datetime('now')
+        ORDER BY starts_at
+        """
+    ).fetchall()
+    return render_template(
+        "client_dashboard.html",
+        appointments=appointments,
+        open_slots=open_slots,
+    )
+
+
+@app.route("/slots", methods=("POST",))
+@role_required("provider")
+def create_slot():
+    starts_at = parse_local_datetime(request.form.get("starts_at"))
+    ends_at = parse_local_datetime(request.form.get("ends_at"))
+
+    if starts_at is None or ends_at is None:
+        flash("Start and end times are required.", "error")
+    elif ends_at <= starts_at:
+        flash("The end time must be after the start time.", "error")
+    else:
+        try:
+            db = get_db()
+            db.execute(
+                """
+                INSERT INTO slots (provider_id, starts_at, ends_at)
+                VALUES (?, ?, ?)
+                """,
+                (
+                    g.user["id"],
+                    starts_at.isoformat(timespec="minutes"),
+                    ends_at.isoformat(timespec="minutes"),
+                ),
+            )
+            db.commit()
+            flash("Availability published.", "success")
+        except sqlite3.IntegrityError:
+            flash("That slot already exists.", "error")
+
+    return redirect(url_for("dashboard"))
+
+
+@app.route("/slots/<int:slot_id>/book", methods=("POST",))
+@role_required("client")
+def book_slot(slot_id):
+    confirmation_code = f"CNF-{datetime.utcnow().strftime('%Y%m%d%H%M%S')}-{g.user['id']}-{slot_id}"
+    db = get_db()
+    cursor = db.execute(
+        """
+        UPDATE slots
+        SET booked_by = ?, booked_at = CURRENT_TIMESTAMP, confirmation_code = ?
+        WHERE id = ? AND booked_by IS NULL
+        """,
+        (g.user["id"], confirmation_code, slot_id),
+    )
+    db.commit()
+
+    if cursor.rowcount == 0:
+        flash("That slot is no longer available.", "error")
+        return redirect(url_for("dashboard"))
+
+    slot = db.execute(
+        """
+        SELECT slots.*, providers.name AS provider_name, providers.email AS provider_email
+        FROM slots
+        JOIN users AS providers ON providers.id = slots.provider_id
+        WHERE slots.id = ? AND booked_by = ?
+        """,
+        (slot_id, g.user["id"]),
+    ).fetchone()
+    return render_template("confirmation.html", slot=slot)
+
+
+if __name__ == "__main__":
+    app.run(host="0.0.0.0", port=5068, debug=True)
