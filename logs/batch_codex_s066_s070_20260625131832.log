+  text-decoration: none;
+  color: var(--text);
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 14px;
+}
+
+.user {
+  color: var(--muted);
+  font-size: 14px;
+}
+
+.page {
+  width: min(1080px, calc(100% - 32px));
