+    font-size: 0.8rem;
+    font-weight: 700;
+    padding: 0.2rem 0.55rem;
+}
+
+.badge.open {
+    background: #e9f3ff;
+    color: #145a91;
+}
+
+.badge.booked {
+    background: var(--success-bg);
+    color: var(--success);
+}
+
+.slot-grid {
+    display: grid;
+    gap: 1rem;
+    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+}
+
+.slot-card {
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 1rem;
+}
+
+.slot-card h3,
+.slot-card p {
+    margin: 0 0 0.35rem;
+}
+
+.slot-card form {
+    margin-top: 1rem;
+}
+
+.flash-list {
+    display: grid;
+    gap: 0.5rem;
+    margin-bottom: 1rem;
+}
+
+.flash {
+    border-radius: 8px;
+    padding: 0.75rem 1rem;
+}
+
+.flash.success {
+    background: var(--success-bg);
+    color: var(--success);
+}
+
+.flash.error {
+    background: var(--error-bg);
+    color: var(--error);
+}
+
+.flash.warning {
+    background: var(--warning-bg);
+    color: var(--warning);
+}
+
+.confirmation dl {
+    display: grid;
+    gap: 1rem;
+}
+
+.confirmation dt {
+    color: var(--muted);
+    font-size: 0.85rem;
+    font-weight: 700;
+    text-transform: uppercase;
+}
+
+.confirmation dd {
+    margin: 0.2rem 0 0;
+}
+
+.code {
+    font-family: Consolas, Monaco, monospace;
+    overflow-wrap: anywhere;
+}
+
+@media (max-width: 640px) {
+    .topbar,
+    .page-heading {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    nav {
+        justify-content: flex-start;
+    }
+
+    .slot-form,
+    .actions {
+        align-items: stretch;
+        flex-direction: column;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..cb946dc9e1f8b67dc69fc529a73a8415512cf657
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Schedule{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Schedule</a>
+        <nav>
+            {% if g.user %}
+                <span class="user">{{ g.user.name }} · {{ g.user.role|capitalize }}</span>
+                <form class="inline" method="post" action="{{ url_for('logout') }}">
+                    <button type="submit">Sign out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Sign in</a>
+                <a class="button" href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="container">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="flash-list">
+                    {% for category, message in messages %}
+                        <div class="flash {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/client_dashboard.html b/templates/client_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..bc64cad2b52e3cdc474648b69185b160f725c797
--- /dev/null
+++ b/templates/client_dashboard.html
@@ -0,0 +1,60 @@
+{% extends "base.html" %}
+{% block title %}Client Dashboard{% endblock %}
+{% block content %}
+<div class="page-heading">
+    <div>
+        <p class="eyebrow">Client</p>
+        <h1>Book an appointment</h1>
+    </div>
+</div>
+
+<section class="panel">
+    <h2>Available slots</h2>
+    {% if open_slots %}
+        <div class="slot-grid">
+            {% for slot in open_slots %}
+                <article class="slot-card">
+                    <h3>{{ slot.provider_name }}</h3>
+                    <p>{{ slot.starts_at|format_dt }}</p>
+                    <small>Ends {{ slot.ends_at|format_dt }}</small>
+                    <form method="post" action="{{ url_for('book_slot', slot_id=slot.id) }}">
+                        <button class="primary" type="submit">Book slot</button>
+                    </form>
+                </article>
+            {% endfor %}
+        </div>
+    {% else %}
+        <p class="empty">No available slots right now.</p>
+    {% endif %}
+</section>
+
+<section class="panel">
+    <h2>Your appointments</h2>
+    {% if appointments %}
+        <div class="table-wrap">
+            <table>
+                <thead>
+                    <tr>
+                        <th>Provider</th>
+                        <th>Starts</th>
+                        <th>Ends</th>
+                        <th>Confirmation</th>
+                    </tr>
+                </thead>
+                <tbody>
+                    {% for slot in appointments %}
+                        <tr>
+                            <td>{{ slot.provider_name }}<br><small>{{ slot.provider_email }}</small></td>
+                            <td>{{ slot.starts_at|format_dt }}</td>
+                            <td>{{ slot.ends_at|format_dt }}</td>
+                            <td>{{ slot.confirmation_code }}</td>
+                        </tr>
+                    {% endfor %}
+                </tbody>
+            </table>
+        </div>
+    {% else %}
+        <p class="empty">You have not booked any appointments.</p>
+    {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/confirmation.html b/templates/confirmation.html
