index 0000000000000000000000000000000000000000..95fef4eb6610cb155983d86c4b22f59d83e4046b
--- /dev/null
+++ b/requirements.txt
@@ -0,0 +1 @@
+Flask==3.0.3
diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..2a268367bf7ac5ed225a0aea8ed691bbb7d9312b
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,338 @@
+:root {
+    --bg: #f7f8fb;
+    --panel: #ffffff;
+    --text: #1b2430;
+    --muted: #657085;
+    --line: #dbe1ea;
+    --primary: #1769aa;
+    --primary-dark: #0f4f82;
+    --success-bg: #e7f7ee;
+    --success: #137044;
+    --error-bg: #fdecec;
+    --error: #a52727;
+    --warning-bg: #fff6dc;
+    --warning: #806000;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--bg);
+    color: var(--text);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.5;
+}
+
+a {
+    color: var(--primary);
+    text-decoration: none;
+}
+
+.topbar {
+    align-items: center;
+    background: var(--panel);
+    border-bottom: 1px solid var(--line);
+    display: flex;
+    gap: 1rem;
+    justify-content: space-between;
+    padding: 1rem clamp(1rem, 4vw, 3rem);
+}
+
+.brand {
+    color: var(--text);
+    font-size: 1.2rem;
+    font-weight: 700;
+}
+
+nav {
+    align-items: center;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 0.75rem;
+    justify-content: flex-end;
+}
+
+.user {
+    color: var(--muted);
+    font-size: 0.95rem;
+}
+
+.container {
+    margin: 0 auto;
+    max-width: 1120px;
+    padding: 2rem 1rem 4rem;
+}
+
+.hero {
+    align-items: center;
+    display: grid;
+    min-height: 58vh;
+}
+
+.hero h1,
+.page-heading h1,
+.panel h1 {
+    line-height: 1.1;
+    margin: 0.25rem 0 1rem;
+}
+
+.hero h1 {
+    font-size: clamp(2.1rem, 6vw, 4.5rem);
+    max-width: 850px;
+}
+
+.hero p {
+    color: var(--muted);
+    font-size: 1.15rem;
+    max-width: 680px;
+}
+
+.eyebrow {
+    color: var(--primary-dark);
+    font-size: 0.8rem;
+    font-weight: 700;
+    letter-spacing: 0;
+    margin: 0;
+    text-transform: uppercase;
+}
+
+.actions,
+.slot-form {
+    align-items: end;
+    display: flex;
+    flex-wrap: wrap;
+    gap: 1rem;
+    margin-top: 1.5rem;
+}
+
+.button,
+button {
+    background: #eef3f8;
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    color: var(--text);
+    cursor: pointer;
+    display: inline-flex;
+    font: inherit;
+    font-weight: 700;
+    justify-content: center;
+    min-height: 2.5rem;
+    padding: 0.55rem 0.9rem;
+}
+
+.button.primary,
+button.primary {
+    background: var(--primary);
+    border-color: var(--primary);
+    color: #fff;
+}
+
+.button:hover,
+button:hover {
+    filter: brightness(0.96);
+}
+
+.inline {
+    margin: 0;
+}
+
+.panel {
+    background: var(--panel);
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    margin: 1rem 0;
+    padding: 1.25rem;
+}
+
+.panel h2 {
+    margin: 0 0 1rem;
+}
+
+.narrow {
+    margin-left: auto;
+    margin-right: auto;
+    max-width: 520px;
+}
+
+form {
+    display: grid;
+    gap: 1rem;
+}
+
+label,
+legend {
+    color: var(--text);
+    font-weight: 700;
+}
+
+input {
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    display: block;
+    font: inherit;
+    margin-top: 0.35rem;
+    padding: 0.7rem;
+    width: 100%;
+}
+
+fieldset {
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    display: flex;
+    gap: 1rem;
+    margin: 0;
+    padding: 1rem;
+}
+
+.choice {
+    align-items: center;
+    display: flex;
+    gap: 0.45rem;
+}
+
+.choice input {
+    margin: 0;
+    width: auto;
+}
+
+.page-heading {
+    align-items: end;
+    display: flex;
+    justify-content: space-between;
+    margin-bottom: 1rem;
+}
+
+.table-wrap {
+    overflow-x: auto;
+}
+
+table {
+    border-collapse: collapse;
+    width: 100%;
+}
+
+th,
+td {
+    border-bottom: 1px solid var(--line);
+    padding: 0.75rem;
+    text-align: left;
+    vertical-align: top;
+}
+
+th {
+    color: var(--muted);
+    font-size: 0.85rem;
+    text-transform: uppercase;
+}
+
+small,
+.empty {
+    color: var(--muted);
+}
+
+.badge {
+    border-radius: 999px;
+    display: inline-block;
+    font-size: 0.8rem;
+    font-weight: 700;
+    padding: 0.2rem 0.55rem;
+}
+
+.badge.open {
+    background: #e9f3ff;
+    color: #145a91;
+}
+
+.badge.booked {
+    background: var(--success-bg);
+    color: var(--success);
+}
+
+.slot-grid {
+    display: grid;
+    gap: 1rem;
+    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+}
+
+.slot-card {
+    border: 1px solid var(--line);
+    border-radius: 8px;
+    padding: 1rem;
+}
+
+.slot-card h3,
+.slot-card p {
+    margin: 0 0 0.35rem;
+}
+
+.slot-card form {
+    margin-top: 1rem;
+}
+
+.flash-list {
+    display: grid;
+    gap: 0.5rem;
+    margin-bottom: 1rem;
+}
+
+.flash {
+    border-radius: 8px;
+    padding: 0.75rem 1rem;
+}
+
+.flash.success {
+    background: var(--success-bg);
+    color: var(--success);
+}
+
+.flash.error {
+    background: var(--error-bg);
+    color: var(--error);
+}
+
+.flash.warning {
+    background: var(--warning-bg);
+    color: var(--warning);
+}
+
+.confirmation dl {
+    display: grid;
+    gap: 1rem;
+}
+
+.confirmation dt {
+    color: var(--muted);
+    font-size: 0.85rem;
+    font-weight: 700;
+    text-transform: uppercase;
+}
+
+.confirmation dd {
+    margin: 0.2rem 0 0;
+}
+
+.code {
+    font-family: Consolas, Monaco, monospace;
+    overflow-wrap: anywhere;
+}
+
+@media (max-width: 640px) {
+    .topbar,
+    .page-heading {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    nav {
+        justify-content: flex-start;
+    }
+
+    .slot-form,
+    .actions {
+        align-items: stretch;
+        flex-direction: column;
+    }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..cb946dc9e1f8b67dc69fc529a73a8415512cf657
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Schedule{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="topbar">
+        <a class="brand" href="{{ url_for('index') }}">Schedule</a>
+        <nav>
+            {% if g.user %}
+                <span class="user">{{ g.user.name }} · {{ g.user.role|capitalize }}</span>
+                <form class="inline" method="post" action="{{ url_for('logout') }}">
+                    <button type="submit">Sign out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Sign in</a>
+                <a class="button" href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="container">
+        {% with messages = get_flashed_messages(with_categories=true) %}
+            {% if messages %}
+                <div class="flash-list">
+                    {% for category, message in messages %}
+                        <div class="flash {{ category }}">{{ message }}</div>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
diff --git a/templates/client_dashboard.html b/templates/client_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..bc64cad2b52e3cdc474648b69185b160f725c797
--- /dev/null
+++ b/templates/client_dashboard.html
@@ -0,0 +1,60 @@
+{% extends "base.html" %}
+{% block title %}Client Dashboard{% endblock %}
+{% block content %}
+<div class="page-heading">
+    <div>
+        <p class="eyebrow">Client</p>
+        <h1>Book an appointment</h1>
+    </div>
+</div>
+
+<section class="panel">
+    <h2>Available slots</h2>
+    {% if open_slots %}
+        <div class="slot-grid">
+            {% for slot in open_slots %}
+                <article class="slot-card">
+                    <h3>{{ slot.provider_name }}</h3>
+                    <p>{{ slot.starts_at|format_dt }}</p>
+                    <small>Ends {{ slot.ends_at|format_dt }}</small>
+                    <form method="post" action="{{ url_for('book_slot', slot_id=slot.id) }}">
+                        <button class="primary" type="submit">Book slot</button>
+                    </form>
+                </article>
+            {% endfor %}
+        </div>
+    {% else %}
+        <p class="empty">No available slots right now.</p>
+    {% endif %}
+</section>
+
+<section class="panel">
+    <h2>Your appointments</h2>
+    {% if appointments %}
+        <div class="table-wrap">
+            <table>
+                <thead>
+                    <tr>
+                        <th>Provider</th>
+                        <th>Starts</th>
+                        <th>Ends</th>
+                        <th>Confirmation</th>
+                    </tr>
+                </thead>
+                <tbody>
+                    {% for slot in appointments %}
+                        <tr>
+                            <td>{{ slot.provider_name }}<br><small>{{ slot.provider_email }}</small></td>
+                            <td>{{ slot.starts_at|format_dt }}</td>
+                            <td>{{ slot.ends_at|format_dt }}</td>
+                            <td>{{ slot.confirmation_code }}</td>
+                        </tr>
+                    {% endfor %}
+                </tbody>
+            </table>
+        </div>
+    {% else %}
+        <p class="empty">You have not booked any appointments.</p>
+    {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/confirmation.html b/templates/confirmation.html
new file mode 100644
index 0000000000000000000000000000000000000000..51a2354bcc8214682937d8c54a73e46214fec124
--- /dev/null
+++ b/templates/confirmation.html
@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+{% block title %}Booking Confirmed{% endblock %}
+{% block content %}
+<section class="panel narrow confirmation">
+    <p class="eyebrow">Confirmed</p>
+    <h1>Your appointment is booked.</h1>
+    <dl>
+        <div>
+            <dt>Provider</dt>
+            <dd>{{ slot.provider_name }}</dd>
+        </div>
+        <div>
+            <dt>Time</dt>
+            <dd>{{ slot.starts_at|format_dt }} to {{ slot.ends_at|format_dt }}</dd>
+        </div>
+        <div>
+            <dt>Confirmation</dt>
+            <dd class="code">{{ slot.confirmation_code }}</dd>
+        </div>
+    </dl>
+    <a class="button primary" href="{{ url_for('dashboard') }}">Back to dashboard</a>
+</section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..b746ae6934985e9821ab4c51fafa0f67cc5247c6
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,15 @@
+{% extends "base.html" %}
+{% block title %}Schedule App{% endblock %}
+{% block content %}
+<section class="hero">
+    <div>
+        <p class="eyebrow">SQLite scheduling</p>
+        <h1>Publish availability and book confirmed appointments.</h1>
+        <p>Providers manage open slots. Clients reserve available times and receive an immediate confirmation.</p>
+        <div class="actions">
+            <a class="button primary" href="{{ url_for('register') }}">Create account</a>
+            <a class="button" href="{{ url_for('login') }}">Sign in</a>
+        </div>
+    </div>
+</section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..c78700880227d1f69c0cc7859249efcded14c6e2
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,18 @@
+{% extends "base.html" %}
+{% block title %}Sign in{% endblock %}
+{% block content %}
+<section class="panel narrow">
+    <h1>Sign in</h1>
+    <form method="post">
+        <label>
+            Email
+            <input name="email" type="email" autocomplete="email" required>
+        </label>
+        <label>
+            Password
+            <input name="password" type="password" autocomplete="current-password" required>
+        </label>
+        <button class="primary" type="submit">Sign in</button>
+    </form>
+</section>
+{% endblock %}
diff --git a/templates/provider_dashboard.html b/templates/provider_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..689a5080ecb111575c2963362d7d0111dcd36f77
--- /dev/null
+++ b/templates/provider_dashboard.html
@@ -0,0 +1,70 @@
+{% extends "base.html" %}
+{% block title %}Provider Dashboard{% endblock %}
+{% block content %}
+<div class="page-heading">
+    <div>
+        <p class="eyebrow">Provider</p>
+        <h1>Your availability</h1>
+    </div>
+</div>
+
+<section class="panel">
+    <h2>Publish a slot</h2>
+    <form class="slot-form" method="post" action="{{ url_for('create_slot') }}">
+        <label>
+            Starts
+            <input name="starts_at" type="datetime-local" required>
+        </label>
+        <label>
+            Ends
+            <input name="ends_at" type="datetime-local" required>
+        </label>
+        <button class="primary" type="submit">Publish</button>
+    </form>
+</section>
+
+<section class="panel">
+    <h2>Appointments and open slots</h2>
+    {% if slots %}
+        <div class="table-wrap">
+            <table>
+                <thead>
+                    <tr>
+                        <th>Starts</th>
+                        <th>Ends</th>
+                        <th>Status</th>
+                        <th>Client</th>
+                        <th>Confirmation</th>
+                    </tr>
+                </thead>
+                <tbody>
+                    {% for slot in slots %}
+                        <tr>
+                            <td>{{ slot.starts_at|format_dt }}</td>
+                            <td>{{ slot.ends_at|format_dt }}</td>
+                            <td>
+                                {% if slot.booked_by %}
+                                    <span class="badge booked">Booked</span>
+                                {% else %}
+                                    <span class="badge open">Open</span>
+                                {% endif %}
+                            </td>
+                            <td>
+                                {% if slot.client_name %}
+                                    {{ slot.client_name }}<br>
+                                    <small>{{ slot.client_email }}</small>
+                                {% else %}
+                                    -
+                                {% endif %}
+                            </td>
+                            <td>{{ slot.confirmation_code or "-" }}</td>
+                        </tr>
+                    {% endfor %}
+                </tbody>
+            </table>
+        </div>
+    {% else %}
+        <p class="empty">No slots published yet.</p>
+    {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/register.html b/templates/register.html
new file mode 100644
