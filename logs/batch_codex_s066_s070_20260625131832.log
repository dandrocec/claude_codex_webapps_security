+function current_user(PDO $pdo): ?array
+{
+    if (empty($_SESSION['user_id'])) {
+        return null;
+    }
+    $stmt = $pdo->prepare('SELECT id, name, email, role FROM users WHERE id = ?');
+    $stmt->execute([(int) $_SESSION['user_id']]);
+    return $stmt->fetch() ?: null;
