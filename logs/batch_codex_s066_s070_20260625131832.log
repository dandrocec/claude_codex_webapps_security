+    <label>Order note <textarea name="customer_note" maxlength="300"></textarea></label>
+    <div class="total">Total: <%= money(cart.totalCents) %></div>
+    <button type="submit">Place Order</button>
+  </form>
+<% } %>
+
+<%- include('partials/footer') %>
