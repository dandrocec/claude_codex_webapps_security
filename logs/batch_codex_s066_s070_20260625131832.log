+      <tr>
+        <td><%= item.item_name %></td>
+        <td><%= money(item.unit_price_cents) %></td>
+        <td><%= item.quantity %></td>
+        <td><%= money(item.unit_price_cents * item.quantity) %></td>
+      </tr>
+    <% }) %>
