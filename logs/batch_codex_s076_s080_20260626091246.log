+}
+
+h2 {
+  font-size: 1.1rem;
+}
+
+.stack {
+  display: grid;
+  gap: 1rem;
+}
+
+label {
+  color: var(--muted);
+  display: grid;
+  font-size: 0.9rem;
+  font-weight: 700;
+  gap: 0.4rem;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  padding: 0.8rem 0.85rem;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+.swap {
+  color: var(--muted);
+  margin: 1.25rem 0 0;
+}
+
+.swap a,
+.back-link,
+.state-page a {
+  color: var(--accent-dark);
+  font-weight: 800;
+}
+
+.alert,
+.inline-error {
