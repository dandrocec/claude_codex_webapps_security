diff --git a/src/views/users.ejs b/src/views/users.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..be7980e4705810871cde50f8d6f02e9de6361c95
--- /dev/null
+++ b/src/views/users.ejs
@@ -0,0 +1,42 @@
+<%- include('partials/header') %>
+<section class="heading">
