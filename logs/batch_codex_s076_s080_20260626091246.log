diff --git a/templates/history.html b/templates/history.html
new file mode 100644
index 0000000000000000000000000000000000000000..c1895a9b697a3eb31a455e76caed8fb5631dc5fa
--- /dev/null
+++ b/templates/history.html
@@ -0,0 +1,38 @@
+{% extends "base.html" %}
+
+{% block title %}History · {{ page.title }}{% endblock %}
+
+{% block content %}
+  <section class="page-head">
+    <div>
+      <h1>History</h1>
+      <p><a href="{{ url_for('view_page', slug=page.slug) }}">{{ page.title }}</a></p>
+    </div>
+    {% if is_editor %}
+      <a class="button" href="{{ url_for('edit_page', slug=page.slug) }}">Edit current</a>
+    {% endif %}
+  </section>
+
+  <div class="history">
+    {% for revision in revisions %}
+      <article class="revision-row">
+        <div>
+          <h2>
+            <a href="{{ url_for('view_revision', slug=page.slug, revision_id=revision.id) }}">
+              Revision #{{ revision.id }}
+            </a>
+          </h2>
+          <p>
+            {{ revision.created_at }} by {{ revision.author }}
+            {% if revision.note %} · {{ revision.note }}{% endif %}
+          </p>
+        </div>
+        {% if is_editor %}
+          <form method="post" action="{{ url_for('restore_revision', slug=page.slug, revision_id=revision.id) }}">
+            <button type="submit" class="secondary">Restore</button>
+          </form>
+        {% endif %}
+      </article>
+    {% endfor %}
+  </div>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..781ee0ad30fb1ade5f5f9f7857c3108c7b9a7602
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,38 @@
+{% extends "base.html" %}
+
+{% block title %}Pages · Wiki{% endblock %}
+
+{% block content %}
+  <section class="page-head">
+    <div>
+      <h1>Pages</h1>
+      <p>Browse wiki pages{% if not is_editor %}. Editor-only pages are hidden{% endif %}.</p>
+    </div>
+    {% if is_editor %}
+      <a class="button" href="{{ url_for('new_page') }}">Create page</a>
+    {% endif %}
+  </section>
+
+  {% if pages %}
+    <div class="page-list">
+      {% for page in pages %}
+        <article class="page-row">
+          <div>
+            <h2><a href="{{ url_for('view_page', slug=page.slug) }}">{{ page.title }}</a></h2>
+            <p>Updated {{ page.updated_at }}</p>
+          </div>
+          {% if page.editor_only %}
+            <span class="badge">Editor-only</span>
+          {% endif %}
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <div class="empty">
+      <p>No pages yet.</p>
+      {% if is_editor %}
+        <a href="{{ url_for('new_page') }}">Create the first page</a>
+      {% endif %}
+    </div>
+  {% endif %}
+{% endblock %}
