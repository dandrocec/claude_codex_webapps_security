+  text-decoration: none;
+}
+
+.account {
+  align-items: center;
+  display: flex;
+  gap: 0.75rem;
+}
+
+.account form {
+  margin: 0;
+}
+
+.ghost {
+  background: rgba(255, 255, 255, 0.12);
+  padding: 0.55rem 0.75rem;
+}
+
+.ghost:hover {
