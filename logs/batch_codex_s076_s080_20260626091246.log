+{% extends "base.html" %}
+{% block content %}
+<section class="panel">
+  <h1>{{ title }}</h1>
+  <p>{{ message }}</p>
+  <a class="button secondary" href="{{ url_for('index') }}">Go back</a>
+</section>
+{% endblock %}
diff --git a/templates/invoice_form.html b/templates/invoice_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..58b4207e975fee9cd99722825b4338409723849c
--- /dev/null
+++ b/templates/invoice_form.html
@@ -0,0 +1,70 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="panel">
+  <h1>{{ "Edit invoice" if invoice else "New invoice" }}</h1>
+  {% if not clients %}
+    <p>Create a client before adding invoices.</p>
+    <a class="button" href="{{ url_for('client_new') }}">New client</a>
+  {% else %}
+    <form method="post">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <div class="grid">
+        <div>
+          <label for="client_id">Client</label>
+          <select id="client_id" name="client_id" required>
+            {% for client in clients %}
+              <option value="{{ client.id }}" {% if invoice and invoice.client_id == client.id %}selected{% endif %}>{{ client.name }}</option>
+            {% endfor %}
+          </select>
+        </div>
+        <div>
+          <label for="invoice_number">Invoice number</label>
+          <input id="invoice_number" name="invoice_number" required maxlength="40" value="{{ invoice.invoice_number if invoice else '' }}">
+        </div>
+        <div>
+          <label for="issue_date">Issue date</label>
+          <input id="issue_date" name="issue_date" type="date" required value="{{ invoice.issue_date if invoice else '' }}">
+        </div>
+        <div>
+          <label for="due_date">Due date</label>
+          <input id="due_date" name="due_date" type="date" value="{{ invoice.due_date if invoice else '' }}">
+        </div>
+        <div>
+          <label for="tax_rate">Tax rate (%)</label>
+          <input id="tax_rate" name="tax_rate" inputmode="decimal" required value="{{ invoice.tax_rate if invoice else '0.00' }}">
+        </div>
+      </div>
+      <h2>Line items</h2>
+      {% for item in items %}
+        <div class="line-grid">
+          <div>
+            <label>Description</label>
+            <input name="description" maxlength="200" value="{{ item.description or '' }}">
+          </div>
+          <div>
+            <label>Quantity</label>
+            <input name="quantity" inputmode="decimal" value="{{ item.quantity or '1.00' }}">
+          </div>
+          <div>
+            <label>Unit price</label>
+            <input name="unit_price" inputmode="decimal" value="{{ item.unit_price or '0.00' }}">
+          </div>
+        </div>
+      {% endfor %}
+      {% for _ in range(4 - items|length) %}
+        <div class="line-grid">
+          <div><label>Description</label><input name="description" maxlength="200"></div>
+          <div><label>Quantity</label><input name="quantity" inputmode="decimal" value="1.00"></div>
+          <div><label>Unit price</label><input name="unit_price" inputmode="decimal" value="0.00"></div>
+        </div>
+      {% endfor %}
+      <label for="notes">Notes</label>
+      <textarea id="notes" name="notes" maxlength="1000">{{ invoice.notes if invoice else '' }}</textarea>
+      <p class="actions">
+        <button type="submit">Save invoice</button>
+        <a class="button secondary" href="{{ url_for('invoices') }}">Cancel</a>
+      </p>
+    </form>
+  {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/invoice_print.html b/templates/invoice_print.html
new file mode 100644
index 0000000000000000000000000000000000000000..cb0cc8344bc256c27c56f95e94bc104cfcffb2fc
--- /dev/null
+++ b/templates/invoice_print.html
@@ -0,0 +1,72 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>Invoice {{ invoice.invoice_number }}</title>
+  <style>
+    body { margin: 0; font-family: Arial, sans-serif; color: #1f2937; background: #f6f7f9; }
+    main { max-width: 860px; margin: 30px auto; padding: 42px; background: #fff; border: 1px solid #d6d9df; }
+    header { display: flex; justify-content: space-between; gap: 20px; border-bottom: 2px solid #1f2937; padding-bottom: 18px; margin-bottom: 24px; }
+    h1 { margin: 0; font-size: 34px; }
+    h2 { font-size: 16px; margin-top: 0; color: #667085; text-transform: uppercase; letter-spacing: .04em; }
+    table { width: 100%; border-collapse: collapse; margin-top: 24px; }
+    th, td { padding: 11px; border-bottom: 1px solid #d6d9df; text-align: left; }
+    th { background: #f2f4f7; }
+    .right { text-align: right; }
+    .totals { margin-left: auto; width: 320px; }
+    .actions { max-width: 860px; margin: 20px auto; display: flex; gap: 8px; }
+    .button { display: inline-flex; padding: 9px 13px; border-radius: 6px; background: #155eef; color: #fff; text-decoration: none; border: 0; font: inherit; cursor: pointer; }
+    .secondary { background: #fff; color: #155eef; border: 1px solid #155eef; }
+    @media print { body { background: #fff; } main { border: 0; margin: 0; max-width: none; } .actions { display: none; } }
+  </style>
+</head>
+<body>
+  <div class="actions">
+    <button class="button" onclick="window.print()">Print</button>
+    <a class="button secondary" href="{{ url_for('invoices') }}">Back</a>
+  </div>
+  <main>
+    <header>
+      <div>
+        <h1>Invoice</h1>
+        <p><strong>{{ invoice.invoice_number }}</strong></p>
+      </div>
+      <div>
+        <p><strong>Issue date:</strong> {{ invoice.issue_date }}</p>
+        {% if invoice.due_date %}<p><strong>Due date:</strong> {{ invoice.due_date }}</p>{% endif %}
+      </div>
+    </header>
+    <section>
+      <h2>Bill to</h2>
+      <p><strong>{{ invoice.client_name }}</strong><br>
+      {% if invoice.client_email %}{{ invoice.client_email }}<br>{% endif %}
+      {{ invoice.client_address or "" }}</p>
+    </section>
+    <table>
+      <thead><tr><th>Description</th><th class="right">Qty</th><th class="right">Unit price</th><th class="right">Amount</th></tr></thead>
+      <tbody>
+        {% for item in items %}
+          <tr>
+            <td>{{ item.description }}</td>
+            <td class="right">{{ item.quantity }}</td>
+            <td class="right">{{ item.unit_price }}</td>
+            <td class="right">{{ "%.2f"|format(item.quantity|float * item.unit_price|float) }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+    <table class="totals">
+      <tr><th>Subtotal</th><td class="right">{{ "%.2f"|format(totals.subtotal) }}</td></tr>
+      <tr><th>Tax ({{ invoice.tax_rate }}%)</th><td class="right">{{ "%.2f"|format(totals.tax) }}</td></tr>
+      <tr><th>Total</th><td class="right"><strong>{{ "%.2f"|format(totals.total) }}</strong></td></tr>
+    </table>
+    {% if invoice.notes %}
+      <section>
+        <h2>Notes</h2>
+        <p>{{ invoice.notes }}</p>
+      </section>
+    {% endif %}
+  </main>
+</body>
+</html>
