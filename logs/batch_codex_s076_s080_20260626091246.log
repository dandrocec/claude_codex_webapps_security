@@ -0,0 +1,38 @@
+<%- include("partials/header", { title: "New order" }) %>
+<section class="section-heading">
+  <div>
+    <h1>Process order</h1>
+    <p>Only positive quantities are included. Fulfilled orders decrement stock immediately.</p>
+  </div>
+</section>
+
+<form method="post" action="/orders" class="panel">
+  <table>
+    <thead>
+      <tr>
+        <th>Include</th>
+        <th>SKU</th>
+        <th>Product</th>
+        <th>Available</th>
+        <th>Quantity to fulfill</th>
+      </tr>
+    </thead>
+    <tbody>
+      <% products.forEach((product) => { %>
+        <tr>
+          <td><input type="checkbox" name="product_id" value="<%= product.id %>"></td>
+          <td><%= product.sku %></td>
+          <td><%= product.name %></td>
+          <td><%= product.quantity %></td>
+          <td><input type="number" min="0" name="quantity_<%= product.id %>" value="0"></td>
+        </tr>
+      <% }) %>
+    </tbody>
+  </table>
+  <label class="full">
+    Note
+    <input name="note" placeholder="Optional order note">
+  </label>
+  <button type="submit">Fulfill order</button>
+</form>
+<%- include("partials/footer") %>
diff --git a/src/views/orders.ejs b/src/views/orders.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..f861064f6c105340cfbaa79be615dc638c2412d7
--- /dev/null
+++ b/src/views/orders.ejs
@@ -0,0 +1,51 @@
+<%- include("partials/header", { title: "Orders" }) %>
+<section class="section-heading">
+  <div>
+    <h1>Orders</h1>
+    <p>Rejected orders do not decrement stock.</p>
+  </div>
+  <a class="button" href="/orders/new">New order</a>
+</section>
+
+<% if (orders.length === 0) { %>
+  <p class="muted">No orders have been processed.</p>
+<% } %>
+
+<div class="orders">
+  <% orders.forEach((order) => { %>
+    <article class="order-card">
+      <div class="order-card-header">
+        <h2>Order #<%= order.id %></h2>
+        <span class="pill <%= order.status === "fulfilled" ? "ok" : "danger" %>"><%= order.status %></span>
+      </div>
+      <p class="muted">Processed by <%= order.username %> on <%= order.created_at %></p>
+      <% if (order.note) { %><p><%= order.note %></p><% } %>
+      <% const items = itemsByOrder[order.id] || []; %>
+      <% if (items.length > 0) { %>
+        <table>
+          <thead>
+            <tr>
+              <th>SKU</th>
+              <th>Product</th>
+              <th>Qty</th>
+              <th>Before</th>
+              <th>After</th>
+            </tr>
+          </thead>
+          <tbody>
+            <% items.forEach((item) => { %>
+              <tr>
+                <td><%= item.sku %></td>
+                <td><%= item.name %></td>
+                <td><%= item.quantity %></td>
+                <td><%= item.stock_before %></td>
+                <td><%= item.stock_after %></td>
+              </tr>
+            <% }) %>
+          </tbody>
+        </table>
+      <% } %>
+    </article>
+  <% }) %>
+</div>
+<%- include("partials/footer") %>
