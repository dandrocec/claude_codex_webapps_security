+  gap: 1rem;
+  flex-wrap: wrap;
+}
+
+.message p {
+  margin: 0.35rem 0 0;
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+}
+
+.composer {
+  margin-top: 1rem;
+}
+
+@media (max-width: 760px) {
+  .grid,
+  .room-heading,
+  .room-card {
+    grid-template-columns: 1fr;
+    display: grid;
+  }
+
+  .topbar {
+    align-items: flex-start;
+    flex-direction: column;
+  }
