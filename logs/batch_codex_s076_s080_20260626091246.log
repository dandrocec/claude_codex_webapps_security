+++ b/static/styles.css
@@ -0,0 +1,255 @@
+:root {
+  color-scheme: light;
+  --bg: #f7f8fa;
+  --panel: #ffffff;
+  --text: #20242a;
+  --muted: #667085;
+  --line: #d9dee7;
+  --accent: #146c5c;
+  --accent-dark: #0f5146;
+  --danger: #a33b3b;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font: 16px/1.55 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+  padding: 16px 28px;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  color: var(--text);
+  font-size: 20px;
+  font-weight: 700;
+}
+
+.topbar nav {
+  display: flex;
+  align-items: center;
+  gap: 16px;
+  flex-wrap: wrap;
+}
+
+.user,
+.page-head p,
+.page-row p,
+.revision-row p {
+  color: var(--muted);
+}
+
+.container {
+  width: min(1040px, calc(100% - 32px));
+  margin: 32px auto;
+}
+
+.page-head {
+  display: flex;
+  justify-content: space-between;
+  align-items: flex-start;
+  gap: 24px;
+  margin-bottom: 24px;
+}
+
+h1,
+h2,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  margin-bottom: 6px;
+  font-size: clamp(30px, 5vw, 44px);
+  line-height: 1.1;
+}
+
+h2 {
+  margin-bottom: 4px;
+  font-size: 20px;
+}
+
+.page-list,
+.history,
+.messages {
+  display: grid;
+  gap: 12px;
+}
+
+.page-row,
+.revision-row,
+.empty,
+.narrow,
+.wiki-body,
+.note {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.page-row,
+.revision-row {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 18px;
+}
+
+.badge {
+  display: inline-flex;
+  align-items: center;
+  min-height: 28px;
+  padding: 4px 10px;
+  border-radius: 999px;
+  background: #fff2cc;
+  color: #684d00;
+  font-size: 13px;
+  font-weight: 700;
+  white-space: nowrap;
+}
+
+.badge.inline {
+  margin-left: 8px;
+}
+
+.button,
+button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 40px;
+  border: 0;
+  border-radius: 6px;
+  padding: 9px 14px;
+  background: var(--accent);
+  color: #ffffff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.secondary,
+button.secondary {
+  background: #eef1f4;
+  color: var(--text);
+}
+
+.actions {
+  display: flex;
+  gap: 10px;
+  align-items: center;
+  flex-wrap: wrap;
+}
+
+.form {
+  display: grid;
+  gap: 16px;
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.form label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+.form input,
+.form select,
+.form textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 10px 12px;
+  color: var(--text);
+  font: inherit;
+}
+
+.form textarea {
+  resize: vertical;
+}
+
+.check {
+  display: flex !important;
+  grid-template-columns: auto 1fr;
+  align-items: center;
+  gap: 10px !important;
+}
+
+.check input {
+  width: auto;
+}
+
+.narrow {
+  max-width: 560px;
+}
+
+.wiki-body {
+  min-height: 220px;
+  white-space: pre-wrap;
+}
+
+.message {
+  border-radius: 6px;
+  padding: 10px 12px;
+  background: #eaf6f1;
+  color: #164d3c;
+}
+
+.message.error {
+  background: #fae9e9;
+  color: var(--danger);
+}
+
+.note {
+  color: var(--muted);
+}
+
+@media (max-width: 720px) {
+  .topbar,
+  .page-head,
+  .page-row,
+  .revision-row {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .topbar nav,
+  .actions {
+    align-items: stretch;
+  }
+
+  .button,
+  button {
+    width: 100%;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..c528e05eed0754b3ff627edc6010b3cc160e6641
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Wiki{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Wiki</a>
+    <nav>
+      {% if is_editor %}
+        <a href="{{ url_for('new_page') }}">New page</a>
+      {% endif %}
+      <span class="user">{{ current_user.name }} · {{ current_user.role }}</span>
+      {% if session.get("name") %}
+        <a href="{{ url_for('logout') }}">Sign out</a>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages">
+          {% for category, message in messages %}
+            <div class="message {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/edit.html b/templates/edit.html
new file mode 100644
index 0000000000000000000000000000000000000000..27c5463d3798d76f934496ce653d224f310323b1
--- /dev/null
+++ b/templates/edit.html
@@ -0,0 +1,37 @@
+{% extends "base.html" %}
+
+{% block title %}{{ "Edit" if page else "New page" }} · Wiki{% endblock %}
+
+{% block content %}
+  <section class="page-head">
+    <div>
+      <h1>{{ "Edit page" if page else "New page" }}</h1>
+      {% if page %}
+        <p>Saving creates a new revision.</p>
+      {% endif %}
+    </div>
+    {% if page %}
+      <a class="button secondary" href="{{ url_for('view_page', slug=page.slug) }}">Cancel</a>
+    {% endif %}
+  </section>
+
+  <form method="post" class="form editor-form">
+    <label>
+      Title
+      <input name="title" required value="{{ request.form.title or revision.title if revision else request.form.title }}">
+    </label>
+    <label>
+      Body
+      <textarea name="body" rows="18">{{ request.form.body or revision.body if revision else request.form.body }}</textarea>
+    </label>
+    <label>
+      Revision note
+      <input name="note" value="{{ request.form.note }}" placeholder="What changed?">
+    </label>
+    <label class="check">
+      <input type="checkbox" name="editor_only" {% if request.form.editor_only or (page and page.editor_only) %}checked{% endif %}>
+      Editor-only page
+    </label>
+    <button type="submit">Save revision</button>
+  </form>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
