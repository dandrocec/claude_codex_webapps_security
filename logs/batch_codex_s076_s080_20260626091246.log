+}
+
+.page-list li:first-child {
+  border-top: 0;
+}
+
+.badge {
+  background: #f0eee6;
+  border: 1px solid #d4c9a6;
+  border-radius: 999px;
+  color: #5a4b17;
+  display: inline-block;
+  font-size: 12px;
