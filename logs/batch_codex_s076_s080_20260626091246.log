diff --git a/templates/invoice_form.html b/templates/invoice_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..f79c208055d5024068b629c4625d7ef855285a71
--- /dev/null
+++ b/templates/invoice_form.html
@@ -0,0 +1,60 @@
+{% extends "base.html" %}
+{% block title %}{{ "Edit invoice" if invoice else "New invoice" }}{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>{{ "Edit invoice" if invoice else "New invoice" }}</h1>
+  <form method="post" class="stack invoice-form">
+    <div class="grid two">
+      <label>Client
+        <select name="client_id" required>
+          {% for client in clients %}
+            <option value="{{ client.id }}" {% if invoice and invoice.client_id == client.id %}selected{% endif %}>{{ client.name }}</option>
+          {% endfor %}
+        </select>
+      </label>
+      <label>Invoice number
+        <input name="invoice_number" required value="{{ invoice.invoice_number if invoice else 'INV-' ~ today.replace('-', '') }}">
+      </label>
+      <label>Issue date
+        <input type="date" name="issue_date" required value="{{ invoice.issue_date if invoice else today }}">
+      </label>
+      <label>Due date
+        <input type="date" name="due_date" value="{{ invoice.due_date if invoice else '' }}">
+      </label>
+      <label>Status
+        <select name="status">
+          {% for status in ["draft", "sent", "paid", "overdue"] %}
+            <option value="{{ status }}" {% if invoice and invoice.status == status %}selected{% endif %}>{{ status.title() }}</option>
+          {% endfor %}
+        </select>
+      </label>
+      <label>Tax rate %
+        <input type="number" name="tax_rate" min="0" step="0.01" value="{{ invoice.tax_rate if invoice else '0.00' }}">
+      </label>
+    </div>
+
+    <div class="line-editor">
+      <div class="line-head"><span>Description</span><span>Qty</span><span>Unit price</span></div>
+      {% for line in lines %}
+        <div class="line-row">
+          <input name="description" placeholder="Design services" value="{{ line.description or '' }}">
+          <input name="quantity" type="number" min="0" step="0.01" value="{{ line.quantity or '1.00' }}">
+          <input name="unit_price" type="number" min="0" step="0.01" value="{{ (line.unit_price_cents / 100) if line.unit_price_cents else '' }}">
+        </div>
+      {% endfor %}
+      {% for _ in range(4) %}
+        <div class="line-row">
+          <input name="description" placeholder="Additional item">
+          <input name="quantity" type="number" min="0" step="0.01" value="1.00">
+          <input name="unit_price" type="number" min="0" step="0.01">
+        </div>
+      {% endfor %}
+    </div>
+
+    <label>Notes
+      <textarea name="notes" rows="4">{{ invoice.notes if invoice else '' }}</textarea>
+    </label>
+    <button class="button" type="submit">Save invoice</button>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/invoice_print.html b/templates/invoice_print.html
new file mode 100644
index 0000000000000000000000000000000000000000..8323e298edf9cd13c3cc6b07b05200de036df18a
--- /dev/null
+++ b/templates/invoice_print.html
@@ -0,0 +1,64 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>Invoice {{ invoice.invoice_number }}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
+</head>
+<body class="print-body">
+  <main class="invoice-page">
+    <div class="print-actions">
+      <a href="{{ url_for('invoices') }}">Back</a>
+      <a href="{{ url_for('invoice_edit', invoice_id=invoice.id) }}">Edit</a>
+      <button onclick="window.print()">Print</button>
+    </div>
+    <header class="invoice-header">
+      <div>
+        <p class="eyebrow">Invoice</p>
+        <h1>{{ invoice.invoice_number }}</h1>
+      </div>
+      <div class="invoice-meta">
+        <p><strong>Issued:</strong> {{ invoice.issue_date }}</p>
+        <p><strong>Due:</strong> {{ invoice.due_date or "-" }}</p>
+        <p><strong>Status:</strong> {{ invoice.status.title() }}</p>
+      </div>
+    </header>
+
+    <section class="bill-to">
+      <p class="eyebrow">Bill to</p>
+      <h2>{{ client.name }}</h2>
+      <p>{{ client.email }}</p>
+      <p>{{ client.address|replace('\n', '<br>')|safe }}</p>
+      {% if client.tax_id %}<p>Tax ID: {{ client.tax_id }}</p>{% endif %}
+    </section>
+
+    <table class="print-table">
+      <thead><tr><th>Description</th><th>Qty</th><th>Unit</th><th>Total</th></tr></thead>
+      <tbody>
+        {% for line in lines %}
+          <tr>
+            <td>{{ line.description }}</td>
+            <td>{{ line.quantity }}</td>
+            <td>{{ line.unit_price_cents|money }}</td>
+            <td>{{ line.line_total_cents|money }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+
+    <section class="totals">
+      <p><span>Subtotal</span><strong>{{ invoice.subtotal_cents|money }}</strong></p>
+      <p><span>Tax {{ invoice.tax_rate }}%</span><strong>{{ invoice.tax_cents|money }}</strong></p>
+      <p class="grand"><span>Total</span><strong>{{ invoice.total_cents|money }}</strong></p>
+    </section>
+
+    {% if invoice.notes %}
+      <section class="notes">
+        <p class="eyebrow">Notes</p>
+        <p>{{ invoice.notes }}</p>
+      </section>
+    {% endif %}
+  </main>
+</body>
+</html>
