+              </form>
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p class="muted">No invoices yet. Create a client first, then add an invoice.</p>
+  {% endif %}
+</section>
+{% endblock %}
