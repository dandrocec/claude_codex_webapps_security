diff --git a/static/style.css b/static/style.css
new file mode 100644
index 0000000000000000000000000000000000000000..07559a92b541920935d5ae2dba98ce80ddb6bd8d
--- /dev/null
+++ b/static/style.css
@@ -0,0 +1,223 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1d2430;
+  --muted: #5e6877;
+  --line: #d8dde5;
+  --accent: #1f6f5f;
+  --accent-dark: #155448;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  font-weight: 600;
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 14px 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 20px;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 28px 18px;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 24px;
+}
+
+.narrow {
+  max-width: 460px;
+}
+
+h1 {
+  font-size: 28px;
+  line-height: 1.2;
+  margin: 0 0 18px;
+}
+
+form {
+  display: grid;
+  gap: 16px;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+.check {
+  align-items: center;
+  display: flex;
+  gap: 8px;
+}
+
+input,
+textarea,
+button {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  padding: 10px 12px;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button {
+  background: var(--accent);
+  border-color: var(--accent);
+  color: white;
+  cursor: pointer;
+  font-weight: 700;
+}
+
+button:hover {
+  background: var(--accent-dark);
+}
+
+.page-list {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.page-list li {
+  border-top: 1px solid var(--line);
+  display: grid;
+  gap: 4px;
+  padding: 14px 0;
+}
+
+.page-list li:first-child {
+  border-top: 0;
+}
+
+.badge {
+  background: #f0eee6;
+  border: 1px solid #d4c9a6;
+  border-radius: 999px;
+  color: #5a4b17;
+  display: inline-block;
+  font-size: 12px;
+  font-weight: 700;
+  margin-left: 6px;
+  padding: 2px 8px;
+  vertical-align: middle;
+}
+
+.page-head {
+  align-items: flex-start;
+  display: flex;
+  justify-content: space-between;
+  gap: 18px;
+}
+
+.actions {
+  display: flex;
+  gap: 12px;
+}
+
+.wiki-content {
+  background: #fbfbfc;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  overflow: auto;
+  padding: 16px;
+  white-space: pre-wrap;
+  word-break: break-word;
+}
+
+.meta,
+small {
+  color: var(--muted);
+}
+
+.flash {
+  background: #fff8d8;
+  border: 1px solid #e5d27d;
+  border-radius: 8px;
+  margin-bottom: 18px;
+  padding: 10px 14px;
+}
+
+.flash p {
+  margin: 0;
+}
+
+table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-top: 1px solid var(--line);
+  padding: 10px;
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  color: var(--muted);
+  font-size: 13px;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .page-head {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..929b3950bac6910aa13e9e3ebdc3a54b4be334a5
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,41 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Flask Wiki{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Flask Wiki</a>
+    <nav>
+      {% if current_user() %}
+        <span>{{ current_user().username }} ({{ current_user().role }})</span>
+        {% if current_user().role == "editor" %}
+          <a href="{{ url_for('new_page') }}">New page</a>
+        {% endif %}
+        <form class="inline" method="post" action="{{ url_for('logout') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages() %}
+      {% if messages %}
+        <div class="flash">
+          {% for message in messages %}
+            <p>{{ message }}</p>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..5387c56593bf218726b4d97a7437284222484370
--- /dev/null
+++ b/templates/error.html
@@ -0,0 +1,8 @@
+{% extends "base.html" %}
+{% block title %}Error - Flask Wiki{% endblock %}
+{% block content %}
+  <section class="panel narrow">
+    <h1>Request failed</h1>
+    <p>{{ message }}</p>
+  </section>
+{% endblock %}
diff --git a/templates/history.html b/templates/history.html
new file mode 100644
index 0000000000000000000000000000000000000000..f05ee822f020df2ad2c6da558192ab1b94d8b0dd
--- /dev/null
+++ b/templates/history.html
@@ -0,0 +1,32 @@
+{% extends "base.html" %}
+{% block title %}History for {{ page.title }} - Flask Wiki{% endblock %}
+{% block content %}
+  <section class="panel">
+    <div class="page-head">
+      <h1>History for {{ page.title }}</h1>
+      <a href="{{ url_for('view_page', slug=page.slug) }}">Back to page</a>
+    </div>
+    <table>
+      <thead>
+        <tr>
+          <th>Revision</th>
+          <th>Edited</th>
+          <th>Editor</th>
+          <th>Summary</th>
+          <th></th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for revision in revisions %}
+          <tr>
+            <td>{{ revision.revision_number }}</td>
+            <td>{{ revision.edited_at }}</td>
+            <td>{{ revision.edited_by_name }}</td>
+            <td>{{ revision.summary }}</td>
+            <td><a href="{{ url_for('revision', slug=page.slug, revision_id=revision.id) }}">View</a></td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
