diff --git a/views/partials/header.ejs b/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..d86a97dccdf3a88923f9e1ccdf5958f7e28d010a
--- /dev/null
+++ b/views/partials/header.ejs
@@ -0,0 +1,35 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>Secure Chat</title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="/rooms">Secure Chat</a>
+    <nav>
+      <% if (currentUser) { %>
+        <span class="user"><%= currentUser.username %></span>
+        <form class="inline" method="post" action="/logout">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Sign out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Sign in</a>
+        <a href="/register">Register</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="shell">
+    <% if (errors && errors.length) { %>
+      <section class="notice error">
+        <% errors.forEach(function(error) { %><p><%= error %></p><% }) %>
+      </section>
+    <% } %>
+    <% if (info && info.length) { %>
+      <section class="notice">
+        <% info.forEach(function(message) { %><p><%= message %></p><% }) %>
+      </section>
+    <% } %>
diff --git a/views/register.ejs b/views/register.ejs
new file mode 100644
