+  padding: 2px 8px;
+  vertical-align: middle;
+}
+
+.page-head {
+  align-items: flex-start;
+  display: flex;
+  justify-content: space-between;
+  gap: 18px;
+}
+
+.actions {
+  display: flex;
+  gap: 12px;
+}
+
+.wiki-content {
+  background: #fbfbfc;
+  border: 1px solid var(--line);
+  border-radius: 6px;
