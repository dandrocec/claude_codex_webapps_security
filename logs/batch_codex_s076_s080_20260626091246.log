+  position: sticky;
+  top: 1rem;
+}
+
+.room-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.room-card {
+  display: grid;
+  gap: 1rem;
+  grid-template-columns: 1fr auto;
+  padding: 1.25rem;
+  text-decoration: none;
+}
+
+.room-card:hover {
+  border-color: var(--accent);
+}
+
+.room-card p,
+.empty p,
+.chat-header p {
+  color: var(--muted);
+  margin-bottom: 0;
+}
+
+dl {
+  display: flex;
+  gap: 1rem;
+  margin: 0;
+  text-align: right;
+}
+
+dt {
+  color: var(--muted);
+  font-size: 0.75rem;
