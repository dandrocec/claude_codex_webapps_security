@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+{% block title %}{{ page.title }} - Flask Wiki{% endblock %}
+{% block content %}
+  <article class="panel">
+    <div class="page-head">
+      <div>
+        <h1>{{ page.title }}</h1>
+        {% if page.editor_only %}<span class="badge">editor-only</span>{% endif %}
+      </div>
+      <div class="actions">
+        <a href="{{ url_for('history', slug=page.slug) }}">History</a>
+        {% if current_user() and current_user().role == "editor" %}
+          <a href="{{ url_for('edit_page', slug=page.slug) }}">Edit</a>
+        {% endif %}
+      </div>
+    </div>
+    <pre class="wiki-content">{{ page.content }}</pre>
+    <footer class="meta">
+      Created by {{ page.created_by_name }} on {{ page.created_at }}.
+      Last updated by {{ page.updated_by_name }} on {{ page.updated_at }}.
+    </footer>
+  </article>
+{% endblock %}
