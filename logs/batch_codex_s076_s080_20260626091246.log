@@ -0,0 +1,18 @@
+<%- include("partials/header") %>
+<section class="panel narrow">
+  <h1>Sign in</h1>
+  <form method="post" action="/login" autocomplete="on">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>
+      Username
+      <input name="username" type="text" maxlength="30" required autocomplete="username">
+    </label>
+    <label>
+      Password
+      <input name="password" type="password" maxlength="128" required autocomplete="current-password">
+    </label>
+    <button type="submit">Sign in</button>
+  </form>
+  <p class="muted">Need an account? <a href="/register">Register</a></p>
+</section>
+<%- include("partials/footer") %>
