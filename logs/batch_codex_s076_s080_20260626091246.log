+:root {
+  color-scheme: light;
+  --bg: #f4f6f8;
+  --panel: #ffffff;
+  --text: #1c2430;
+  --muted: #667085;
+  --border: #d9dee7;
+  --accent: #2364aa;
+  --danger: #b42318;
+  --success: #067647;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 14px 24px;
+  background: #172033;
+  color: white;
+}
+
+.brand {
+  color: white;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  display: flex;
+  gap: 14px;
+  align-items: center;
+}
+
+nav a {
+  color: white;
+  text-decoration: none;
+}
+
+.page {
+  max-width: 1120px;
+  margin: 0 auto;
+  padding: 28px 18px;
+}
+
+.heading {
+  display: flex;
+  justify-content: space-between;
+  align-items: end;
+  margin-bottom: 18px;
+}
+
+.heading h1,
+.panel h1,
+.panel h2 {
+  margin-top: 0;
+}
+
+.heading p {
+  margin: 4px 0 0;
+  color: var(--muted);
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
+  gap: 18px;
+  margin-bottom: 18px;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.narrow {
+  max-width: 460px;
+  margin: 40px auto;
+}
+
+form {
+  display: grid;
+  gap: 12px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  color: var(--muted);
+  font-size: 0.94rem;
+}
+
+input,
+select,
+button,
+.button {
+  min-height: 40px;
+  border-radius: 6px;
+  border: 1px solid var(--border);
+  padding: 8px 10px;
+  font: inherit;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border-color: var(--accent);
+  color: white;
+  cursor: pointer;
+  text-decoration: none;
+  text-align: center;
+}
+
+button:disabled {
+  opacity: 0.55;
+  cursor: not-allowed;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--border);
+  padding: 10px 8px;
+  text-align: left;
+  vertical-align: middle;
+}
+
+th {
+  color: var(--muted);
+  font-weight: 600;
+}
+
+.inline {
+  display: inline-grid;
+  grid-auto-flow: column;
+  gap: 8px;
+  align-items: center;
+}
+
+nav .inline button {
+  min-height: 32px;
+  background: transparent;
+  border-color: rgba(255, 255, 255, 0.45);
+}
+
+.row-form {
+  grid-template-columns: 1fr 2fr 110px auto;
+  margin-bottom: 16px;
+}
+
+.edit-stock {
+  grid-template-columns: 90px auto;
+}
+
+.errors {
+  color: var(--danger);
+  background: #fff0ed;
+  border: 1px solid #ffdad4;
+  border-radius: 8px;
+  padding: 12px 12px 12px 28px;
+}
+
+.flash {
+  border-radius: 8px;
+  padding: 12px;
+  margin-bottom: 18px;
+  border: 1px solid var(--border);
+  background: white;
+}
+
+.flash.success {
+  color: var(--success);
+  border-color: #abefc6;
+  background: #ecfdf3;
+}
+
+.flash.error {
+  color: var(--danger);
+  border-color: #ffdad4;
+  background: #fff0ed;
+}
+
+dl {
+  display: grid;
+  grid-template-columns: 120px 1fr;
+  gap: 10px;
+}
+
+dt {
+  color: var(--muted);
+}
+
+dd {
+  margin: 0;
+}
+
+@media (max-width: 760px) {
+  .topbar,
+  nav,
+  .heading {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .grid,
+  .row-form {
+    grid-template-columns: 1fr;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/src/views/dashboard.ejs b/src/views/dashboard.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..76eb9134159283b9a5a362195f569fa8e4beacec
--- /dev/null
+++ b/src/views/dashboard.ejs
@@ -0,0 +1,90 @@
+<%- include('partials/header') %>
+<section class="heading">
+  <div>
+    <h1>Stock</h1>
+    <p>Signed in as <%= currentUser.username %> (<%= currentUser.role %>)</p>
+  </div>
+</section>
+
+<% if (errors.length) { %>
+  <ul class="errors">
+    <% errors.forEach((error) => { %><li><%= error %></li><% }) %>
+  </ul>
+<% } %>
+
+<section class="grid">
+  <div class="panel">
+    <h2>Inventory</h2>
+    <% if (currentUser.role === 'manager') { %>
+      <form method="post" action="/items" class="row-form">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <input name="sku" placeholder="SKU" required maxlength="40">
+        <input name="name" placeholder="Item name" required maxlength="120">
+        <input name="quantity" type="number" min="0" max="1000000" required placeholder="Qty">
+        <button type="submit">Add</button>
+      </form>
+    <% } %>
+    <table>
+      <thead>
+        <tr><th>SKU</th><th>Name</th><th>Qty</th><th></th></tr>
+      </thead>
+      <tbody>
+        <% items.forEach((item) => { %>
+          <tr>
+            <td><%= item.sku %></td>
+            <td><%= item.name %></td>
+            <td><%= item.quantity %></td>
+            <td>
+              <% if (currentUser.role === 'manager') { %>
+                <form method="post" action="/items/<%= item.id %>" class="inline edit-stock">
+                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+                  <input name="quantity" type="number" min="0" max="1000000" value="<%= item.quantity %>" required>
+                  <button type="submit">Update</button>
+                </form>
+              <% } %>
+            </td>
+          </tr>
+        <% }) %>
+      </tbody>
+    </table>
+  </div>
+
+  <div class="panel">
+    <h2>Fulfill order</h2>
+    <form method="post" action="/orders">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <label>Item
+        <select name="itemId" required>
+          <% items.forEach((item) => { %>
+            <option value="<%= item.id %>"><%= item.sku %> - <%= item.name %> (<%= item.quantity %> available)</option>
+          <% }) %>
+        </select>
+      </label>
+      <label>Quantity
+        <input name="quantity" type="number" min="1" max="1000000" required>
+      </label>
+      <button type="submit" <%= items.length ? '' : 'disabled' %>>Fulfill</button>
+    </form>
+  </div>
+</section>
+
+<section class="panel">
+  <h2>Recent orders</h2>
+  <table>
+    <thead>
+      <tr><th>Order</th><th>Created</th><th>User</th><th>Item</th><th>Qty</th></tr>
+    </thead>
+    <tbody>
+      <% orders.forEach((order) => { %>
+        <tr>
+          <td><a href="/orders/<%= order.id %>">#<%= order.id %></a></td>
+          <td><%= order.created_at %></td>
+          <td><%= order.username %></td>
+          <td><%= order.sku %> - <%= order.name %></td>
+          <td><%= order.quantity %></td>
+        </tr>
+      <% }) %>
+    </tbody>
+  </table>
+</section>
+<%- include('partials/footer') %>
