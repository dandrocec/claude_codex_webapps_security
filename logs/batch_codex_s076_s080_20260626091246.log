diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..b1b571119d5d789de19f97017b40cd89294cb7a6
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,63 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{{ title or "Invoices" }}</title>
+  <style>
+    :root { color-scheme: light; --border: #d6d9df; --ink: #1f2937; --muted: #667085; --accent: #155eef; --danger: #b42318; }
+    * { box-sizing: border-box; }
+    body { margin: 0; font-family: Arial, sans-serif; color: var(--ink); background: #f6f7f9; }
+    a { color: var(--accent); text-decoration: none; }
+    header { background: #fff; border-bottom: 1px solid var(--border); }
+    nav { max-width: 1040px; margin: 0 auto; padding: 14px 20px; display: flex; gap: 18px; align-items: center; }
+    nav .brand { font-weight: 700; color: var(--ink); margin-right: auto; }
+    main { max-width: 1040px; margin: 0 auto; padding: 28px 20px; }
+    .panel { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px; }
+    .topline { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 18px; }
+    h1 { font-size: 28px; margin: 0 0 18px; }
+    h2 { font-size: 20px; margin: 0 0 12px; }
+    label { display: block; font-weight: 700; margin: 14px 0 6px; }
+    input, textarea, select { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 6px; font: inherit; background: #fff; }
+    textarea { min-height: 92px; resize: vertical; }
+    table { width: 100%; border-collapse: collapse; background: #fff; }
+    th, td { padding: 12px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; }
+    th { color: var(--muted); font-size: 13px; text-transform: uppercase; letter-spacing: .03em; }
+    .actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
+    .button, button { display: inline-flex; align-items: center; justify-content: center; min-height: 38px; padding: 9px 13px; border: 1px solid var(--accent); border-radius: 6px; background: var(--accent); color: #fff; font: inherit; cursor: pointer; }
+    .button.secondary, button.secondary { background: #fff; color: var(--accent); }
+    button.danger { background: var(--danger); border-color: var(--danger); }
+    .flash { padding: 11px 12px; border-radius: 6px; margin-bottom: 14px; background: #fff4ed; border: 1px solid #f9dbaf; color: #9c2a10; }
+    .success { background: #ecfdf3; border-color: #abefc6; color: #067647; }
+    .muted { color: var(--muted); }
+    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
+    .line-grid { display: grid; grid-template-columns: 1fr 120px 140px; gap: 10px; align-items: end; }
+    form.inline { display: inline; }
+    @media (max-width: 720px) { nav { flex-wrap: wrap; } .grid, .line-grid { grid-template-columns: 1fr; } table { display: block; overflow-x: auto; } }
+  </style>
+</head>
+<body>
+  <header>
+    <nav>
+      <a class="brand" href="{{ url_for('index') }}">Invoice Desk</a>
+      {% if g.user %}
+        <a href="{{ url_for('clients') }}">Clients</a>
+        <a href="{{ url_for('invoices') }}">Invoices</a>
+        <form class="inline" action="{{ url_for('logout') }}" method="post">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button class="secondary" type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main>
+    {% for category, message in get_flashed_messages(with_categories=true) %}
+      <div class="flash {{ category }}">{{ message }}</div>
+    {% endfor %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/client_form.html b/templates/client_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..6b6d4c17678cb1c66fcbf5be0193fd07bb2a9802
--- /dev/null
+++ b/templates/client_form.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="panel">
+  <h1>{{ "Edit client" if client else "New client" }}</h1>
+  <form method="post">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label for="name">Name</label>
+    <input id="name" name="name" required maxlength="120" value="{{ client.name if client else '' }}">
+    <label for="email">Email</label>
+    <input id="email" name="email" type="email" maxlength="254" value="{{ client.email if client else '' }}">
+    <label for="address">Address</label>
+    <textarea id="address" name="address" maxlength="1000">{{ client.address if client else '' }}</textarea>
+    <p class="actions">
+      <button type="submit">Save client</button>
+      <a class="button secondary" href="{{ url_for('clients') }}">Cancel</a>
+    </p>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/clients.html b/templates/clients.html
new file mode 100644
index 0000000000000000000000000000000000000000..db7f4e72d5651af2eb7032d174fe0d9de6f7f694
--- /dev/null
+++ b/templates/clients.html
@@ -0,0 +1,32 @@
+{% extends "base.html" %}
+{% block content %}
+<div class="topline">
+  <h1>Clients</h1>
+  <a class="button" href="{{ url_for('client_new') }}">New client</a>
+</div>
+<section class="panel">
+  {% if clients %}
+    <table>
+      <thead><tr><th>Name</th><th>Email</th><th>Address</th><th>Actions</th></tr></thead>
+      <tbody>
+        {% for client in clients %}
+          <tr>
+            <td>{{ client.name }}</td>
+            <td>{{ client.email or "" }}</td>
+            <td>{{ client.address or "" }}</td>
+            <td class="actions">
+              <a class="button secondary" href="{{ url_for('client_edit', client_id=client.id) }}">Edit</a>
+              <form class="inline" method="post" action="{{ url_for('client_delete', client_id=client.id) }}">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <button class="danger" type="submit">Delete</button>
+              </form>
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p class="muted">No clients yet.</p>
+  {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..0c2d7b9647231660f6615a633c4b212c163e692a
--- /dev/null
+++ b/templates/error.html
@@ -0,0 +1,8 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="panel">
+  <h1>{{ title }}</h1>
+  <p>{{ message }}</p>
+  <a class="button secondary" href="{{ url_for('index') }}">Go back</a>
+</section>
+{% endblock %}
diff --git a/templates/invoice_form.html b/templates/invoice_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..58b4207e975fee9cd99722825b4338409723849c
--- /dev/null
+++ b/templates/invoice_form.html
@@ -0,0 +1,70 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="panel">
+  <h1>{{ "Edit invoice" if invoice else "New invoice" }}</h1>
+  {% if not clients %}
+    <p>Create a client before adding invoices.</p>
+    <a class="button" href="{{ url_for('client_new') }}">New client</a>
+  {% else %}
+    <form method="post">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <div class="grid">
+        <div>
+          <label for="client_id">Client</label>
+          <select id="client_id" name="client_id" required>
+            {% for client in clients %}
+              <option value="{{ client.id }}" {% if invoice and invoice.client_id == client.id %}selected{% endif %}>{{ client.name }}</option>
+            {% endfor %}
+          </select>
+        </div>
+        <div>
+          <label for="invoice_number">Invoice number</label>
+          <input id="invoice_number" name="invoice_number" required maxlength="40" value="{{ invoice.invoice_number if invoice else '' }}">
+        </div>
+        <div>
+          <label for="issue_date">Issue date</label>
+          <input id="issue_date" name="issue_date" type="date" required value="{{ invoice.issue_date if invoice else '' }}">
+        </div>
+        <div>
+          <label for="due_date">Due date</label>
+          <input id="due_date" name="due_date" type="date" value="{{ invoice.due_date if invoice else '' }}">
+        </div>
+        <div>
+          <label for="tax_rate">Tax rate (%)</label>
+          <input id="tax_rate" name="tax_rate" inputmode="decimal" required value="{{ invoice.tax_rate if invoice else '0.00' }}">
+        </div>
+      </div>
+      <h2>Line items</h2>
+      {% for item in items %}
+        <div class="line-grid">
+          <div>
+            <label>Description</label>
+            <input name="description" maxlength="200" value="{{ item.description or '' }}">
+          </div>
+          <div>
+            <label>Quantity</label>
+            <input name="quantity" inputmode="decimal" value="{{ item.quantity or '1.00' }}">
+          </div>
+          <div>
+            <label>Unit price</label>
+            <input name="unit_price" inputmode="decimal" value="{{ item.unit_price or '0.00' }}">
+          </div>
+        </div>
+      {% endfor %}
+      {% for _ in range(4 - items|length) %}
+        <div class="line-grid">
+          <div><label>Description</label><input name="description" maxlength="200"></div>
+          <div><label>Quantity</label><input name="quantity" inputmode="decimal" value="1.00"></div>
+          <div><label>Unit price</label><input name="unit_price" inputmode="decimal" value="0.00"></div>
+        </div>
+      {% endfor %}
+      <label for="notes">Notes</label>
+      <textarea id="notes" name="notes" maxlength="1000">{{ invoice.notes if invoice else '' }}</textarea>
+      <p class="actions">
+        <button type="submit">Save invoice</button>
+        <a class="button secondary" href="{{ url_for('invoices') }}">Cancel</a>
+      </p>
+    </form>
+  {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/invoice_print.html b/templates/invoice_print.html
new file mode 100644
index 0000000000000000000000000000000000000000..cb0cc8344bc256c27c56f95e94bc104cfcffb2fc
--- /dev/null
+++ b/templates/invoice_print.html
@@ -0,0 +1,72 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>Invoice {{ invoice.invoice_number }}</title>
+  <style>
+    body { margin: 0; font-family: Arial, sans-serif; color: #1f2937; background: #f6f7f9; }
+    main { max-width: 860px; margin: 30px auto; padding: 42px; background: #fff; border: 1px solid #d6d9df; }
+    header { display: flex; justify-content: space-between; gap: 20px; border-bottom: 2px solid #1f2937; padding-bottom: 18px; margin-bottom: 24px; }
+    h1 { margin: 0; font-size: 34px; }
+    h2 { font-size: 16px; margin-top: 0; color: #667085; text-transform: uppercase; letter-spacing: .04em; }
+    table { width: 100%; border-collapse: collapse; margin-top: 24px; }
+    th, td { padding: 11px; border-bottom: 1px solid #d6d9df; text-align: left; }
+    th { background: #f2f4f7; }
+    .right { text-align: right; }
+    .totals { margin-left: auto; width: 320px; }
+    .actions { max-width: 860px; margin: 20px auto; display: flex; gap: 8px; }
+    .button { display: inline-flex; padding: 9px 13px; border-radius: 6px; background: #155eef; color: #fff; text-decoration: none; border: 0; font: inherit; cursor: pointer; }
+    .secondary { background: #fff; color: #155eef; border: 1px solid #155eef; }
+    @media print { body { background: #fff; } main { border: 0; margin: 0; max-width: none; } .actions { display: none; } }
+  </style>
+</head>
+<body>
+  <div class="actions">
+    <button class="button" onclick="window.print()">Print</button>
+    <a class="button secondary" href="{{ url_for('invoices') }}">Back</a>
+  </div>
+  <main>
+    <header>
+      <div>
+        <h1>Invoice</h1>
+        <p><strong>{{ invoice.invoice_number }}</strong></p>
+      </div>
+      <div>
+        <p><strong>Issue date:</strong> {{ invoice.issue_date }}</p>
+        {% if invoice.due_date %}<p><strong>Due date:</strong> {{ invoice.due_date }}</p>{% endif %}
+      </div>
+    </header>
+    <section>
+      <h2>Bill to</h2>
+      <p><strong>{{ invoice.client_name }}</strong><br>
+      {% if invoice.client_email %}{{ invoice.client_email }}<br>{% endif %}
+      {{ invoice.client_address or "" }}</p>
+    </section>
+    <table>
+      <thead><tr><th>Description</th><th class="right">Qty</th><th class="right">Unit price</th><th class="right">Amount</th></tr></thead>
+      <tbody>
+        {% for item in items %}
+          <tr>
+            <td>{{ item.description }}</td>
+            <td class="right">{{ item.quantity }}</td>
+            <td class="right">{{ item.unit_price }}</td>
+            <td class="right">{{ "%.2f"|format(item.quantity|float * item.unit_price|float) }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+    <table class="totals">
+      <tr><th>Subtotal</th><td class="right">{{ "%.2f"|format(totals.subtotal) }}</td></tr>
+      <tr><th>Tax ({{ invoice.tax_rate }}%)</th><td class="right">{{ "%.2f"|format(totals.tax) }}</td></tr>
+      <tr><th>Total</th><td class="right"><strong>{{ "%.2f"|format(totals.total) }}</strong></td></tr>
+    </table>
+    {% if invoice.notes %}
+      <section>
+        <h2>Notes</h2>
+        <p>{{ invoice.notes }}</p>
+      </section>
+    {% endif %}
+  </main>
+</body>
+</html>
