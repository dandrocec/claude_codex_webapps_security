+<%- include('partials/header', { title: 'Patient Record' }) %>
+
+<section class="section-heading">
+  <div>
+    <p class="eyebrow">Assigned patient</p>
+    <h1><%= patient.full_name %></h1>
+    <p class="lede">DOB <%= patient.date_of_birth %> · <%= patient.phone %></p>
+  </div>
+  <a class="button secondary" href="/doctor">Back</a>
+</section>
+
+<section class="grid two">
+  <form class="panel form" action="/doctor/patients/<%= patient.id %>/records" method="post">
+    <h2>Add record</h2>
+    <label>
