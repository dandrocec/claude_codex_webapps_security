+{% extends "base.html" %}
+{% block title %}Ledger{% endblock %}
+{% block content %}
+  <section class="panel stack">
+    <div>
+      <h1>Secure SQLite ledger</h1>
+      <p>Open an account, transfer funds to another user, and review your own immutable transaction history.</p>
+    </div>
+    <div>
+      <a class="button" href="{{ url_for('register') }}">Create account</a>
+      <a class="button secondary" href="{{ url_for('login') }}">Sign in</a>
+    </div>
+  </section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..9a2bf95e528eab11545e620def0b66ca4e3c90c1
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+{% block title %}Sign in{% endblock %}
+{% block content %}
+  <section class="panel">
+    <h1>Sign in</h1>
+    <form class="stack" method="post" action="{{ url_for('login') }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label>
+        Username
+        <input name="username" maxlength="32" required autocomplete="username">
+      </label>
+      <label>
+        Password
+        <input name="password" type="password" required autocomplete="current-password">
+      </label>
+      <button type="submit">Sign in</button>
+    </form>
+  </section>
+{% endblock %}
