index 0000000000000000000000000000000000000000..643cd799dfd34002d08ebd4393b918496fbb8fa2
--- /dev/null
+++ b/app/queue.py
@@ -0,0 +1,22 @@
+import os
+from typing import Any
+
+from redis import Redis
+from rq import Queue
+
+
+REDIS_URL = os.getenv("REDIS_URL", "redis://localhost:6379/0")
+QUEUE_NAME = "microblog"
+
+
+def redis_connection() -> Redis:
+    return Redis.from_url(REDIS_URL)
+
+
+def queue() -> Queue:
+    return Queue(QUEUE_NAME, connection=redis_connection())
+
+
+def enqueue(task: str, *args: Any, **kwargs: Any) -> str:
+    job = queue().enqueue(task, *args, **kwargs)
+    return job.id
