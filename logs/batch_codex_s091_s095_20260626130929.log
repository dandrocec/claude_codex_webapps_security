@@ -0,0 +1,196 @@
+:root {
+  color-scheme: light;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: #f6f7f9;
+  color: #20242c;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+}
+
+.topbar {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid #dfe3e8;
+  display: flex;
+  gap: 24px;
+  justify-content: space-between;
+  padding: 18px 28px;
+}
+
+h1,
+h2,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  font-size: 24px;
+  margin-bottom: 0;
+}
+
+h2 {
+  font-size: 16px;
+}
+
+.layout {
+  display: grid;
+  gap: 20px;
+  grid-template-columns: minmax(220px, 300px) minmax(360px, 1fr) minmax(220px, 320px);
+  margin: 0 auto;
+  max-width: 1240px;
+  padding: 24px;
+}
+
+.panel,
+.post {
+  background: #ffffff;
+  border: 1px solid #dfe3e8;
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.panel h2:not(:first-child) {
+  border-top: 1px solid #edf0f3;
+  margin-top: 20px;
+  padding-top: 20px;
+}
+
+.stack {
+  display: grid;
+  gap: 10px;
+}
+
+input,
+select,
+textarea {
+  border: 1px solid #ccd3dc;
+  border-radius: 6px;
+  font: inherit;
+  padding: 10px 12px;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button {
+  background: #166f68;
+  border: 1px solid #166f68;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  font: inherit;
+  font-weight: 650;
+  padding: 9px 12px;
+}
+
+button.secondary {
+  background: #ffffff;
+  color: #374151;
+  border-color: #b9c2ce;
+}
+
+.switcher {
+  align-items: center;
+  display: flex;
+  gap: 10px;
+}
+
+.switcher label {
+  color: #667085;
+  white-space: nowrap;
+}
+
+.feed {
+  display: grid;
+  gap: 14px;
+}
+
+.section-title {
+  align-items: baseline;
+  display: flex;
+  justify-content: space-between;
+}
+
+.section-title span,
+.post-meta span,
+.post-meta time,
+.people span,
+.empty {
+  color: #667085;
+}
+
+.post p {
+  line-height: 1.5;
+  white-space: pre-wrap;
+}
+
+.post-meta {
+  align-items: baseline;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+
+.preview {
+  border: 1px solid #d8dee6;
+  border-radius: 8px;
+  color: inherit;
+  display: grid;
+  gap: 4px;
+  margin-top: 12px;
+  padding: 12px;
+  text-decoration: none;
+}
+
+.preview-title {
+  color: #115e59;
