+  color: #ffffff;
+  text-decoration: none;
+  border-color: #14515f;
+  cursor: pointer;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+th,
+td {
+  padding: 10px;
+  border-bottom: 1px solid #d8e0e8;
+  text-align: left;
+  vertical-align: top;
+}
+
+.item {
