+        <a class="button" href="/doctor/patients/<%= patient.id %>">Records</a>
+      </div>
+    <% }) %>
+  </article>
+  <article class="panel">
+    <h2>Your schedule</h2>
+    <% appointments.forEach((appointment) => { %>
+      <div class="item">
+        <strong><%= appointment.patient_name %></strong>
