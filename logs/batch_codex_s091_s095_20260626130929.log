+{% extends "base.html" %}
+{% block title %}Error{% endblock %}
+{% block content %}
+  <section class="panel">
+    <h1>Unable to complete request</h1>
+    <p>{{ message }}</p>
+    <p><a class="button secondary" href="{{ url_for('index') }}">Go home</a></p>
+  </section>
+{% endblock %}
