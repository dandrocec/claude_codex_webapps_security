+}
+
+.button:hover {
+  background: var(--primary-dark);
+}
+
+.button.secondary {
+  color: var(--ink);
+  background: #e9eef3;
+}
+
+.button.danger {
+  background: var(--danger);
+}
+
+.button.small {
+  min-height: 36px;
+  padding: 7px 12px;
+  font-size: 0.9rem;
+}
+
+.stack {
+  display: grid;
+  gap: 12px;
+}
+
+.record,
+.list-row,
+.appointment-row,
+.schedule-row {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 14px;
+  background: #fbfcfd;
