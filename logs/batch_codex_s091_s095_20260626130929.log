+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= title || 'Clinic Portal' %></title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="/">Clinic Portal</a>
+    <% if (currentUser) { %>
+      <nav class="nav">
+        <span><%= currentUser.fullName %> · <%= currentUser.role %></span>
+        <form action="/logout" method="post">
+          <button class="button secondary" type="submit">Sign out</button>
+        </form>
+      </nav>
+    <% } %>
+  </header>
+  <main class="page">
+    <% if (flash) { %>
+      <div class="flash <%= flash.type %>"><%= flash.message %></div>
+    <% } %>
diff --git a/src/views/patient.ejs b/src/views/patient.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..ce620096b1f33271875c58b27e50c760b6814ea4
--- /dev/null
+++ b/src/views/patient.ejs
@@ -0,0 +1,66 @@
+<%- include('partials/header', { title: 'Patient Portal' }) %>
+
+<section class="section-heading">
+  <div>
+    <p class="eyebrow">Patient workspace</p>
+    <h1>Appointments and records</h1>
+  </div>
+</section>
+
+<section class="grid two">
+  <form class="panel form" action="/patient/appointments" method="post">
+    <h2>Book appointment</h2>
+    <label>
+      Doctor
+      <select name="doctor_id" required>
+        <% doctors.forEach((doctor) => { %>
+          <option value="<%= doctor.id %>"><%= doctor.full_name %> · <%= doctor.specialty %></option>
+        <% }) %>
+      </select>
+    </label>
+    <label>
+      Date and time
+      <input name="starts_at" type="datetime-local" required>
+    </label>
+    <label>
+      Reason
+      <textarea name="reason" rows="3" required></textarea>
+    </label>
+    <button class="button" type="submit">Book</button>
+  </form>
+
+  <div class="panel">
+    <h2>My records</h2>
+    <div class="stack">
+      <% records.forEach((record) => { %>
+        <article class="record">
+          <strong><%= record.diagnosis %></strong>
+          <p><%= record.treatment %></p>
+          <small><%= record.doctor_name %> · <%= record.updated_at %></small>
+        </article>
+      <% }) %>
+      <% if (!records.length) { %><p class="muted">No records yet.</p><% } %>
+    </div>
+  </div>
+</section>
+
+<section class="panel">
+  <h2>My appointments</h2>
+  <table>
+    <thead>
+      <tr><th>When</th><th>Doctor</th><th>Reason</th><th>Status</th></tr>
+    </thead>
+    <tbody>
+      <% appointments.forEach((appointment) => { %>
+        <tr>
+          <td><%= appointment.starts_at %></td>
+          <td><%= appointment.doctor_name %></td>
+          <td><%= appointment.reason %></td>
+          <td><span class="status"><%= appointment.status %></span></td>
+        </tr>
+      <% }) %>
+    </tbody>
+  </table>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/src/views/reception.ejs b/src/views/reception.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..17e2b4961c6ed2a916ae05df99f45fefc06003b2
--- /dev/null
+++ b/src/views/reception.ejs
@@ -0,0 +1,77 @@
+<%- include('partials/header', { title: 'Reception Portal' }) %>
+
+<section class="section-heading">
+  <div>
+    <p class="eyebrow">Reception workspace</p>
+    <h1>Schedule management</h1>
+  </div>
+</section>
+
+<form class="panel form inline-form" action="/reception/appointments" method="post">
+  <h2>Create appointment</h2>
+  <label>
+    Patient
+    <select name="patient_id" required>
+      <% patients.forEach((patient) => { %>
+        <option value="<%= patient.id %>"><%= patient.full_name %></option>
+      <% }) %>
+    </select>
+  </label>
+  <label>
+    Doctor
+    <select name="doctor_id" required>
+      <% doctors.forEach((doctor) => { %>
+        <option value="<%= doctor.id %>"><%= doctor.full_name %> · <%= doctor.specialty %></option>
+      <% }) %>
+    </select>
+  </label>
+  <label>
+    Date and time
+    <input name="starts_at" type="datetime-local" required>
+  </label>
+  <label>
+    Reason
+    <input name="reason" required>
+  </label>
+  <label>
+    Status
+    <select name="status">
+      <option>booked</option>
+      <option>checked-in</option>
+      <option>completed</option>
+      <option>cancelled</option>
+    </select>
+  </label>
+  <button class="button" type="submit">Create</button>
+</form>
+
+<section class="panel">
+  <h2>All appointments</h2>
+  <div class="stack">
+    <% appointments.forEach((appointment) => { %>
+      <form class="schedule-row" action="/reception/appointments/<%= appointment.id %>" method="post">
+        <select name="patient_id" aria-label="Patient">
+          <% patients.forEach((patient) => { %>
+            <option value="<%= patient.id %>" <%= patient.id === appointment.patient_id ? 'selected' : '' %>><%= patient.full_name %></option>
+          <% }) %>
+        </select>
+        <select name="doctor_id" aria-label="Doctor">
+          <% doctors.forEach((doctor) => { %>
+            <option value="<%= doctor.id %>" <%= doctor.id === appointment.doctor_id ? 'selected' : '' %>><%= doctor.full_name %></option>
+          <% }) %>
+        </select>
+        <input name="starts_at" type="datetime-local" value="<%= appointment.starts_at %>" aria-label="Date and time" required>
+        <input name="reason" value="<%= appointment.reason %>" aria-label="Reason" required>
+        <select name="status" aria-label="Status">
+          <% ['booked', 'checked-in', 'completed', 'cancelled'].forEach((status) => { %>
+            <option value="<%= status %>" <%= status === appointment.status ? 'selected' : '' %>><%= status %></option>
+          <% }) %>
+        </select>
+        <button class="button small" type="submit">Save</button>
+        <button class="button danger small" type="submit" formaction="/reception/appointments/<%= appointment.id %>/delete">Delete</button>
+      </form>
+    <% }) %>
+  </div>
+</section>
+
+<%- include('partials/footer') %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..79787fe8512b2b7ff6f46de13fb46a6913ad8aaa
--- /dev/null
+++ b/README.md
@@ -0,0 +1,30 @@
+# Clinic Portal
+
+A Node.js/Express clinic portal with SQLite storage and role-based access control.
+
+## Run locally on port 5092
+
+```bash
+npm install
+npm start
+```
+
+Open `http://localhost:5092`.
+
+## Demo accounts
+
+All demo accounts use password `password123`.
+
+- Patient: `alice.patient`
+- Patient: `bob.patient`
+- Doctor: `dr.smith`
+- Doctor: `dr.lee`
+- Receptionist: `reception`
+
+## Roles
+
+- Patients can book appointments and view only their own appointments and medical records.
+- Doctors can view their schedule and view or update records only for patients assigned to them.
+- Receptionists can manage the appointment schedule for all doctors and patients, but cannot view or edit clinical records.
+
+The app creates and seeds `data/clinic.sqlite` automatically on first start.
