+
+.alert {
+  background: #fff1f0;
+  color: var(--danger);
+}
+
+.notice {
+  background: #ecfdf3;
+  color: var(--success);
+}
+
+.topbar {
+  min-height: 78px;
+  padding: 18px 28px;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 18px;
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+}
+
+.layout {
+  width: min(1180px, calc(100% - 32px));
+  margin: 24px auto 42px;
+  display: grid;
+  gap: 20px;
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 20px;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.panel-header,
+.inline-form {
+  display: flex;
