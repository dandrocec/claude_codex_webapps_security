+      <label>Password <input name="password" type="password" required minlength="12" maxlength="128" autocomplete="${isRegister ? 'new-password' : 'current-password'}"></label>
+      <button type="submit">${isRegister ? 'Register' : 'Log in'}</button>
+    </form>
