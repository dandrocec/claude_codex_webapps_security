+{% extends "base.html" %}
+{% block title %}Error{% endblock %}
+{% block content %}
+<div class="panel">
+  <h1>Request failed</h1>
+  <p>{{ message }}</p>
+  <p><a href="/">Return home</a></p>
+</div>
