@@ -0,0 +1,282 @@
+:root {
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1f2937;
+  --muted: #6b7280;
+  --line: #d8dee8;
+  --primary: #155e75;
+  --primary-dark: #0e4a5c;
+  --danger: #b42318;
+  --success: #147a4b;
+  --warning: #9a5b00;
+}
+
+* {
