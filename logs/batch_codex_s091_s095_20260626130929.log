+}
+
+.status.failed {
+  background: #fee2e2;
+  color: var(--danger);
+}
+
+.status.pending {
+  background: #fef3c7;
+  color: var(--warning);
+}
+
+.back {
+  display: inline-block;
+  margin-bottom: 8px;
+  font-size: 13px;
+}
+
+@media (max-width: 860px) {
+  .topbar,
+  .panel-header,
+  .inline-form,
+  .action-form {
+    align-items: stretch;
+    flex-direction: column;
