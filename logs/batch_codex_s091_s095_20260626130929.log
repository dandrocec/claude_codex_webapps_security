+      <div class="item">
+        <strong><%= appointment.patient_name %></strong>
+        <p><%= appointment.reason %></p>
+        <small><%= appointment.starts_at %> · <%= appointment.status %></small>
+      </div>
+    <% }) %>
+  </article>
+</section>
+<%- include('partials/end') %>
diff --git a/src/views/error.ejs b/src/views/error.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..5bf101eecd476883fa3c88fb2c04ab64fc6bbe6e
--- /dev/null
