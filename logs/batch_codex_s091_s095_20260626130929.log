+}
+
+.narrow {
+  max-width: 420px;
+  margin-inline: auto;
+}
+
+form {
+  display: grid;
+  gap: 12px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 650;
+}
+
+input,
+select,
+textarea,
+button,
+.button {
+  min-height: 40px;
+  border-radius: 6px;
+  border: 1px solid #bcc9d4;
+  font: inherit;
+}
+
+input,
+select,
+textarea {
+  width: 100%;
+  padding: 8px 10px;
+  background: #ffffff;
+  color: #18212f;
+}
+
+textarea {
+  min-height: 110px;
+  resize: vertical;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: fit-content;
+  padding: 8px 14px;
+  background: #14515f;
+  color: #ffffff;
+  text-decoration: none;
+  border-color: #14515f;
+  cursor: pointer;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+th,
+td {
+  padding: 10px;
+  border-bottom: 1px solid #d8e0e8;
+  text-align: left;
+  vertical-align: top;
+}
+
+.item {
+  border-top: 1px solid #d8e0e8;
+  padding: 14px 0;
+}
+
+.item:first-of-type {
+  border-top: 0;
+}
+
+.item p {
+  margin: 6px 0;
+}
+
+small {
+  color: #596878;
+}
+
+.alert {
+  padding: 12px 16px;
+  border: 1px solid #c85050;
+  border-radius: 8px;
+  background: #fff1f1;
+  color: #7c2020;
+  margin-bottom: 18px;
+}
+
+@media (max-width: 760px) {
