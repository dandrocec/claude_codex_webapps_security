+}
+
+input,
+select,
+textarea,
+button,
+.button {
+  min-height: 40px;
+  border-radius: 6px;
+  border: 1px solid #bcc9d4;
+  font: inherit;
+}
+
+input,
+select,
+textarea {
+  width: 100%;
+  padding: 8px 10px;
+  background: #ffffff;
+  color: #18212f;
+}
+
+textarea {
+  min-height: 110px;
+  resize: vertical;
+}
+
+button,
+.button {
