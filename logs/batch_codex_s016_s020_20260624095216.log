+            chmod($this->dataFile, 0640);
+        }
+    }
+
+    private function normalisedVotes(array $votes): array
+    {
+        $normalised = [];
+        foreach (self::OPTIONS as $key => $_label) {
+            $value = $votes[$key] ?? 0;
