+:root {
+  color-scheme: light;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: #f5f7f9;
+  color: #17202a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+}
+
+.page {
+  width: min(1180px, calc(100% - 32px));
+  margin: 0 auto;
+  padding: 40px 0;
+}
+
+.workspace {
+  display: grid;
+  gap: 24px;
+}
+
+.header {
+  border-bottom: 1px solid #d8dee6;
+  padding-bottom: 18px;
+}
+
+h1,
+h2,
+p {
+  margin: 0;
+}
+
+h1 {
+  font-size: 2rem;
+  line-height: 1.15;
+}
+
+.header p {
+  margin-top: 8px;
+  color: #516071;
+}
+
+.compare-form {
+  display: grid;
+  gap: 16px;
+}
+
+.editors {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 16px;
+}
+
+.editor {
+  display: grid;
+  gap: 8px;
+  min-width: 0;
+}
+
+.editor span {
+  font-weight: 700;
+  color: #273341;
+}
+
+textarea {
+  min-height: 300px;
+  width: 100%;
+  resize: vertical;
+  border: 1px solid #b8c2cc;
+  border-radius: 8px;
+  padding: 14px;
+  font: 0.95rem/1.5 ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
+  color: #111827;
+  background: #ffffff;
+  outline: none;
+}
+
+textarea:focus {
+  border-color: #2364aa;
+  box-shadow: 0 0 0 3px rgba(35, 100, 170, 0.16);
+}
+
+.actions {
+  display: flex;
+  justify-content: flex-end;
+}
+
+button {
+  border: 0;
+  border-radius: 8px;
+  background: #2364aa;
+  color: #ffffff;
+  cursor: pointer;
+  font-weight: 700;
+  padding: 11px 18px;
+}
+
+button:hover {
+  background: #1c548f;
+}
+
+.results {
+  display: grid;
+  gap: 14px;
+  border-top: 1px solid #d8dee6;
+  padding-top: 22px;
+}
+
+.results-heading {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+}
+
+h2 {
+  font-size: 1.2rem;
+}
+
+.legend {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+  color: #516071;
+  font-size: 0.9rem;
+}
+
+.legend span {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+}
+
+.swatch {
+  display: inline-block;
+  width: 12px;
+  height: 12px;
+  border-radius: 3px;
+  border: 1px solid transparent;
+}
+
+.swatch.removed {
+  background: #ffe1e1;
+  border-color: #e6a1a1;
+}
+
+.swatch.added {
+  background: #daf3df;
+  border-color: #93d39e;
+}
+
+.swatch.unchanged {
+  background: #eef1f4;
+  border-color: #cbd3dc;
+}
+
+.diff-list {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  border: 1px solid #d8dee6;
+  border-radius: 8px;
+  overflow: hidden;
+  background: #ffffff;
+}
+
+.diff-row {
+  display: grid;
+  grid-template-columns: 42px minmax(0, 1fr);
+  min-height: 34px;
+  border-bottom: 1px solid #e8edf2;
+}
+
+.diff-row:last-child {
+  border-bottom: 0;
+}
+
+.diff-row.removed {
+  background: #fff0f0;
+}
+
+.diff-row.added {
+  background: #ecf9ef;
+}
+
+.diff-row.unchanged {
+  background: #ffffff;
+}
+
+.marker {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-right: 1px solid rgba(0, 0, 0, 0.08);
+  color: #4b5563;
+  font-weight: 800;
+}
+
+.diff-row.removed .marker {
+  color: #a42323;
+}
+
+.diff-row.added .marker {
+  color: #1f7a35;
+}
+
+code {
+  display: block;
+  min-width: 0;
+  padding: 8px 12px;
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+  font: 0.92rem/1.45 ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
+}
+
+.empty {
+  color: #516071;
+}
+
+@media (max-width: 760px) {
+  .page {
+    width: min(100% - 24px, 1180px);
+    padding: 24px 0;
+  }
+
+  .editors,
+  .results-heading {
+    grid-template-columns: 1fr;
+  }
+
+  .editors {
+    display: grid;
+  }
+
+  .results-heading {
+    display: grid;
+    align-items: start;
+  }
+
+  textarea {
+    min-height: 220px;
+  }
+}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..95b641eba0f53fa10b0a3b9fdc3691a7245f6930
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,65 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Line Diff</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <main class="page">
+      <section class="workspace" aria-labelledby="title">
+        <header class="header">
+          <div>
+            <h1 id="title">Line Diff</h1>
+            <p>Compare two blocks of text and review additions and removals line by line.</p>
+          </div>
+        </header>
+
+        <form method="post" class="compare-form">
+          <div class="editors">
+            <label class="editor">
+              <span>Original text</span>
+              <textarea name="left_text" spellcheck="false" placeholder="Paste the original text here">{{ left_text }}</textarea>
+            </label>
+
+            <label class="editor">
+              <span>Updated text</span>
+              <textarea name="right_text" spellcheck="false" placeholder="Paste the updated text here">{{ right_text }}</textarea>
+            </label>
+          </div>
+
+          <div class="actions">
+            <button type="submit">Compare texts</button>
+          </div>
+        </form>
+
+        {% if compared %}
+          <section class="results" aria-labelledby="results-title">
+            <div class="results-heading">
+              <h2 id="results-title">Differences</h2>
+              <div class="legend" aria-label="Diff legend">
+                <span><i class="swatch removed"></i>Removed</span>
+                <span><i class="swatch added"></i>Added</span>
+                <span><i class="swatch unchanged"></i>Unchanged</span>
+              </div>
+            </div>
+
+            {% if diff_rows %}
+              <ol class="diff-list">
+                {% for row in diff_rows %}
+                  <li class="diff-row {{ row.kind }}">
+                    <span class="marker" aria-hidden="true">{{ row.label }}</span>
+                    <code>{{ row.text if row.text else " " }}</code>
+                  </li>
+                {% endfor %}
+              </ol>
+            {% else %}
+              <p class="empty">Both text areas are empty.</p>
+            {% endif %}
+          </section>
+        {% endif %}
+      </section>
+    </main>
+  </body>
+</html>

