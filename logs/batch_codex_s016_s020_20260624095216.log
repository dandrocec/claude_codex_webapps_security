diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..345375431667322c18361d10be47696dfe6d858e
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,234 @@
+:root {
+  color-scheme: light;
+  --bg: #f7f8fa;
+  --panel: #ffffff;
+  --text: #17202a;
+  --muted: #657282;
+  --border: #d8dee6;
+  --accent: #1d6f5f;
+  --added: #e6f5ea;
+  --added-bar: #268547;
+  --removed: #fdeaea;
+  --removed-bar: #c93c37;
+  --unchanged: #f7f8fa;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+  display: flex;
+  justify-content: space-between;
+  padding: 14px 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.1rem;
+  font-weight: 700;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  gap: 14px;
+}
+
+.user {
+  color: var(--muted);
+  max-width: 32ch;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.inline {
+  display: inline;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1180px;
+  padding: 28px 24px;
+}
+
+.workspace,
+.auth-panel,
+.error-panel,
+.recent {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.editor-grid {
+  display: grid;
+  gap: 18px;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+}
+
+label {
+  display: grid;
+  gap: 8px;
+  font-weight: 700;
+}
+
+textarea,
+input {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 12px;
+  width: 100%;
+}
+
+textarea {
+  font-family: Consolas, "Liberation Mono", monospace;
+  min-height: 360px;
+  resize: vertical;
+}
+
+button,
+.primary {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 16px;
+}
+
+button:hover,
+.primary:hover {
+  filter: brightness(0.95);
+}
+
+.actions {
+  display: flex;
+  justify-content: flex-end;
+  margin-top: 16px;
+}
+
+.diff-output {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  margin-top: 22px;
+  overflow: hidden;
+}
+
+.diff-row {
+  display: grid;
+  font-family: Consolas, "Liberation Mono", monospace;
+  grid-template-columns: 42px minmax(0, 1fr);
+  min-height: 30px;
+}
+
+.diff-row .prefix {
+  border-right: 1px solid var(--border);
+  padding: 4px 12px;
+  text-align: center;
+  user-select: none;
+}
+
+.diff-row code {
+  overflow-wrap: anywhere;
+  padding: 4px 12px;
+  white-space: pre-wrap;
+}
+
+.diff-row.added {
+  background: var(--added);
+  border-left: 4px solid var(--added-bar);
+}
+
+.diff-row.removed {
+  background: var(--removed);
+  border-left: 4px solid var(--removed-bar);
+}
+
+.diff-row.unchanged {
+  background: var(--unchanged);
+  border-left: 4px solid transparent;
+}
+
+.auth-panel {
+  max-width: 460px;
+}
+
+.auth-panel form {
+  display: grid;
+  gap: 16px;
+}
+
+.messages {
+  margin-bottom: 18px;
+}
+
+.message {
+  border-radius: 6px;
+  margin: 0 0 8px;
+  padding: 10px 12px;
+}
+
+.message.error {
+  background: var(--removed);
+}
+
+.message.success {
+  background: var(--added);
+}
+
+.recent {
+  margin-top: 20px;
+}
+
+.recent h2 {
+  font-size: 1rem;
+  margin: 0 0 10px;
+}
+
+.recent ul {
+  margin: 0;
+  padding-left: 20px;
+}
+
+@media (max-width: 760px) {
+  .topbar,
+  nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .editor-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .page {
+    padding: 18px 12px;
+  }
+}
