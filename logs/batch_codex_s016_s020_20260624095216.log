+:root {
+  color-scheme: light;
+  --bg: #f5f7fb;
+  --panel: #ffffff;
+  --text: #18212f;
+  --muted: #687386;
+  --border: #d8dee9;
+  --accent: #0f766e;
+  --accent-dark: #115e59;
+  --danger: #b42318;
+  --success: #067647;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent-dark);
+}
+
+.site-header {
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  width: min(980px, calc(100% - 2rem));
+  margin: 0 auto;
+  padding: 1rem 0;
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.nav-links {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+  flex-wrap: wrap;
+}
+
+.inline-form {
+  margin: 0;
+}
+
+.inline-form button,
+.link-button {
+  border: 0;
+  padding: 0;
+  background: transparent;
+  color: var(--accent-dark);
+  cursor: pointer;
+  font: inherit;
+  text-decoration: underline;
+}
+
+.page {
+  width: min(980px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.panel {
+  max-width: 560px;
+  margin: 0 auto;
+  padding: 1.5rem;
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  box-shadow: 0 12px 32px rgba(24, 33, 47, 0.08);
+}
+
+.panel.wide {
+  max-width: 980px;
+}
+
+.panel.auth {
+  max-width: 460px;
+}
+
+h1 {
+  margin: 0 0 1.25rem;
+  font-size: 1.6rem;
+}
+
+form {
+  display: grid;
+  gap: 1rem;
+}
+
+.field {
+  display: grid;
+  gap: 0.35rem;
+}
+
+label {
+  font-weight: 700;
+}
+
+input,
+select {
+  width: 100%;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  padding: 0.75rem;
+  color: var(--text);
+  background: #fff;
+  font: inherit;
+}
+
+input:focus,
+select:focus,
+button:focus-visible,
+a:focus-visible {
+  outline: 3px solid rgba(15, 118, 110, 0.28);
+  outline-offset: 2px;
+}
+
+.grid.two {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 1rem;
+}
+
+.primary,
+.button-link {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: fit-content;
+  min-height: 2.75rem;
+  border: 0;
+  border-radius: 6px;
+  padding: 0 1rem;
+  background: var(--accent);
+  color: #fff;
+  cursor: pointer;
+  font: inherit;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.primary:hover,
+.button-link:hover {
+  background: var(--accent-dark);
+}
+
+.result {
+  display: grid;
+  gap: 0.25rem;
+  margin-top: 1.25rem;
+  padding: 1rem;
+  border: 1px solid #9fd3cd;
+  border-radius: 8px;
+  background: #e8f6f4;
+}
+
+.result strong {
+  font-size: 1.8rem;
+}
+
+.messages {
+  max-width: 560px;
+  margin: 0 auto 1rem;
+}
+
+.message {
+  margin: 0 0 0.5rem;
+  padding: 0.75rem 1rem;
+  border-radius: 6px;
+  background: #eef2f7;
+}
+
+.message.error,
+.error {
+  color: var(--danger);
+}
+
+.message.success {
+  color: var(--success);
+}
+
+.muted {
+  color: var(--muted);
+}
+
+.table-wrap {
+  overflow-x: auto;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--border);
+  padding: 0.75rem;
+  text-align: left;
+}
+
+th {
+  color: var(--muted);
+  font-size: 0.9rem;
+}
+
+.action-cell {
+  text-align: right;
+}
+
+@media (max-width: 640px) {
+  .nav {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .grid.two {
+    grid-template-columns: 1fr;
+  }
+
+  .panel {
+    padding: 1rem;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..b3844664dd608b12ce28f333aeaf4cc36a60a02b
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,42 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Currency Converter{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <nav class="nav" aria-label="Primary navigation">
+        <a class="brand" href="{{ url_for('converter') }}">Currency Converter</a>
+        <div class="nav-links">
+          {% if g.user %}
+            <a href="{{ url_for('converter') }}">Convert</a>
+            <a href="{{ url_for('history') }}">History</a>
+            <form class="inline-form" action="{{ url_for('logout') }}" method="post">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button type="submit">Sign out</button>
+            </form>
+          {% else %}
+            <a href="{{ url_for('login') }}">Sign in</a>
+            <a href="{{ url_for('register') }}">Register</a>
+          {% endif %}
+        </div>
+      </nav>
+    </header>
+
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages" role="status" aria-live="polite">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/converter.html b/templates/converter.html
new file mode 100644
index 0000000000000000000000000000000000000000..533d125b46261d99bc0c37387fc23dbcd99a83da
--- /dev/null
+++ b/templates/converter.html
@@ -0,0 +1,47 @@
+{% extends "base.html" %}
+
+{% block title %}Convert Currency{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <h1>Convert currency</h1>
+    <form method="post" novalidate>
+      {{ form.hidden_tag() }}
+
+      <div class="field">
+        {{ form.amount.label }}
+        {{ form.amount(inputmode="decimal", autocomplete="off") }}
+        {% for error in form.amount.errors %}
+          <span class="error">{{ error }}</span>
+        {% endfor %}
+      </div>
+
+      <div class="grid two">
+        <div class="field">
+          {{ form.source_currency.label }}
+          {{ form.source_currency }}
+          {% for error in form.source_currency.errors %}
+            <span class="error">{{ error }}</span>
+          {% endfor %}
+        </div>
+
+        <div class="field">
+          {{ form.target_currency.label }}
+          {{ form.target_currency }}
+          {% for error in form.target_currency.errors %}
+            <span class="error">{{ error }}</span>
+          {% endfor %}
+        </div>
+      </div>
+
+      {{ form.submit(class="primary") }}
+    </form>
+
+    {% if result %}
+      <div class="result" aria-live="polite">
+        <span>{{ result.amount }} {{ result.source }}</span>
+        <strong>{{ result.converted }} {{ result.target }}</strong>
+      </div>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
