+:root {
+  color-scheme: light;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: #f4f6f8;
+  color: #17202a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+}
+
+.app-shell {
+  min-height: 100vh;
+  display: grid;
+  place-items: center;
+  padding: 32px 18px;
+}
+
+.converter {
+  width: min(100%, 560px);
+  background: #ffffff;
+  border: 1px solid #d9e0e7;
+  border-radius: 8px;
+  padding: 32px;
+  box-shadow: 0 18px 45px rgba(23, 32, 42, 0.1);
+}
+
+.intro {
+  margin-bottom: 28px;
+}
+
+.eyebrow {
+  margin: 0 0 8px;
+  color: #3b6f8f;
+  font-size: 0.78rem;
+  font-weight: 700;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+h1 {
+  margin: 0;
+  font-size: clamp(2rem, 8vw, 3rem);
+  line-height: 1;
+}
+
+.converter-form {
+  display: grid;
+  gap: 16px;
+}
+
+.currency-row {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 16px;
+}
+
+label {
+  display: block;
+  margin-bottom: 7px;
+  color: #52616f;
+  font-size: 0.92rem;
+  font-weight: 700;
+}
+
+input,
+select,
+button {
+  width: 100%;
+  min-height: 46px;
+  border-radius: 6px;
+  font: inherit;
+}
+
+input,
+select {
+  border: 1px solid #bdc7d1;
+  background: #ffffff;
+  color: #17202a;
+  padding: 0 12px;
+}
+
+input:focus,
+select:focus {
+  border-color: #2d7da1;
+  outline: 3px solid rgba(45, 125, 161, 0.2);
+}
+
+button {
+  border: 0;
+  background: #1f6f8b;
+  color: #ffffff;
+  cursor: pointer;
+  font-weight: 800;
+}
+
+button:hover {
+  background: #195d74;
+}
+
+.message,
+.result {
+  margin-top: 18px;
+  border-radius: 6px;
+  padding: 16px;
+}
+
+.error {
+  background: #fff1f1;
+  color: #9f1d1d;
+  border: 1px solid #f1b8b8;
+}
+
+.result {
+  display: grid;
+  gap: 6px;
+  background: #eef8f2;
+  border: 1px solid #badbc8;
+}
+
+.result span {
+  color: #52616f;
+}
+
+.result strong {
+  font-size: 2rem;
+}
+
+@media (max-width: 560px) {
+  .converter {
+    padding: 24px;
+  }
+
+  .currency-row {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..62fa8e1c461358ef0d93a754400ab8f1ab934648
