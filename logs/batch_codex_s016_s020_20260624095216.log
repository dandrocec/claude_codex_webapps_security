+{% extends "base.html" %}
+{% block content %}
+  <section class="auth-panel">
+    <h1>{{ title }}</h1>
+    <form method="post" novalidate>
+      {{ form.hidden_tag() }}
+      <label>
+        <span>Email</span>
+        {{ form.email(autocomplete="email") }}
+      </label>
+      <label>
+        <span>Password</span>
+        {{ form.password(autocomplete="current-password") }}
+      </label>
+      {{ form.submit(class_="primary") }}
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..f965fc3cb58fab1b203f6e7b0f7d2524afe2c9fa
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{{ title or "Line Diff" }}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('index') }}">Line Diff</a>
+      <nav>
+        {% if g.user %}
+          <span class="user">{{ g.user.email }}</span>
+          <form class="inline" method="post" action="{{ url_for('logout') }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Sign in</a>
+          <a href="{{ url_for('register') }}">Create account</a>
+        {% endif %}
+      </nav>
+    </header>
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
