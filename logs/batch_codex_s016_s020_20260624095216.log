+            <span>Rating</span>
+            <strong id="rating">Weak</strong>
+          </div>
+          <div class="meter" aria-hidden="true">
+            <span id="meter-bar"></span>
+          </div>
+          <ul id="feedback"></ul>
+        </section>
+      </section>
+    </main>
+
+    <script src="/script.js"></script>
+  </body>
+</html>
