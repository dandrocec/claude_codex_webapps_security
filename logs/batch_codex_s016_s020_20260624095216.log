+        echo '.wrap{max-width:760px;margin:0 auto;padding:48px 20px}.panel{background:#fff;border:1px solid #d9e0ec;border-radius:8px;padding:28px;box-shadow:0 10px 28px rgba(23,32,51,.08)}';
