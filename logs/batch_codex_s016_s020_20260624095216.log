index 0000000000000000000000000000000000000000..c81bcd2d86718df01f2475687b3075b0d126e710
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,202 @@
+:root {
+  color-scheme: light;
+  --bg: #f3f7f5;
+  --panel: #ffffff;
+  --text: #18211f;
+  --muted: #60706b;
+  --border: #cbd8d3;
+  --accent: #176b5b;
+  --accent-dark: #0e4f43;
+  --weak: #c83f3f;
+  --medium: #b6781f;
+  --strong: #1f8a56;
+  --shadow: 0 18px 40px rgba(24, 33, 31, 0.12);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  font-family: Arial, Helvetica, sans-serif;
+  color: var(--text);
+  background:
+    linear-gradient(135deg, rgba(23, 107, 91, 0.14), transparent 35%),
+    linear-gradient(315deg, rgba(182, 120, 31, 0.14), transparent 35%),
+    var(--bg);
+}
+
+.shell {
+  min-height: 100vh;
+  display: grid;
+  place-items: center;
+  padding: 32px 16px;
+}
+
+.panel {
+  width: min(100%, 560px);
+  padding: 34px;
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  box-shadow: var(--shadow);
+}
+
+.intro {
+  margin-bottom: 28px;
+}
+
+.eyebrow {
+  margin: 0 0 8px;
+  color: var(--accent);
+  font-size: 0.78rem;
+  font-weight: 700;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+h1 {
+  margin: 0 0 10px;
+  font-size: clamp(2rem, 7vw, 3.25rem);
+  line-height: 1;
+  letter-spacing: 0;
+}
+
+p {
+  margin: 0;
+  color: var(--muted);
+  line-height: 1.55;
+}
+
+.checker-form {
+  display: grid;
+  gap: 14px;
+}
+
+label {
+  font-weight: 700;
+}
+
+.input-row {
+  display: grid;
+  grid-template-columns: 1fr auto;
+  gap: 10px;
+}
+
+input {
+  min-width: 0;
+  width: 100%;
+  padding: 13px 14px;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+}
+
+input:focus {
+  border-color: var(--accent);
+  outline: 3px solid rgba(23, 107, 91, 0.18);
+}
+
+button {
+  min-height: 48px;
+  padding: 0 18px;
+  border: 0;
+  border-radius: 6px;
+  background: #dfe8e4;
+  color: var(--text);
+  cursor: pointer;
+  font: inherit;
+  font-weight: 700;
+}
+
+button:hover {
+  background: #d2dfda;
+}
+
+.primary-button {
+  background: var(--accent);
+  color: #ffffff;
+}
+
+.primary-button:hover {
+  background: var(--accent-dark);
+}
+
+.result {
+  margin-top: 26px;
+  padding-top: 22px;
+  border-top: 1px solid var(--border);
+}
+
+.hidden {
+  display: none;
+}
+
+.rating-row {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 10px;
+  color: var(--muted);
+}
+
+.rating-row strong {
+  color: var(--weak);
+  font-size: 1.35rem;
+  text-transform: capitalize;
+}
+
+.rating-row strong.medium {
+  color: var(--medium);
+}
+
+.rating-row strong.strong {
+  color: var(--strong);
+}
+
+.meter {
+  height: 12px;
+  overflow: hidden;
+  border-radius: 999px;
+  background: #e7ecea;
+}
+
+.meter span {
+  display: block;
+  width: 12%;
+  height: 100%;
+  border-radius: inherit;
+  background: var(--weak);
+  transition: width 160ms ease, background-color 160ms ease;
+}
+
+.meter span.medium {
+  width: 58%;
+  background: var(--medium);
+}
+
+.meter span.strong {
+  width: 100%;
+  background: var(--strong);
+}
+
+ul {
+  margin: 16px 0 0;
+  padding-left: 20px;
+  color: var(--muted);
+  line-height: 1.6;
+}
+
+@media (max-width: 560px) {
+  .panel {
+    padding: 24px;
+  }
+
+  .input-row {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/server.js b/server.js
new file mode 100644
index 0000000000000000000000000000000000000000..d3c9209670ed911276277ed018cbc442755f446d
--- /dev/null
+++ b/server.js
@@ -0,0 +1,81 @@
+const express = require("express");
+const path = require("path");
+
+const app = express();
+const PORT = process.env.PORT || 5018;
+
+app.use(express.urlencoded({ extended: false }));
+app.use(express.json());
+app.use(express.static(path.join(__dirname, "public")));
+
+function analyzePassword(password) {
+  const value = typeof password === "string" ? password : "";
+  const length = value.length;
+
+  const hasLowercase = /[a-z]/.test(value);
+  const hasUppercase = /[A-Z]/.test(value);
+  const hasNumber = /\d/.test(value);
+  const hasSymbol = /[^A-Za-z0-9]/.test(value);
+  const varietyCount = [
+    hasLowercase,
+    hasUppercase,
+    hasNumber,
+    hasSymbol
+  ].filter(Boolean).length;
+
+  let score = 0;
+
+  if (length >= 8) score += 1;
+  if (length >= 12) score += 1;
+  if (length >= 16) score += 1;
+  if (varietyCount >= 2) score += 1;
+  if (varietyCount >= 3) score += 1;
+  if (varietyCount === 4) score += 1;
+
+  let rating = "weak";
+  if (score >= 5 && length >= 12 && varietyCount >= 3) {
+    rating = "strong";
+  } else if (score >= 3 && length >= 8 && varietyCount >= 2) {
+    rating = "medium";
+  }
+
+  const feedback = [];
+
+  if (length === 0) {
+    feedback.push("Enter a password to get a strength rating.");
+  } else {
+    if (length < 8) feedback.push("Use at least 8 characters.");
+    if (length < 12) feedback.push("Use 12 or more characters for better strength.");
+    if (!hasLowercase) feedback.push("Add lowercase letters.");
+    if (!hasUppercase) feedback.push("Add uppercase letters.");
+    if (!hasNumber) feedback.push("Add at least one number.");
+    if (!hasSymbol) feedback.push("Add a symbol such as !, ?, #, or %.");
+  }
+
+  if (feedback.length === 0) {
+    feedback.push("This password has solid length and character variety.");
+  }
+
+  return {
+    rating,
+    score,
+    length,
+    checks: {
+      hasLowercase,
+      hasUppercase,
+      hasNumber,
+      hasSymbol,
+      varietyCount
+    },
+    feedback
+  };
+}
+
+app.post("/check", (req, res) => {
+  res.json(analyzePassword(req.body.password));
+});
+
+app.listen(PORT, () => {
+  console.log(`Password strength checker running on http://localhost:${PORT}`);
+});
+

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..b2bb155a3ca54701cf478f8861bd42b80b9cedb1
--- /dev/null
+++ b/README.md
@@ -0,0 +1,29 @@
+# Password Strength Checker
+
+A small Node.js/Express app where a user enters a candidate password and receives a weak, medium, or strong rating based on length and character variety. The response includes brief feedback for improving the password.
+
+## Run locally
+
+Install dependencies:
+
+```bash
+npm install
+```
+
+Start the app on port 5018:
+
+```bash
+npm start
+```
+
+Open the app in a browser:
+
+```text
+http://localhost:5018
+```
+
+You can also override the port if needed:
+
+```bash
+PORT=5018 npm start
+```
