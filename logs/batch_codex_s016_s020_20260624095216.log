+            'path' => '/',
+            'domain' => '',
+            'secure' => $isHttps,
+            'httponly' => true,
+            'samesite' => 'Lax',
+        ]);
+        session_start();
+
+        if (!isset($_SESSION['created_at'])) {
+            session_regenerate_id(true);
