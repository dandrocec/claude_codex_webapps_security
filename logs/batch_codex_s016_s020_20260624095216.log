--- /dev/null
+++ b/view-helpers.js
@@ -0,0 +1,16 @@
+'use strict';
+
+function escapeHtml(value) {
+  return String(value)
+    .replaceAll('&', '&amp;')
+    .replaceAll('<', '&lt;')
+    .replaceAll('>', '&gt;')
+    .replaceAll('"', '&quot;')
+    .replaceAll("'", '&#39;');
+}
+
+function escapeAttr(value) {
+  return escapeHtml(value).replaceAll('`', '&#96;');
+}
+
+module.exports = { escapeHtml, escapeAttr };
