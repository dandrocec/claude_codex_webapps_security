+++ b/package.json
@@ -0,0 +1,26 @@
+{
+  "name": "password-strength-express",
+  "version": "1.0.0",
+  "description": "Secure Express app for rating candidate password strength.",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js"
+  },
+  "dependencies": {
+    "bcrypt": "^5.1.1",
+    "better-sqlite3": "^11.9.1",
+    "connect-sqlite3": "^0.9.16",
+    "csurf": "^1.11.0",
+    "dotenv": "^16.4.7",
+    "ejs": "^3.1.10",
+    "express": "^4.21.2",
+    "express-rate-limit": "^7.5.0",
+    "express-session": "^1.18.1",
+    "express-validator": "^7.2.1",
+    "helmet": "^8.0.0",
+    "selfsigned": "^2.4.1"
+  },
+  "engines": {
+    "node": ">=20"
+  }
+}
diff --git a/public/styles.css b/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..5b93f4c01d2fb55ae98f71ee2b7acf3f472bad95
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,166 @@
+:root {
+  color-scheme: light;
+  --bg: #f5f7fa;
+  --panel: #ffffff;
+  --text: #172033;
+  --muted: #607086;
+  --line: #d9e0ea;
+  --accent: #0f766e;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+}
+
+.shell {
+  width: min(760px, calc(100% - 32px));
+  margin: 0 auto;
+  padding: 24px 0 48px;
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 24px;
+  margin-bottom: 18px;
+}
+
+.auth-panel {
+  max-width: 460px;
+}
+
+h1,
+h2 {
+  margin: 0 0 18px;
+  line-height: 1.2;
+}
+
+label {
+  display: block;
+  margin: 14px 0 6px;
+  font-weight: 650;
+}
+
+input {
+  width: 100%;
+  min-height: 44px;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 10px 12px;
+  font: inherit;
+}
+
+button {
+  min-height: 42px;
+  border: 0;
+  border-radius: 6px;
+  margin-top: 18px;
+  padding: 10px 16px;
+  background: var(--accent);
+  color: #ffffff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+.link-button {
+  min-height: auto;
+  margin: 0;
+  padding: 0;
+  background: transparent;
+  color: var(--accent);
+}
+
+.danger {
+  background: var(--danger);
+}
+
+.muted {
+  color: var(--muted);
+}
+
+.alert {
+  border-left: 4px solid var(--danger);
+  background: #fff1f0;
+  color: #7a271a;
+  padding: 10px 12px;
+}
+
+.result {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  margin-top: 18px;
+  padding: 14px;
+}
+
+.result strong {
+  text-transform: capitalize;
+}
+
+.result-weak {
+  border-color: #f04438;
+}
+
+.result-medium {
+  border-color: #f79009;
+}
+
+.result-strong {
+  border-color: #12b76a;
+}
+
+.checks {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.checks li {
+  display: flex;
