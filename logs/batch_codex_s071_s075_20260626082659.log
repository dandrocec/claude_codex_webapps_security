+    <div>
+      <h1>People</h1>
+      <p class="muted">Follow people to bring their latest photos into your feed.</p>
+    </div>
+  </section>
+  ${users.length ? `
+    <section class="user-list">
+      ${users.map((user) => `
+        <article class="user-row">
+          <div>
+            <strong><a href="/users/${user.username}">@${user.username}</a></strong>
+            <div class="muted">${user.photo_count} photos</div>
+          </div>
+          ${user.is_following
+            ? `<form action="/users/${user.id}/follow?_method=DELETE" method="post"><button class="secondary" type="submit">Unfollow</button></form>`
+            : `<form action="/users/${user.id}/follow" method="post"><button type="submit">Follow</button></form>`
+          }
+        </article>
+      `).join("")}
+    </section>
+  ` : '<div class="empty">No other users have joined yet.</div>'}
+` }) %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..283604571fe8328cdc3f0b5c3436a695f4eb496b
--- /dev/null
+++ b/README.md
@@ -0,0 +1,14 @@
+# Photo Share Express
+
+A small Node.js/Express photo-sharing app. Users can register, upload photos, follow other users, like photos, comment on photos, and browse a feed of recent photos from people they follow.
+
+## Run Locally
+
+```bash
+npm install
+npm start
+```
+
+Open `http://localhost:5073`.
+
+The app stores SQLite data in `data/app.db` and uploaded images in `uploads/`. Both folders are created automatically on startup.
