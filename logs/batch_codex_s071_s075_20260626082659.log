+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title><%= title %> · Photo Share</title>
+    <link rel="stylesheet" href="/public/styles.css">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="<%= currentUser ? '/feed' : '/' %>">Photo Share</a>
+      <nav class="nav">
