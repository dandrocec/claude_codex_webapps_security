--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,45 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Membership{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">MemberSpace</a>
+    <nav class="nav">
+      {% if g.user %}
+        <a href="{{ url_for('dashboard') }}">Dashboard</a>
+        {% if g.user["tier"] == "premium" or g.user["is_admin"] %}
+          <a href="{{ url_for('premium') }}">Premium Library</a>
+        {% else %}
+          <a href="{{ url_for('upgrade') }}">Upgrade</a>
+        {% endif %}
+        {% if g.user["is_admin"] %}
+          <a href="{{ url_for('admin_users') }}">Admin</a>
+        {% endif %}
+        <a href="{{ url_for('logout') }}">Logout</a>
+      {% else %}
+        <a href="{{ url_for('index') }}">Home</a>
+        <a href="{{ url_for('login') }}">Login</a>
+        <a class="button small" href="{{ url_for('register') }}">Join Free</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="flash-list">
+          {% for category, message in messages %}
+            <div class="flash {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
