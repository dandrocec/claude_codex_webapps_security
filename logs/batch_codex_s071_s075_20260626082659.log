+}
+
+.bid-panel h2,
+.history h2,
+.empty h2 {
+  margin: 0 0 16px;
+  font-size: 1.25rem;
+}
+
+.history {
+  margin-top: 18px;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
