diff --git a/views/partials/header.ejs b/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c2826e19c2a22e4baede186e507cb5058bfece87
--- /dev/null
+++ b/views/partials/header.ejs
@@ -0,0 +1,32 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= title || "Quiz Platform" %></title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="/">Quiz Platform</a>
+    <nav>
+      <% if (user) { %>
+        <span><%= user.username %> (<%= user.role %>)</span>
+        <form action="/logout" method="post" class="inline">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Sign out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Sign in</a>
+        <a href="/register">Register</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="container">
+    <% if (typeof errors !== "undefined" && errors.length) { %>
+      <div class="alert" role="alert">
+        <% errors.forEach(function(error) { %>
+          <p><%= error %></p>
+        <% }) %>
+      </div>
+    <% } %>
diff --git a/views/quiz_new.ejs b/views/quiz_new.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..6c2647694ce687bbaded8bc1e2578d4fa88c4cc5
--- /dev/null
+++ b/views/quiz_new.ejs
@@ -0,0 +1,35 @@
+<%- include("partials/header", { title: "New quiz" }) %>
+<section class="panel">
+  <h1>New quiz</h1>
+  <form action="/teacher/quizzes" method="post">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Title
+      <input name="title" maxlength="120" value="<%= values.title || "" %>" required>
+    </label>
+    <label>Description
+      <textarea name="description" maxlength="500"><%= values.description || "" %></textarea>
+    </label>
+    <% for (let i = 0; i < 5; i += 1) { %>
+      <fieldset>
+        <legend>Question <%= i + 1 %></legend>
+        <label>Prompt
+          <textarea name="question_prompt" maxlength="500"><%= Array.isArray(values.question_prompt) ? (values.question_prompt[i] || "") : "" %></textarea>
+        </label>
+        <% for (let j = 0; j < 4; j += 1) { %>
+          <label>Option <%= j + 1 %>
+            <input name="option_<%= j %>" maxlength="250" value="<%= Array.isArray(values["option_" + j]) ? (values["option_" + j][i] || "") : "" %>">
+          </label>
+        <% } %>
+        <label>Correct answer
+          <select name="correct_answer">
+            <% for (let j = 0; j < 4; j += 1) { %>
+              <option value="<%= j %>" <%= Array.isArray(values.correct_answer) && values.correct_answer[i] === String(j) ? "selected" : "" %>>Option <%= j + 1 %></option>
+            <% } %>
+          </select>
+        </label>
+      </fieldset>
+    <% } %>
+    <button type="submit">Create quiz</button>
+  </form>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/register.ejs b/views/register.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..149b2d6bb6037c4230d3b71cd4fd710ad6822b8e
--- /dev/null
+++ b/views/register.ejs
@@ -0,0 +1,21 @@
+<%- include("partials/header", { title: "Register" }) %>
+<section class="panel narrow">
+  <h1>Register</h1>
+  <form action="/register" method="post">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Username
+      <input name="username" autocomplete="username" maxlength="40" pattern="[a-zA-Z0-9_.-]{3,40}" value="<%= values.username || "" %>" required>
+    </label>
+    <label>Password
+      <input name="password" type="password" autocomplete="new-password" minlength="10" maxlength="128" required>
+    </label>
+    <label>Role
+      <select name="role" required>
+        <option value="student" <%= values.role === "student" ? "selected" : "" %>>Student</option>
+        <option value="teacher" <%= values.role === "teacher" ? "selected" : "" %>>Teacher</option>
+      </select>
+    </label>
+    <button type="submit">Create account</button>
+  </form>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/score.ejs b/views/score.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..cdc2645771103486b915f932ddc6bef771230513
--- /dev/null
+++ b/views/score.ejs
@@ -0,0 +1,7 @@
+<%- include("partials/header", { title: "Score" }) %>
+<section class="panel narrow">
+  <h1>Score</h1>
+  <p>You scored <strong><%= score %>/<%= total %></strong> on <%= quiz.title %>.</p>
+  <a class="button" href="/student/quizzes">Back to quizzes</a>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/student_quizzes.ejs b/views/student_quizzes.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..54a41300a812d32ed0b7d7504fd36402a81ee7ea
--- /dev/null
+++ b/views/student_quizzes.ejs
@@ -0,0 +1,30 @@
+<%- include("partials/header", { title: "Available quizzes" }) %>
+<h1>Available quizzes</h1>
+<section class="grid">
+  <% if (!quizzes.length) { %>
+    <p>No quizzes are available.</p>
+  <% } %>
+  <% quizzes.forEach(function(quiz) { %>
+    <article class="card">
+      <h2><a href="/student/quizzes/<%= quiz.id %>"><%= quiz.title %></a></h2>
+      <p><%= quiz.description %></p>
+      <p class="meta">By <%= quiz.teacher_name %> · <%= quiz.question_count %> questions</p>
+    </article>
+  <% }) %>
+</section>
+<section class="panel">
+  <h2>Your recent attempts</h2>
+  <% if (!attempts.length) { %>
+    <p>No submissions yet.</p>
+  <% } else { %>
+    <table>
+      <thead><tr><th>Quiz ID</th><th>Score</th><th>Submitted</th></tr></thead>
+      <tbody>
+      <% attempts.forEach(function(attempt) { %>
+        <tr><td><%= attempt.quiz_id %></td><td><%= attempt.score %>/<%= attempt.total %></td><td><%= attempt.submitted_at %></td></tr>
+      <% }) %>
+      </tbody>
+    </table>
+  <% } %>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/take_quiz.ejs b/views/take_quiz.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2b8e43ce33d90eaa824a20263b3a5146e9422a5d
--- /dev/null
+++ b/views/take_quiz.ejs
@@ -0,0 +1,21 @@
+<%- include("partials/header", { title: quiz.title }) %>
+<section class="panel">
+  <h1><%= quiz.title %></h1>
+  <p><%= quiz.description %></p>
+  <form action="/student/quizzes/<%= quiz.id %>/submit" method="post">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <% questions.forEach(function(question, index) { %>
+      <fieldset>
+        <legend><%= index + 1 %>. <%= question.prompt %></legend>
+        <% question.options.forEach(function(option) { %>
+          <label class="choice">
+            <input type="radio" name="question_<%= question.id %>" value="<%= option.id %>">
+            <span><%= option.text %></span>
+          </label>
+        <% }) %>
+      </fieldset>
+    <% }) %>
+    <button type="submit">Submit quiz</button>
+  </form>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/teacher_quiz_detail.ejs b/views/teacher_quiz_detail.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..6b27cc91541a153b169cd1844781d2bf601a110c
--- /dev/null
+++ b/views/teacher_quiz_detail.ejs
@@ -0,0 +1,33 @@
+<%- include("partials/header", { title: quiz.title }) %>
+<section class="panel">
+  <h1><%= quiz.title %></h1>
+  <p><%= quiz.description %></p>
+  <% let currentQuestion = null; %>
+  <% questions.forEach(function(row) { %>
+    <% if (currentQuestion !== row.id) { %>
+      <% currentQuestion = row.id; %>
+      <h2><%= row.prompt %></h2>
+    <% } %>
+    <p class="<%= row.is_correct ? "correct" : "" %>"><%= row.option_text %><%= row.is_correct ? " (correct)" : "" %></p>
+  <% }) %>
+</section>
+<section class="panel">
+  <h2>Attempts</h2>
+  <% if (!attempts.length) { %>
+    <p>No submissions yet.</p>
+  <% } else { %>
+    <table>
+      <thead><tr><th>Student</th><th>Score</th><th>Submitted</th></tr></thead>
+      <tbody>
+      <% attempts.forEach(function(attempt) { %>
+        <tr>
+          <td><%= attempt.username %></td>
+          <td><%= attempt.score %>/<%= attempt.total %></td>
+          <td><%= attempt.submitted_at %></td>
+        </tr>
+      <% }) %>
+      </tbody>
+    </table>
+  <% } %>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/teacher_quizzes.ejs b/views/teacher_quizzes.ejs
