diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..9f8c3c80ded127b960335f4f3e99e3ab2c9360da
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,233 @@
+:root {
+  color-scheme: light;
+  --bg: #f7f8fb;
+  --text: #17202a;
+  --muted: #5f6b7a;
+  --line: #d8dee8;
+  --surface: #ffffff;
+  --primary: #116466;
+  --primary-dark: #0b4446;
+  --premium: #7c4d12;
+  --danger: #9b1c1c;
+  --success: #136f3a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.5;
+}
+
+a {
+  color: var(--primary);
+}
+
+.site-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem 2rem;
+  background: var(--surface);
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  font-size: 1.25rem;
+  font-weight: 700;
+  text-decoration: none;
+  color: var(--text);
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+  flex-wrap: wrap;
+}
+
+.nav a {
+  text-decoration: none;
+  font-weight: 600;
+}
+
+.container {
+  width: min(1080px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.panel {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 2rem;
+}
+
+.panel.narrow {
+  max-width: 520px;
+  margin: 0 auto;
+}
+
+.panel.premium {
+  border-color: #d6a34f;
+}
+
+h1,
+h2 {
+  margin-top: 0;
+  line-height: 1.2;
+}
+
+p {
+  color: var(--muted);
+}
+
+form {
+  display: grid;
+  gap: 1rem;
+}
+
+label {
+  display: grid;
+  gap: 0.4rem;
+  font-weight: 700;
+}
+
+input,
+textarea,
+select {
+  width: 100%;
+  padding: 0.7rem;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  color: var(--text);
+  background: #fff;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 2.5rem;
+  padding: 0.65rem 1rem;
+  border: 1px solid var(--primary);
+  border-radius: 6px;
+  background: var(--primary);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--primary-dark);
+}
+
+.button.secondary {
+  background: #fff;
+  color: var(--primary);
+}
+
+.button.secondary:hover {
+  background: #eef6f6;
+}
+
+.inline-form {
+  display: inline;
+}
+
+.inline-form button {
+  min-height: auto;
+  padding: 0.45rem 0.75rem;
+}
+
+.actions,
+.grid {
+  display: grid;
+  gap: 1rem;
+}
+
+.actions {
+  grid-template-columns: repeat(auto-fit, minmax(150px, max-content));
+}
+
+.grid {
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message {
+  padding: 0.75rem 1rem;
+  border-radius: 6px;
+  background: #eef1f5;
+}
+
+.message.error {
+  color: var(--danger);
+  background: #fdecec;
+}
+
+.message.success {
+  color: var(--success);
+  background: #e9f7ef;
+}
+
+.note {
+  padding: 1rem;
+  background: #f3f6f9;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  white-space: pre-wrap;
+}
+
+.table-wrap {
+  overflow-x: auto;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+th,
+td {
+  padding: 0.8rem;
+  border-bottom: 1px solid var(--line);
+  text-align: left;
+  vertical-align: top;
+}
+
+.tier-form {
+  grid-template-columns: minmax(120px, 1fr) auto;
+  align-items: center;
+}
+
+@media (max-width: 720px) {
+  .site-header {
+    align-items: flex-start;
+    flex-direction: column;
+    padding: 1rem;
+  }
+
+  .panel {
+    padding: 1.25rem;
+  }
+
+  .tier-form {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/templates/admin_users.html b/templates/admin_users.html
new file mode 100644
index 0000000000000000000000000000000000000000..f8aa199b5724533a8975f9a7931005905508bec3
--- /dev/null
+++ b/templates/admin_users.html
@@ -0,0 +1,39 @@
+{% extends "base.html" %}
+{% block title %}Admin Users{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>User tiers</h1>
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th>User</th>
+          <th>Email</th>
+          <th>Tier</th>
+          <th>Change tier</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for user in users %}
+          <tr>
+            <td>{{ user.username }}</td>
+            <td>{{ user.email }}</td>
+            <td>{{ user.tier }}</td>
+            <td>
+              <form method="post" action="{{ url_for('change_tier', user_id=user.id) }}" class="tier-form">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <select name="tier" required>
+                  {% for tier in ["free", "premium", "admin"] %}
+                    <option value="{{ tier }}" {% if user.tier == tier %}selected{% endif %}>{{ tier }}</option>
+                  {% endfor %}
+                </select>
+                <button type="submit">Update</button>
+              </form>
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+</section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..168254701d5c7698a54f44838f8ec80d3b7be956
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,45 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Membership{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">Membership</a>
+    <nav class="nav" aria-label="Primary">
+      {% if g.user %}
+        <a href="{{ url_for('dashboard') }}">Dashboard</a>
+        <a href="{{ url_for('free_content') }}">Free</a>
+        {% if g.user.tier in ["premium", "admin"] %}
+          <a href="{{ url_for('premium_content') }}">Premium</a>
+        {% endif %}
+        {% if g.user.tier == "admin" %}
+          <a href="{{ url_for('admin_users') }}">Admin</a>
+        {% endif %}
+        <form method="post" action="{{ url_for('logout') }}" class="inline-form">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Log out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Log in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="messages" aria-live="polite">
+          {% for category, message in messages %}
+            <p class="message {{ category }}">{{ message }}</p>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..3ac75a1c7f8dffaec5b798365b7d7b2812a76c24
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,33 @@
+{% extends "base.html" %}
+{% block title %}Dashboard{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Dashboard</h1>
+  <p>Signed in as {{ g.user.username }}. Current tier: <strong>{{ g.user.tier }}</strong>.</p>
+  <div class="grid">
+    <article>
+      <h2>Your note</h2>
+      {% if note %}
+        <p class="note">{{ note.body }}</p>
+      {% else %}
+        <p>No note saved yet.</p>
+      {% endif %}
+      <form method="post" action="{{ url_for('save_note') }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <label>Private note
+          <textarea name="body" maxlength="500" rows="5" required></textarea>
+        </label>
+        <button type="submit">Save note</button>
+      </form>
+    </article>
+    <article>
+      <h2>Tier navigation</h2>
+      <p>Your navigation only shows areas available to your membership tier.</p>
+      <a class="button secondary" href="{{ url_for('free_content') }}">Open free content</a>
+      {% if g.user.tier in ["premium", "admin"] %}
+        <a class="button secondary" href="{{ url_for('premium_content') }}">Open premium content</a>
+      {% endif %}
+    </article>
+  </div>
+</section>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..1a7d475e10ee3c1bbe457419f616886fd511b37b
--- /dev/null
+++ b/templates/error.html
@@ -0,0 +1,9 @@
+{% extends "base.html" %}
+{% block title %}Error {{ code }}{% endblock %}
+{% block content %}
+<section class="panel narrow">
+  <h1>Error {{ code }}</h1>
+  <p>{{ message }}</p>
+  <a class="button secondary" href="{{ url_for('index') }}">Return home</a>
+</section>
+{% endblock %}
diff --git a/templates/free_content.html b/templates/free_content.html
new file mode 100644
index 0000000000000000000000000000000000000000..985468f25b20fa6cd67236d41cd08bcc4f39fd30
--- /dev/null
+++ b/templates/free_content.html
@@ -0,0 +1,13 @@
+{% extends "base.html" %}
+{% block title %}Free Content{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Free member content</h1>
+  <p>This area is available to every signed-in member.</p>
+  <ul>
+    <li>Starter guide</li>
+    <li>Community updates</li>
+    <li>Monthly public resources</li>
+  </ul>
