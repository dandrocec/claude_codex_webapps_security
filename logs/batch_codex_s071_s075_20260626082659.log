+<%- include("partials/header", { title }) %>
+<section class="auth-panel">
+  <h1><%= title %></h1>
+  <p><%= message %></p>
+  <p><a href="/">Return home</a></p>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/explore.ejs b/views/explore.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b90fb688dc16c1347e9f6cbdac1526e41bbcf2ab
--- /dev/null
+++ b/views/explore.ejs
@@ -0,0 +1,37 @@
+<%- include("partials/header", { title: "Explore" }) %>
+<section class="section-head">
+  <h1>Explore</h1>
+</section>
+<section class="people">
+  <h2>People</h2>
+  <% if (!users.length) { %><p class="empty">No other users yet.</p><% } %>
+  <% users.forEach((user) => { %>
+    <div class="person">
+      <span>@<%= user.username %></span>
+      <% if (user.followed) { %>
+        <form method="post" action="/users/<%= user.id %>/unfollow">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Unfollow</button>
+        </form>
+      <% } else { %>
+        <form method="post" action="/users/<%= user.id %>/follow">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Follow</button>
+        </form>
+      <% } %>
+    </div>
+  <% }) %>
+</section>
+<section>
+  <h2>All photos</h2>
+  <div class="photo-grid compact">
+    <% photos.forEach((photo) => { %>
+      <article class="photo-card">
+        <div class="photo-meta"><strong>@<%= photo.username %></strong><time><%= photo.created_at %></time></div>
+        <img src="/media/<%= photo.stored_name %>" alt="Photo by <%= photo.username %>">
+        <% if (photo.caption) { %><p><%= photo.caption %></p><% } %>
+      </article>
+    <% }) %>
+  </div>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/feed.ejs b/views/feed.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2f799c9ed26bd641c8ee66e2c5c645e884274eb2
--- /dev/null
+++ b/views/feed.ejs
@@ -0,0 +1,43 @@
+<%- include("partials/header", { title: "Feed" }) %>
+<section class="section-head">
+  <h1>Recent photos</h1>
+  <a class="button-link" href="/upload">Upload</a>
+</section>
+<% if (!photos.length) { %>
+  <p class="empty">Follow people or upload a photo to start your feed.</p>
+<% } %>
+<div class="photo-grid">
+  <% photos.forEach((photo) => { %>
+    <article class="photo-card">
+      <div class="photo-meta">
+        <strong>@<%= photo.username %></strong>
+        <time><%= photo.created_at %></time>
+      </div>
+      <img src="/media/<%= photo.stored_name %>" alt="Photo by <%= photo.username %>">
+      <% if (photo.caption) { %><p><%= photo.caption %></p><% } %>
+      <div class="actions">
+        <form method="post" action="/photos/<%= photo.id %>/like">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit"><%= photo.liked_by_me ? "Unlike" : "Like" %> (<%= photo.like_count %>)</button>
+        </form>
+        <% if (photo.user_id === currentUser.id) { %>
+          <form method="post" action="/photos/<%= photo.id %>/delete">
+            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+            <button type="submit" class="danger">Delete</button>
+          </form>
+        <% } %>
+      </div>
+      <div class="comments">
+        <% comments.filter((comment) => comment.photo_id === photo.id).forEach((comment) => { %>
+          <p><strong>@<%= comment.username %></strong> <%= comment.body %></p>
+        <% }) %>
+      </div>
+      <form method="post" action="/photos/<%= photo.id %>/comments" class="comment-form">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <input name="body" maxlength="500" required placeholder="Add a comment">
+        <button type="submit">Post</button>
+      </form>
+    </article>
+  <% }) %>
+</div>
+<%- include("partials/footer") %>
diff --git a/views/login.ejs b/views/login.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c7e7a847e1fe9bfea96b78f83ff310532ede73f6
--- /dev/null
+++ b/views/login.ejs
@@ -0,0 +1,13 @@
+<%- include("partials/header", { title: "Log in" }) %>
+<section class="auth-panel">
+  <h1>Log in</h1>
+  <% if (typeof error !== "undefined" && error) { %><p class="error"><%= error %></p><% } %>
+  <form method="post" action="/login" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Username <input name="username" autocomplete="username" maxlength="24" required></label>
+    <label>Password <input name="password" type="password" autocomplete="current-password" maxlength="128" required></label>
+    <button type="submit">Log in</button>
+  </form>
+  <p>Need an account? <a href="/register">Register</a></p>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/partials/footer.ejs b/views/partials/footer.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..8f0b997cf27cd319fccfc51d64ea2ce6551cb675
--- /dev/null
+++ b/views/partials/footer.ejs
@@ -0,0 +1,3 @@
+  </main>
+</body>
+</html>
diff --git a/views/partials/header.ejs b/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..853a5ccb29710e4d9b656f15a18d2f59b4711d48
--- /dev/null
+++ b/views/partials/header.ejs
@@ -0,0 +1,28 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= typeof title !== "undefined" ? title : "Photo Share" %></title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="/">Photo Share</a>
+    <nav>
+      <% if (currentUser) { %>
+        <a href="/feed">Feed</a>
+        <a href="/explore">Explore</a>
+        <a href="/upload">Upload</a>
+        <span>@<%= currentUser.username %></span>
+        <form action="/logout" method="post" class="inline">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Log out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Log in</a>
+        <a href="/register">Register</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="page">
diff --git a/views/register.ejs b/views/register.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2bd2f0483177744a1ec5b871c84ee6c8fd98d3a5
--- /dev/null
+++ b/views/register.ejs
@@ -0,0 +1,13 @@
+<%- include("partials/header", { title: "Register" }) %>
+<section class="auth-panel">
+  <h1>Create account</h1>
+  <% if (typeof error !== "undefined" && error) { %><p class="error"><%= error %></p><% } %>
+  <form method="post" action="/register" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Username <input name="username" autocomplete="username" minlength="3" maxlength="24" pattern="[A-Za-z0-9_]+" required></label>
+    <label>Password <input name="password" type="password" autocomplete="new-password" minlength="12" maxlength="128" required></label>
+    <button type="submit">Register</button>
+  </form>
+  <p>Already registered? <a href="/login">Log in</a></p>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/upload.ejs b/views/upload.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..a7205f931a6a3c9ea3cb3bd138c6933a3ff08439
--- /dev/null
+++ b/views/upload.ejs
@@ -0,0 +1,12 @@
+<%- include("partials/header", { title: "Upload" }) %>
+<section class="auth-panel">
+  <h1>Upload photo</h1>
+  <% if (typeof error !== "undefined" && error) { %><p class="error"><%= error %></p><% } %>
+  <form method="post" action="/photos" enctype="multipart/form-data" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Photo <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" required></label>
+    <label>Caption <textarea name="caption" maxlength="240" rows="3"></textarea></label>
+    <button type="submit">Share</button>
+  </form>
