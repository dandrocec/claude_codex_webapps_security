+        }
+        $body .= '<section class="panel"><h2>Order #' . (int) $order['id'] . ' - ' . money((int) $order['total_cents']) . '</h2><p class="muted">' . h($order['created_at']) . '</p><table><tr><th>Product</th><th>Vendor</th><th>Qty</th><th>Total</th></tr>' . $rows . '</table></section>';
