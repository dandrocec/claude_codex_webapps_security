diff --git a/src/views/feed.ejs b/src/views/feed.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..fb310e84744089c4e716471267fe7bd04451e2e9
--- /dev/null
+++ b/src/views/feed.ejs
@@ -0,0 +1,10 @@
+<%- include("layout", { body: `
+  <section class="page-title">
+    <div>
+      <h1>${title}</h1>
+      <p class="muted">${title === "Feed" ? "Recent photos from you and people you follow." : "Recent photos from everyone."}</p>
+    </div>
+    ${currentUser ? '<a class="button" href="/upload">Upload photo</a>' : '<a class="button" href="/register">Register</a>'}
+  </section>
+  ${include("partials/photos", { photos, commentsByPhoto, currentUser })}
+` }) %>
diff --git a/src/views/index.ejs b/src/views/index.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..21205531222b5408af9db50a959f1666572ca8e4
--- /dev/null
+++ b/src/views/index.ejs
@@ -0,0 +1,10 @@
+<%- include("layout", { body: `
+  <section class="page-title">
+    <div>
+      <h1>Share photos with people you follow.</h1>
+      <p class="muted">Create an account to upload, follow other photographers, like photos, and join the conversation.</p>
+    </div>
+    <a class="button" href="/register">Get started</a>
+  </section>
+  ${include("partials/photos", { photos, commentsByPhoto, currentUser })}
+` }) %>
diff --git a/src/views/layout.ejs b/src/views/layout.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c1d4269d2caf6c289658775ca8534a3b123c3815
--- /dev/null
+++ b/src/views/layout.ejs
@@ -0,0 +1,36 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title><%= title %> · Photo Share</title>
+    <link rel="stylesheet" href="/public/styles.css">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="<%= currentUser ? '/feed' : '/' %>">Photo Share</a>
+      <nav class="nav">
+        <% if (currentUser) { %>
+          <a href="/feed">Feed</a>
+          <a href="/explore">Explore</a>
+          <a href="/users">People</a>
+          <a href="/upload">Upload</a>
+          <a href="/users/<%= currentUser.username %>">@<%= currentUser.username %></a>
+          <form class="inline" action="/logout" method="post">
+            <button class="secondary" type="submit">Sign out</button>
+          </form>
+        <% } else { %>
+          <a href="/explore">Explore</a>
+          <a href="/login">Sign in</a>
+          <a class="button" href="/register">Register</a>
+        <% } %>
+      </nav>
+    </header>
+    <main class="container">
+      <% if (flash) { %>
+        <div class="flash <%= flash.type %>"><%= flash.message %></div>
+      <% } %>
+      <%- body %>
+    </main>
+  </body>
+</html>
diff --git a/src/views/login.ejs b/src/views/login.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..a608488325c072fc77b77b052f9577b0968feca2
--- /dev/null
+++ b/src/views/login.ejs
@@ -0,0 +1,16 @@
+<%- include("layout", { body: `
+  <section class="form-panel">
+    <h1>Sign In</h1>
+    <form action="/login" method="post">
+      <div class="field">
+        <label for="username">Username</label>
+        <input id="username" name="username" autocomplete="username" required>
+      </div>
+      <div class="field">
+        <label for="password">Password</label>
+        <input id="password" name="password" type="password" autocomplete="current-password" required>
+      </div>
+      <button type="submit">Sign in</button>
+    </form>
+  </section>
+` }) %>
diff --git a/src/views/partials/photos.ejs b/src/views/partials/photos.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..f4629798ee7c249df770f9773068f22e93783052
--- /dev/null
+++ b/src/views/partials/photos.ejs
@@ -0,0 +1,47 @@
+<% if (!photos.length) { %>
+  <div class="empty">No photos to show yet.</div>
+<% } else { %>
+  <section class="grid">
+    <% photos.forEach((photo) => { %>
+      <article class="photo-card">
+        <a href="/users/<%= photo.username %>">
+          <img src="/uploads/<%= photo.filename %>" alt="<%= photo.caption || photo.original_name %>">
+        </a>
+        <div class="photo-body">
+          <div class="photo-meta">
+            <strong><a href="/users/<%= photo.username %>">@<%= photo.username %></a></strong>
+            <span class="muted"><%= new Date(photo.created_at).toLocaleString() %></span>
+          </div>
+          <% if (photo.caption) { %>
+            <p class="caption"><%= photo.caption %></p>
+          <% } %>
+          <div class="actions">
+            <span class="muted"><%= photo.like_count %> likes · <%= photo.comment_count %> comments</span>
+            <% if (currentUser) { %>
+              <% if (photo.liked_by_me) { %>
+                <form action="/photos/<%= photo.id %>/like?_method=DELETE" method="post">
+                  <button class="secondary" type="submit">Unlike</button>
+                </form>
+              <% } else { %>
+                <form action="/photos/<%= photo.id %>/like" method="post">
+                  <button type="submit">Like</button>
+                </form>
+              <% } %>
+            <% } %>
+          </div>
+          <div class="comments">
+            <% (commentsByPhoto.get(photo.id) || []).forEach((comment) => { %>
+              <p class="comment"><strong>@<%= comment.username %></strong> <%= comment.body %></p>
+            <% }) %>
+            <% if (currentUser) { %>
+              <form class="comment-form" action="/photos/<%= photo.id %>/comments" method="post">
+                <input name="body" maxlength="300" placeholder="Add a comment" required>
+                <button type="submit">Post</button>
+              </form>
+            <% } %>
+          </div>
+        </div>
+      </article>
+    <% }) %>
+  </section>
+<% } %>
diff --git a/src/views/profile.ejs b/src/views/profile.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..8e776fb030dafff6c510d5f405d37a1a402fc79c
--- /dev/null
+++ b/src/views/profile.ejs
@@ -0,0 +1,14 @@
+<%- include("layout", { body: `
+  <section class="page-title">
+    <div>
+      <h1>@${profileUser.username}</h1>
+      <p class="muted">${profileUser.bio || "Photo Share member"}</p>
+    </div>
+    ${currentUser && currentUser.id !== profileUser.id ? (
+      isFollowing
+        ? `<form action="/users/${profileUser.id}/follow?_method=DELETE" method="post"><button class="secondary" type="submit">Unfollow</button></form>`
+        : `<form action="/users/${profileUser.id}/follow" method="post"><button type="submit">Follow</button></form>`
+    ) : ""}
+  </section>
+  ${include("partials/photos", { photos, commentsByPhoto, currentUser })}
+` }) %>
diff --git a/src/views/register.ejs b/src/views/register.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2153f4595b570f83d5f99da2a3b2de536a45a309
--- /dev/null
+++ b/src/views/register.ejs
@@ -0,0 +1,16 @@
+<%- include("layout", { body: `
+  <section class="form-panel">
+    <h1>Register</h1>
+    <form action="/register" method="post">
+      <div class="field">
+        <label for="username">Username</label>
+        <input id="username" name="username" pattern="[a-zA-Z0-9_]{3,24}" autocomplete="username" required>
+      </div>
+      <div class="field">
+        <label for="password">Password</label>
+        <input id="password" name="password" type="password" minlength="6" autocomplete="new-password" required>
+      </div>
+      <button type="submit">Create account</button>
+    </form>
+  </section>
+` }) %>
diff --git a/src/views/upload.ejs b/src/views/upload.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..f38c889fa6067d131b0acee7d6ead443d36199fb
--- /dev/null
+++ b/src/views/upload.ejs
@@ -0,0 +1,16 @@
+<%- include("layout", { body: `
+  <section class="form-panel">
+    <h1>Upload Photo</h1>
+    <form action="/photos" method="post" enctype="multipart/form-data">
+      <div class="field">
+        <label for="photo">Image</label>
+        <input id="photo" name="photo" type="file" accept="image/*" required>
+      </div>
+      <div class="field">
+        <label for="caption">Caption</label>
+        <textarea id="caption" name="caption" maxlength="500" placeholder="What is happening in this photo?"></textarea>
+      </div>
+      <button type="submit">Upload</button>
+    </form>
+  </section>
