+const questions = document.querySelector('#questions');
+const addQuestion = document.querySelector('#addQuestion');
+
+addQuestion.addEventListener('click', () => {
+  const count = questions.querySelectorAll('.question-editor').length + 1;
+  const fieldset = document.createElement('fieldset');
+  fieldset.className = 'question-editor';
+  fieldset.innerHTML = `
+    <legend>Question ${count}</legend>
+    <label>
+      Prompt
+      <textarea name="prompt" rows="2" required></textarea>
+    </label>
+    <div class="option-grid">
+      <label>A <input name="option_a" required></label>
+      <label>B <input name="option_b" required></label>
+      <label>C <input name="option_c" required></label>
+      <label>D <input name="option_d" required></label>
+    </div>
+    <label>
+      Correct answer
+      <select name="correct_option" required>
+        <option value="">Select</option>
+        <option value="A">A</option>
+        <option value="B">B</option>
+        <option value="C">C</option>
+        <option value="D">D</option>
+      </select>
+    </label>
+  `;
+  questions.appendChild(fieldset);
+});
diff --git a/public/styles.css b/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..d2379694a042fa3a716ed0c1b17d9f6845888237
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,271 @@
+:root {
+  color-scheme: light;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: #f5f7fb;
+  color: #172033;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+}
+
+a {
+  color: #1f5fbd;
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid #dfe5f0;
+  display: flex;
+  justify-content: space-between;
+  padding: 16px clamp(18px, 4vw, 48px);
+}
+
+.brand {
+  color: #172033;
+  font-size: 1.1rem;
+  font-weight: 800;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  gap: 16px;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1080px;
+  padding: 32px clamp(18px, 4vw, 48px) 56px;
+}
+
+.hero,
+.panel,
+.card {
+  background: #ffffff;
+  border: 1px solid #dfe5f0;
+  border-radius: 8px;
+}
+
+.hero {
+  align-items: center;
+  display: flex;
+  gap: 24px;
+  justify-content: space-between;
+  margin-bottom: 32px;
+  padding: 32px;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  font-size: clamp(2rem, 5vw, 3.2rem);
+  line-height: 1.05;
+  margin-bottom: 12px;
+}
+
+h2 {
+  font-size: 1.35rem;
+}
+
+.button,
+button {
+  background: #1f5fbd;
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 700;
+  justify-content: center;
+  min-height: 42px;
+  padding: 10px 16px;
+  text-decoration: none;
+}
+
+.button:hover {
