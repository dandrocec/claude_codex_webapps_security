diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..b1c81508f874358b2872c7a872794f62ee8bc6ea
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,334 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f4;
+  --surface: #ffffff;
+  --text: #17201b;
+  --muted: #5f6f67;
+  --line: #dce3dd;
+  --accent: #0f766e;
+  --accent-dark: #115e59;
+  --gold: #b7791f;
+  --danger: #b42318;
+  --success: #287947;
+  --info: #315b8f;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+}
+
+a {
+  color: var(--accent-dark);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.site-header {
+  align-items: center;
+  background: rgba(255, 255, 255, 0.92);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  gap: 24px;
+  justify-content: space-between;
+  padding: 16px clamp(18px, 5vw, 56px);
+  position: sticky;
+  top: 0;
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.15rem;
+  font-weight: 900;
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 14px;
+  justify-content: flex-end;
+}
+
+.nav a {
+  color: var(--text);
+  font-size: 0.95rem;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 1100px;
+  padding: 42px clamp(18px, 5vw, 56px) 72px;
+}
+
+.hero {
+  align-items: center;
+  display: grid;
+  gap: 40px;
+  grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
+  min-height: 62vh;
+}
+
+.hero h1,
+.page-head h1,
+.auth-card h1 {
+  font-size: clamp(2rem, 7vw, 4.8rem);
+  letter-spacing: 0;
+  line-height: 1;
+  margin: 0;
+}
+
+.page-head h1,
+.auth-card h1 {
+  font-size: clamp(2rem, 5vw, 3.2rem);
+}
+
+.eyebrow {
+  color: var(--accent-dark);
+  font-size: 0.78rem;
+  font-weight: 900;
+  letter-spacing: 0.12em;
+  margin: 0 0 12px;
+  text-transform: uppercase;
+}
+
+.lead {
+  color: var(--muted);
+  font-size: 1.12rem;
+  line-height: 1.65;
+  max-width: 680px;
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+  margin-top: 26px;
+}
+
+.button,
+button.button {
+  background: var(--accent);
+  border: 1px solid var(--accent);
+  border-radius: 8px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 800;
+  justify-content: center;
+  line-height: 1;
+  padding: 13px 18px;
+}
+
+.button:hover,
+button.button:hover {
+  background: var(--accent-dark);
+  border-color: var(--accent-dark);
+}
+
+.button.secondary {
+  background: transparent;
+  color: var(--accent-dark);
+}
+
+.button.small {
+  min-height: 36px;
+  padding: 9px 12px;
+}
+
+.tier-panel,
+.auth-card,
+.card,
+.table-wrap {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  box-shadow: 0 18px 45px rgba(23, 32, 27, 0.08);
+}
+
+.tier-panel {
+  display: grid;
+  gap: 14px;
+  padding: 20px;
+}
+
+.tier {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  display: grid;
+  gap: 6px;
+  padding: 18px;
+}
+
+.tier strong {
+  font-size: 1.2rem;
+}
+
+.tier span,
+.card p {
+  color: var(--muted);
+  line-height: 1.6;
+}
+
+.tier.premium {
+  border-color: rgba(183, 121, 31, 0.5);
+  background: #fff8eb;
+}
+
+.page-head {
+  margin-bottom: 28px;
+}
+
+.grid {
+  display: grid;
+  gap: 18px;
+  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
+}
+
+.card {
+  padding: 22px;
+}
+
+.card h2 {
+  font-size: 1.2rem;
+  margin: 0 0 10px;
+}
+
+.card.wide {
