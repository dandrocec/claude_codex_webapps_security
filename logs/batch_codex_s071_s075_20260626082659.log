diff --git a/views/explore.ejs b/views/explore.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b90fb688dc16c1347e9f6cbdac1526e41bbcf2ab
--- /dev/null
+++ b/views/explore.ejs
@@ -0,0 +1,37 @@
+<%- include("partials/header", { title: "Explore" }) %>
+<section class="section-head">
+  <h1>Explore</h1>
+</section>
+<section class="people">
+  <h2>People</h2>
+  <% if (!users.length) { %><p class="empty">No other users yet.</p><% } %>
+  <% users.forEach((user) => { %>
+    <div class="person">
+      <span>@<%= user.username %></span>
+      <% if (user.followed) { %>
+        <form method="post" action="/users/<%= user.id %>/unfollow">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Unfollow</button>
+        </form>
+      <% } else { %>
+        <form method="post" action="/users/<%= user.id %>/follow">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Follow</button>
+        </form>
+      <% } %>
+    </div>
+  <% }) %>
+</section>
+<section>
+  <h2>All photos</h2>
+  <div class="photo-grid compact">
+    <% photos.forEach((photo) => { %>
+      <article class="photo-card">
+        <div class="photo-meta"><strong>@<%= photo.username %></strong><time><%= photo.created_at %></time></div>
+        <img src="/media/<%= photo.stored_name %>" alt="Photo by <%= photo.username %>">
+        <% if (photo.caption) { %><p><%= photo.caption %></p><% } %>
+      </article>
+    <% }) %>
+  </div>
+</section>
+<%- include("partials/footer") %>
diff --git a/views/feed.ejs b/views/feed.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2f799c9ed26bd641c8ee66e2c5c645e884274eb2
--- /dev/null
+++ b/views/feed.ejs
@@ -0,0 +1,43 @@
+<%- include("partials/header", { title: "Feed" }) %>
+<section class="section-head">
+  <h1>Recent photos</h1>
+  <a class="button-link" href="/upload">Upload</a>
+</section>
+<% if (!photos.length) { %>
+  <p class="empty">Follow people or upload a photo to start your feed.</p>
+<% } %>
+<div class="photo-grid">
+  <% photos.forEach((photo) => { %>
+    <article class="photo-card">
+      <div class="photo-meta">
+        <strong>@<%= photo.username %></strong>
+        <time><%= photo.created_at %></time>
+      </div>
+      <img src="/media/<%= photo.stored_name %>" alt="Photo by <%= photo.username %>">
+      <% if (photo.caption) { %><p><%= photo.caption %></p><% } %>
+      <div class="actions">
+        <form method="post" action="/photos/<%= photo.id %>/like">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit"><%= photo.liked_by_me ? "Unlike" : "Like" %> (<%= photo.like_count %>)</button>
+        </form>
+        <% if (photo.user_id === currentUser.id) { %>
+          <form method="post" action="/photos/<%= photo.id %>/delete">
+            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+            <button type="submit" class="danger">Delete</button>
+          </form>
+        <% } %>
+      </div>
+      <div class="comments">
+        <% comments.filter((comment) => comment.photo_id === photo.id).forEach((comment) => { %>
+          <p><strong>@<%= comment.username %></strong> <%= comment.body %></p>
+        <% }) %>
+      </div>
+      <form method="post" action="/photos/<%= photo.id %>/comments" class="comment-form">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <input name="body" maxlength="500" required placeholder="Add a comment">
+        <button type="submit">Post</button>
+      </form>
+    </article>
+  <% }) %>
+</div>
+<%- include("partials/footer") %>
diff --git a/views/login.ejs b/views/login.ejs
