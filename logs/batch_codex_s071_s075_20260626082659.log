+          <label><input type="radio" name="answer_<%= question.id %>" value="B"> <%= question.option_b %></label>
+          <label><input type="radio" name="answer_<%= question.id %>" value="C"> <%= question.option_c %></label>
+          <label><input type="radio" name="answer_<%= question.id %>" value="D"> <%= question.option_d %></label>
+        </fieldset>
+      <% }) %>
+    </div>
+
+    <button class="button" type="submit">Submit quiz</button>
