+<%- include("partials/header", { title: "Log in" }) %>
+<section class="auth-panel">
+  <h1>Log in</h1>
+  <% if (typeof error !== "undefined" && error) { %><p class="error"><%= error %></p><% } %>
+  <form method="post" action="/login" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Username <input name="username" autocomplete="username" maxlength="24" required></label>
+    <label>Password <input name="password" type="password" autocomplete="current-password" maxlength="128" required></label>
+    <button type="submit">Log in</button>
+  </form>
+  <p>Need an account? <a href="/register">Register</a></p>
+</section>
+<%- include("partials/footer") %>
