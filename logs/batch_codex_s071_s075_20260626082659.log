diff --git a/templates/premium_content.html b/templates/premium_content.html
new file mode 100644
index 0000000000000000000000000000000000000000..22f62b3ba1b950e2bd817d4925a3209cb2373f8a
--- /dev/null
+++ b/templates/premium_content.html
@@ -0,0 +1,13 @@
+{% extends "base.html" %}
+{% block title %}Premium Content{% endblock %}
+{% block content %}
+<section class="panel premium">
+  <h1>Premium content</h1>
+  <p>This private area is available only to premium members and admins.</p>
+  <ul>
+    <li>Advanced tutorials</li>
+    <li>Downloadable premium resources</li>
+    <li>Members-only briefings</li>
+  </ul>
+</section>
+{% endblock %}
