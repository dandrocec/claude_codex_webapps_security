+<%- include("partials/header", { title: "My quizzes" }) %>
+<div class="heading-row">
+  <h1>My quizzes</h1>
+  <a class="button" href="/teacher/quizzes/new">New quiz</a>
+</div>
+<section class="grid">
+  <% if (!quizzes.length) { %>
+    <p>No quizzes yet.</p>
+  <% } %>
+  <% quizzes.forEach(function(quiz) { %>
