+{% extends "base.html" %}
+{% block title %}Forbidden{% endblock %}
+{% block content %}
+  <section class="page-head">
+    <p class="eyebrow">Forbidden</p>
+    <h1>Admin access is required.</h1>
+    <p class="lead">Your account does not have permission to view that page.</p>
+  </section>
+{% endblock %}
diff --git a/templates/admin_users.html b/templates/admin_users.html
new file mode 100644
index 0000000000000000000000000000000000000000..d6dd20d978c4c3c41f9030b0fd13efbe7a894a14
--- /dev/null
+++ b/templates/admin_users.html
@@ -0,0 +1,43 @@
+{% extends "base.html" %}
+{% block title %}Admin Users{% endblock %}
+{% block content %}
+  <section class="page-head">
+    <p class="eyebrow">Admin</p>
+    <h1>User tiers</h1>
+    <p class="lead">Change a member between free and premium access.</p>
+  </section>
+
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th>Name</th>
+          <th>Email</th>
+          <th>Role</th>
+          <th>Tier</th>
+          <th>Change Tier</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for user in users %}
+          <tr>
+            <td>{{ user["name"] }}</td>
+            <td>{{ user["email"] }}</td>
+            <td>{{ "Admin" if user["is_admin"] else "Member" }}</td>
+            <td><span class="pill {{ user['tier'] }}">{{ user["tier"]|title }}</span></td>
+            <td>
+              <form class="inline-form" method="post">
+                <input type="hidden" name="user_id" value="{{ user['id'] }}">
+                <select name="tier" aria-label="Tier for {{ user['email'] }}">
+                  <option value="free" {% if user["tier"] == "free" %}selected{% endif %}>Free</option>
+                  <option value="premium" {% if user["tier"] == "premium" %}selected{% endif %}>Premium</option>
+                </select>
+                <button class="button small" type="submit">Save</button>
+              </form>
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..bf4a2bad076481612a2e83c4f120d70ac08165e9
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,45 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Membership{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">MemberSpace</a>
+    <nav class="nav">
+      {% if g.user %}
+        <a href="{{ url_for('dashboard') }}">Dashboard</a>
+        {% if g.user["tier"] == "premium" or g.user["is_admin"] %}
+          <a href="{{ url_for('premium') }}">Premium Library</a>
+        {% else %}
+          <a href="{{ url_for('upgrade') }}">Upgrade</a>
+        {% endif %}
+        {% if g.user["is_admin"] %}
+          <a href="{{ url_for('admin_users') }}">Admin</a>
+        {% endif %}
+        <a href="{{ url_for('logout') }}">Logout</a>
+      {% else %}
+        <a href="{{ url_for('index') }}">Home</a>
+        <a href="{{ url_for('login') }}">Login</a>
+        <a class="button small" href="{{ url_for('register') }}">Join Free</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="flash-list">
+          {% for category, message in messages %}
+            <div class="flash {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
