+            SELECT orders.*, users.email
+            FROM orders JOIN users ON users.id = orders.user_id
+            WHERE orders.status = ?
+            ORDER BY orders.created_at DESC
+            """,
+            (status,),
+        )
+    else:
+        orders = query_all(
+            """
+            SELECT orders.*, users.email
+            FROM orders JOIN users ON users.id = orders.user_id
+            ORDER BY orders.created_at DESC
+            """
+        )
