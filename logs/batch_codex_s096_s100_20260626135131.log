diff --git a/templates/orders.html b/templates/orders.html
new file mode 100644
index 0000000000000000000000000000000000000000..b91e35501dfcd73bbf17081f2cdd30884d55211f
--- /dev/null
+++ b/templates/orders.html
@@ -0,0 +1,18 @@
+{% extends "base.html" %}
+{% block title %}Orders{% endblock %}
+{% block content %}
