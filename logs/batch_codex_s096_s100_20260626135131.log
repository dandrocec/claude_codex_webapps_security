+}
+
+.danger {
+  background: #fee2e2;
+}
+
+.warning {
+  background: #fef3c7;
+}
+
+.info {
+  background: #dbeafe;
+}
+
+.stat-grid {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
+  margin: 22px 0;
+}
+
+.stat-grid div {
+  padding: 18px;
+}
+
+.stat-grid span {
+  color: var(--muted);
+  display: block;
+}
+
+.stat-grid strong {
+  font-size: 2rem;
+}
+
+.admin-tabs {
+  justify-content: flex-start;
+  margin: 18px 0;
+}
+
+@media (max-width: 780px) {
+  .site-header,
+  .hero,
+  .detail-layout,
+  .split,
+  .admin-head {
+    align-items: stretch;
+    display: grid;
+    grid-template-columns: 1fr;
+  }
+
+  .page {
+    padding: 20px;
+  }
+
+  .search-form,
+  .inline-form,
+  .status-form {
+    display: grid;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
