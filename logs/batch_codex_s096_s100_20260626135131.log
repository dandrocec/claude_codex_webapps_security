+  <thead><tr><th>Order</th><th>Customer</th><th>Status</th><th>Total</th><th>Date</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+    <tr><td><a href="{{ url_for('admin_order_detail', order_id=order.id) }}">#{{ order.id }}</a></td><td>{{ order.email }}</td><td>{{ order.status }}</td><td>{{ order.total_cents|money }}</td><td>{{ order.created_at }}</td></tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/admin/product_form.html b/templates/admin/product_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..e150be5094356e69f6cb6bead673eaae32cda954
--- /dev/null
+++ b/templates/admin/product_form.html
@@ -0,0 +1,14 @@
+{% extends "base.html" %}
+{% block title %}Product{% endblock %}
+{% block content %}
+<h1>{{ "Edit" if product else "New" }} product</h1>
+<form method="post" class="form">
+  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+  <label>Name <input name="name" required maxlength="120" value="{{ product.name if product else '' }}"></label>
+  <label>Description <textarea name="description" required maxlength="1000">{{ product.description if product else '' }}</textarea></label>
+  <label>Price <input name="price" required value="{{ product.price_cents|price_input if product else '' }}"></label>
+  <label>Inventory <input name="inventory" type="number" min="0" max="100000" required value="{{ product.inventory if product else 0 }}"></label>
+  <label class="check"><input name="active" type="checkbox" {% if not product or product.active %}checked{% endif %}> Active</label>
+  <button type="submit">Save</button>
+</form>
+{% endblock %}
diff --git a/templates/admin/products.html b/templates/admin/products.html
new file mode 100644
index 0000000000000000000000000000000000000000..3441bf8300d40ee3aed004d3956c911423a8e6f4
--- /dev/null
+++ b/templates/admin/products.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block title %}Products Admin{% endblock %}
+{% block content %}
+<h1>Products</h1>
+<p><a class="button" href="{{ url_for('admin_product_new') }}">New product</a></p>
+<table>
+  <thead><tr><th>Name</th><th>Price</th><th>Inventory</th><th>Active</th><th></th></tr></thead>
+  <tbody>
+    {% for product in products %}
+    <tr>
+      <td>{{ product.name }}</td>
+      <td>{{ product.price_cents|money }}</td>
+      <td>{{ product.inventory }}</td>
+      <td>{{ "yes" if product.active else "no" }}</td>
+      <td><a href="{{ url_for('admin_product_edit', product_id=product.id) }}">Edit</a></td>
+    </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..fec0f9084c324b3efa7c91ae76222fc1b4b4b6cf
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,41 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Secure Shop{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Secure Shop</a>
+    <nav>
+      <a href="{{ url_for('index') }}">Storefront</a>
+      {% if user %}
+        <a href="{{ url_for('cart') }}">Cart ({{ cart_count }})</a>
+        <a href="{{ url_for('orders') }}">Orders</a>
+        {% if user.is_admin %}<a href="{{ url_for('admin_dashboard') }}">Admin</a>{% endif %}
+        <form class="inline" method="post" action="{{ url_for('logout') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="flash-list">
+          {% for category, message in messages %}
+            <div class="flash {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
new file mode 100644
index 0000000000000000000000000000000000000000..a1ee7d906c7e5c4f1bdf9ee4d98e443e08fb78db
--- /dev/null
+++ b/templates/cart.html
@@ -0,0 +1,24 @@
+{% extends "base.html" %}
+{% block title %}Cart{% endblock %}
+{% block content %}
+<h1>Cart</h1>
+<form method="post">
+  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+  <table>
+    <thead><tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr></thead>
+    <tbody>
+      {% for item in items %}
+      <tr>
+        <td>{{ item.name }}</td>
+        <td>{{ item.price_cents|money }}</td>
+        <td><input type="number" name="qty_{{ item.id }}" value="{{ item.quantity }}" min="0" max="{{ item.inventory }}"></td>
+        <td>{{ item.line_total|money }}</td>
+      </tr>
+      {% endfor %}
+    </tbody>
+  </table>
+  <p class="price">Total: {{ total|money }}</p>
+  <button type="submit">Update cart</button>
+  <a class="button" href="{{ url_for('checkout') }}">Checkout</a>
+</form>
+{% endblock %}
