+<%- include("partials/header") %>
+<section class="panel">
+  <h1>Create account</h1>
+  <form method="post" action="/register" autocomplete="off">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label for="email">Email</label>
+    <input id="email" name="email" type="email" maxlength="254" required>
+    <label for="password">Password</label>
+    <input id="password" name="password" type="password" minlength="12" maxlength="128" required>
+    <label for="role">Role</label>
+    <select id="role" name="role">
+      <option value="viewer">Viewer</option>
+      <option value="operator">Operator</option>
+    </select>
+    <p><button type="submit">Register</button></p>
+  </form>
+</section>
+<%- include("partials/footer") %>
diff --git a/src/views/service_detail.ejs b/src/views/service_detail.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b1eda1751016627ae8b113906180191af1bae3b4
--- /dev/null
+++ b/src/views/service_detail.ejs
@@ -0,0 +1,70 @@
+<%- include("partials/header") %>
+<section class="panel">
+  <div class="row">
+    <div>
+      <h1><%= service.name %></h1>
+      <p class="muted"><%= service.repository_url %></p>
+    </div>
+    <% if (user.role === "operator") { %>
+      <div class="nav">
+        <a class="button secondary" href="/services/<%= service.id %>/edit">Edit</a>
+        <form method="post" action="/services/<%= service.id %>/deploy">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Deploy</button>
+        </form>
+      </div>
+    <% } %>
+  </div>
+  <h2>Deployment steps</h2>
+  <pre><%= deploySteps %></pre>
+</section>
+
+<% if (user.role === "operator") { %>
+  <section class="panel">
+    <h2>Secrets</h2>
+    <form method="post" action="/services/<%= service.id %>/secrets">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <label for="name">Name</label>
+      <input id="name" name="name" placeholder="API_TOKEN" maxlength="80" required>
+      <label for="value">Value</label>
+      <input id="value" name="value" type="password" maxlength="4000" required>
+      <p><button type="submit">Save secret</button></p>
+    </form>
+    <table>
+      <thead><tr><th>Name</th><th>Updated</th><th></th></tr></thead>
+      <tbody>
+        <% secrets.forEach((secret) => { %>
+          <tr>
+            <td><%= secret.name %></td>
+            <td><%= secret.updated_at %></td>
+            <td>
+              <form method="post" action="/services/<%= service.id %>/secrets/<%= secret.id %>/delete">
+                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+                <button class="danger" type="submit">Delete</button>
+              </form>
+            </td>
+          </tr>
+        <% }) %>
+      </tbody>
+    </table>
+  </section>
+<% } %>
+
+<section class="panel">
+  <h2>Deployments</h2>
+  <table>
+    <thead><tr><th>ID</th><th>Status</th><th>Triggered by</th><th>Started</th><th>Finished</th></tr></thead>
+    <tbody>
+      <% deployments.forEach((deployment) => { %>
+        <tr>
+          <td><a href="/deployments/<%= deployment.id %>">#<%= deployment.id %></a></td>
+          <td><span class="badge <%= deployment.status %>"><%= deployment.status %></span></td>
+          <td><%= deployment.triggered_by_email %></td>
+          <td><%= deployment.started_at || "" %></td>
+          <td><%= deployment.finished_at || "" %></td>
+        </tr>
+      <% }) %>
+    </tbody>
+  </table>
+</section>
+<%- include("partials/footer") %>
diff --git a/src/views/service_form.ejs b/src/views/service_form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..12bab9e1baf6c4a76f3f1631fbd9cfd446fe5e98
--- /dev/null
+++ b/src/views/service_form.ejs
@@ -0,0 +1,17 @@
+<%- include("partials/header") %>
+<section class="panel">
+  <h1><%= service ? "Edit service" : "New service" %></h1>
+  <form method="post" action="<%= service ? `/services/${service.id}` : "/services" %>">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label for="name">Name</label>
+    <input id="name" name="name" maxlength="80" value="<%= service ? service.name : "" %>" required>
+    <label for="repository_url">Repository URL</label>
+    <input id="repository_url" name="repository_url" type="url" maxlength="500" value="<%= service ? service.repository_url : "" %>" required>
+    <label for="working_directory">Working directory</label>
+    <input id="working_directory" name="working_directory" maxlength="500" value="<%= service && service.working_directory ? service.working_directory : "" %>">
+    <label for="deploy_steps">Deployment steps</label>
+    <textarea id="deploy_steps" name="deploy_steps" maxlength="4000" required><%= deploySteps %></textarea>
+    <p><button type="submit">Save service</button></p>
+  </form>
+</section>
+<%- include("partials/footer") %>
diff --git a/src/views/services.ejs b/src/views/services.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c38a68528e48af30e781177138b21a7c99c19bb1
--- /dev/null
+++ b/src/views/services.ejs
@@ -0,0 +1,23 @@
+<%- include("partials/header") %>
+<div class="row">
+  <h1>Services</h1>
+  <% if (user.role === "operator") { %><a class="button" href="/services/new">New service</a><% } %>
+</div>
+<section class="grid">
+  <% services.forEach((service) => { %>
+    <article class="card">
+      <div class="row">
+        <h2><a href="/services/<%= service.id %>"><%= service.name %></a></h2>
+        <% if (service.last_status) { %><span class="badge <%= service.last_status %>"><%= service.last_status %></span><% } %>
+      </div>
+      <p class="muted"><%= service.repository_url %></p>
+      <% if (service.last_deployment_id) { %>
+        <a href="/deployments/<%= service.last_deployment_id %>">Latest deployment</a>
+      <% } %>
+    </article>
+  <% }) %>
+  <% if (services.length === 0) { %>
+    <p class="muted">No services registered.</p>
+  <% } %>
+</section>
+<%- include("partials/footer") %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..1d743726c0cca5452086481d1c0b84a03fc9d522
--- /dev/null
+++ b/README.md
@@ -0,0 +1,29 @@
+# DevOps Dashboard
+
+Node.js/Express dashboard for registering services, managing per-service encrypted environment secrets, triggering shell-step deployments, and viewing stored/streamed deployment logs.
+
+## Run locally on port 5100
+
+1. Install dependencies:
+   ```sh
+   npm install
+   ```
+2. Set required secrets:
+   ```sh
+   export SESSION_SECRET="replace-with-a-long-random-session-secret"
+   export APP_ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"
+   export COOKIE_SECURE="false"
+   ```
+   PowerShell equivalent:
+   ```powershell
+   $env:SESSION_SECRET="replace-with-a-long-random-session-secret"
+   $env:APP_ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"
+   $env:COOKIE_SECURE="false"
+   ```
+3. Start the app:
+   ```sh
+   npm start
+   ```
+4. Open `http://localhost:5100`.
+
+Use `COOKIE_SECURE=true` behind HTTPS in production. The first registered account may choose `operator`; operators can create services, manage secrets, and deploy. Viewers can only read their own dashboard data.
