+<ul>
+  {% for item in items %}
+  <li>{{ item.quantity }} × {{ item.name }}: {{ (item.quantity * item.price_cents)|money }}</li>
+  {% endfor %}
+</ul>
+<p class="price">Total: {{ total|money }}</p>
+<form method="post" class="form">
+  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+  <label>Shipping name <input name="shipping_name" required maxlength="100"></label>
+  <label>Shipping address <textarea name="shipping_address" required maxlength="500"></textarea></label>
+  <button type="submit">Place order</button>
+</form>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..836cd15599aa9b03e779fb032d8f1f88bc770205
--- /dev/null
+++ b/templates/error.html
@@ -0,0 +1,6 @@
+{% extends "base.html" %}
+{% block title %}Error {{ code }}{% endblock %}
+{% block content %}
+<h1>Error {{ code }}</h1>
+<p>The request could not be completed.</p>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
