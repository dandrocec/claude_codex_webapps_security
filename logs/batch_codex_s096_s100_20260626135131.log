diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..452bfcdd3b94012194f8214bb6284f917fe98374
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,172 @@
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  color: #1f2933;
+  background: #f6f7f9;
+}
+
+a {
+  color: #075985;
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 14px 24px;
+  background: #111827;
+  color: #fff;
+}
+
+.topbar a,
+.topbar button {
+  color: #fff;
+}
+
+.brand {
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 14px;
+  flex-wrap: wrap;
+}
+
+.container {
+  max-width: 1120px;
+  margin: 0 auto;
+  padding: 28px 20px 48px;
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
+  gap: 18px;
+}
+
+.card,
+.panel,
+.review,
+.form,
+.flash,
+.stats > div {
+  background: #fff;
+  border: 1px solid #d9e0e8;
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.price {
+  font-size: 1.2rem;
+  font-weight: 700;
+}
+
+form {
+  display: grid;
+  gap: 12px;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 600;
+}
+
+input,
+textarea,
+select {
+  width: 100%;
+  padding: 10px;
+  border: 1px solid #b7c2cf;
+  border-radius: 6px;
+  font: inherit;
+}
+
+textarea {
+  min-height: 100px;
+}
+
+button,
+.button {
+  display: inline-block;
+  width: fit-content;
+  padding: 10px 14px;
+  border: 0;
+  border-radius: 6px;
+  background: #0f766e;
+  color: #fff;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+button:disabled {
+  background: #94a3b8;
+  cursor: not-allowed;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+  background: #fff;
+  border: 1px solid #d9e0e8;
+}
+
+th,
+td {
+  padding: 12px;
+  border-bottom: 1px solid #d9e0e8;
+  text-align: left;
+  vertical-align: top;
+}
+
+.flash-list {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 18px;
+}
+
+.flash.error {
+  border-color: #dc2626;
+}
+
+.flash.success {
+  border-color: #16a34a;
+}
+
+.flash.warning {
+  border-color: #d97706;
+}
+
+.stats {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
+  gap: 14px;
+}
+
+.stats strong {
+  display: block;
+  font-size: 1.5rem;
+  margin-top: 6px;
+}
+
+.check {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+
+.check input {
+  width: auto;
+}
diff --git a/templates/admin/dashboard.html b/templates/admin/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..9af3f744ffb15fe926a45038e3811813a310f7a9
--- /dev/null
+++ b/templates/admin/dashboard.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block title %}Admin{% endblock %}
+{% block content %}
+<h1>Admin dashboard</h1>
+<div class="stats">
+  <div>Products <strong>{{ stats.products }}</strong></div>
+  <div>Orders <strong>{{ stats.orders }}</strong></div>
+  <div>Revenue <strong>{{ stats.revenue|money }}</strong></div>
+</div>
+<p><a class="button" href="{{ url_for('admin_products') }}">Manage products</a> <a class="button" href="{{ url_for('admin_orders') }}">Manage orders</a></p>
+<h2>Recent orders</h2>
+<table>
+  <thead><tr><th>Order</th><th>Customer</th><th>Status</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+    <tr><td><a href="{{ url_for('admin_order_detail', order_id=order.id) }}">#{{ order.id }}</a></td><td>{{ order.email }}</td><td>{{ order.status }}</td><td>{{ order.total_cents|money }}</td></tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/admin/order_detail.html b/templates/admin/order_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..4b611599ef57ac1c493852d9cbce01c6368a03cd
--- /dev/null
+++ b/templates/admin/order_detail.html
@@ -0,0 +1,27 @@
+{% extends "base.html" %}
+{% block title %}Admin Order #{{ order.id }}{% endblock %}
+{% block content %}
+<h1>Order #{{ order.id }}</h1>
+<p>Customer: {{ order.email }}</p>
+<p>Ship to: {{ order.shipping_name }}, {{ order.shipping_address }}</p>
+<form method="post">
+  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
+  <label>Status
+    <select name="status">
+      {% for status in statuses|sort %}
+      <option value="{{ status }}" {% if order.status == status %}selected{% endif %}>{{ status }}</option>
+      {% endfor %}
+    </select>
+  </label>
+  <button type="submit">Update</button>
+</form>
+<table>
+  <thead><tr><th>Product</th><th>Unit</th><th>Qty</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for item in items %}
+    <tr><td>{{ item.product_name }}</td><td>{{ item.unit_price_cents|money }}</td><td>{{ item.quantity }}</td><td>{{ item.line_total_cents|money }}</td></tr>
+    {% endfor %}
+  </tbody>
+</table>
+<p class="price">Total: {{ order.total_cents|money }}</p>
+{% endblock %}
