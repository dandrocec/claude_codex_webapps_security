+{% extends "base.html" %}
+{% block content %}
+<section class="auth-card">
+  <h1>{{ title }}</h1>
+  <p>{{ message }}</p>
+  <a class="button" href="{{ url_for('index') }}">Back to shop</a>
+</section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..5001c340491d83ca3bffa2fe76a541843925725a
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,44 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="hero">
+  <div>
+    <p class="eyebrow">Small-batch goods for home, work, and travel</p>
+    <h1>Shop practical pieces with live inventory.</h1>
+  </div>
+  <form class="search-form" method="get">
+    <input name="q" value="{{ search }}" placeholder="Search products">
+    <select name="category">
+      <option value="">All categories</option>
+      {% for row in categories %}
+        <option value="{{ row.category }}" {% if selected_category == row.category %}selected{% endif %}>{{ row.category }}</option>
+      {% endfor %}
+    </select>
+    <button type="submit">Filter</button>
+  </form>
+</section>
+
+<section class="product-grid">
+  {% for product in products %}
+    <article class="product-card">
+      <a href="{{ url_for('product_detail', product_id=product.id) }}">
+        <img src="{{ product.image_url }}" alt="{{ product.name }}">
+      </a>
+      <div class="product-body">
+        <span class="tag">{{ product.category }}</span>
+        <h2><a href="{{ url_for('product_detail', product_id=product.id) }}">{{ product.name }}</a></h2>
+        <p>{{ product.description }}</p>
+        <div class="row">
+          <strong>{{ product.price_cents|money }}</strong>
+          <span>{{ product.inventory }} in stock</span>
+        </div>
+        <form method="post" action="{{ url_for('add_to_cart', product_id=product.id) }}">
+          <input type="number" name="quantity" min="1" max="{{ product.inventory }}" value="1">
+          <button {% if product.inventory == 0 %}disabled{% endif %}>Add to cart</button>
+        </form>
+      </div>
+    </article>
+  {% else %}
+    <p>No products matched your filters.</p>
+  {% endfor %}
+</section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..9a8d0b2c7833f9b9cc9e28ef03dae6e7720e4240
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,11 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="auth-card">
+  <h1>Sign in</h1>
+  <form method="post" class="panel-form">
+    <label>Email <input name="email" type="email" required></label>
+    <label>Password <input name="password" type="password" required></label>
+    <button>Login</button>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/order_detail.html b/templates/order_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..f1cec12ec5592e373c260d60e1f20ed031319b9e
--- /dev/null
+++ b/templates/order_detail.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block content %}
+<h1>Order #{{ order.id }}</h1>
+<p>Status: <strong>{{ order.status }}</strong></p>
+<table>
+  <thead><tr><th>Product</th><th>Unit</th><th>Quantity</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for item in items %}
+      <tr>
+        <td>{{ item.product_name }}</td>
+        <td>{{ item.unit_price_cents|money }}</td>
+        <td>{{ item.quantity }}</td>
+        <td>{{ item.line_total_cents|money }}</td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% set cart = {"subtotal_cents": order.subtotal_cents, "tax_cents": order.tax_cents, "shipping_cents": order.shipping_cents, "total_cents": order.total_cents} %}
+{% include "_totals.html" %}
+{% endblock %}
diff --git a/templates/orders.html b/templates/orders.html
new file mode 100644
index 0000000000000000000000000000000000000000..0ef5613514b7c423680b81ffa539f73f12ad51ea
--- /dev/null
+++ b/templates/orders.html
@@ -0,0 +1,19 @@
+{% extends "base.html" %}
+{% block content %}
+<h1>Your orders</h1>
+<table>
+  <thead><tr><th>Order</th><th>Status</th><th>Date</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+      <tr>
+        <td><a href="{{ url_for('order_detail', order_id=order.id) }}">#{{ order.id }}</a></td>
+        <td>{{ order.status }}</td>
+        <td>{{ order.created_at[:10] }}</td>
+        <td>{{ order.total_cents|money }}</td>
+      </tr>
+    {% else %}
+      <tr><td colspan="4">No orders yet.</td></tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/product_detail.html b/templates/product_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..467df13e8a230019865e717efb1d3b1a7c2b9a45
--- /dev/null
+++ b/templates/product_detail.html
@@ -0,0 +1,52 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="detail-layout">
+  <img class="detail-image" src="{{ product.image_url }}" alt="{{ product.name }}">
+  <div>
+    <p class="eyebrow">{{ product.category }}</p>
+    <h1>{{ product.name }}</h1>
+    <p class="lead">{{ product.description }}</p>
+    <p class="price">{{ product.price_cents|money }}</p>
+    <p>{{ product.inventory }} available{% if average %} · {{ "%.1f"|format(average) }} average rating{% endif %}</p>
+    <form class="inline-form" method="post" action="{{ url_for('add_to_cart', product_id=product.id) }}">
+      <input type="number" name="quantity" min="1" max="{{ product.inventory }}" value="1">
+      <button {% if product.inventory == 0 %}disabled{% endif %}>Add to cart</button>
+    </form>
+  </div>
+</section>
+
+<section class="split">
+  <div>
+    <h2>Reviews</h2>
+    {% for review in reviews %}
+      <article class="review">
+        <strong>{{ review.user_name }}</strong>
+        <span>{{ "★" * review.rating }}{{ "☆" * (5 - review.rating) }}</span>
+        <p>{{ review.comment }}</p>
+      </article>
+    {% else %}
+      <p>No reviews yet.</p>
+    {% endfor %}
+  </div>
+  <div>
+    <h2>Write a review</h2>
+    {% if g.user %}
+      <form method="post" action="{{ url_for('add_review', product_id=product.id) }}" class="panel-form">
+        <label>Rating
+          <select name="rating">
+            {% for rating in [5,4,3,2,1] %}
+              <option value="{{ rating }}">{{ rating }}</option>
+            {% endfor %}
+          </select>
+        </label>
+        <label>Comment
+          <textarea name="comment" rows="4" required></textarea>
+        </label>
+        <button>Post review</button>
+      </form>
+    {% else %}
+      <p><a href="{{ url_for('login') }}">Sign in</a> to review this product.</p>
+    {% endif %}
+  </div>
+</section>
+{% endblock %}
