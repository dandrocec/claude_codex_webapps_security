diff --git a/src/views/partials/header.ejs b/src/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b8cd68368a893dafe3a4394cd8f8d5fea65741c7
--- /dev/null
+++ b/src/views/partials/header.ejs
@@ -0,0 +1,27 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>DevOps Dashboard</title>
+  <link rel="stylesheet" href="/styles.css">
+  <script src="/app.js" defer></script>
+</head>
+<body>
+  <header>
+    <a href="/services"><strong>DevOps Dashboard</strong></a>
+    <nav class="nav">
