+      status TEXT NOT NULL CHECK(status IN ('queued', 'running', 'succeeded', 'failed')),
+      started_at TEXT,
+      finished_at TEXT,
+      exit_code INTEGER,
+      created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
