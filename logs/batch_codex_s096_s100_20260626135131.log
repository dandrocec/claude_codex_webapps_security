+<aside class="totals">
+  <div><span>Subtotal</span><strong>{{ cart.subtotal_cents|money }}</strong></div>
+  <div><span>Tax</span><strong>{{ cart.tax_cents|money }}</strong></div>
+  <div><span>Shipping</span><strong>{{ cart.shipping_cents|money }}</strong></div>
+  <div class="grand"><span>Total</span><strong>{{ cart.total_cents|money }}</strong></div>
+</aside>
diff --git a/templates/admin/dashboard.html b/templates/admin/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..c197bf47451293b6c905d9428a69ecccb2805eab
--- /dev/null
+++ b/templates/admin/dashboard.html
@@ -0,0 +1,33 @@
+{% extends "base.html" %}
+{% block content %}
+<div class="admin-head">
+  <h1>Admin dashboard</h1>
+  <a class="button" href="{{ url_for('admin_product_new') }}">New product</a>
+</div>
+<section class="stat-grid">
+  <div><span>Orders</span><strong>{{ stats.orders }}</strong></div>
+  <div><span>Revenue</span><strong>{{ stats.revenue|money }}</strong></div>
+  <div><span>Products</span><strong>{{ stats.products }}</strong></div>
+  <div><span>Low stock</span><strong>{{ stats.low_stock }}</strong></div>
+</section>
+<nav class="admin-tabs">
+  <a href="{{ url_for('admin_products') }}">Products</a>
+  <a href="{{ url_for('admin_orders') }}">Orders</a>
+</nav>
+<h2>Recent orders</h2>
+<table>
+  <thead><tr><th>Order</th><th>Customer</th><th>Status</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for order in recent_orders %}
+      <tr>
+        <td><a href="{{ url_for('admin_order_detail', order_id=order.id) }}">#{{ order.id }}</a></td>
+        <td>{{ order.email }}</td>
+        <td>{{ order.status }}</td>
+        <td>{{ order.total_cents|money }}</td>
+      </tr>
+    {% else %}
+      <tr><td colspan="4">No orders yet.</td></tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/admin/order_detail.html b/templates/admin/order_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..ca45fccc5607b773dc279f05040a1f04c79439d6
--- /dev/null
+++ b/templates/admin/order_detail.html
@@ -0,0 +1,33 @@
+{% extends "base.html" %}
+{% block content %}
+<div class="admin-head">
+  <div>
+    <h1>Order #{{ order.id }}</h1>
+    <p>{{ order.email }} · {{ order.created_at[:10] }}</p>
+  </div>
+  <form method="post" class="status-form">
+    <select name="status">
+      {% for option in ["pending", "paid", "packed", "shipped", "cancelled"] %}
+        <option value="{{ option }}" {% if order.status == option %}selected{% endif %}>{{ option }}</option>
+      {% endfor %}
+    </select>
+    <button>Update</button>
+  </form>
+</div>
+<p><strong>Ship to:</strong> {{ order.shipping_name }}, {{ order.shipping_address }}</p>
+<table>
+  <thead><tr><th>Product</th><th>Unit</th><th>Quantity</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for item in items %}
+      <tr>
+        <td>{{ item.product_name }}</td>
+        <td>{{ item.unit_price_cents|money }}</td>
+        <td>{{ item.quantity }}</td>
+        <td>{{ item.line_total_cents|money }}</td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% set cart = {"subtotal_cents": order.subtotal_cents, "tax_cents": order.tax_cents, "shipping_cents": order.shipping_cents, "total_cents": order.total_cents} %}
+{% include "_totals.html" %}
+{% endblock %}
diff --git a/templates/admin/orders.html b/templates/admin/orders.html
new file mode 100644
index 0000000000000000000000000000000000000000..f89c70594b0af3e2bc6490903ae31f6a508a3f2a
--- /dev/null
+++ b/templates/admin/orders.html
@@ -0,0 +1,29 @@
+{% extends "base.html" %}
+{% block content %}
+<h1>Orders</h1>
+<form method="get" class="search-form compact">
+  <select name="status">
+    <option value="">All statuses</option>
+    {% for option in ["pending", "paid", "packed", "shipped", "cancelled"] %}
+      <option value="{{ option }}" {% if status == option %}selected{% endif %}>{{ option }}</option>
+    {% endfor %}
+  </select>
+  <button>Filter</button>
+</form>
+<table>
+  <thead><tr><th>Order</th><th>Customer</th><th>Status</th><th>Date</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+      <tr>
+        <td><a href="{{ url_for('admin_order_detail', order_id=order.id) }}">#{{ order.id }}</a></td>
+        <td>{{ order.email }}</td>
+        <td>{{ order.status }}</td>
+        <td>{{ order.created_at[:10] }}</td>
+        <td>{{ order.total_cents|money }}</td>
+      </tr>
+    {% else %}
+      <tr><td colspan="5">No orders found.</td></tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/admin/product_form.html b/templates/admin/product_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..bef81ebdc53a0feb04756844ee888cd00fe47586
--- /dev/null
+++ b/templates/admin/product_form.html
@@ -0,0 +1,14 @@
+{% extends "base.html" %}
+{% block content %}
+<h1>{{ "Edit product" if product else "New product" }}</h1>
+<form method="post" class="panel-form wide">
+  <label>Name <input name="name" value="{{ product.name if product else '' }}" required></label>
+  <label>Description <textarea name="description" rows="4" required>{{ product.description if product else '' }}</textarea></label>
+  <label>Category <input name="category" value="{{ product.category if product else '' }}"></label>
+  <label>Image URL <input name="image_url" value="{{ product.image_url if product else '' }}"></label>
+  <label>Price <input name="price" type="number" min="0" step="0.01" value="{{ '%.2f'|format((product.price_cents if product else 0) / 100) }}"></label>
+  <label>Inventory <input name="inventory" type="number" min="0" value="{{ product.inventory if product else 0 }}"></label>
+  <label class="checkbox"><input type="checkbox" name="active" {% if not product or product.active %}checked{% endif %}> Active</label>
+  <button>Save product</button>
+</form>
+{% endblock %}
diff --git a/templates/admin/products.html b/templates/admin/products.html
new file mode 100644
index 0000000000000000000000000000000000000000..af0d7b83307bdf0fbcd693748679c19df5b4ede6
--- /dev/null
+++ b/templates/admin/products.html
@@ -0,0 +1,22 @@
+{% extends "base.html" %}
+{% block content %}
+<div class="admin-head">
+  <h1>Products</h1>
+  <a class="button" href="{{ url_for('admin_product_new') }}">New product</a>
+</div>
+<table>
+  <thead><tr><th>Name</th><th>Category</th><th>Price</th><th>Inventory</th><th>Status</th><th></th></tr></thead>
+  <tbody>
+    {% for product in products %}
+      <tr>
+        <td>{{ product.name }}</td>
+        <td>{{ product.category }}</td>
+        <td>{{ product.price_cents|money }}</td>
+        <td>{{ product.inventory }}</td>
+        <td>{{ "Active" if product.active else "Hidden" }}</td>
+        <td><a href="{{ url_for('admin_product_edit', product_id=product.id) }}">Edit</a></td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..c0123abc09c634190f5147a68cf7a8210e07527d
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,40 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{{ title or "Northline Market" }}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('index') }}">Northline Market</a>
+    <nav>
+      <a href="{{ url_for('index') }}">Shop</a>
+      <a href="{{ url_for('cart') }}">Cart ({{ g.cart_count }})</a>
+      {% if g.user %}
+        <a href="{{ url_for('orders') }}">Orders</a>
+        {% if g.user.is_admin %}
+          <a href="{{ url_for('admin_dashboard') }}">Admin</a>
+        {% endif %}
+        <a href="{{ url_for('logout') }}">Logout</a>
+      {% else %}
+        <a href="{{ url_for('login') }}">Login</a>
+        <a class="button small" href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="page">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="flash-stack">
+          {% for category, message in messages %}
+            <div class="flash {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
new file mode 100644
index 0000000000000000000000000000000000000000..3198ff6bf611101d85408e1da7a54119c71f45e8
--- /dev/null
+++ b/templates/cart.html
@@ -0,0 +1,28 @@
+{% extends "base.html" %}
+{% block content %}
+<h1>Your cart</h1>
+{% if cart.items %}
+  <form method="post" action="{{ url_for('update_cart') }}">
+    <table>
+      <thead><tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr></thead>
+      <tbody>
+        {% for item in cart.items %}
+          <tr>
+            <td>{{ item.product.name }}</td>
+            <td>{{ item.product.price_cents|money }}</td>
+            <td><input type="number" name="quantity_{{ item.product.id }}" min="0" max="{{ item.product.inventory }}" value="{{ item.quantity }}"></td>
+            <td>{{ item.line_total_cents|money }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+    <div class="cart-actions">
+      <button type="submit">Update cart</button>
+      <a class="button" href="{{ url_for('checkout') }}">Checkout</a>
+    </div>
+  </form>
+  {% include "_totals.html" %}
+{% else %}
+  <p>Your cart is empty.</p>
+{% endif %}
+{% endblock %}
diff --git a/templates/checkout.html b/templates/checkout.html
new file mode 100644
index 0000000000000000000000000000000000000000..9fd6cd96ec38bb084be4acf4c9425bfe2f712a98
--- /dev/null
+++ b/templates/checkout.html
@@ -0,0 +1,23 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="split">
+  <div>
+    <h1>Checkout</h1>
+    <form method="post" class="panel-form">
+      <label>Shipping name <input name="shipping_name" value="{{ g.user.name }}" required></label>
+      <label>Shipping address <textarea name="shipping_address" rows="5" required></textarea></label>
+      <button>Place order</button>
+    </form>
+  </div>
+  <div>
+    <h2>Order summary</h2>
+    {% for item in cart.items %}
+      <div class="summary-line">
+        <span>{{ item.product.name }} x {{ item.quantity }}</span>
+        <strong>{{ item.line_total_cents|money }}</strong>
+      </div>
+    {% endfor %}
+    {% include "_totals.html" %}
+  </div>
+</section>
+{% endblock %}
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..28b7d90d75cd7c795c323d3c4830f36e93974371
--- /dev/null
+++ b/templates/error.html
