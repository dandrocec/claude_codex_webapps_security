+    req.params.id,
+    req.body.name,
+    req.body.value
+  );
+  res.redirect(`/services/${req.params.id}`);
+});
+app.post("/services/:serviceId/secrets/:secretId/delete", requireAuth, requireOperator, async (req, res) => {
