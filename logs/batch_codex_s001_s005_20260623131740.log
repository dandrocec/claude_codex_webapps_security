+{
+  "name": "secure-markdown-preview",
+  "version": "1.0.0",
+  "description": "A secure Node.js/Express Markdown preview app.",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js"
+  },
+  "dependencies": {
+    "bcrypt": "^5.1.1",
+    "better-sqlite3": "^11.10.0",
+    "connect-sqlite3": "^0.9.16",
+    "csurf": "^1.11.0",
+    "dotenv": "^16.5.0",
+    "ejs": "^3.1.10",
+    "express": "^4.21.2",
+    "express-rate-limit": "^7.5.0",
+    "express-session": "^1.18.1",
+    "helmet": "^8.1.0",
+    "joi": "^17.13.3",
+    "marked": "^15.0.12",
+    "sanitize-html": "^2.15.0"
+  },
+  "engines": {
+    "node": ">=18"
+  }
+}
