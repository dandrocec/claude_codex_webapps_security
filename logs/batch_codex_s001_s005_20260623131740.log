+        min-height: 42px;
+        border: 1px solid #aeb7c4;
+        border-radius: 6px;
+        padding: 8px 10px;
+        font-size: 1rem;
+      }
+
+      button,
+      input[type="submit"],
+      .button {
+        display: inline-block;
+        margin-top: 16px;
+        border: 0;
+        border-radius: 6px;
+        background: #0f766e;
+        color: #ffffff;
+        padding: 10px 16px;
+        font-size: 1rem;
+        font-weight: 700;
+        text-decoration: none;
+        cursor: pointer;
+      }
+
+      .errors {
+        margin: 10px 0 0;
+        padding-left: 20px;
+        color: #b42318;
+      }
+    </style>
+  </head>
+  <body>
+    <main>
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
