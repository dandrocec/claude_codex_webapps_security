+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Temperature Converter{% endblock %}</title>
+  <style>
+    :root {
+      color-scheme: light;
+      font-family: Arial, sans-serif;
+      background: #f5f7fb;
+      color: #172033;
+    }
+    body {
+      margin: 0;
+    }
+    header {
+      background: #ffffff;
+      border-bottom: 1px solid #d8deea;
+      padding: 16px 24px;
+    }
+    nav {
+      align-items: center;
