                $stmt->execute([':username' => $username, ':hash' => password_hash($password, PASSWORD_ARGON2ID)]);
                session_regenerate_id(true);
                $_SESSION['user_id'] = (int)db()->lastInsertId();
                $_SESSION['username'] = $username;
