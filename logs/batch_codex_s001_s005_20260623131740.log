+    }
+    nav a, button.link-button {
+      color: #1a5fb4;
+      font: inherit;
+      text-decoration: none;
+    }
+    button.link-button {
+      background: none;
+      border: 0;
+      cursor: pointer;
+      padding: 0;
+    }
+    main {
+      max-width: 860px;
+      margin: 32px auto;
+      padding: 0 24px;
+    }
+    .panel {
+      background: #ffffff;
+      border: 1px solid #d8deea;
+      border-radius: 8px;
+      padding: 24px;
+    }
+    label {
+      display: block;
+      font-weight: 700;
+      margin: 16px 0 8px;
+    }
+    input[type="text"], input[type="password"] {
+      border: 1px solid #9aa7bd;
+      border-radius: 6px;
+      box-sizing: border-box;
+      font: inherit;
+      max-width: 420px;
+      padding: 10px 12px;
+      width: 100%;
+    }
+    .radio-list label {
+      font-weight: 400;
+      margin: 8px 0;
+    }
+    button, input[type="submit"] {
+      background: #1f7a4f;
