+{% extends "base.html" %}
+{% block title %}Conversion History{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Conversion History</h1>
+  {% if rows %}
+    <table>
+      <thead>
+        <tr>
+          <th>Input</th>
+          <th>Direction</th>
+          <th>Output</th>
+          <th>Created</th>
+          <th>Action</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for row in rows %}
+          <tr>
+            <td>{{ row.input_value }}</td>
+            <td>{{ row.direction|direction_label }}</td>
+            <td>{{ row.output_value }}</td>
+            <td>{{ row.created_at }}</td>
+            <td>
+              <form action="{{ url_for('delete_history_item', conversion_id=row.id) }}" method="post">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <button class="danger" type="submit">Delete</button>
+              </form>
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p>No saved conversions yet.</p>
+  {% endif %}
+</section>
+{% endblock %}
