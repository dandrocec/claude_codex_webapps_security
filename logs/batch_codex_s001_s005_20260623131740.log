diff --git a/templates/history.html b/templates/history.html
new file mode 100644
index 0000000000000000000000000000000000000000..71bba6b5887e94066bf9f7817ce4a98c6cead92a
--- /dev/null
+++ b/templates/history.html
@@ -0,0 +1,38 @@
+{% extends "base.html" %}
+{% block title %}Conversion History{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Conversion History</h1>
+  {% if rows %}
+    <table>
+      <thead>
+        <tr>
+          <th>Input</th>
+          <th>Direction</th>
+          <th>Output</th>
+          <th>Created</th>
+          <th>Action</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for row in rows %}
+          <tr>
+            <td>{{ row.input_value }}</td>
+            <td>{{ row.direction|direction_label }}</td>
+            <td>{{ row.output_value }}</td>
+            <td>{{ row.created_at }}</td>
+            <td>
+              <form action="{{ url_for('delete_history_item', conversion_id=row.id) }}" method="post">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <button class="danger" type="submit">Delete</button>
+              </form>
+            </td>
+          </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  {% else %}
+    <p>No saved conversions yet.</p>
+  {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..a9a52ba57f77208c15da846027f0ab47e551726f
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,31 @@
+{% extends "base.html" %}
+{% block title %}Convert Temperature{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Convert Temperature</h1>
+  <form method="post" novalidate>
+    {{ form.csrf_token }}
+    {{ form.value.label }}
+    {{ form.value(inputmode="decimal", autocomplete="off") }}
+    {% for error in form.value.errors %}
+      <p class="errors">{{ error }}</p>
+    {% endfor %}
+
+    <label>{{ form.direction.label.text }}</label>
+    <div class="radio-list">
+      {% for option in form.direction %}
+        <label>{{ option }} {{ option.label.text }}</label>
+      {% endfor %}
+    </div>
+    {% for error in form.direction.errors %}
+      <p class="errors">{{ error }}</p>
+    {% endfor %}
+
+    {{ form.submit() }}
+  </form>
+
+  {% if result %}
+    <div class="result">Converted value: {{ result }}</div>
+  {% endif %}
+</section>
+{% endblock %}
