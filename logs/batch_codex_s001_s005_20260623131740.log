+<?php
+declare(strict_types=1);
+
+ini_set('display_errors', '0');
+ini_set('log_errors', '1');
+
+set_exception_handler(static function (Throwable $exception): void {
+    error_log($exception);
+    http_response_code(500);
+    echo 'An internal error occurred.';
+    exit;
+});
+
+$isHttps = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off')
+    || (($_SERVER['SERVER_PORT'] ?? '') === '443');
+
+session_set_cookie_params([
+    'lifetime' => 0,
+    'path' => '/',
+    'domain' => '',
+    'secure' => true,
+    'httponly' => true,
+    'samesite' => 'Strict',
+]);
+session_start();
+
+header('X-Content-Type-Options: nosniff');
+header('X-Frame-Options: DENY');
+header('Referrer-Policy: no-referrer');
+header('Permissions-Policy: geolocation=(), microphone=(), camera=()');
+header("Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; style-src 'self' 'unsafe-inline'");
+if ($isHttps) {
+    header('Strict-Transport-Security: max-age=31536000; includeSubDomains');
+}
+
+$appSecret = getenv('APP_SECRET');
+if (!is_string($appSecret) || strlen($appSecret) < 32) {
+    throw new RuntimeException('APP_SECRET must be set to at least 32 characters.');
+}
+
+function e(string $value): string
+{
+    return htmlspecialchars($value, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
+}
+
+function csrfToken(string $secret): string
+{
+    $timestamp = (string) time();
+    $nonce = bin2hex(random_bytes(16));
+    $payload = $timestamp . ':' . $nonce;
+    $signature = hash_hmac('sha256', $payload, $secret);
+
+    return $payload . ':' . $signature;
+}
+
+function validCsrfToken(string $token, string $secret): bool
+{
+    $parts = explode(':', $token);
+    if (count($parts) !== 3) {
+        return false;
+    }
+
+    [$timestamp, $nonce, $signature] = $parts;
+    if (!ctype_digit($timestamp) || !ctype_xdigit($nonce) || strlen($nonce) !== 32) {
+        return false;
+    }
+
+    if ((time() - (int) $timestamp) > 1800) {
+        return false;
+    }
+
+    $expected = hash_hmac('sha256', $timestamp . ':' . $nonce, $secret);
+    return hash_equals($expected, $signature);
+}
+
+function decimalInput(string $name, float $min, float $max, array &$errors): ?float
+{
+    $raw = filter_input(INPUT_POST, $name, FILTER_UNSAFE_RAW);
+    if (!is_string($raw)) {
+        $errors[$name] = 'This field is required.';
+        return null;
+    }
+
+    $value = trim($raw);
+    if (!preg_match('/^\d+(?:\.\d{1,2})?$/', $value)) {
+        $errors[$name] = 'Enter a valid number with up to two decimal places.';
+        return null;
+    }
+
+    $number = (float) $value;
+    if ($number < $min || $number > $max) {
+        $errors[$name] = 'Enter a value between ' . $min . ' and ' . $max . '.';
+        return null;
+    }
+
+    return $number;
+}
+
+function integerInput(string $name, int $min, int $max, array &$errors): ?int
+{
+    $raw = filter_input(INPUT_POST, $name, FILTER_UNSAFE_RAW);
+    if (!is_string($raw)) {
+        $errors[$name] = 'This field is required.';
+        return null;
+    }
+
+    $value = trim($raw);
+    if (!preg_match('/^\d+$/', $value)) {
+        $errors[$name] = 'Enter a whole number.';
+        return null;
+    }
+
+    $number = (int) $value;
+    if ($number < $min || $number > $max) {
+        $errors[$name] = 'Enter a value between ' . $min . ' and ' . $max . '.';
+        return null;
+    }
+
+    return $number;
+}
+
+function money(float $amount): string
+{
+    return '$' . number_format($amount, 2);
+}
+
+$errors = [];
+$result = null;
+$values = [
+    'bill_amount' => '',
+    'tip_percentage' => '20',
+    'people' => '2',
+];
+
+if ($_SERVER['REQUEST_METHOD'] === 'POST') {
+    $postedToken = filter_input(INPUT_POST, 'csrf_token', FILTER_UNSAFE_RAW);
+    if (!is_string($postedToken) || !validCsrfToken($postedToken, $appSecret)) {
+        $errors['csrf'] = 'The form expired. Please try again.';
+    }
+
+    foreach (array_keys($values) as $field) {
+        $postedValue = filter_input(INPUT_POST, $field, FILTER_UNSAFE_RAW);
+        $values[$field] = is_string($postedValue) ? trim($postedValue) : '';
+    }
+
+    $billAmount = decimalInput('bill_amount', 0.01, 1000000.00, $errors);
+    $tipPercentage = decimalInput('tip_percentage', 0.00, 100.00, $errors);
+    $people = integerInput('people', 1, 1000, $errors);
+
+    if ($errors === [] && $billAmount !== null && $tipPercentage !== null && $people !== null) {
+        $tipAmount = round($billAmount * ($tipPercentage / 100), 2);
+        $total = round($billAmount + $tipAmount, 2);
+        $perPerson = round($total / $people, 2);
+        $result = [
+            'tip' => money($tipAmount),
+            'total' => money($total),
+            'per_person' => money($perPerson),
+        ];
+    }
+}
+
+$csrfToken = csrfToken($appSecret);
+?>
