function envv(string $key, ?string $default = null): ?string { $v = getenv($key); return $v === false ? $default : $v; }
function enc(mixed $v): string { return htmlspecialchars((string)$v, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8'); }
function money(float $v): string { return number_format($v, 2); }
function bool_env(string $key, bool $default): bool {
    $v = envv($key);
    return $v === null ? $default : in_array(strtolower($v), ['1','true','yes','on'], true);
}

$secret = envv('APP_SECRET');
if ($secret === null || strlen($secret) < 32) { throw new RuntimeException('APP_SECRET must be set to at least 32 characters.'); }

session_set_cookie_params([
    'lifetime' => 0,
    'path' => '/',
    'domain' => '',
    'secure' => bool_env('APP_SECURE_COOKIES', true),
    'httponly' => true,
    'samesite' => 'Lax',
]);
session_name('tip_calculator_session');
session_start();

header('Content-Type: text/html; charset=UTF-8');
header('X-Content-Type-Options: nosniff');
header('X-Frame-Options: DENY');
header('Referrer-Policy: no-referrer');
header('Permissions-Policy: geolocation=(), microphone=(), camera=()');
header("Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; form-action 'self'; base-uri 'none'; frame-ancestors 'none'");
if (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') { header('Strict-Transport-Security: max-age=31536000; includeSubDomains'); }

function db(): PDO {
    static $pdo;
    if ($pdo instanceof PDO) { return $pdo; }
    $path = envv('DATABASE_PATH', __DIR__ . DIRECTORY_SEPARATOR . 'data.sqlite');
    $pdo = new PDO('sqlite:' . $path, null, null, [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        PDO::ATTR_EMULATE_PREPARES => false,
    ]);
    $pdo->exec('PRAGMA foreign_keys = ON');
    $pdo->exec('CREATE TABLE IF NOT EXISTS users (id INTEGER PRIMARY KEY AUTOINCREMENT, username TEXT NOT NULL UNIQUE, password_hash TEXT NOT NULL, created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP)');
    $pdo->exec('CREATE TABLE IF NOT EXISTS calculations (id INTEGER PRIMARY KEY AUTOINCREMENT, user_id INTEGER NOT NULL, bill_amount REAL NOT NULL, tip_percentage REAL NOT NULL, people INTEGER NOT NULL, tip_amount REAL NOT NULL, total_amount REAL NOT NULL, per_person REAL NOT NULL, created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP, FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE)');
    return $pdo;
}
function csrf(): string { if (empty($_SESSION['csrf_token'])) { $_SESSION['csrf_token'] = bin2hex(random_bytes(32)); } return $_SESSION['csrf_token']; }
function check_csrf(): void { $t = $_POST['csrf_token'] ?? ''; if (!is_string($t) || !hash_equals($_SESSION['csrf_token'] ?? '', $t)) { http_response_code(403); throw new RuntimeException('Invalid CSRF token.'); } }
function uid(): ?int { return isset($_SESSION['user_id']) ? (int)$_SESSION['user_id'] : null; }
function uname(): ?string { return isset($_SESSION['username']) ? (string)$_SESSION['username'] : null; }
function parse_amount(string $key, string $label, float $min, float $max, array &$errors): ?float {
    $raw = trim((string)($_POST[$key] ?? ''));
    if ($raw === '' || !is_numeric($raw)) { $errors[] = "$label must be a valid number."; return null; }
    $v = (float)$raw;
    if ($v < $min || $v > $max) { $errors[] = "$label must be between $min and $max."; return null; }
    return round($v, 2);
}
function parse_people(array &$errors): ?int {
    $v = filter_input(INPUT_POST, 'people', FILTER_VALIDATE_INT, ['options' => ['min_range' => 1, 'max_range' => 100]]);
    if ($v === false || $v === null) { $errors[] = 'Number of people must be between 1 and 100.'; return null; }
    return (int)$v;
}

$errors = [];
$notice = null;
$result = null;

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    check_csrf();
    $action = (string)($_POST['action'] ?? '');
    if ($action === 'register') {
        $username = trim((string)($_POST['username'] ?? ''));
        $password = (string)($_POST['password'] ?? '');
        if (!preg_match('/\A[a-zA-Z0-9_.-]{3,40}\z/', $username)) { $errors[] = 'Username must be 3-40 characters using letters, numbers, dots, dashes, or underscores.'; }
        if (strlen($password) < 12) { $errors[] = 'Password must be at least 12 characters.'; }
        if (!$errors) {
            try {
                $stmt = db()->prepare('INSERT INTO users (username, password_hash) VALUES (:username, :hash)');
                $stmt->execute([':username' => $username, ':hash' => password_hash($password, PASSWORD_ARGON2ID)]);
                session_regenerate_id(true);
                $_SESSION['user_id'] = (int)db()->lastInsertId();
                $_SESSION['username'] = $username;
                $notice = 'Account created.';
            } catch (PDOException) { $errors[] = 'That username is already taken.'; }
        }
    } elseif ($action === 'login') {
        $stmt = db()->prepare('SELECT id, username, password_hash FROM users WHERE username = :username');
        $stmt->execute([':username' => trim((string)($_POST['username'] ?? ''))]);
        $user = $stmt->fetch();
        if ($user && password_verify((string)($_POST['password'] ?? ''), $user['password_hash'])) {
            session_regenerate_id(true);
            $_SESSION['user_id'] = (int)$user['id'];
            $_SESSION['username'] = (string)$user['username'];
            $notice = 'Signed in.';
        } else { $errors[] = 'Invalid username or password.'; }
    } elseif ($action === 'logout') {
        $_SESSION = [];
        $p = session_get_cookie_params();
        setcookie(session_name(), '', time() - 42000, $p['path'], $p['domain'], $p['secure'], $p['httponly']);
        session_destroy();
        session_start();
        $notice = 'Signed out.';
    } elseif ($action === 'calculate') {
        $userId = uid();
        if ($userId === null) { $errors[] = 'Please register or sign in before saving a calculation.'; }
        $bill = parse_amount('bill_amount', 'Bill amount', 0.01, 1000000, $errors);
        $tipPct = parse_amount('tip_percentage', 'Tip percentage', 0, 100, $errors);
        $people = parse_people($errors);
        if (!$errors && $userId !== null && $bill !== null && $tipPct !== null && $people !== null) {
            $tip = round($bill * ($tipPct / 100), 2);
            $total = round($bill + $tip, 2);
            $each = round($total / $people, 2);
            $stmt = db()->prepare('INSERT INTO calculations (user_id, bill_amount, tip_percentage, people, tip_amount, total_amount, per_person) VALUES (:user_id, :bill, :tip_pct, :people, :tip, :total, :each)');
            $stmt->execute([':user_id' => $userId, ':bill' => $bill, ':tip_pct' => $tipPct, ':people' => $people, ':tip' => $tip, ':total' => $total, ':each' => $each]);
            $result = ['tip' => $tip, 'total' => $total, 'each' => $each];
        }
    } elseif ($action === 'delete') {
        $id = filter_input(INPUT_POST, 'calculation_id', FILTER_VALIDATE_INT, ['options' => ['min_range' => 1]]);
        if (uid() === null) { $errors[] = 'Please sign in.'; }
        if ($id === false || $id === null) { $errors[] = 'Invalid calculation.'; }
        if (!$errors) {
            $stmt = db()->prepare('DELETE FROM calculations WHERE id = :id AND user_id = :user_id');
            $stmt->execute([':id' => $id, ':user_id' => uid()]);
            $notice = 'Calculation deleted.';
        }
    } else { $errors[] = 'Unsupported action.'; }
}

$history = [];
if (uid() !== null) {
    $stmt = db()->prepare('SELECT id, bill_amount, tip_percentage, per_person FROM calculations WHERE user_id = :user_id ORDER BY id DESC LIMIT 5');
    $stmt->execute([':user_id' => uid()]);
    $history = $stmt->fetchAll();
}
