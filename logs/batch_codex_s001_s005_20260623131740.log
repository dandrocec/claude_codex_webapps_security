+
+    if ($errors === []) {
+        $tipAmount = $billAmount * ($tipPercentage / 100);
+        $total = $billAmount + $tipAmount;
+        $perPerson = $total / $people;
+
+        $result = [
+            'tip_amount' => $tipAmount,
+            'total' => $total,
+            'per_person' => $perPerson,
+        ];
+    }
