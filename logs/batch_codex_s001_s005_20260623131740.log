    check_csrf();
    $action = (string)($_POST['action'] ?? '');
    if ($action === 'register') {
        $username = trim((string)($_POST['username'] ?? ''));
        $password = (string)($_POST['password'] ?? '');
        if (!preg_match('/\A[a-zA-Z0-9_.-]{3,40}\z/', $username)) { $errors[] = 'Username must be 3-40 characters using letters, numbers, dots, dashes, or underscores.'; }
        if (strlen($password) < 12) { $errors[] = 'Password must be at least 12 characters.'; }
        if (!$errors) {
            try {
