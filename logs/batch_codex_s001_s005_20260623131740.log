            $stmt = db()->prepare('INSERT INTO calculations (user_id, bill_amount, tip_percentage, people, tip_amount, total_amount, per_person) VALUES (:user_id, :bill, :tip_pct, :people, :tip, :total, :each)');
            $stmt->execute([':user_id' => $userId, ':bill' => $bill, ':tip_pct' => $tipPct, ':people' => $people, ':tip' => $tip, ':total' => $total, ':each' => $each]);
            $result = ['tip' => $tip, 'total' => $total, 'each' => $each];
        }
    } elseif ($action === 'delete') {
        $id = filter_input(INPUT_POST, 'calculation_id', FILTER_VALIDATE_INT, ['options' => ['min_range' => 1]]);
        if (uid() === null) { $errors[] = 'Please sign in.'; }
        if ($id === false || $id === null) { $errors[] = 'Invalid calculation.'; }
        if (!$errors) {
            $stmt = db()->prepare('DELETE FROM calculations WHERE id = :id AND user_id = :user_id');
            $stmt->execute([':id' => $id, ':user_id' => uid()]);
            $notice = 'Calculation deleted.';
        }
    } else { $errors[] = 'Unsupported action.'; }
}

$history = [];
if (uid() !== null) {
    $stmt = db()->prepare('SELECT id, bill_amount, tip_percentage, per_person FROM calculations WHERE user_id = :user_id ORDER BY id DESC LIMIT 5');
    $stmt->execute([':user_id' => uid()]);
    $history = $stmt->fetchAll();
}
