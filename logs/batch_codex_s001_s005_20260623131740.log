+  padding: 10px 12px;
+  font: inherit;
+}
+
+button {
+  margin-top: 8px;
+  border: 0;
+  border-radius: 6px;
+  padding: 12px 16px;
+  background: #1f7a5c;
+  color: #ffffff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+button:hover,
+button:focus {
+  background: #176247;
+}
+
+.alert {
+  border: 1px solid #cc3340;
+  border-radius: 6px;
+  padding: 12px;
+  margin-bottom: 16px;
+  background: #fff2f3;
+  color: #8a1f28;
+}
+
+.alert p:last-child,
+.result p:last-child {
+  margin-bottom: 0;
+}
+
+.result {
+  margin-top: 24px;
+  border-top: 1px solid #d8dee4;
+  padding-top: 20px;
+}
+
+.bmi {
