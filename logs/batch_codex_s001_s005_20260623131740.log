+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+}
+
+.app-shell {
+  width: min(1040px, calc(100% - 32px));
+  margin: 0 auto;
+  padding: 32px 0;
+}
+
+.editor-panel,
+.preview-panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 24px;
+}
+
+.preview-panel {
+  margin-top: 20px;
+}
+
+.header-row {
+  display: flex;
+  align-items: flex-start;
+  justify-content: space-between;
+  gap: 20px;
+  margin-bottom: 20px;
+}
+
+h1,
+h2,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  margin-bottom: 8px;
+  font-size: 2rem;
+}
+
+h2 {
+  margin-bottom: 16px;
+  font-size: 1.25rem;
+}
+
+p {
+  color: var(--muted);
+  line-height: 1.5;
+}
+
+label {
+  display: block;
+  margin-bottom: 8px;
+  font-weight: 700;
+}
+
+textarea {
+  width: 100%;
+  min-height: 280px;
+  resize: vertical;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  padding: 16px;
+  color: var(--text);
+  font: 1rem/1.5 Consolas, "Courier New", monospace;
+}
+
+textarea:focus {
+  border-color: var(--accent);
+  outline: 3px solid rgba(31, 122, 104, 0.18);
+}
+
+button {
+  flex: 0 0 auto;
+  border: 0;
+  border-radius: 6px;
+  background: var(--accent);
+  color: #ffffff;
+  cursor: pointer;
+  font-weight: 700;
+  padding: 12px 18px;
+}
+
+button:hover {
+  background: var(--accent-dark);
+}
+
+button:disabled {
+  cursor: wait;
+  opacity: 0.72;
+}
+
+.preview {
+  min-height: 160px;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  padding: 18px;
+  overflow-wrap: anywhere;
+  line-height: 1.6;
+}
+
+.preview > :first-child {
+  margin-top: 0;
+}
+
+.preview > :last-child {
+  margin-bottom: 0;
+}
+
+.preview code {
+  background: var(--code-bg);
+  border-radius: 4px;
+  padding: 2px 5px;
+}
+
+.preview pre {
+  background: var(--code-bg);
+  border-radius: 6px;
+  overflow: auto;
+  padding: 14px;
+}
+
+.preview pre code {
+  padding: 0;
+}
+
+.preview blockquote {
+  border-left: 4px solid var(--accent);
+  color: var(--muted);
+  margin-left: 0;
+  padding-left: 14px;
+}
+
+@media (max-width: 640px) {
+  .app-shell {
+    width: min(100% - 20px, 1040px);
+    padding: 20px 0;
+  }
+
+  .editor-panel,
+  .preview-panel {
+    padding: 18px;
+  }
+
+  .header-row {
+    display: block;
+  }
+
+  button {
+    margin-top: 8px;
+    width: 100%;
+  }
+}
diff --git a/server.js b/server.js
new file mode 100644
index 0000000000000000000000000000000000000000..c696830c3e6eebc6980f419b451f005c796d5c37
--- /dev/null
+++ b/server.js
@@ -0,0 +1,24 @@
+const express = require('express');
+const { marked } = require('marked');
+
+const app = express();
+const PORT = process.env.PORT || 5005;
+
+app.use(express.static('public'));
+app.use(express.json({ limit: '1mb' }));
+
+marked.setOptions({
+  breaks: true,
+  gfm: true
+});
+
+app.post('/render', (req, res) => {
+  const markdown = typeof req.body?.markdown === 'string' ? req.body.markdown : '';
+  const html = marked.parse(markdown);
+
+  res.json({ html });
+});
+
+app.listen(PORT, () => {
+  console.log(`Markdown preview app running on http://localhost:${PORT}`);
+});

