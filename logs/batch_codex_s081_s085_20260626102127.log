diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..67396a4c06c633e9773976afa198f59af810e38c
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,16 @@
+{% extends "base.html" %}
+{% block title %}Elections{% endblock %}
+{% block content %}
+  <h1>Elections</h1>
+  {% if not elections %}
+    <div class="panel">No elections have been created.</div>
+  {% endif %}
+  {% for election in elections %}
+    <section class="election">
+      <h2><a href="{{ url_for('election_detail', election_id=election.id) }}">{{ election.title }}</a></h2>
+      <p>{{ election.description }}</p>
+      <p class="muted">Open: {{ format_dt(election.opens_at) }} | Close: {{ format_dt(election.closes_at) }} | Votes: {{ election.vote_count }}</p>
+      <a class="button" href="{{ url_for('election_detail', election_id=election.id) }}">View</a>
+    </section>
+  {% endfor %}
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..dc308e08f6ddea836198b1ce0e3f89ff3cf167b1
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,15 @@
+{% extends "base.html" %}
+{% block title %}Sign in{% endblock %}
+{% block content %}
+  <div class="panel">
+    <h1>Sign in</h1>
+    <form method="post">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
