diff --git a/static/style.css b/static/style.css
new file mode 100644
index 0000000000000000000000000000000000000000..e025e583b3182ae27f718dcf3e089d701f822159
--- /dev/null
+++ b/static/style.css
@@ -0,0 +1,358 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --surface: #ffffff;
+  --ink: #17202a;
+  --muted: #657180;
+  --line: #dde3ea;
+  --accent: #176b5f;
+  --accent-dark: #0f5148;
+  --danger: #b42318;
+  --warning: #946200;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--ink);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--surface);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  gap: 24px;
+  justify-content: space-between;
+  padding: 14px clamp(16px, 4vw, 48px);
+}
+
+.brand {
+  color: var(--ink);
+  font-size: 1.15rem;
+  font-weight: 700;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 14px;
+  justify-content: flex-end;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 1120px;
+  padding: 32px 18px 56px;
+}
+
+.page-head {
+  align-items: center;
+  display: flex;
+  gap: 18px;
+  justify-content: space-between;
+  margin-bottom: 24px;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 8px;
+}
+
+p {
+  margin: 0 0 14px;
+}
+
+.muted,
+.page-head p,
+.card p,
+.notice {
+  color: var(--muted);
+}
+
+.grid {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+}
+
+.card,
+.panel,
+.auth-panel {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.card-head {
+  align-items: flex-start;
+  display: flex;
+  gap: 12px;
+  justify-content: space-between;
+}
+
+.badge {
+  border-radius: 999px;
+  display: inline-block;
+  font-size: 0.78rem;
+  font-weight: 700;
+  padding: 4px 10px;
+  text-transform: uppercase;
+}
+
+.badge.open {
+  background: #d9f2ea;
+  color: #07503f;
+}
+
+.badge.closed {
+  background: #e8eaee;
+  color: #4a5564;
+}
+
+.badge.upcoming {
+  background: #fff2cc;
+  color: var(--warning);
+}
+
+.meta {
+  display: grid;
+  gap: 10px;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  margin: 18px 0;
+}
+
+.meta.wide {
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  margin: 0;
+}
+
+dt {
+  color: var(--muted);
+  font-size: 0.78rem;
+  text-transform: uppercase;
+}
+
+dd {
+  margin: 0;
+}
+
+.button,
+button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 14px;
+}
+
+.button:hover,
+button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.button.secondary {
+  background: #e9f2f0;
+  color: var(--accent-dark);
+}
+
+.button.small {
+  padding: 7px 10px;
+}
+
+.flashes {
+  display: grid;
+  gap: 8px;
+  margin-bottom: 20px;
+}
+
+.flash {
+  border-radius: 6px;
+  padding: 10px 12px;
+}
+
+.flash.success {
+  background: #d9f2ea;
+}
+
+.flash.danger {
+  background: #ffe1df;
+  color: var(--danger);
+}
+
+.flash.warning {
+  background: #fff2cc;
+}
+
+.flash.info {
+  background: #e8eef8;
+}
+
+.auth-panel {
+  margin: 0 auto;
+  max-width: 440px;
+}
+
+.wide-form {
+  max-width: 760px;
+}
+
+form {
+  display: grid;
+  gap: 14px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--ink);
+  font: inherit;
+  padding: 10px 12px;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+.two-col {
+  display: grid;
+  gap: 14px;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+}
+
+.choice {
+  align-items: flex-start;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  display: flex;
+  gap: 10px;
+  padding: 14px;
+}
+
+.choice input {
+  margin-top: 5px;
+  width: auto;
+}
+
+.choice small {
+  color: var(--muted);
+  display: block;
+  font-weight: 400;
+}
+
+.candidate-list {
+  margin-bottom: 16px;
+}
+
+.results {
+  display: grid;
+  gap: 16px;
+}
+
+.result-label {
+  align-items: baseline;
+  display: flex;
+  gap: 12px;
+  justify-content: space-between;
+}
+
+.result-label span {
+  color: var(--muted);
+}
+
+.bar {
+  background: #e8eaee;
+  border-radius: 999px;
+  height: 12px;
+  overflow: hidden;
+}
+
+.bar span {
+  background: var(--accent);
+  display: block;
+  height: 100%;
+}
+
+table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: 12px 8px;
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  color: var(--muted);
+  font-size: 0.8rem;
+  text-transform: uppercase;
+}
+
+.link-danger {
+  background: none;
+  color: var(--danger);
+  font-weight: 700;
+  padding: 0;
+}
+
+.link-danger:hover {
+  background: none;
+  text-decoration: underline;
+}
+
+.empty {
+  color: var(--muted);
+  grid-column: 1 / -1;
+}
+
+@media (max-width: 720px) {
+  .topbar,
+  .page-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  nav {
+    justify-content: flex-start;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/admin_dashboard.html b/templates/admin_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..cb7c2b0e4cb6d3a8a523437e47cfd68b6c8ea135
--- /dev/null
+++ b/templates/admin_dashboard.html
@@ -0,0 +1,44 @@
+{% extends "base.html" %}
+{% block title %}Admin{% endblock %}
+{% block content %}
+  <section class="page-head">
+    <div>
+      <h1>Admin</h1>
+      <p>Create and manage elections.</p>
+    </div>
+    <a class="button" href="{{ url_for('create_election') }}">Create election</a>
+  </section>
+
+  <section class="panel">
+    <table>
+      <thead>
+        <tr>
+          <th>Election</th>
+          <th>Status</th>
+          <th>Candidates</th>
+          <th>Votes</th>
+          <th>Window</th>
+          <th></th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for election in elections %}
+          <tr>
+            <td><a href="{{ url_for('election_detail', election_id=election['id']) }}">{{ election["title"] }}</a></td>
+            <td><span class="badge {{ election_status(election) }}">{{ election_status(election) }}</span></td>
+            <td>{{ election["candidate_count"] }}</td>
+            <td>{{ election["vote_count"] }}</td>
+            <td>{{ election["opens_at"].replace("T", " ") }} to {{ election["closes_at"].replace("T", " ") }}</td>
+            <td>
+              <form method="post" action="{{ url_for('delete_election', election_id=election['id']) }}" onsubmit="return confirm('Delete this election and all votes?')">
+                <button class="link-danger" type="submit">Delete</button>
+              </form>
+            </td>
+          </tr>
+        {% else %}
+          <tr><td colspan="6">No elections yet.</td></tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..5e85a13ead694b7d7a8c31feefd640d798cec11a
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Voting Platform{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Voting Platform</a>
+    <nav>
+      {% if g.user %}
+        {% if g.user["is_admin"] %}
+          <a href="{{ url_for('admin_dashboard') }}">Admin</a>
+        {% endif %}
+        <span class="muted">Signed in as {{ g.user["username"] }}</span>
+        <a href="{{ url_for('logout') }}">Logout</a>
+      {% else %}
+        <a href="{{ url_for('login') }}">Login</a>
+        <a class="button small" href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main class="container">
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <section class="flashes">
+          {% for category, message in messages %}
+            <div class="flash {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </section>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/create_election.html b/templates/create_election.html
new file mode 100644
index 0000000000000000000000000000000000000000..6ff3ebcf39ce3212e8f67a85e3d5a12d8a069d5c
--- /dev/null
+++ b/templates/create_election.html
@@ -0,0 +1,17 @@
+{% extends "base.html" %}
+{% block title %}Create election{% endblock %}
+{% block content %}
+  <section class="auth-panel wide-form">
+    <h1>Create election</h1>
+    <form method="post">
+      <label>Title<input name="title" required></label>
+      <label>Description<textarea name="description" rows="3"></textarea></label>
+      <div class="two-col">
+        <label>Open time<input type="datetime-local" name="opens_at" required></label>
+        <label>Close time<input type="datetime-local" name="closes_at" required></label>
+      </div>
+      <label>Candidates<textarea name="candidates" rows="7" placeholder="One candidate per line" required></textarea></label>
+      <button class="button" type="submit">Create election</button>
+    </form>
+  </section>
+{% endblock %}
diff --git a/templates/election_detail.html b/templates/election_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..1448cabb29bafbfbea41e02bcc6b5fc6f4a30813
--- /dev/null
+++ b/templates/election_detail.html
@@ -0,0 +1,68 @@
+{% extends "base.html" %}
+{% block title %}{{ election["title"] }}{% endblock %}
+{% block content %}
+  <section class="page-head">
+    <div>
+      <h1>{{ election["title"] }}</h1>
+      <p>{{ election["description"] or "No description provided." }}</p>
+    </div>
+    <span class="badge {{ election_status(election) }}">{{ election_status(election) }}</span>
+  </section>
+
+  <section class="panel">
+    <dl class="meta wide">
+      <div><dt>Opens</dt><dd>{{ election["opens_at"].replace("T", " ") }}</dd></div>
+      <div><dt>Closes</dt><dd>{{ election["closes_at"].replace("T", " ") }}</dd></div>
+    </dl>
+  </section>
+
+  {% if election_status(election) == "closed" %}
+    <section class="panel">
+      <h2>Results</h2>
+      <div class="results">
+        {% for row in results %}
+          {% set percent = (row["votes"] / total_votes * 100) if total_votes else 0 %}
+          <div class="result-row">
+            <div class="result-label">
+              <strong>{{ row["name"] }}</strong>
+              <span>{{ row["votes"] }} vote{{ "" if row["votes"] == 1 else "s" }} · {{ "%.1f"|format(percent) }}%</span>
+            </div>
+            <div class="bar"><span style="width: {{ percent }}%"></span></div>
+          </div>
+        {% endfor %}
+      </div>
+    </section>
+  {% elif election_status(election) == "open" %}
+    <section class="panel">
+      <h2>Cast your vote</h2>
+      {% if not g.user %}
+        <p><a href="{{ url_for('login', next=request.path) }}">Log in</a> to vote in this election.</p>
+      {% elif user_vote %}
+        <p class="notice">You have already voted in this election.</p>
+      {% else %}
+        <form method="post" action="{{ url_for('vote', election_id=election['id']) }}" class="vote-form">
+          {% for candidate in candidates %}
+            <label class="choice">
+              <input type="radio" name="candidate_id" value="{{ candidate['id'] }}" required>
+              <span>
+                <strong>{{ candidate["name"] }}</strong>
+                {% if candidate["statement"] %}<small>{{ candidate["statement"] }}</small>{% endif %}
+              </span>
+            </label>
+          {% endfor %}
+          <button class="button" type="submit">Submit vote</button>
+        </form>
+      {% endif %}
+    </section>
+  {% else %}
+    <section class="panel">
+      <h2>Candidates</h2>
+      <ul class="candidate-list">
+        {% for candidate in candidates %}
+          <li>{{ candidate["name"] }}</li>
+        {% endfor %}
+      </ul>
+      <p class="notice">Voting has not opened yet.</p>
+    </section>
+  {% endif %}
+{% endblock %}
