+        </div>
+        <a class="button-link" href="{{ url_for('view_candidate', user_id=candidate.user_id) }}">View profile</a>
+      </article>
+    {% endfor %}
+  {% else %}
+    <p class="empty-state">No candidates found.</p>
+  {% endif %}
+</section>
+{% endblock %}
