+  <h1>Sign in</h1>
+  <form method="post" class="stacked-form">
+    <label>
+      Email
+      <input type="email" name="email" required autocomplete="email">
+    </label>
+    <label>
+      Password
+      <input type="password" name="password" required autocomplete="current-password">
+    </label>
+    <button type="submit">Sign in</button>
+  </form>
+</section>
+{% endblock %}
