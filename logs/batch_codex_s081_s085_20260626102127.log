+<%- include("partials/header") %>
+
+<section class="form-panel wide">
+  <h1>Create event</h1>
+  <%- include("partials/errors", { errors }) %>
+  <form method="post" action="/events" novalidate>
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>
+      Title
+      <input name="title" maxlength="120" required value="<%= old.title || "" %>">
+    </label>
+    <label>
+      Description
+      <textarea name="description" maxlength="2000" rows="5" required><%= old.description || "" %></textarea>
+    </label>
+    <label>
+      Starts at
+      <input name="starts_at" type="datetime-local" required value="<%= old.starts_at || "" %>">
+    </label>
+    <label>
+      Ticket limit
+      <input name="ticket_limit" type="number" min="1" max="100000" required value="<%= old.ticket_limit || "" %>">
+    </label>
+    <button type="submit" class="button">Create event</button>
+  </form>
+</section>
+
+<%- include("partials/footer") %>
diff --git a/views/event.ejs b/views/event.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b82f3fe7ec5b6519bd0301e0953692931ec817f7
--- /dev/null
+++ b/views/event.ejs
@@ -0,0 +1,27 @@
+<%- include("partials/header") %>
+
+<article class="detail">
+  <div>
+    <h1><%= event.title %></h1>
+    <p class="muted">Organised by <%= event.organiser_name %> · <%= new Date(event.starts_at).toLocaleString() %></p>
+    <p class="description"><%= event.description %></p>
+  </div>
+  <aside class="purchase-box">
+    <p class="inventory"><strong><%= event.ticket_limit - event.sold_count %></strong> tickets left</p>
+    <p class="muted"><%= event.sold_count %> sold from <%= event.ticket_limit %></p>
+    <% if (currentUser) { %>
+      <% if (event.ticket_limit > event.sold_count) { %>
+        <form method="post" action="/events/<%= event.id %>/buy">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit" class="button full">Buy ticket</button>
+        </form>
+      <% } else { %>
+        <button class="button full" disabled>Sold out</button>
+      <% } %>
+    <% } else { %>
+      <a class="button full" href="/login">Sign in to buy</a>
+    <% } %>
+  </aside>
+</article>
+
+<%- include("partials/footer") %>
diff --git a/views/index.ejs b/views/index.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..ec3a5032595dc7d3838a9697cbdf81b94e644767
--- /dev/null
+++ b/views/index.ejs
@@ -0,0 +1,32 @@
+<%- include("partials/header") %>
+
+<section class="page-head">
+  <div>
+    <h1>Events</h1>
+    <p>Browse available events and buy tickets while inventory remains.</p>
+  </div>
+  <% if (currentUser) { %>
+    <a class="button" href="/events/new">Create event</a>
+  <% } %>
+</section>
+
+<section class="event-grid">
+  <% if (!events.length) { %>
+    <p class="empty">No events have been created yet.</p>
+  <% } %>
+  <% events.forEach((event) => { %>
+    <article class="card">
+      <div class="card-main">
+        <h2><a href="/events/<%= event.id %>"><%= event.title %></a></h2>
+        <p class="muted">Organised by <%= event.organiser_name %></p>
+        <p><%= event.description %></p>
+      </div>
+      <div class="meta-row">
+        <span><%= new Date(event.starts_at).toLocaleString() %></span>
+        <strong><%= event.ticket_limit - event.sold_count %> / <%= event.ticket_limit %> left</strong>
+      </div>
+    </article>
+  <% }) %>
+</section>
+
+<%- include("partials/footer") %>
