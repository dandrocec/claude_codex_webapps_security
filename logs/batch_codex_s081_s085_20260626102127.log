diff --git a/static/style.css b/static/style.css
new file mode 100644
index 0000000000000000000000000000000000000000..e025e583b3182ae27f718dcf3e089d701f822159
--- /dev/null
+++ b/static/style.css
@@ -0,0 +1,358 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --surface: #ffffff;
+  --ink: #17202a;
+  --muted: #657180;
+  --line: #dde3ea;
+  --accent: #176b5f;
+  --accent-dark: #0f5148;
+  --danger: #b42318;
+  --warning: #946200;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--ink);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--surface);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  gap: 24px;
+  justify-content: space-between;
+  padding: 14px clamp(16px, 4vw, 48px);
+}
+
+.brand {
+  color: var(--ink);
+  font-size: 1.15rem;
+  font-weight: 700;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 14px;
+  justify-content: flex-end;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 1120px;
+  padding: 32px 18px 56px;
+}
+
+.page-head {
+  align-items: center;
+  display: flex;
+  gap: 18px;
+  justify-content: space-between;
+  margin-bottom: 24px;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 8px;
+}
+
+p {
+  margin: 0 0 14px;
+}
+
+.muted,
+.page-head p,
+.card p,
+.notice {
+  color: var(--muted);
+}
+
+.grid {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+}
+
+.card,
+.panel,
+.auth-panel {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.card-head {
+  align-items: flex-start;
+  display: flex;
+  gap: 12px;
+  justify-content: space-between;
+}
+
+.badge {
+  border-radius: 999px;
+  display: inline-block;
+  font-size: 0.78rem;
+  font-weight: 700;
+  padding: 4px 10px;
+  text-transform: uppercase;
+}
+
+.badge.open {
+  background: #d9f2ea;
+  color: #07503f;
+}
+
+.badge.closed {
+  background: #e8eaee;
+  color: #4a5564;
+}
+
+.badge.upcoming {
+  background: #fff2cc;
+  color: var(--warning);
+}
+
+.meta {
+  display: grid;
+  gap: 10px;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  margin: 18px 0;
+}
+
+.meta.wide {
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  margin: 0;
+}
+
+dt {
+  color: var(--muted);
+  font-size: 0.78rem;
+  text-transform: uppercase;
+}
+
+dd {
+  margin: 0;
+}
+
+.button,
+button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 14px;
+}
+
+.button:hover,
+button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.button.secondary {
+  background: #e9f2f0;
+  color: var(--accent-dark);
+}
+
+.button.small {
+  padding: 7px 10px;
+}
+
+.flashes {
+  display: grid;
+  gap: 8px;
+  margin-bottom: 20px;
+}
+
+.flash {
+  border-radius: 6px;
+  padding: 10px 12px;
+}
+
+.flash.success {
+  background: #d9f2ea;
+}
+
+.flash.danger {
+  background: #ffe1df;
+  color: var(--danger);
+}
+
+.flash.warning {
+  background: #fff2cc;
+}
+
+.flash.info {
+  background: #e8eef8;
+}
+
+.auth-panel {
+  margin: 0 auto;
+  max-width: 440px;
+}
+
+.wide-form {
+  max-width: 760px;
+}
+
+form {
+  display: grid;
+  gap: 14px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+input,
+textarea {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--ink);
+  font: inherit;
+  padding: 10px 12px;
+  width: 100%;
+}
+
+textarea {
+  resize: vertical;
+}
+
+.two-col {
+  display: grid;
+  gap: 14px;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+}
+
+.choice {
+  align-items: flex-start;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  display: flex;
+  gap: 10px;
+  padding: 14px;
+}
+
+.choice input {
+  margin-top: 5px;
+  width: auto;
+}
+
+.choice small {
+  color: var(--muted);
+  display: block;
+  font-weight: 400;
+}
+
+.candidate-list {
+  margin-bottom: 16px;
+}
+
+.results {
+  display: grid;
+  gap: 16px;
+}
+
+.result-label {
+  align-items: baseline;
+  display: flex;
+  gap: 12px;
+  justify-content: space-between;
+}
+
+.result-label span {
+  color: var(--muted);
+}
+
+.bar {
+  background: #e8eaee;
+  border-radius: 999px;
+  height: 12px;
+  overflow: hidden;
+}
+
+.bar span {
+  background: var(--accent);
+  display: block;
+  height: 100%;
+}
+
+table {
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: 12px 8px;
+  text-align: left;
+  vertical-align: top;
+}
+
+th {
+  color: var(--muted);
+  font-size: 0.8rem;
+  text-transform: uppercase;
+}
+
+.link-danger {
+  background: none;
+  color: var(--danger);
+  font-weight: 700;
+  padding: 0;
+}
+
+.link-danger:hover {
+  background: none;
+  text-decoration: underline;
+}
+
+.empty {
+  color: var(--muted);
+  grid-column: 1 / -1;
+}
+
+@media (max-width: 720px) {
+  .topbar,
+  .page-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  nav {
+    justify-content: flex-start;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/admin_dashboard.html b/templates/admin_dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..cb7c2b0e4cb6d3a8a523437e47cfd68b6c8ea135
--- /dev/null
