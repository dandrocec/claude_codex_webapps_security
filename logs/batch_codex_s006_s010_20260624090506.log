diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..c654515e9c3f74bc7a36c0925f96c8995042aaa5
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,262 @@
+:root {
+  color-scheme: light;
+  --bg: #f5f7fb;
+  --panel: #ffffff;
+  --text: #182033;
+  --muted: #607089;
+  --accent: #176b87;
+  --accent-dark: #0f4e65;
+  --border: #d9e1ec;
+  --danger: #a92525;
+  --warning: #876000;
+  --info: #176b87;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.site-header {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+  display: flex;
+  justify-content: space-between;
+  min-height: 64px;
+  padding: 0 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  gap: 16px;
+}
+
+.user-label {
+  color: var(--muted);
+}
+
+.inline-form {
+  display: inline;
+}
+
+.link-button {
+  background: transparent;
+  border: 0;
+  color: var(--accent);
+  cursor: pointer;
+  font: inherit;
+  padding: 0;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 32px 20px;
+}
+
+.hero,
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 28px;
+}
+
+.hero h1,
+.panel h1 {
+  font-size: 2rem;
+  line-height: 1.2;
+  margin: 0 0 12px;
+}
+
+.panel h2 {
+  font-size: 1.25rem;
+  margin: 0 0 16px;
+}
+
+.panel + .panel {
+  margin-top: 20px;
+}
+
+.narrow {
+  max-width: 520px;
+}
+
+form {
+  display: grid;
+  gap: 16px;
+}
+
+label {
+  color: var(--text);
+  display: grid;
+  font-weight: 700;
+  gap: 8px;
+}
+
+input,
+textarea {
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 11px 12px;
+  width: 100%;
+}
+
+textarea {
+  min-height: 160px;
+  resize: vertical;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 1px solid var(--accent);
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 16px;
+  text-align: center;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.button.secondary {
+  background: #ffffff;
+  color: var(--accent);
+}
+
+.button.secondary:hover {
+  background: #eef6f9;
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 12px;
+  margin-top: 20px;
+}
+
+.flash-list {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 20px;
+}
+
+.flash {
+  border-radius: 6px;
+  margin: 0;
+  padding: 10px 12px;
+}
+
+.flash-danger,
+.field-error {
+  color: var(--danger);
+}
+
+.flash-warning {
+  color: var(--warning);
+}
+
+.flash-info {
+  color: var(--info);
+}
+
+.qr-list {
+  display: grid;
+  gap: 10px;
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.qr-list li {
+  align-items: center;
+  border-top: 1px solid var(--border);
+  display: flex;
+  gap: 16px;
+  justify-content: space-between;
+  padding-top: 10px;
+}
+
+.qr-list span,
+.muted {
+  color: var(--muted);
+}
+
+.result-grid {
+  align-items: start;
+  display: grid;
+  gap: 28px;
+  grid-template-columns: 1fr 320px;
+}
+
+.content-preview {
+  background: #f1f5f9;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  overflow-wrap: anywhere;
+  padding: 12px;
+}
+
+.qr-preview {
+  background: #ffffff;
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 16px;
+}
+
+.qr-preview img {
+  display: block;
+  height: auto;
+  width: 100%;
+}
+
+@media (max-width: 720px) {
+  .site-header,
+  .nav,
+  .qr-list li {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .site-header {
+    gap: 12px;
+    padding: 16px 20px;
+  }
+
+  .result-grid {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..8e5394383e87a2bb38bfcbac88e18fa7c2762225
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Secure QR Generator{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <a class="brand" href="{{ url_for('index') }}">Secure QR Generator</a>
+      <nav class="nav">
+        {% if g.user %}
+          <span class="user-label">{{ g.user["username"] }}</span>
+          <form action="{{ url_for('logout') }}" method="post" class="inline-form">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="link-button">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Sign in</a>
+          <a href="{{ url_for('register') }}">Create account</a>
+        {% endif %}
+      </nav>
+    </header>
+
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="flash-list" role="status" aria-live="polite">
+            {% for category, message in messages %}
+              <p class="flash flash-{{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..35ee9f9678e22cf713188b60a4d0c8d4d6caa171
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,31 @@
+{% extends "base.html" %}
+{% block title %}Generate QR Code{% endblock %}
+{% block content %}
+  <section class="panel">
+    <h1>Generate QR code</h1>
+    <form action="{{ url_for('create_qr') }}" method="post">
+      {{ form.hidden_tag() }}
+      <label>
+        Text or URL
+        {{ form.qr_text(rows="7", maxlength="2048", placeholder="Enter text or an https:// URL") }}
+      </label>
+      <button type="submit">Generate QR code</button>
+    </form>
+  </section>
+
+  <section class="panel">
+    <h2>Recent QR codes</h2>
+    {% if qrs %}
+      <ul class="qr-list">
+        {% for qr in qrs %}
+          <li>
+            <a href="{{ url_for('qr_result', qr_id=qr['id']) }}">{{ qr["content"]|truncate_middle }}</a>
+            <span>{{ qr["created_at"] }}</span>
+          </li>
+        {% endfor %}
+      </ul>
+    {% else %}
+      <p class="muted">No QR codes yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
