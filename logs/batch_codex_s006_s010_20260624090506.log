+    if ($text === '' || strlen($text) > MAX_TEXT_BYTES || !isValidUtf8($text)) {
+        http_response_code(422);
+        renderHome($pdo, 'Enter valid UTF-8 text up to ' . MAX_TEXT_BYTES . ' bytes.');
