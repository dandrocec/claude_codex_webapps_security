+                    </div>
+                    <div class="stat">
+                        <span>Lines</span>
+                        <strong><?= number_format($stats['lines']) ?></strong>
+                    </div>
+                </div>
+
+                <h2>Submitted text</h2>
+                <pre><?= htmlspecialchars($submittedText, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8') ?></pre>
+            </section>
+        <?php endif; ?>
+    </main>
+</body>
+</html>

