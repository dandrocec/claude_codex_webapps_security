+{% extends "base.html" %}
+{% block title %}Secure QR Generator{% endblock %}
+{% block content %}
+  <section class="hero">
+    <div>
+      <h1>Generate QR codes from text or URLs.</h1>
+      <p>Create an account, submit text or an http/https URL, and download the generated QR code as a PNG.</p>
+      <div class="actions">
+        <a class="button" href="{{ url_for('register') }}">Create account</a>
+        <a class="button secondary" href="{{ url_for('login') }}">Sign in</a>
+      </div>
+    </div>
+  </section>
+{% endblock %}
