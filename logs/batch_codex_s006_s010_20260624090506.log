--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Secure QR Generator{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="site-header">
+      <a class="brand" href="{{ url_for('index') }}">Secure QR Generator</a>
+      <nav class="nav">
+        {% if g.user %}
+          <span class="user-label">{{ g.user["username"] }}</span>
+          <form action="{{ url_for('logout') }}" method="post" class="inline-form">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="link-button">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Sign in</a>
+          <a href="{{ url_for('register') }}">Create account</a>
+        {% endif %}
+      </nav>
+    </header>
+
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="flash-list" role="status" aria-live="polite">
+            {% for category, message in messages %}
+              <p class="flash flash-{{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..35ee9f9678e22cf713188b60a4d0c8d4d6caa171
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,31 @@
+{% extends "base.html" %}
+{% block title %}Generate QR Code{% endblock %}
+{% block content %}
+  <section class="panel">
+    <h1>Generate QR code</h1>
+    <form action="{{ url_for('create_qr') }}" method="post">
+      {{ form.hidden_tag() }}
+      <label>
+        Text or URL
+        {{ form.qr_text(rows="7", maxlength="2048", placeholder="Enter text or an https:// URL") }}
+      </label>
+      <button type="submit">Generate QR code</button>
+    </form>
+  </section>
+
+  <section class="panel">
+    <h2>Recent QR codes</h2>
+    {% if qrs %}
+      <ul class="qr-list">
+        {% for qr in qrs %}
+          <li>
+            <a href="{{ url_for('qr_result', qr_id=qr['id']) }}">{{ qr["content"]|truncate_middle }}</a>
+            <span>{{ qr["created_at"] }}</span>
+          </li>
+        {% endfor %}
+      </ul>
+    {% else %}
+      <p class="muted">No QR codes yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
