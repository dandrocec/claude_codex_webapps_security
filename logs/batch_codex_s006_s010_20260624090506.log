+    "express-rate-limit": "^7.3.1",
+    "express-session": "^1.18.0",
+    "helmet": "^7.1.0"
+  }
+}
diff --git a/public/styles.css b/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..a263f0072e138ff2c41bb8c82cd7bdfe6b3920bc
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,162 @@
+:root {
+  color-scheme: light;
+  --bg: #f5f7f9;
+  --panel: #ffffff;
+  --text: #17202a;
+  --muted: #5d6978;
+  --border: #d8dee6;
+  --accent: #176b87;
+  --accent-dark: #0f4e63;
+  --error-bg: #fff1f1;
+  --error-text: #8a1f1f;
+  --success-bg: #edf8f1;
+  --success-text: #1d6b3a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+}
+
+.page {
+  width: min(920px, calc(100% - 32px));
+  margin: 48px auto;
+}
+
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 24px;
+  margin-bottom: 20px;
+}
+
+h1,
+h2 {
+  margin: 0 0 18px;
+  line-height: 1.2;
+}
+
+h1 {
+  font-size: 2rem;
+}
+
+h2 {
+  font-size: 1.25rem;
+}
+
+label {
+  display: block;
+  margin-bottom: 8px;
+  font-weight: 700;
+}
+
+.form-row {
+  display: grid;
+  grid-template-columns: 1fr auto;
+  gap: 12px;
+}
+
+input {
+  width: 100%;
+  min-width: 0;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  padding: 12px;
+  font-size: 1rem;
+}
+
+button {
+  border: 0;
+  border-radius: 6px;
+  background: var(--accent);
+  color: #ffffff;
+  cursor: pointer;
+  font-size: 1rem;
+  font-weight: 700;
+  padding: 0 18px;
+}
+
+button:hover,
+button:focus {
+  background: var(--accent-dark);
+}
+
+.message {
+  border-radius: 6px;
+  margin: 16px 0 0;
+  padding: 12px;
+}
+
+.error {
+  background: var(--error-bg);
+  color: var(--error-text);
+}
+
+.success {
+  background: var(--success-bg);
+  color: var(--success-text);
+  overflow-wrap: anywhere;
+}
+
+.success span {
+  font-weight: 700;
+}
+
+.empty {
+  color: var(--muted);
+  margin-bottom: 0;
+}
+
+.links {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.links li {
+  border-top: 1px solid var(--border);
+  display: grid;
+  gap: 6px;
+  padding: 14px 0;
+}
+
+.links li:first-child {
+  border-top: 0;
+  padding-top: 0;
+}
+
+.code {
+  font-family: Consolas, Monaco, monospace;
+  font-weight: 700;
+}
+
+.target {
+  color: var(--muted);
+  overflow-wrap: anywhere;
+}
+
+@media (max-width: 620px) {
+  .page {
+    margin: 24px auto;
+  }
+
+  .form-row {
+    grid-template-columns: 1fr;
+  }
+
+  button {
+    min-height: 44px;
+  }
+}
