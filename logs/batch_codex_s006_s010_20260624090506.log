+{% extends "base.html" %}
+{% block title %}Error {{ status_code }}{% endblock %}
+{% block content %}
+  <section class="panel narrow">
+    <h1>Error {{ status_code }}</h1>
+    <p>{{ message }}</p>
+    <a class="button secondary" href="{{ url_for('index') }}">Go home</a>
+  </section>
+{% endblock %}
