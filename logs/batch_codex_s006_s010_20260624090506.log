+  color: #526170;
+  line-height: 1.6;
+}
+
+.qr-form {
+  display: grid;
+  gap: 12px;
+}
+
+label,
+.encoded-content span {
+  color: #334155;
+  font-size: 0.95rem;
+  font-weight: 700;
+}
+
+textarea {
+  width: 100%;
+  resize: vertical;
+  min-height: 144px;
+  padding: 14px 16px;
+  border: 1px solid #cbd5e1;
+  border-radius: 8px;
+  color: #15202b;
+  font: inherit;
+  line-height: 1.5;
+}
+
+textarea:focus {
+  border-color: #2563eb;
+  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.14);
+  outline: none;
+}
+
+.error {
+  margin: 0;
+  color: #b42318;
+  font-weight: 700;
+}
+
+button,
+.button {
