@@ -0,0 +1,31 @@
+{% extends "base.html" %}
+{% block title %}Generate QR Code{% endblock %}
+{% block content %}
+  <section class="panel">
+    <h1>Generate QR code</h1>
+    <form action="{{ url_for('create_qr') }}" method="post">
+      {{ form.hidden_tag() }}
+      <label>
+        Text or URL
+        {{ form.qr_text(rows="7", maxlength="2048", placeholder="Enter text or an https:// URL") }}
+      </label>
+      <button type="submit">Generate QR code</button>
+    </form>
+  </section>
+
+  <section class="panel">
+    <h2>Recent QR codes</h2>
+    {% if qrs %}
+      <ul class="qr-list">
+        {% for qr in qrs %}
+          <li>
+            <a href="{{ url_for('qr_result', qr_id=qr['id']) }}">{{ qr["content"]|truncate_middle }}</a>
+            <span>{{ qr["created_at"] }}</span>
+          </li>
+        {% endfor %}
+      </ul>
+    {% else %}
+      <p class="muted">No QR codes yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
