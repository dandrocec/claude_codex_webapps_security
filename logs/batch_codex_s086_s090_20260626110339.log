+{% extends "base.html" %}
+{% block title %}Order #{{ order.id }} - Flask Shop{% endblock %}
+{% block content %}
+<section class="page-heading">
+  <h1>Order #{{ order.id }}</h1>
+  <p>Status: <span class="status {{ order.status }}">{{ order.status }}</span></p>
+</section>
+
+<div class="table-wrap">
+  <table>
+    <thead>
+      <tr>
+        <th>Item</th>
+        <th>Unit price</th>
+        <th>Quantity</th>
+        <th>Total</th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for item in order.items %}
+        <tr>
+          <td>{{ item.product_name }}</td>
+          <td>{{ item.unit_price_cents|money }}</td>
+          <td>{{ item.quantity }}</td>
+          <td>{{ (item.unit_price_cents * item.quantity)|money }}</td>
+        </tr>
+      {% endfor %}
+    </tbody>
+    <tfoot>
+      <tr>
+        <th colspan="3">Order total</th>
+        <th>{{ order.total_cents|money }}</th>
+      </tr>
+    </tfoot>
+  </table>
+</div>
+
+{% if order.status == "pending" %}
+  <p class="note">This order is waiting for a Stripe checkout webhook before it is marked paid.</p>
+{% endif %}
+{% endblock %}
