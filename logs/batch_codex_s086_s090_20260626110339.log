diff --git a/src/views/partials/header.ejs b/src/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2f430551c7790510fe1a0845df79a3338f1c2d97
--- /dev/null
+++ b/src/views/partials/header.ejs
@@ -0,0 +1,12 @@
+<header class="topbar">
+  <a class="brand" href="/dashboard">Admin Dashboard</a>
+  <% if (currentAdmin) { %>
+    <div class="session">
+      <span><%= currentAdmin.name %></span>
+      <form method="post" action="/logout">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <button class="button button-secondary" type="submit">Sign out</button>
+      </form>
+    </div>
+  <% } %>
+</header>
diff --git a/src/views/user-form.ejs b/src/views/user-form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..e387cdd9f699754a1f77528dc9110b3acf527167
--- /dev/null
+++ b/src/views/user-form.ejs
@@ -0,0 +1,40 @@
+<%- include("partials/head", { title }) %>
+<%- include("partials/header") %>
+<main class="page narrow">
+  <div class="page-title">
+    <div>
+      <h1><%= title %></h1>
+      <p class="muted"><%= user ? "Update account details." : "Create a database-backed user account." %></p>
+    </div>
+    <a class="button button-secondary" href="/dashboard">Back</a>
+  </div>
+
+  <form class="form-panel" method="post" action="<%= action %>" novalidate>
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+
+    <label for="name">Name</label>
+    <input id="name" name="name" type="text" value="<%= formData.name || "" %>" required minlength="2" maxlength="80">
+    <% if (fieldErrors.name) { %><p class="field-error"><%= fieldErrors.name %></p><% } %>
+
+    <label for="email">Email</label>
+    <input id="email" name="email" type="email" value="<%= formData.email || "" %>" required maxlength="254">
+    <% if (fieldErrors.email) { %><p class="field-error"><%= fieldErrors.email %></p><% } %>
+
+    <label for="role">Role</label>
+    <select id="role" name="role" required>
+      <option value="user" <%= (formData.role || "user") === "user" ? "selected" : "" %>>User</option>
+      <option value="admin" <%= formData.role === "admin" ? "selected" : "" %>>Admin</option>
+    </select>
+    <% if (fieldErrors.role) { %><p class="field-error"><%= fieldErrors.role %></p><% } %>
+
+    <label for="password">Password <%= user ? "(leave blank to keep current password)" : "" %></label>
+    <input id="password" name="password" type="password" autocomplete="new-password" <%= user ? "" : "required" %> minlength="12" maxlength="200">
+    <% if (fieldErrors.password) { %><p class="field-error"><%= fieldErrors.password %></p><% } %>
+
+    <div class="form-actions">
+      <button class="button button-primary" type="submit"><%= submitLabel %></button>
+      <a class="button button-secondary" href="/dashboard">Cancel</a>
+    </div>
+  </form>
+</main>
+<%- include("partials/foot") %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..64164ff10c1b393d829742cfa4f7a0a0d7521017
--- /dev/null
+++ b/README.md
@@ -0,0 +1,27 @@
+# Secure Admin Dashboard
+
+An Express and SQLite admin dashboard with bcrypt password hashing, CSRF protection, secure headers, input validation, parameterised SQL queries, and role-based access control.
+
+## Run locally on port 5086
+
+1. Install dependencies:
+   ```bash
+   npm install
+   ```
+2. Create a `.env` file:
+   ```bash
+   PORT=5086
+   SESSION_SECRET=replace-with-a-long-random-secret
+   ADMIN_EMAIL=admin@example.com
+   ADMIN_PASSWORD=replace-with-a-strong-password
+   DATABASE_FILE=./data/app.sqlite
+   NODE_ENV=development
+   COOKIE_SECURE=false
+   ```
+3. Start the app:
+   ```bash
+   npm start
+   ```
+4. Open `http://localhost:5086` and sign in with `ADMIN_EMAIL` and `ADMIN_PASSWORD`.
+
+For production, run behind HTTPS, set `NODE_ENV=production`, set `COOKIE_SECURE=true`, and use strong unique environment secrets.
