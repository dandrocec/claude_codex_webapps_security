new file mode 100644
index 0000000000000000000000000000000000000000..67b99f95b9e5c0c1284c6c04be9b5a4b53cd613a
--- /dev/null
+++ b/templates/admin_orders.html
@@ -0,0 +1,38 @@
+{% extends "base.html" %}
+{% block title %}Admin Orders - Flask Shop{% endblock %}
+{% block content %}
+<section class="page-heading">
+  <h1>Admin Orders</h1>
+</section>
+
+<div class="table-wrap">
+  <table>
+    <thead>
+      <tr>
+        <th>Order</th>
+        <th>Customer</th>
+        <th>Date</th>
+        <th>Status</th>
+        <th>Total</th>
+        <th>Stripe session</th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for order in orders %}
+        <tr>
+          <td>#{{ order.id }}</td>
+          <td>{{ order.user.email }}</td>
+          <td>{{ order.created_at.strftime("%Y-%m-%d %H:%M") }}</td>
+          <td><span class="status {{ order.status }}">{{ order.status }}</span></td>
+          <td>{{ order.total_cents|money }}</td>
+          <td class="mono">{{ order.stripe_session_id or "-" }}</td>
+        </tr>
+      {% else %}
+        <tr>
+          <td colspan="6">No orders yet.</td>
+        </tr>
+      {% endfor %}
+    </tbody>
+  </table>
+</div>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..f2fb258cdc83c76ae6e27bb9d1162a1354cf986a
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,43 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Flask Shop{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="{{ url_for('products') }}">Market Lane</a>
+    <nav>
+      <a href="{{ url_for('products') }}">Products</a>
+      <a href="{{ url_for('cart') }}">Cart ({{ cart_count }})</a>
+      {% if current_user %}
+        <a href="{{ url_for('orders') }}">Orders</a>
+        {% if current_user.is_admin %}
+          <a href="{{ url_for('admin_orders') }}">Admin</a>
+        {% endif %}
+        <form class="inline" action="{{ url_for('logout') }}" method="post">
+          <button class="link-button" type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+
+  <main>
+    {% with messages = get_flashed_messages(with_categories=true) %}
+      {% if messages %}
+        <div class="flash-stack">
+          {% for category, message in messages %}
+            <div class="flash {{ category }}">{{ message }}</div>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
