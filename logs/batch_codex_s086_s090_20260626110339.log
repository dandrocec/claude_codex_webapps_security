+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --text: #17202a;
+  --muted: #667085;
+  --line: #d8dee8;
+  --card: #ffffff;
+  --accent: #0f766e;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding: 1rem max(1rem, calc((100vw - 1100px) / 2));
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.2rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 1rem;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1100px;
+  padding: 2rem 1rem;
+}
+
+.heading {
+  margin-bottom: 1.5rem;
+}
+
+.heading h1,
+.panel h1 {
+  margin: 0 0 .4rem;
+}
+
+.grid {
+  display: grid;
+  gap: 1rem;
+  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
+}
+
+.card,
+.panel {
+  background: var(--card);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 1rem;
+}
+
+.panel {
+  max-width: 480px;
+}
+
+.price {
+  font-size: 1.25rem;
+  font-weight: 700;
+}
+
+.muted {
+  color: var(--muted);
+}
+
+form {
+  display: grid;
+  gap: .85rem;
+}
+
+.inline {
+  display: inline;
+}
+
+.row-form {
+  align-items: center;
+  display: flex;
+  gap: .5rem;
+}
+
+label {
+  display: grid;
+  font-weight: 700;
+  gap: .25rem;
+}
+
+input {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  padding: .65rem;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: .7rem 1rem;
+  text-align: center;
+  text-decoration: none;
+}
+
+button:disabled {
+  cursor: not-allowed;
+  opacity: .55;
+}
+
+.link-button {
+  background: transparent;
+  color: var(--accent);
+  font-weight: 400;
+  padding: 0;
+}
+
+table {
+  background: #ffffff;
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: .8rem;
+  text-align: left;
+  vertical-align: middle;
+}
+
+.checkout {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+  justify-content: flex-end;
+  margin-top: 1rem;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message {
+  border-radius: 6px;
+  margin: .5rem 0;
+  padding: .75rem;
+}
+
+.success {
+  background: #ecfdf3;
+  color: #05603a;
+}
+
+.error {
+  background: #fef3f2;
+  color: var(--danger);
+}
+
+@media (max-width: 700px) {
+  .topbar,
+  .checkout {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/admin_orders.html b/templates/admin_orders.html
new file mode 100644
