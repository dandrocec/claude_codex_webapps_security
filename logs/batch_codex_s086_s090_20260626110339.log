+  cursor: pointer;
+}
+
+.button-primary {
+  color: #ffffff;
+  background: var(--primary);
+}
+
+.button-primary:hover {
+  background: var(--primary-dark);
+}
+
+.button-secondary {
+  color: var(--text);
+  background: #ffffff;
+  border-color: var(--line);
+}
+
+.button-danger {
+  color: var(--danger);
+  background: var(--danger-bg);
+  border-color: #ffd0cc;
+}
+
+.full-width {
+  width: 100%;
+}
+
+label {
+  display: block;
+  margin: 16px 0 6px;
+  font-weight: 650;
+}
+
+input,
+select {
+  width: 100%;
+  min-height: 44px;
+  padding: 10px 12px;
+  color: var(--text);
+  background: #ffffff;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
