+
+.eyebrow,
+.label {
+  color: #667085;
+  font-size: 0.78rem;
+  font-weight: 700;
+  letter-spacing: 0;
+  margin: 0 0 8px;
+  text-transform: uppercase;
+}
+
+h1 {
+  font-size: clamp(2rem, 4vw, 3rem);
+  line-height: 1.05;
+  margin: 0 0 16px;
+}
+
+.lede {
+  color: #475467;
+  font-size: 1.08rem;
+  line-height: 1.6;
+  margin: 0 0 24px;
+}
+
+.notice {
+  background: #fff7e6;
+  border: 1px solid #fedf89;
+  border-radius: 8px;
+  color: #7a4d00;
+  line-height: 1.5;
+  margin: 0 0 24px;
+  padding: 14px 16px;
+}
+
+.button {
+  align-items: center;
+  background: #1f6feb;
+  border: 0;
+  border-radius: 8px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-flex;
+  font: inherit;
+  font-weight: 700;
+  justify-content: center;
+  min-height: 44px;
+  padding: 0 18px;
+  text-decoration: none;
+}
+
+.button.secondary {
+  background: #e8eef7;
+  color: #172033;
+}
+
+.profile-header {
+  align-items: center;
+  display: flex;
+  gap: 18px;
+  margin-bottom: 28px;
+}
+
+.avatar {
+  border-radius: 50%;
+  flex: 0 0 auto;
+  height: 96px;
+  width: 96px;
+}
+
+.grid {
+  display: grid;
+  gap: 12px;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
