+            )
+        flash("Added to cart.", "success")
+        return redirect(url_for("cart"))
+
+    @app.route("/cart/update", methods=["POST"])
+    @login_required
+    def update_cart():
+        item_id = parse_positive_int(request.form.get("item_id"))
+        quantity = parse_positive_int(request.form.get("quantity"), maximum=25, allow_zero=True)
+        item = query_one(
+            "SELECT ci.id, p.stock FROM cart_items ci JOIN products p ON p.id = ci.product_id "
+            "WHERE ci.id = ? AND ci.user_id = ?",
+            (item_id, g.user["id"]),
+        )
+        if not item:
+            abort(404)
+        if quantity == 0:
+            execute("DELETE FROM cart_items WHERE id = ? AND user_id = ?", (item_id, g.user["id"]))
+        else:
+            execute(
+                "UPDATE cart_items SET quantity = ? WHERE id = ? AND user_id = ?",
+                (min(quantity, item["stock"]), item_id, g.user["id"]),
+            )
+        return redirect(url_for("cart"))
+
+    @app.route("/checkout", methods=["POST"])
+    @login_required
+    def checkout():
+        items = cart_items()
+        if not items:
+            flash("Your cart is empty.", "error")
+            return redirect(url_for("cart"))
+        total = sum(i["line_total"] for i in items)
+        now = utc_now()
+        token = secrets.token_urlsafe(32)
+        db = get_db()
+        try:
+            db.execute("BEGIN")
+            cur = db.execute(
+                "INSERT INTO orders (user_id, status, total_cents, payment_token, created_at) "
+                "VALUES (?, 'pending', ?, ?, ?)",
+                (g.user["id"], total, token, now),
+            )
+            order_id = cur.lastrowid
+            for item in items:
+                product = db.execute(
+                    "SELECT stock FROM products WHERE id = ?", (item["product_id"],)
+                ).fetchone()
+                if not product or product["stock"] < item["quantity"]:
+                    raise ValueError("Insufficient stock")
+                db.execute(
+                    "INSERT INTO order_items (order_id, product_id, product_name, unit_price_cents, quantity) "
+                    "VALUES (?, ?, ?, ?, ?)",
+                    (
+                        order_id,
+                        item["product_id"],
+                        item["name"],
+                        item["price_cents"],
+                        item["quantity"],
+                    ),
+                )
+                db.execute(
+                    "UPDATE products SET stock = stock - ? WHERE id = ?",
+                    (item["quantity"], item["product_id"]),
+                )
+            db.execute("DELETE FROM cart_items WHERE user_id = ?", (g.user["id"],))
+            db.commit()
+        except Exception:
+            db.rollback()
+            abort(500)
+        return redirect(url_for("payment_sandbox", order_id=order_id, token=token))
+
+    @app.route("/payment/sandbox/<int:order_id>")
+    @login_required
+    def payment_sandbox(order_id):
+        token = request.args.get("token", "")
+        order = query_one(
+            "SELECT id, status, total_cents, payment_token FROM orders WHERE id = ? AND user_id = ?",
+            (order_id, g.user["id"]),
+        )
+        if not order or not hmac.compare_digest(order["payment_token"], token):
+            abort(404)
+        return render_template("payment.html", order=order, webhook_secret_configured=bool(webhook_secret()))
+
+    @app.route("/payment/sandbox/<int:order_id>/pay", methods=["POST"])
+    @login_required
+    def sandbox_pay(order_id):
+        token = request.form.get("token", "")
+        order = query_one(
+            "SELECT id, payment_token FROM orders WHERE id = ? AND user_id = ? AND status = 'pending'",
+            (order_id, g.user["id"]),
+        )
+        if not order or not hmac.compare_digest(order["payment_token"], token):
+            abort(404)
+        secret = webhook_secret()
+        if not secret:
+            flash("Payment sandbox is not configured.", "error")
+            return redirect(url_for("payment_sandbox", order_id=order_id, token=token))
+        signature = sign_webhook(order_id, "paid", secret)
+        mark_order_paid(order_id, signature)
+        flash("Payment completed in sandbox.", "success")
+        return redirect(url_for("orders"))
+
+    @app.route("/webhooks/payment", methods=["POST"])
+    @csrf.exempt
+    def payment_webhook():
+        payload = request.get_json(silent=True) or {}
+        order_id = parse_positive_int(payload.get("order_id"))
+        status = clean_text(str(payload.get("status", "")), 20)
+        signature = request.headers.get("X-Sandbox-Signature", "")
+        if status != "paid" or not mark_order_paid(order_id, signature):
+            abort(400)
+        return jsonify({"ok": True})
+
+    @app.route("/orders")
+    @login_required
+    def orders():
+        rows = query_all(
+            "SELECT id, status, total_cents, created_at, paid_at FROM orders "
+            "WHERE user_id = ? ORDER BY created_at DESC",
+            (g.user["id"],),
+        )
+        return render_template("orders.html", orders=rows)
+
+    @app.route("/orders/<int:order_id>")
+    @login_required
+    def order_detail(order_id):
+        order = query_one(
+            "SELECT id, status, total_cents, created_at, paid_at FROM orders "
+            "WHERE id = ? AND user_id = ?",
+            (order_id, g.user["id"]),
+        )
+        if not order:
+            abort(404)
+        items = query_all(
+            "SELECT product_name, unit_price_cents, quantity FROM order_items WHERE order_id = ?",
+            (order_id,),
+        )
+        return render_template("order_detail.html", order=order, items=items)
+
+    @app.route("/admin/orders")
+    @admin_required
+    def admin_orders():
+        rows = query_all(
+            "SELECT o.id, o.status, o.total_cents, o.created_at, o.paid_at, u.email "
+            "FROM orders o JOIN users u ON u.id = o.user_id ORDER BY o.created_at DESC"
+        )
+        return render_template("admin_orders.html", orders=rows)
+
+    with app.app_context():
+        init_db()
+    return app
+
+
+def get_db():
+    if "db" not in g:
+        g.db = sqlite3.connect(DATABASE)
+        g.db.row_factory = sqlite3.Row
+        g.db.execute("PRAGMA foreign_keys = ON")
+    return g.db
+
+
+def close_db(_error=None):
+    db = g.pop("db", None)
+    if db is not None:
+        db.close()
+
+
+def query_one(sql, params=()):
+    return get_db().execute(sql, params).fetchone()
+
+
+def query_all(sql, params=()):
+    return get_db().execute(sql, params).fetchall()
+
+
+def execute(sql, params=()):
+    db = get_db()
+    db.execute(sql, params)
+    db.commit()
+
+
+def init_db():
+    db = get_db()
+    db.executescript(
+        """
+        CREATE TABLE IF NOT EXISTS users (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            email TEXT NOT NULL UNIQUE,
+            name TEXT NOT NULL,
+            password_hash TEXT NOT NULL,
+            is_admin INTEGER NOT NULL DEFAULT 0
+        );
+        CREATE TABLE IF NOT EXISTS products (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            name TEXT NOT NULL,
+            description TEXT NOT NULL,
+            price_cents INTEGER NOT NULL CHECK (price_cents > 0),
+            stock INTEGER NOT NULL CHECK (stock >= 0)
+        );
+        CREATE TABLE IF NOT EXISTS cart_items (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            user_id INTEGER NOT NULL,
+            product_id INTEGER NOT NULL,
+            quantity INTEGER NOT NULL CHECK (quantity > 0),
+            UNIQUE(user_id, product_id),
+            FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE,
+            FOREIGN KEY(product_id) REFERENCES products(id) ON DELETE CASCADE
+        );
+        CREATE TABLE IF NOT EXISTS orders (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            user_id INTEGER NOT NULL,
+            status TEXT NOT NULL CHECK (status IN ('pending', 'paid')),
+            total_cents INTEGER NOT NULL CHECK (total_cents >= 0),
+            payment_token TEXT NOT NULL UNIQUE,
+            created_at TEXT NOT NULL,
+            paid_at TEXT,
+            FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE
+        );
+        CREATE TABLE IF NOT EXISTS order_items (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            order_id INTEGER NOT NULL,
+            product_id INTEGER NOT NULL,
+            product_name TEXT NOT NULL,
+            unit_price_cents INTEGER NOT NULL CHECK (unit_price_cents > 0),
+            quantity INTEGER NOT NULL CHECK (quantity > 0),
+            FOREIGN KEY(order_id) REFERENCES orders(id) ON DELETE CASCADE,
+            FOREIGN KEY(product_id) REFERENCES products(id)
+        );
+        """
+    )
+    if not db.execute("SELECT 1 FROM products LIMIT 1").fetchone():
+        db.executemany(
+            "INSERT INTO products (name, description, price_cents, stock) VALUES (?, ?, ?, ?)",
+            [
+                ("Trail Mug", "Insulated stainless mug for daily use.", 2499, 30),
+                ("Canvas Tote", "Heavy cotton tote with reinforced handles.", 1899, 45),
+                ("Desk Lamp", "Compact LED lamp with warm and cool modes.", 4299, 18),
+                ("Notebook Set", "Three recycled-paper notebooks.", 1299, 60),
+            ],
+        )
+    admin_email = os.environ.get("ADMIN_EMAIL", "").strip().lower()
+    admin_password = os.environ.get("ADMIN_PASSWORD", "")
+    if admin_email and admin_password and not db.execute(
+        "SELECT 1 FROM users WHERE email = ?", (admin_email,)
+    ).fetchone():
+        db.execute(
+            "INSERT INTO users (email, name, password_hash, is_admin) VALUES (?, ?, ?, 1)",
+            (admin_email, "Admin", ph.hash(admin_password)),
+        )
+    db.commit()
+
+
+def login_required(view):
+    @wraps(view)
+    def wrapped(*args, **kwargs):
+        if not g.user:
+            return redirect(url_for("login"))
+        return view(*args, **kwargs)
+
+    return wrapped
+
+
+def admin_required(view):
+    @wraps(view)
+    @login_required
+    def wrapped(*args, **kwargs):
+        if not g.user["is_admin"]:
+            abort(403)
+        return view(*args, **kwargs)
+
+    return wrapped
+
+
+def clean_text(value, max_len):
+    value = str(value or "").strip()
+    value = re.sub(r"[\x00-\x1f\x7f]", "", value)
+    return value[:max_len]
+
+
+def parse_positive_int(value, maximum=1_000_000, allow_zero=False):
+    try:
+        parsed = int(value)
+    except (TypeError, ValueError):
+        abort(400)
+    minimum = 0 if allow_zero else 1
+    if parsed < minimum or parsed > maximum:
+        abort(400)
+    return parsed
+
+
+def verify_password(stored_hash, password):
+    try:
+        return ph.verify(stored_hash, password)
+    except (VerifyMismatchError, VerificationError, TypeError):
+        return False
+
+
+def money(cents):
+    try:
+        return f"${Decimal(cents) / Decimal(100):,.2f}"
+    except (InvalidOperation, TypeError):
+        return "$0.00"
+
+
+def utc_now():
+    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()
+
+
+def cart_items():
+    return query_all(
+        "SELECT ci.id, ci.product_id, ci.quantity, p.name, p.price_cents, p.stock, "
+        "(ci.quantity * p.price_cents) AS line_total "
+        "FROM cart_items ci JOIN products p ON p.id = ci.product_id "
+        "WHERE ci.user_id = ? ORDER BY p.name",
+        (g.user["id"],),
+    )
+
+
+def webhook_secret():
+    return os.environ.get("PAYMENT_WEBHOOK_SECRET", "")
+
+
+def sign_webhook(order_id, status, secret):
+    body = f"{order_id}:{status}".encode()
+    return hmac.new(secret.encode(), body, "sha256").hexdigest()
+
+
+def mark_order_paid(order_id, signature):
+    secret = webhook_secret()
+    if not secret:
+        return False
+    expected = sign_webhook(order_id, "paid", secret)
+    if not hmac.compare_digest(expected, signature):
+        return False
+    order = query_one("SELECT id, status FROM orders WHERE id = ?", (order_id,))
+    if not order:
+        return False
+    if order["status"] != "paid":
+        execute(
+            "UPDATE orders SET status = 'paid', paid_at = ? WHERE id = ?",
+            (utc_now(), order_id),
+        )
+    return True
+
+
+app = create_app()
+app.teardown_appcontext(close_db)
+app.jinja_env.filters["money"] = money
+
+
+if __name__ == "__main__":
+    app.run(host="127.0.0.1", port=5089, debug=False)
