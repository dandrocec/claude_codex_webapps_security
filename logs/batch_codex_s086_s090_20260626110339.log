@@ -0,0 +1,48 @@
+{% extends "base.html" %}
+{% block title %}Cart - Flask Shop{% endblock %}
+{% block content %}
+<section class="page-heading">
+  <h1>Your Cart</h1>
+</section>
+
+{% if rows %}
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th>Product</th>
+          <th>Price</th>
+          <th>Quantity</th>
+          <th>Total</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for row in rows %}
+          <tr>
+            <td>{{ row.product.name }}</td>
+            <td>{{ row.product.price_cents|money }}</td>
+            <td>
+              <form class="qty-form" action="{{ url_for('update_cart', product_id=row.product.id) }}" method="post">
+                <input type="number" name="quantity" value="{{ row.quantity }}" min="0">
+                <button type="submit">Update</button>
+              </form>
+            </td>
+            <td>{{ row.line_cents|money }}</td>
+          </tr>
+        {% endfor %}
+      </tbody>
+      <tfoot>
+        <tr>
+          <th colspan="3">Total</th>
+          <th>{{ total_cents|money }}</th>
+        </tr>
+      </tfoot>
+    </table>
+  </div>
+  <form class="checkout-form" action="{{ url_for('checkout') }}" method="post">
+    <button class="primary" type="submit">Check out</button>
+  </form>
+{% else %}
+  <p class="empty">Your cart is empty.</p>
+{% endif %}
+{% endblock %}
