+ph = PasswordHasher(time_cost=3, memory_cost=65536, parallelism=2)
+
+
+def create_app():
+    app = Flask(__name__)
+    app.config.update(
+        SECRET_KEY=os.environ.get("FLASK_SECRET_KEY") or secrets.token_urlsafe(32),
+        WTF_CSRF_TIME_LIMIT=3600,
+        SESSION_COOKIE_HTTPONLY=True,
+        SESSION_COOKIE_SECURE=True,
+        SESSION_COOKIE_SAMESITE="Lax",
+        MAX_CONTENT_LENGTH=1024 * 1024,
+    )
+    CSRFProtect(app)
+
+    @app.before_request
+    def load_user():
+        g.user = None
+        user_id = session.get("user_id")
+        if user_id:
+            g.user = query_one(
+                "SELECT id, email, name, is_admin FROM users WHERE id = ?",
+                (user_id,),
+            )
+
+    @app.after_request
+    def set_security_headers(response):
+        response.headers["Content-Security-Policy"] = (
+            "default-src 'self'; img-src 'self' data:; style-src 'self'; "
+            "script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; "
+            "form-action 'self'"
+        )
+        response.headers["X-Content-Type-Options"] = "nosniff"
+        response.headers["X-Frame-Options"] = "DENY"
+        response.headers["Referrer-Policy"] = "strict-origin-when-cross-origin"
+        response.headers["Permissions-Policy"] = "geolocation=(), microphone=(), camera=()"
+        return response
+
+    @app.errorhandler(400)
+    @app.errorhandler(403)
+    @app.errorhandler(404)
+    @app.errorhandler(413)
+    @app.errorhandler(500)
+    def handle_error(error):
+        status = getattr(error, "code", 500)
+        message = {
+            400: "Bad request.",
+            403: "Access denied.",
+            404: "Page not found.",
+            413: "Request too large.",
+            500: "Something went wrong.",
+        }.get(status, "Something went wrong.")
+        return render_template("error.html", status=status, message=message), status
+
+    @app.route("/")
+    def index():
+        products = query_all(
+            "SELECT id, name, description, price_cents, stock FROM products ORDER BY name"
+        )
+        return render_template("products.html", products=products)
+
+    @app.route("/register", methods=["GET", "POST"])
+    def register():
+        if request.method == "POST":
+            email = clean_text(request.form.get("email", ""), 254).lower()
+            name = clean_text(request.form.get("name", ""), 80)
