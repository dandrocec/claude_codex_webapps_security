+  padding: 10px;
+  font: inherit;
+}
+
+.notes {
+  list-style: none;
+  margin: 18px 0 0;
+  padding: 0;
+}
+
+.notes li {
+  display: flex;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 12px 0;
+  border-top: 1px solid var(--line);
+}
+
+@media (max-width: 760px) {
+  .hero,
+  .profile {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .grid {
+    grid-template-columns: 1fr;
+  }
+
+  dl {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/src/server.js b/src/server.js
new file mode 100644
index 0000000000000000000000000000000000000000..d99c5433bc80f6a7c98c308432f9bf123794c4b1
--- /dev/null
+++ b/src/server.js
@@ -0,0 +1,230 @@
+require("dotenv").config();
+
+const path = require("path");
+const express = require("express");
+const session = require("express-session");
+const SQLiteStore = require("connect-sqlite3")(session);
+const helmet = require("helmet");
+const rateLimit = require("express-rate-limit");
+const csrf = require("csurf");
+const morgan = require("morgan");
+const createError = require("http-errors");
+const fetch = require("node-fetch");
+const { body, param, validationResult } = require("express-validator");
+const DOMPurify = require("isomorphic-dompurify");
+const { configurePassport, passport } = require("./passport");
+const { statements } = require("./db");
+
+const app = express();
+const port = Number(process.env.PORT || 5090);
+const isProduction = process.env.NODE_ENV === "production";
+
+if (!process.env.SESSION_SECRET || process.env.SESSION_SECRET.length < 32) {
+  throw new Error("SESSION_SECRET must be set to at least 32 characters");
+}
+
+app.set("trust proxy", 1);
+app.set("view engine", "ejs");
+app.set("views", path.join(__dirname, "views"));
+app.disable("x-powered-by");
+
+app.use(helmet({
+  contentSecurityPolicy: {
+    directives: {
+      defaultSrc: ["'self'"],
+      baseUri: ["'self'"],
+      formAction: ["'self'"],
+      frameAncestors: ["'none'"],
+      imgSrc: ["'self'", "https:", "data:"],
+      scriptSrc: ["'self'"],
+      styleSrc: ["'self'", "'unsafe-inline'"]
+    }
+  },
+  referrerPolicy: { policy: "no-referrer" }
+}));
+app.use(morgan(isProduction ? "combined" : "dev"));
+app.use(express.urlencoded({ extended: false, limit: "20kb" }));
+
+app.use(rateLimit({
+  windowMs: 15 * 60 * 1000,
+  limit: 150,
+  standardHeaders: true,
+  legacyHeaders: false
+}));
+
+app.use(session({
+  store: new SQLiteStore({
+    db: "sessions.sqlite",
+    dir: path.dirname(process.env.DATABASE_PATH || path.join(process.cwd(), "data", "app.sqlite"))
+  }),
+  name: "__Host-oauth_profile.sid",
+  secret: process.env.SESSION_SECRET,
+  resave: false,
+  saveUninitialized: false,
+  cookie: {
+    httpOnly: true,
+    secure: isProduction,
+    sameSite: "lax",
+    path: "/",
+    maxAge: 1000 * 60 * 60 * 8
+  }
+}));
+
+configurePassport();
+app.use(passport.initialize());
+app.use(passport.session());
+
+const csrfProtection = csrf();
+
+app.use((req, res, next) => {
+  res.locals.currentUser = req.user || null;
+  next();
+});
+
+function requireAuth(req, res, next) {
+  if (!req.isAuthenticated || !req.isAuthenticated()) {
+    return res.redirect("/login");
+  }
+  return next();
+}
+
+function validateRequest(req, res, next) {
+  const errors = validationResult(req);
+  if (!errors.isEmpty()) {
+    return res.status(400).render("error", {
+      title: "Invalid request",
+      message: "The submitted data was invalid."
+    });
+  }
+  return next();
+}
+
+function cleanText(value) {
+  return DOMPurify.sanitize(String(value || ""), { ALLOWED_TAGS: [], ALLOWED_ATTR: [] }).trim();
+}
+
+app.get("/", (req, res) => {
+  if (req.user) {
+    return res.redirect("/dashboard");
+  }
+  return res.render("home", { title: "OAuth Profile App" });
+});
+
+app.get("/login", csrfProtection, (req, res) => {
+  res.render("login", {
+    title: "Sign in",
+    csrfToken: req.csrfToken()
+  });
+});
+
+app.post("/auth/github", csrfProtection, passport.authenticate("github"));
+
+app.get("/auth/github/callback",
+  passport.authenticate("github", {
+    failureRedirect: "/login",
+    failureMessage: true
+  }),
+  (req, res) => {
+    res.redirect("/dashboard");
+  }
+);
+
+app.get("/dashboard", requireAuth, csrfProtection, async (req, res, next) => {
+  try {
+    const token = statements.findTokenForUser.get(req.user.id);
+    const accountData = token ? await fetchGitHubAccount(token.access_token) : null;
+    const notes = statements.listNotesForUser.all(req.user.id);
+
+    res.render("dashboard", {
+      title: "Your dashboard",
+      csrfToken: req.csrfToken(),
+      accountData,
+      notes
+    });
+  } catch (error) {
+    next(error);
+  }
+});
+
+app.post("/notes",
+  requireAuth,
+  csrfProtection,
+  body("note").isString().trim().isLength({ min: 1, max: 500 }),
+  validateRequest,
+  (req, res) => {
+    const note = cleanText(req.body.note).slice(0, 500);
+    if (note) {
+      statements.insertNoteForUser.run(req.user.id, note);
+    }
+    res.redirect("/dashboard");
+  }
+);
+
+app.post("/notes/:id/delete",
+  requireAuth,
+  csrfProtection,
+  param("id").isInt({ min: 1 }),
+  validateRequest,
+  (req, res) => {
+    statements.deleteNoteForUser.run(Number(req.params.id), req.user.id);
+    res.redirect("/dashboard");
+  }
+);
+
+app.post("/logout", requireAuth, csrfProtection, (req, res, next) => {
+  req.logout((logoutError) => {
+    if (logoutError) {
+      return next(logoutError);
+    }
+    req.session.destroy((destroyError) => {
+      if (destroyError) {
+        return next(destroyError);
+      }
+      res.clearCookie("__Host-oauth_profile.sid", { path: "/" });
+      return res.redirect("/");
+    });
+  });
+});
+
+app.use((req, res, next) => {
+  next(createError(404, "Not found"));
+});
+
+app.use((err, req, res, next) => {
+  const status = err.status || 500;
+  if (status >= 500) {
+    console.error(err);
+  }
+  res.status(status).render("error", {
+    title: status === 404 ? "Not found" : "Something went wrong",
+    message: status === 404 ? "The page was not found." : "The request could not be completed."
+  });
+});
+
+async function fetchGitHubAccount(accessToken) {
+  const response = await fetch("https://api.github.com/user", {
+    headers: {
+      Accept: "application/vnd.github+json",
+      Authorization: `Bearer ${accessToken}`,
+      "User-Agent": "oauth-profile-express-app"
+    },
+    timeout: 5000
+  });
+
+  if (!response.ok) {
+    return { unavailable: true };
+  }
+
+  const json = await response.json();
+  return {
+    login: cleanText(json.login),
+    publicRepos: Number(json.public_repos || 0),
+    followers: Number(json.followers || 0),
+    following: Number(json.following || 0),
+    createdAt: cleanText(json.created_at)
+  };
+}
+
+app.listen(port, () => {
+  console.log(`OAuth profile app listening on port ${port}`);
+});
diff --git a/src/views/dashboard.ejs b/src/views/dashboard.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c5550775ef76783d55a683094ffda29faf4039c0
--- /dev/null
+++ b/src/views/dashboard.ejs
@@ -0,0 +1,58 @@
+<%- include("partials/header") %>
+
+<section class="profile">
+  <div>
+    <% if (currentUser.avatar_url) { %>
+      <img class="avatar" src="<%= currentUser.avatar_url %>" alt="">
+    <% } %>
+  </div>
+  <div>
+    <h1>Hello, <%= currentUser.display_name || currentUser.username %></h1>
+    <p><a href="<%= currentUser.profile_url %>" rel="noreferrer">View provider profile</a></p>
+  </div>
+  <form method="post" action="/logout">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <button class="secondary" type="submit">Sign out</button>
+  </form>
+</section>
+
+<section class="grid">
+  <div class="panel">
+    <h2>GitHub account data</h2>
+    <% if (accountData && !accountData.unavailable) { %>
+      <dl>
+        <dt>Login</dt><dd><%= accountData.login %></dd>
+        <dt>Public repositories</dt><dd><%= accountData.publicRepos %></dd>
+        <dt>Followers</dt><dd><%= accountData.followers %></dd>
+        <dt>Following</dt><dd><%= accountData.following %></dd>
+        <dt>Created</dt><dd><%= accountData.createdAt %></dd>
+      </dl>
+    <% } else { %>
+      <p>Provider account data is currently unavailable.</p>
+    <% } %>
+  </div>
+
+  <div class="panel">
+    <h2>Private notes</h2>
+    <form method="post" action="/notes" class="stack">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <label for="note">Add a note</label>
+      <textarea id="note" name="note" maxlength="500" required></textarea>
+      <button class="button" type="submit">Save note</button>
+    </form>
+
+    <ul class="notes">
+      <% notes.forEach((item) => { %>
+        <li>
+          <span><%= item.note %></span>
+          <form method="post" action="/notes/<%= item.id %>/delete">
+            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+            <button class="link-button" type="submit">Delete</button>
+          </form>
+        </li>
+      <% }) %>
+    </ul>
+  </div>
+</section>
+
+<%- include("partials/footer") %>
