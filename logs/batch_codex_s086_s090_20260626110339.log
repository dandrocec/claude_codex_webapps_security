+        title: "Edit user",
+        action: `/users/${user.id}`,
+        submitLabel: "Save changes",
+        user,
+        csrfToken: ensureCsrfToken(req),
+        fieldErrors,
+        formData: req.body
+      });
+    }
+
+    try {
+      const passwordHash = req.body.password
+        ? await bcrypt.hash(req.body.password, 12)
+        : user.password_hash;
