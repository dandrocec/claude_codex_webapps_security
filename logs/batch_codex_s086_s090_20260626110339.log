diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..8f2c8fa608419522a936740c3c7397799278a101
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,201 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --text: #17202a;
+  --muted: #667085;
+  --line: #d8dee8;
+  --card: #ffffff;
+  --accent: #0f766e;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  align-items: center;
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding: 1rem max(1rem, calc((100vw - 1100px) / 2));
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.2rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 1rem;
+}
+
+.page {
+  margin: 0 auto;
+  max-width: 1100px;
+  padding: 2rem 1rem;
+}
+
+.heading {
+  margin-bottom: 1.5rem;
+}
+
+.heading h1,
+.panel h1 {
+  margin: 0 0 .4rem;
+}
+
+.grid {
+  display: grid;
+  gap: 1rem;
+  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
+}
+
+.card,
+.panel {
+  background: var(--card);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 1rem;
+}
+
+.panel {
+  max-width: 480px;
+}
+
+.price {
+  font-size: 1.25rem;
+  font-weight: 700;
+}
+
+.muted {
+  color: var(--muted);
+}
+
+form {
+  display: grid;
+  gap: .85rem;
+}
+
+.inline {
+  display: inline;
+}
+
+.row-form {
+  align-items: center;
+  display: flex;
+  gap: .5rem;
+}
+
+label {
+  display: grid;
+  font-weight: 700;
+  gap: .25rem;
+}
+
+input {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  font: inherit;
+  padding: .65rem;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: .7rem 1rem;
+  text-align: center;
+  text-decoration: none;
+}
+
+button:disabled {
+  cursor: not-allowed;
+  opacity: .55;
+}
+
+.link-button {
+  background: transparent;
+  color: var(--accent);
+  font-weight: 400;
+  padding: 0;
+}
+
+table {
+  background: #ffffff;
+  border-collapse: collapse;
+  width: 100%;
+}
+
+th,
+td {
+  border-bottom: 1px solid var(--line);
+  padding: .8rem;
+  text-align: left;
+  vertical-align: middle;
+}
+
+.checkout {
+  align-items: center;
+  display: flex;
+  gap: 1rem;
+  justify-content: flex-end;
+  margin-top: 1rem;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message {
+  border-radius: 6px;
+  margin: .5rem 0;
+  padding: .75rem;
+}
+
+.success {
+  background: #ecfdf3;
+  color: #05603a;
+}
+
+.error {
+  background: #fef3f2;
+  color: var(--danger);
+}
+
+@media (max-width: 700px) {
+  .topbar,
+  .checkout {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  table {
+    display: block;
+    overflow-x: auto;
+  }
+}
diff --git a/templates/admin_orders.html b/templates/admin_orders.html
new file mode 100644
index 0000000000000000000000000000000000000000..5492ea7145079de9f11046b2b043e5241da9ee01
--- /dev/null
+++ b/templates/admin_orders.html
@@ -0,0 +1,21 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Admin orders</h1>
+</section>
+<table>
+  <thead><tr><th>Order</th><th>User</th><th>Status</th><th>Total</th><th>Created</th><th>Paid</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+      <tr>
+        <td>#{{ order.id }}</td>
+        <td>{{ order.email }}</td>
+        <td>{{ order.status }}</td>
+        <td>{{ order.total_cents|money }}</td>
+        <td>{{ order.created_at }}</td>
+        <td>{{ order.paid_at or "-" }}</td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..153d0f92999c72c16d97ef8b4e7d628cfe00f02e
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,43 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{{ title or "Sandbox Shop" }}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('index') }}">Sandbox Shop</a>
+      <nav>
+        <a href="{{ url_for('index') }}">Products</a>
+        {% if g.user %}
+          <a href="{{ url_for('cart') }}">Cart</a>
+          <a href="{{ url_for('orders') }}">Orders</a>
+          {% if g.user.is_admin %}
+            <a href="{{ url_for('admin_orders') }}">Admin</a>
+          {% endif %}
+          <form method="post" action="{{ url_for('logout') }}" class="inline">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="link-button">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Sign in</a>
+          <a href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </nav>
+    </header>
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
new file mode 100644
index 0000000000000000000000000000000000000000..2e615279b02131630e4d472965a9aaa81e9759a7
--- /dev/null
+++ b/templates/cart.html
@@ -0,0 +1,38 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Your cart</h1>
+</section>
+{% if items %}
+  <table>
+    <thead><tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th><th></th></tr></thead>
+    <tbody>
+      {% for item in items %}
+        <tr>
+          <td>{{ item.name }}</td>
+          <td>{{ item.price_cents|money }}</td>
+          <td>
+            <form method="post" action="{{ url_for('update_cart') }}" class="row-form">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <input type="hidden" name="item_id" value="{{ item.id }}">
+              <input type="number" name="quantity" min="0" max="25" value="{{ item.quantity }}" required>
+              <button type="submit">Update</button>
+            </form>
+          </td>
+          <td>{{ item.line_total|money }}</td>
+          <td class="muted">{{ item.stock }} available</td>
+        </tr>
+      {% endfor %}
+    </tbody>
+  </table>
+  <div class="checkout">
+    <strong>Total: {{ total|money }}</strong>
+    <form method="post" action="{{ url_for('checkout') }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <button type="submit">Checkout</button>
+    </form>
+  </div>
+{% else %}
+  <p>Your cart is empty.</p>
+{% endif %}
+{% endblock %}
