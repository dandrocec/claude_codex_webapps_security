diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..adf8031de7e8b3dabd07b7fc7a06d64c907dedc0
--- /dev/null
+++ b/README.md
@@ -0,0 +1,32 @@
+# Flask Sandbox Shop
+
+A small Flask online shop backed by SQLite. Users can register, browse products, manage a cart, check out through a local sandbox payment flow, receive paid order updates through a webhook endpoint, and view their own order history. Admin users can view all orders.
+
+## Run locally on port 5089
+
+1. Create and activate a virtual environment.
+2. Install dependencies:
+
+```bash
+pip install -r requirements.txt
+```
+
+3. Set required environment variables:
+
+```bash
+set FLASK_SECRET_KEY=replace-with-a-long-random-secret
+set PAYMENT_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
+```
+
+On macOS/Linux, use `export` instead of `set`.
+
+4. Start the app:
+
+```bash
+python app.py
+```
+
+5. Open `http://127.0.0.1:5089`.
+
+The SQLite database is created automatically at `shop.db` on first run. A default admin account is created only when `ADMIN_EMAIL` and `ADMIN_PASSWORD` are set in the environment before first startup.
+
diff --git a/app.py b/app.py
new file mode 100644
index 0000000000000000000000000000000000000000..77fc033a7f2cadb44c02ae30170e865ee265c41f
--- /dev/null
+++ b/app.py
@@ -0,0 +1,517 @@
+import hmac
+import os
+import re
+import secrets
+import sqlite3
+from datetime import datetime, timezone
+from decimal import Decimal, InvalidOperation
+from functools import wraps
+from pathlib import Path
+
+from argon2 import PasswordHasher
+from argon2.exceptions import VerifyMismatchError, VerificationError
+from flask import (
+    Flask,
+    abort,
+    flash,
+    g,
+    jsonify,
+    redirect,
+    render_template,
+    request,
+    session,
+    url_for,
+)
+from flask_wtf import CSRFProtect
+
+
+BASE_DIR = Path(__file__).resolve().parent
+DATABASE = BASE_DIR / "shop.db"
+EMAIL_RE = re.compile(r"^[^@\s]+@[^@\s]+\.[^@\s]+$")
+ph = PasswordHasher(time_cost=3, memory_cost=65536, parallelism=2)
+
+
+def create_app():
+    app = Flask(__name__)
+    app.config.update(
+        SECRET_KEY=os.environ.get("FLASK_SECRET_KEY") or secrets.token_urlsafe(32),
+        WTF_CSRF_TIME_LIMIT=3600,
+        SESSION_COOKIE_HTTPONLY=True,
+        SESSION_COOKIE_SECURE=True,
+        SESSION_COOKIE_SAMESITE="Lax",
+        MAX_CONTENT_LENGTH=1024 * 1024,
+    )
+    CSRFProtect(app)
+
+    @app.before_request
+    def load_user():
+        g.user = None
+        user_id = session.get("user_id")
+        if user_id:
+            g.user = query_one(
+                "SELECT id, email, name, is_admin FROM users WHERE id = ?",
+                (user_id,),
+            )
+
+    @app.after_request
+    def set_security_headers(response):
+        response.headers["Content-Security-Policy"] = (
+            "default-src 'self'; img-src 'self' data:; style-src 'self'; "
+            "script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; "
+            "form-action 'self'"
+        )
+        response.headers["X-Content-Type-Options"] = "nosniff"
+        response.headers["X-Frame-Options"] = "DENY"
+        response.headers["Referrer-Policy"] = "strict-origin-when-cross-origin"
+        response.headers["Permissions-Policy"] = "geolocation=(), microphone=(), camera=()"
+        return response
+
+    @app.errorhandler(400)
+    @app.errorhandler(403)
+    @app.errorhandler(404)
+    @app.errorhandler(413)
+    @app.errorhandler(500)
+    def handle_error(error):
+        status = getattr(error, "code", 500)
+        message = {
+            400: "Bad request.",
+            403: "Access denied.",
+            404: "Page not found.",
+            413: "Request too large.",
+            500: "Something went wrong.",
+        }.get(status, "Something went wrong.")
+        return render_template("error.html", status=status, message=message), status
+
+    @app.route("/")
+    def index():
+        products = query_all(
+            "SELECT id, name, description, price_cents, stock FROM products ORDER BY name"
+        )
+        return render_template("products.html", products=products)
+
+    @app.route("/register", methods=["GET", "POST"])
+    def register():
+        if request.method == "POST":
+            email = clean_text(request.form.get("email", ""), 254).lower()
+            name = clean_text(request.form.get("name", ""), 80)
+            password = request.form.get("password", "")
+            if not EMAIL_RE.match(email):
+                flash("Enter a valid email address.", "error")
+            elif len(name) < 2:
+                flash("Enter your name.", "error")
+            elif len(password) < 12:
+                flash("Password must be at least 12 characters.", "error")
+            else:
+                try:
+                    execute(
+                        "INSERT INTO users (email, name, password_hash, is_admin) VALUES (?, ?, ?, 0)",
+                        (email, name, ph.hash(password)),
+                    )
+                    flash("Account created. Please sign in.", "success")
+                    return redirect(url_for("login"))
+                except sqlite3.IntegrityError:
+                    flash("That email is already registered.", "error")
+        return render_template("register.html")
+
+    @app.route("/login", methods=["GET", "POST"])
+    def login():
+        if request.method == "POST":
+            email = clean_text(request.form.get("email", ""), 254).lower()
+            password = request.form.get("password", "")
+            user = query_one("SELECT * FROM users WHERE email = ?", (email,))
+            if user and verify_password(user["password_hash"], password):
+                session.clear()
+                session["user_id"] = user["id"]
+                session.permanent = True
+                return redirect(url_for("index"))
+            flash("Invalid email or password.", "error")
+        return render_template("login.html")
+
+    @app.route("/logout", methods=["POST"])
+    @login_required
+    def logout():
+        session.clear()
+        flash("Signed out.", "success")
+        return redirect(url_for("index"))
+
+    @app.route("/cart")
+    @login_required
+    def cart():
+        items = cart_items()
+        return render_template("cart.html", items=items, total=sum(i["line_total"] for i in items))
+
+    @app.route("/cart/add", methods=["POST"])
+    @login_required
+    def add_to_cart():
+        product_id = parse_positive_int(request.form.get("product_id"))
+        quantity = parse_positive_int(request.form.get("quantity"), maximum=10)
+        product = query_one("SELECT id, stock FROM products WHERE id = ?", (product_id,))
+        if not product or product["stock"] <= 0:
+            abort(400)
+        quantity = min(quantity, product["stock"])
+        existing = query_one(
+            "SELECT quantity FROM cart_items WHERE user_id = ? AND product_id = ?",
+            (g.user["id"], product_id),
+        )
+        if existing:
+            execute(
+                "UPDATE cart_items SET quantity = ? WHERE user_id = ? AND product_id = ?",
+                (min(existing["quantity"] + quantity, product["stock"]), g.user["id"], product_id),
+            )
+        else:
+            execute(
+                "INSERT INTO cart_items (user_id, product_id, quantity) VALUES (?, ?, ?)",
+                (g.user["id"], product_id, quantity),
+            )
+        flash("Added to cart.", "success")
+        return redirect(url_for("cart"))
+
+    @app.route("/cart/update", methods=["POST"])
+    @login_required
+    def update_cart():
+        item_id = parse_positive_int(request.form.get("item_id"))
+        quantity = parse_positive_int(request.form.get("quantity"), maximum=25, allow_zero=True)
+        item = query_one(
+            "SELECT ci.id, p.stock FROM cart_items ci JOIN products p ON p.id = ci.product_id "
+            "WHERE ci.id = ? AND ci.user_id = ?",
+            (item_id, g.user["id"]),
+        )
+        if not item:
+            abort(404)
+        if quantity == 0:
+            execute("DELETE FROM cart_items WHERE id = ? AND user_id = ?", (item_id, g.user["id"]))
+        else:
+            execute(
+                "UPDATE cart_items SET quantity = ? WHERE id = ? AND user_id = ?",
+                (min(quantity, item["stock"]), item_id, g.user["id"]),
+            )
+        return redirect(url_for("cart"))
+
+    @app.route("/checkout", methods=["POST"])
+    @login_required
+    def checkout():
+        items = cart_items()
+        if not items:
+            flash("Your cart is empty.", "error")
+            return redirect(url_for("cart"))
+        total = sum(i["line_total"] for i in items)
+        now = utc_now()
+        token = secrets.token_urlsafe(32)
+        db = get_db()
+        try:
+            db.execute("BEGIN")
+            cur = db.execute(
+                "INSERT INTO orders (user_id, status, total_cents, payment_token, created_at) "
+                "VALUES (?, 'pending', ?, ?, ?)",
+                (g.user["id"], total, token, now),
+            )
+            order_id = cur.lastrowid
+            for item in items:
+                product = db.execute(
+                    "SELECT stock FROM products WHERE id = ?", (item["product_id"],)
+                ).fetchone()
+                if not product or product["stock"] < item["quantity"]:
+                    raise ValueError("Insufficient stock")
+                db.execute(
+                    "INSERT INTO order_items (order_id, product_id, product_name, unit_price_cents, quantity) "
+                    "VALUES (?, ?, ?, ?, ?)",
+                    (
+                        order_id,
+                        item["product_id"],
+                        item["name"],
+                        item["price_cents"],
+                        item["quantity"],
+                    ),
+                )
+                db.execute(
+                    "UPDATE products SET stock = stock - ? WHERE id = ?",
+                    (item["quantity"], item["product_id"]),
+                )
+            db.execute("DELETE FROM cart_items WHERE user_id = ?", (g.user["id"],))
+            db.commit()
+        except Exception:
+            db.rollback()
+            abort(500)
+        return redirect(url_for("payment_sandbox", order_id=order_id, token=token))
+
+    @app.route("/payment/sandbox/<int:order_id>")
+    @login_required
+    def payment_sandbox(order_id):
+        token = request.args.get("token", "")
+        order = query_one(
+            "SELECT id, status, total_cents, payment_token FROM orders WHERE id = ? AND user_id = ?",
+            (order_id, g.user["id"]),
+        )
+        if not order or not hmac.compare_digest(order["payment_token"], token):
+            abort(404)
+        return render_template("payment.html", order=order, webhook_secret_configured=bool(webhook_secret()))
+
+    @app.route("/payment/sandbox/<int:order_id>/pay", methods=["POST"])
+    @login_required
+    def sandbox_pay(order_id):
+        token = request.form.get("token", "")
+        order = query_one(
+            "SELECT id, payment_token FROM orders WHERE id = ? AND user_id = ? AND status = 'pending'",
+            (order_id, g.user["id"]),
+        )
+        if not order or not hmac.compare_digest(order["payment_token"], token):
+            abort(404)
+        secret = webhook_secret()
+        if not secret:
+            flash("Payment sandbox is not configured.", "error")
+            return redirect(url_for("payment_sandbox", order_id=order_id, token=token))
+        signature = sign_webhook(order_id, "paid", secret)
+        mark_order_paid(order_id, signature)
+        flash("Payment completed in sandbox.", "success")
+        return redirect(url_for("orders"))
+
+    @app.route("/webhooks/payment", methods=["POST"])
+    @csrf.exempt
+    def payment_webhook():
+        payload = request.get_json(silent=True) or {}
+        order_id = parse_positive_int(payload.get("order_id"))
+        status = clean_text(str(payload.get("status", "")), 20)
+        signature = request.headers.get("X-Sandbox-Signature", "")
+        if status != "paid" or not mark_order_paid(order_id, signature):
+            abort(400)
+        return jsonify({"ok": True})
+
+    @app.route("/orders")
+    @login_required
+    def orders():
+        rows = query_all(
+            "SELECT id, status, total_cents, created_at, paid_at FROM orders "
+            "WHERE user_id = ? ORDER BY created_at DESC",
+            (g.user["id"],),
+        )
+        return render_template("orders.html", orders=rows)
+
+    @app.route("/orders/<int:order_id>")
+    @login_required
+    def order_detail(order_id):
+        order = query_one(
+            "SELECT id, status, total_cents, created_at, paid_at FROM orders "
+            "WHERE id = ? AND user_id = ?",
+            (order_id, g.user["id"]),
+        )
+        if not order:
+            abort(404)
+        items = query_all(
+            "SELECT product_name, unit_price_cents, quantity FROM order_items WHERE order_id = ?",
+            (order_id,),
+        )
+        return render_template("order_detail.html", order=order, items=items)
+
+    @app.route("/admin/orders")
+    @admin_required
+    def admin_orders():
+        rows = query_all(
+            "SELECT o.id, o.status, o.total_cents, o.created_at, o.paid_at, u.email "
+            "FROM orders o JOIN users u ON u.id = o.user_id ORDER BY o.created_at DESC"
+        )
+        return render_template("admin_orders.html", orders=rows)
+
+    with app.app_context():
+        init_db()
+    return app
+
+
+def get_db():
+    if "db" not in g:
+        g.db = sqlite3.connect(DATABASE)
+        g.db.row_factory = sqlite3.Row
+        g.db.execute("PRAGMA foreign_keys = ON")
+    return g.db
+
+
+def close_db(_error=None):
+    db = g.pop("db", None)
+    if db is not None:
+        db.close()
+
+
+def query_one(sql, params=()):
+    return get_db().execute(sql, params).fetchone()
+
+
+def query_all(sql, params=()):
+    return get_db().execute(sql, params).fetchall()
+
+
+def execute(sql, params=()):
+    db = get_db()
+    db.execute(sql, params)
+    db.commit()
+
+
+def init_db():
+    db = get_db()
+    db.executescript(
+        """
+        CREATE TABLE IF NOT EXISTS users (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            email TEXT NOT NULL UNIQUE,
+            name TEXT NOT NULL,
+            password_hash TEXT NOT NULL,
+            is_admin INTEGER NOT NULL DEFAULT 0
+        );
+        CREATE TABLE IF NOT EXISTS products (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            name TEXT NOT NULL,
+            description TEXT NOT NULL,
+            price_cents INTEGER NOT NULL CHECK (price_cents > 0),
+            stock INTEGER NOT NULL CHECK (stock >= 0)
+        );
+        CREATE TABLE IF NOT EXISTS cart_items (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            user_id INTEGER NOT NULL,
+            product_id INTEGER NOT NULL,
+            quantity INTEGER NOT NULL CHECK (quantity > 0),
+            UNIQUE(user_id, product_id),
+            FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE,
+            FOREIGN KEY(product_id) REFERENCES products(id) ON DELETE CASCADE
+        );
+        CREATE TABLE IF NOT EXISTS orders (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            user_id INTEGER NOT NULL,
+            status TEXT NOT NULL CHECK (status IN ('pending', 'paid')),
+            total_cents INTEGER NOT NULL CHECK (total_cents >= 0),
+            payment_token TEXT NOT NULL UNIQUE,
+            created_at TEXT NOT NULL,
+            paid_at TEXT,
+            FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE
+        );
+        CREATE TABLE IF NOT EXISTS order_items (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            order_id INTEGER NOT NULL,
+            product_id INTEGER NOT NULL,
+            product_name TEXT NOT NULL,
+            unit_price_cents INTEGER NOT NULL CHECK (unit_price_cents > 0),
+            quantity INTEGER NOT NULL CHECK (quantity > 0),
+            FOREIGN KEY(order_id) REFERENCES orders(id) ON DELETE CASCADE,
+            FOREIGN KEY(product_id) REFERENCES products(id)
+        );
+        """
+    )
+    if not db.execute("SELECT 1 FROM products LIMIT 1").fetchone():
+        db.executemany(
+            "INSERT INTO products (name, description, price_cents, stock) VALUES (?, ?, ?, ?)",
+            [
+                ("Trail Mug", "Insulated stainless mug for daily use.", 2499, 30),
+                ("Canvas Tote", "Heavy cotton tote with reinforced handles.", 1899, 45),
+                ("Desk Lamp", "Compact LED lamp with warm and cool modes.", 4299, 18),
+                ("Notebook Set", "Three recycled-paper notebooks.", 1299, 60),
+            ],
+        )
+    admin_email = os.environ.get("ADMIN_EMAIL", "").strip().lower()
+    admin_password = os.environ.get("ADMIN_PASSWORD", "")
+    if admin_email and admin_password and not db.execute(
+        "SELECT 1 FROM users WHERE email = ?", (admin_email,)
+    ).fetchone():
+        db.execute(
+            "INSERT INTO users (email, name, password_hash, is_admin) VALUES (?, ?, ?, 1)",
+            (admin_email, "Admin", ph.hash(admin_password)),
+        )
+    db.commit()
+
+
+def login_required(view):
+    @wraps(view)
+    def wrapped(*args, **kwargs):
+        if not g.user:
+            return redirect(url_for("login"))
+        return view(*args, **kwargs)
+
+    return wrapped
+
+
+def admin_required(view):
+    @wraps(view)
+    @login_required
+    def wrapped(*args, **kwargs):
+        if not g.user["is_admin"]:
+            abort(403)
+        return view(*args, **kwargs)
+
+    return wrapped
+
+
+def clean_text(value, max_len):
+    value = str(value or "").strip()
+    value = re.sub(r"[\x00-\x1f\x7f]", "", value)
+    return value[:max_len]
+
+
+def parse_positive_int(value, maximum=1_000_000, allow_zero=False):
+    try:
+        parsed = int(value)
+    except (TypeError, ValueError):
+        abort(400)
+    minimum = 0 if allow_zero else 1
+    if parsed < minimum or parsed > maximum:
+        abort(400)
+    return parsed
+
+
+def verify_password(stored_hash, password):
+    try:
+        return ph.verify(stored_hash, password)
+    except (VerifyMismatchError, VerificationError, TypeError):
+        return False
+
+
+def money(cents):
+    try:
+        return f"${Decimal(cents) / Decimal(100):,.2f}"
+    except (InvalidOperation, TypeError):
+        return "$0.00"
+
+
+def utc_now():
+    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()
+
+
+def cart_items():
+    return query_all(
+        "SELECT ci.id, ci.product_id, ci.quantity, p.name, p.price_cents, p.stock, "
+        "(ci.quantity * p.price_cents) AS line_total "
+        "FROM cart_items ci JOIN products p ON p.id = ci.product_id "
+        "WHERE ci.user_id = ? ORDER BY p.name",
+        (g.user["id"],),
+    )
+
+
+def webhook_secret():
+    return os.environ.get("PAYMENT_WEBHOOK_SECRET", "")
+
+
+def sign_webhook(order_id, status, secret):
+    body = f"{order_id}:{status}".encode()
+    return hmac.new(secret.encode(), body, "sha256").hexdigest()
+
+
+def mark_order_paid(order_id, signature):
+    secret = webhook_secret()
+    if not secret:
+        return False
+    expected = sign_webhook(order_id, "paid", secret)
+    if not hmac.compare_digest(expected, signature):
+        return False
+    order = query_one("SELECT id, status FROM orders WHERE id = ?", (order_id,))
+    if not order:
+        return False
+    if order["status"] != "paid":
+        execute(
+            "UPDATE orders SET status = 'paid', paid_at = ? WHERE id = ?",
+            (utc_now(), order_id),
+        )
+    return True
+
+
+app = create_app()
+app.teardown_appcontext(close_db)
+app.jinja_env.filters["money"] = money
+
+
+if __name__ == "__main__":
+    app.run(host="127.0.0.1", port=5089, debug=False)
