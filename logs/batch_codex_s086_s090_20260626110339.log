+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{{ title or "Admin Dashboard" }}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <div class="app-shell">
+    {% if session.get("admin_id") %}
+      <aside class="sidebar">
+        <div>
+          <div class="brand">AdminDesk</div>
+          <p class="muted">Signed in as {{ session.get("admin_username") }}</p>
+        </div>
+        <nav class="nav">
+          <a href="{{ url_for('dashboard') }}">Dashboard</a>
+          <a href="{{ url_for('create_user') }}">New User</a>
+        </nav>
+        <form action="{{ url_for('logout') }}" method="post">
+          <button class="ghost-button" type="submit">Log out</button>
+        </form>
+      </aside>
+    {% endif %}
+
+    <main class="content {% if not session.get('admin_id') %}centered{% endif %}">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="flash-stack">
+            {% for category, message in messages %}
+              <div class="flash {{ category }}">{{ message }}</div>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </div>
+</body>
+</html>
