diff --git a/src/db.js b/src/db.js
new file mode 100644
index 0000000000000000000000000000000000000000..1e1247bd7570066be545113158c1a00d2c3d14c5
--- /dev/null
+++ b/src/db.js
@@ -0,0 +1,98 @@
+const path = require("path");
+const fs = require("fs");
+const Database = require("better-sqlite3");
+
+const databasePath = process.env.DATABASE_PATH || path.join(process.cwd(), "data", "app.sqlite");
+fs.mkdirSync(path.dirname(databasePath), { recursive: true });
+
+const db = new Database(databasePath);
+db.pragma("journal_mode = WAL");
+db.pragma("foreign_keys = ON");
+
+db.exec(`
+  CREATE TABLE IF NOT EXISTS users (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    provider TEXT NOT NULL,
+    provider_id TEXT NOT NULL,
+    username TEXT NOT NULL,
+    display_name TEXT,
+    avatar_url TEXT,
+    profile_url TEXT,
+    password_hash TEXT NOT NULL,
+    created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    UNIQUE(provider, provider_id)
+  );
+
+  CREATE TABLE IF NOT EXISTS oauth_tokens (
+    user_id INTEGER PRIMARY KEY,
+    access_token TEXT NOT NULL,
+    scope TEXT,
+    token_type TEXT,
+    updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE
+  );
+
+  CREATE TABLE IF NOT EXISTS account_notes (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    user_id INTEGER NOT NULL,
+    note TEXT NOT NULL,
+    created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    FOREIGN KEY(user_id) REFERENCES users(id) ON DELETE CASCADE
+  );
+`);
+
+const statements = {
+  findUserById: db.prepare(`
+    SELECT id, provider, provider_id, username, display_name, avatar_url, profile_url, created_at, updated_at
+    FROM users
+    WHERE id = ?
+  `),
+  findUserByProvider: db.prepare(`
+    SELECT id, provider, provider_id, username, display_name, avatar_url, profile_url, created_at, updated_at
+    FROM users
+    WHERE provider = ? AND provider_id = ?
+  `),
+  insertUser: db.prepare(`
+    INSERT INTO users (provider, provider_id, username, display_name, avatar_url, profile_url, password_hash)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `),
+  updateUser: db.prepare(`
+    UPDATE users
+    SET username = ?, display_name = ?, avatar_url = ?, profile_url = ?, updated_at = CURRENT_TIMESTAMP
+    WHERE id = ?
+  `),
+  upsertToken: db.prepare(`
+    INSERT INTO oauth_tokens (user_id, access_token, scope, token_type)
+    VALUES (?, ?, ?, ?)
+    ON CONFLICT(user_id) DO UPDATE SET
+      access_token = excluded.access_token,
+      scope = excluded.scope,
+      token_type = excluded.token_type,
+      updated_at = CURRENT_TIMESTAMP
+  `),
+  findTokenForUser: db.prepare(`
+    SELECT access_token, scope, token_type
+    FROM oauth_tokens
+    WHERE user_id = ?
+  `),
+  listNotesForUser: db.prepare(`
+    SELECT id, note, created_at
+    FROM account_notes
+    WHERE user_id = ?
+    ORDER BY id DESC
+  `),
+  insertNoteForUser: db.prepare(`
+    INSERT INTO account_notes (user_id, note)
+    VALUES (?, ?)
+  `),
+  deleteNoteForUser: db.prepare(`
+    DELETE FROM account_notes
+    WHERE id = ? AND user_id = ?
+  `)
+};
+
+module.exports = {
+  db,
+  statements
+};
diff --git a/src/passport.js b/src/passport.js
new file mode 100644
index 0000000000000000000000000000000000000000..fb88650b6971987fba49e99f0b28b8959f5762bf
--- /dev/null
+++ b/src/passport.js
@@ -0,0 +1,79 @@
+const crypto = require("crypto");
+const argon2 = require("argon2");
+const passport = require("passport");
+const GitHubStrategy = require("passport-github2").Strategy;
+const { statements } = require("./db");
+
+function requiredEnv(name) {
+  const value = process.env[name];
+  if (!value) {
+    throw new Error(`${name} is required`);
+  }
+  return value;
+}
+
+passport.serializeUser((user, done) => {
+  done(null, user.id);
+});
+
+passport.deserializeUser((id, done) => {
+  try {
+    const user = statements.findUserById.get(Number(id));
+    done(null, user || false);
+  } catch (error) {
+    done(error);
+  }
+});
+
+function configurePassport() {
+  const baseUrl = requiredEnv("BASE_URL").replace(/\/$/, "");
+
+  passport.use(new GitHubStrategy({
+    clientID: requiredEnv("GITHUB_CLIENT_ID"),
+    clientSecret: requiredEnv("GITHUB_CLIENT_SECRET"),
+    callbackURL: `${baseUrl}/auth/github/callback`,
+    scope: ["read:user", "user:email"]
+  }, async (accessToken, refreshToken, profile, done) => {
+    try {
+      const provider = "github";
+      const providerId = String(profile.id);
+      const username = profile.username || `github-${providerId}`;
+      const displayName = profile.displayName || username;
+      const avatarUrl = profile.photos && profile.photos[0] ? profile.photos[0].value : null;
+      const profileUrl = profile.profileUrl || null;
+
+      let user = statements.findUserByProvider.get(provider, providerId);
+
+      if (!user) {
+        const passwordHash = await argon2.hash(crypto.randomBytes(32).toString("hex"), {
+          type: argon2.argon2id
+        });
+        const result = statements.insertUser.run(
+          provider,
+          providerId,
+          username,
+          displayName,
+          avatarUrl,
+          profileUrl,
+          passwordHash
+        );
+        user = statements.findUserById.get(result.lastInsertRowid);
+      } else {
+        statements.updateUser.run(username, displayName, avatarUrl, profileUrl, user.id);
+        user = statements.findUserById.get(user.id);
+      }
+
+      statements.upsertToken.run(user.id, accessToken, "read:user user:email", "Bearer");
+      done(null, user);
+    } catch (error) {
+      done(error);
+    }
+  }));
+
+  return passport;
+}
+
+module.exports = {
+  configurePassport,
+  passport
+};
diff --git a/src/public/styles.css b/src/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..80162ad986b0020261a67f68370744cb4b540a1a
--- /dev/null
+++ b/src/public/styles.css
@@ -0,0 +1,194 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --text: #15202b;
+  --muted: #526170;
+  --line: #d8dee6;
+  --panel: #ffffff;
+  --primary: #0f766e;
+  --primary-dark: #115e59;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--primary-dark);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 16px 24px;
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+.page {
+  width: min(1040px, calc(100% - 32px));
+  margin: 32px auto;
+}
+
+.panel,
+.profile {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 24px;
+}
+
+.hero,
+.profile {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+}
+
+.narrow {
+  max-width: 520px;
+  margin: 0 auto;
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 20px;
+  margin-top: 20px;
+}
+
+h1,
+h2,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  font-size: 2rem;
+  line-height: 1.15;
+}
+
+h2 {
+  font-size: 1.2rem;
+}
+
+.button,
+.secondary,
+.link-button {
+  border: 0;
+  border-radius: 6px;
+  cursor: pointer;
+  font: inherit;
+}
+
+.button {
+  display: inline-block;
+  background: var(--primary);
+  color: #ffffff;
+  padding: 10px 16px;
+  text-decoration: none;
+}
+
+.button:hover,
+.button:focus {
+  background: var(--primary-dark);
+}
+
+.secondary {
+  background: #edf2f7;
+  color: var(--text);
+  padding: 9px 14px;
+}
+
+.link-button {
+  background: transparent;
+  color: var(--danger);
+  padding: 0;
+}
+
+.avatar {
+  width: 72px;
+  height: 72px;
+  border-radius: 50%;
+}
+
+dl {
+  display: grid;
+  grid-template-columns: 160px 1fr;
+  gap: 8px 16px;
+  margin: 0;
+}
+
+dt {
+  color: var(--muted);
+}
+
+dd {
+  margin: 0;
+}
+
+.stack {
+  display: grid;
+  gap: 10px;
+}
+
+textarea {
+  min-height: 90px;
+  resize: vertical;
+}
+
+textarea,
+input {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 10px;
+  font: inherit;
+}
+
+.notes {
+  list-style: none;
+  margin: 18px 0 0;
+  padding: 0;
+}
+
+.notes li {
+  display: flex;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 12px 0;
+  border-top: 1px solid var(--line);
+}
+
+@media (max-width: 760px) {
+  .hero,
+  .profile {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .grid {
+    grid-template-columns: 1fr;
+  }
+
+  dl {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/src/server.js b/src/server.js
new file mode 100644
index 0000000000000000000000000000000000000000..d99c5433bc80f6a7c98c308432f9bf123794c4b1
--- /dev/null
+++ b/src/server.js
@@ -0,0 +1,230 @@
+require("dotenv").config();
+
+const path = require("path");
+const express = require("express");
+const session = require("express-session");
+const SQLiteStore = require("connect-sqlite3")(session);
+const helmet = require("helmet");
+const rateLimit = require("express-rate-limit");
+const csrf = require("csurf");
+const morgan = require("morgan");
+const createError = require("http-errors");
+const fetch = require("node-fetch");
+const { body, param, validationResult } = require("express-validator");
+const DOMPurify = require("isomorphic-dompurify");
+const { configurePassport, passport } = require("./passport");
+const { statements } = require("./db");
+
+const app = express();
+const port = Number(process.env.PORT || 5090);
+const isProduction = process.env.NODE_ENV === "production";
+
+if (!process.env.SESSION_SECRET || process.env.SESSION_SECRET.length < 32) {
+  throw new Error("SESSION_SECRET must be set to at least 32 characters");
+}
+
+app.set("trust proxy", 1);
+app.set("view engine", "ejs");
+app.set("views", path.join(__dirname, "views"));
+app.disable("x-powered-by");
+
+app.use(helmet({
+  contentSecurityPolicy: {
+    directives: {
+      defaultSrc: ["'self'"],
+      baseUri: ["'self'"],
+      formAction: ["'self'"],
+      frameAncestors: ["'none'"],
+      imgSrc: ["'self'", "https:", "data:"],
+      scriptSrc: ["'self'"],
+      styleSrc: ["'self'", "'unsafe-inline'"]
+    }
+  },
+  referrerPolicy: { policy: "no-referrer" }
+}));
+app.use(morgan(isProduction ? "combined" : "dev"));
+app.use(express.urlencoded({ extended: false, limit: "20kb" }));
+
+app.use(rateLimit({
+  windowMs: 15 * 60 * 1000,
+  limit: 150,
+  standardHeaders: true,
+  legacyHeaders: false
+}));
+
+app.use(session({
+  store: new SQLiteStore({
+    db: "sessions.sqlite",
+    dir: path.dirname(process.env.DATABASE_PATH || path.join(process.cwd(), "data", "app.sqlite"))
+  }),
+  name: "__Host-oauth_profile.sid",
+  secret: process.env.SESSION_SECRET,
+  resave: false,
+  saveUninitialized: false,
+  cookie: {
+    httpOnly: true,
+    secure: isProduction,
+    sameSite: "lax",
+    path: "/",
+    maxAge: 1000 * 60 * 60 * 8
+  }
+}));
+
+configurePassport();
+app.use(passport.initialize());
+app.use(passport.session());
+
+const csrfProtection = csrf();
+
+app.use((req, res, next) => {
+  res.locals.currentUser = req.user || null;
+  next();
+});
+
+function requireAuth(req, res, next) {
+  if (!req.isAuthenticated || !req.isAuthenticated()) {
+    return res.redirect("/login");
+  }
+  return next();
+}
+
+function validateRequest(req, res, next) {
+  const errors = validationResult(req);
+  if (!errors.isEmpty()) {
+    return res.status(400).render("error", {
+      title: "Invalid request",
+      message: "The submitted data was invalid."
+    });
+  }
+  return next();
+}
+
+function cleanText(value) {
+  return DOMPurify.sanitize(String(value || ""), { ALLOWED_TAGS: [], ALLOWED_ATTR: [] }).trim();
+}
+
+app.get("/", (req, res) => {
+  if (req.user) {
+    return res.redirect("/dashboard");
+  }
+  return res.render("home", { title: "OAuth Profile App" });
+});
+
+app.get("/login", csrfProtection, (req, res) => {
+  res.render("login", {
+    title: "Sign in",
+    csrfToken: req.csrfToken()
+  });
+});
+
+app.post("/auth/github", csrfProtection, passport.authenticate("github"));
+
+app.get("/auth/github/callback",
+  passport.authenticate("github", {
+    failureRedirect: "/login",
+    failureMessage: true
+  }),
+  (req, res) => {
+    res.redirect("/dashboard");
+  }
+);
+
+app.get("/dashboard", requireAuth, csrfProtection, async (req, res, next) => {
+  try {
+    const token = statements.findTokenForUser.get(req.user.id);
+    const accountData = token ? await fetchGitHubAccount(token.access_token) : null;
+    const notes = statements.listNotesForUser.all(req.user.id);
+
+    res.render("dashboard", {
+      title: "Your dashboard",
+      csrfToken: req.csrfToken(),
+      accountData,
+      notes
+    });
+  } catch (error) {
+    next(error);
+  }
+});
+
+app.post("/notes",
+  requireAuth,
+  csrfProtection,
+  body("note").isString().trim().isLength({ min: 1, max: 500 }),
+  validateRequest,
+  (req, res) => {
+    const note = cleanText(req.body.note).slice(0, 500);
+    if (note) {
+      statements.insertNoteForUser.run(req.user.id, note);
+    }
+    res.redirect("/dashboard");
+  }
+);
+
+app.post("/notes/:id/delete",
+  requireAuth,
+  csrfProtection,
+  param("id").isInt({ min: 1 }),
+  validateRequest,
+  (req, res) => {
+    statements.deleteNoteForUser.run(Number(req.params.id), req.user.id);
+    res.redirect("/dashboard");
+  }
+);
+
+app.post("/logout", requireAuth, csrfProtection, (req, res, next) => {
+  req.logout((logoutError) => {
+    if (logoutError) {
+      return next(logoutError);
+    }
+    req.session.destroy((destroyError) => {
+      if (destroyError) {
+        return next(destroyError);
+      }
+      res.clearCookie("__Host-oauth_profile.sid", { path: "/" });
+      return res.redirect("/");
+    });
+  });
+});
+
+app.use((req, res, next) => {
+  next(createError(404, "Not found"));
+});
+
+app.use((err, req, res, next) => {
+  const status = err.status || 500;
+  if (status >= 500) {
+    console.error(err);
+  }
+  res.status(status).render("error", {
+    title: status === 404 ? "Not found" : "Something went wrong",
+    message: status === 404 ? "The page was not found." : "The request could not be completed."
+  });
+});
+
+async function fetchGitHubAccount(accessToken) {
+  const response = await fetch("https://api.github.com/user", {
+    headers: {
+      Accept: "application/vnd.github+json",
+      Authorization: `Bearer ${accessToken}`,
+      "User-Agent": "oauth-profile-express-app"
+    },
+    timeout: 5000
+  });
+
+  if (!response.ok) {
+    return { unavailable: true };
+  }
+
+  const json = await response.json();
+  return {
+    login: cleanText(json.login),
+    publicRepos: Number(json.public_repos || 0),
+    followers: Number(json.followers || 0),
+    following: Number(json.following || 0),
+    createdAt: cleanText(json.created_at)
+  };
+}
+
+app.listen(port, () => {
+  console.log(`OAuth profile app listening on port ${port}`);
+});
diff --git a/src/views/dashboard.ejs b/src/views/dashboard.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..c5550775ef76783d55a683094ffda29faf4039c0
--- /dev/null
+++ b/src/views/dashboard.ejs
@@ -0,0 +1,58 @@
+<%- include("partials/header") %>
+
+<section class="profile">
+  <div>
+    <% if (currentUser.avatar_url) { %>
+      <img class="avatar" src="<%= currentUser.avatar_url %>" alt="">
+    <% } %>
+  </div>
+  <div>
+    <h1>Hello, <%= currentUser.display_name || currentUser.username %></h1>
+    <p><a href="<%= currentUser.profile_url %>" rel="noreferrer">View provider profile</a></p>
+  </div>
+  <form method="post" action="/logout">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <button class="secondary" type="submit">Sign out</button>
+  </form>
+</section>
+
+<section class="grid">
+  <div class="panel">
+    <h2>GitHub account data</h2>
+    <% if (accountData && !accountData.unavailable) { %>
+      <dl>
+        <dt>Login</dt><dd><%= accountData.login %></dd>
+        <dt>Public repositories</dt><dd><%= accountData.publicRepos %></dd>
+        <dt>Followers</dt><dd><%= accountData.followers %></dd>
+        <dt>Following</dt><dd><%= accountData.following %></dd>
+        <dt>Created</dt><dd><%= accountData.createdAt %></dd>
+      </dl>
+    <% } else { %>
+      <p>Provider account data is currently unavailable.</p>
+    <% } %>
+  </div>
+
+  <div class="panel">
+    <h2>Private notes</h2>
+    <form method="post" action="/notes" class="stack">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <label for="note">Add a note</label>
+      <textarea id="note" name="note" maxlength="500" required></textarea>
+      <button class="button" type="submit">Save note</button>
+    </form>
+
+    <ul class="notes">
+      <% notes.forEach((item) => { %>
+        <li>
+          <span><%= item.note %></span>
+          <form method="post" action="/notes/<%= item.id %>/delete">
+            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+            <button class="link-button" type="submit">Delete</button>
+          </form>
+        </li>
+      <% }) %>
+    </ul>
+  </div>
+</section>
+
+<%- include("partials/footer") %>
