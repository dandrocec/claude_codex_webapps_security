new file mode 100644
index 0000000000000000000000000000000000000000..fb88650b6971987fba49e99f0b28b8959f5762bf
--- /dev/null
+++ b/src/passport.js
@@ -0,0 +1,79 @@
+const crypto = require("crypto");
+const argon2 = require("argon2");
+const passport = require("passport");
+const GitHubStrategy = require("passport-github2").Strategy;
+const { statements } = require("./db");
+
+function requiredEnv(name) {
+  const value = process.env[name];
+  if (!value) {
+    throw new Error(`${name} is required`);
+  }
+  return value;
+}
+
+passport.serializeUser((user, done) => {
+  done(null, user.id);
+});
+
+passport.deserializeUser((id, done) => {
+  try {
+    const user = statements.findUserById.get(Number(id));
+    done(null, user || false);
+  } catch (error) {
+    done(error);
+  }
+});
+
+function configurePassport() {
+  const baseUrl = requiredEnv("BASE_URL").replace(/\/$/, "");
+
+  passport.use(new GitHubStrategy({
+    clientID: requiredEnv("GITHUB_CLIENT_ID"),
+    clientSecret: requiredEnv("GITHUB_CLIENT_SECRET"),
+    callbackURL: `${baseUrl}/auth/github/callback`,
+    scope: ["read:user", "user:email"]
+  }, async (accessToken, refreshToken, profile, done) => {
+    try {
+      const provider = "github";
+      const providerId = String(profile.id);
+      const username = profile.username || `github-${providerId}`;
+      const displayName = profile.displayName || username;
+      const avatarUrl = profile.photos && profile.photos[0] ? profile.photos[0].value : null;
+      const profileUrl = profile.profileUrl || null;
+
+      let user = statements.findUserByProvider.get(provider, providerId);
+
+      if (!user) {
+        const passwordHash = await argon2.hash(crypto.randomBytes(32).toString("hex"), {
+          type: argon2.argon2id
+        });
+        const result = statements.insertUser.run(
+          provider,
+          providerId,
+          username,
+          displayName,
+          avatarUrl,
+          profileUrl,
+          passwordHash
+        );
+        user = statements.findUserById.get(result.lastInsertRowid);
+      } else {
+        statements.updateUser.run(username, displayName, avatarUrl, profileUrl, user.id);
+        user = statements.findUserById.get(user.id);
+      }
+
+      statements.upsertToken.run(user.id, accessToken, "read:user user:email", "Bearer");
+      done(null, user);
+    } catch (error) {
+      done(error);
+    }
+  }));
+
+  return passport;
+}
+
+module.exports = {
+  configurePassport,
+  passport
+};
