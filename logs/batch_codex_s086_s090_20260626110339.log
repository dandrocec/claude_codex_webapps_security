+
+class ProjectUpdate(BaseModel):
+    name: str | None = Field(default=None, min_length=1, max_length=200)
+    description: str | None = None
+
+
+class ProjectOut(BaseModel):
+    id: int
+    organisation_id: int
+    owner_id: int | None
+    name: str
+    description: str | None
+    created_at: datetime
+
+    model_config = {"from_attributes": True}
