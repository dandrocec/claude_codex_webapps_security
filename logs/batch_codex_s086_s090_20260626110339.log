+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label>Email
+      <input type="email" name="email" maxlength="254" required autocomplete="email">
+    </label>
+    <label>Password
+      <input type="password" name="password" required autocomplete="current-password">
+    </label>
+    <button type="submit">Sign in</button>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/order_detail.html b/templates/order_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..676fe4bff45384c882993d8670d66a352a31ae83
--- /dev/null
+++ b/templates/order_detail.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Order #{{ order.id }}</h1>
+  <p>Status: {{ order.status }} · Total: {{ order.total_cents|money }}</p>
+</section>
+<table>
+  <thead><tr><th>Product</th><th>Unit price</th><th>Quantity</th><th>Total</th></tr></thead>
+  <tbody>
+    {% for item in items %}
+      <tr>
+        <td>{{ item.product_name }}</td>
+        <td>{{ item.unit_price_cents|money }}</td>
+        <td>{{ item.quantity }}</td>
+        <td>{{ (item.unit_price_cents * item.quantity)|money }}</td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/orders.html b/templates/orders.html
new file mode 100644
index 0000000000000000000000000000000000000000..edef2b932063e21a0febcc18bf1306b1d364ce0c
--- /dev/null
+++ b/templates/orders.html
@@ -0,0 +1,24 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Order history</h1>
+</section>
+{% if orders %}
+  <table>
+    <thead><tr><th>Order</th><th>Status</th><th>Total</th><th>Created</th><th>Paid</th></tr></thead>
+    <tbody>
+      {% for order in orders %}
+        <tr>
+          <td><a href="{{ url_for('order_detail', order_id=order.id) }}">#{{ order.id }}</a></td>
+          <td>{{ order.status }}</td>
+          <td>{{ order.total_cents|money }}</td>
+          <td>{{ order.created_at }}</td>
+          <td>{{ order.paid_at or "-" }}</td>
+        </tr>
+      {% endfor %}
+    </tbody>
+  </table>
+{% else %}
+  <p>No orders yet.</p>
+{% endif %}
+{% endblock %}
diff --git a/templates/payment.html b/templates/payment.html
new file mode 100644
index 0000000000000000000000000000000000000000..7a80bbd265eb5061d50bfd4819f4911c3d439d20
--- /dev/null
+++ b/templates/payment.html
@@ -0,0 +1,16 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="panel">
+  <h1>Sandbox payment</h1>
+  <p>Order #{{ order.id }} total: <strong>{{ order.total_cents|money }}</strong></p>
+  <p>Status: {{ order.status }}</p>
+  <form method="post" action="{{ url_for('sandbox_pay', order_id=order.id) }}">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <input type="hidden" name="token" value="{{ order.payment_token }}">
+    <button type="submit" {% if not webhook_secret_configured or order.status == "paid" %}disabled{% endif %}>Pay in sandbox</button>
+  </form>
+  {% if not webhook_secret_configured %}
+    <p class="message error">Set PAYMENT_WEBHOOK_SECRET to enable sandbox payments.</p>
+  {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/products.html b/templates/products.html
new file mode 100644
index 0000000000000000000000000000000000000000..7f9aa883773ff8c508b802b38aea4e6ddf110075
--- /dev/null
+++ b/templates/products.html
@@ -0,0 +1,29 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Products</h1>
+  <p>Browse stocked items and add them to your cart.</p>
+</section>
+<div class="grid">
+  {% for product in products %}
+    <article class="card">
+      <h2>{{ product.name }}</h2>
+      <p>{{ product.description }}</p>
+      <p class="price">{{ product.price_cents|money }}</p>
+      <p class="muted">{{ product.stock }} in stock</p>
+      {% if g.user %}
+        <form method="post" action="{{ url_for('add_to_cart') }}">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <input type="hidden" name="product_id" value="{{ product.id }}">
+          <label>Quantity
+            <input type="number" name="quantity" min="1" max="10" value="1" required>
+          </label>
+          <button type="submit" {% if product.stock == 0 %}disabled{% endif %}>Add to cart</button>
+        </form>
+      {% else %}
+        <a class="button" href="{{ url_for('login') }}">Sign in to buy</a>
+      {% endif %}
+    </article>
+  {% endfor %}
+</div>
+{% endblock %}
