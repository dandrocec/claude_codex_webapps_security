@@ -0,0 +1,21 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Admin orders</h1>
+</section>
+<table>
+  <thead><tr><th>Order</th><th>User</th><th>Status</th><th>Total</th><th>Created</th><th>Paid</th></tr></thead>
+  <tbody>
+    {% for order in orders %}
+      <tr>
+        <td>#{{ order.id }}</td>
+        <td>{{ order.email }}</td>
+        <td>{{ order.status }}</td>
+        <td>{{ order.total_cents|money }}</td>
+        <td>{{ order.created_at }}</td>
+        <td>{{ order.paid_at or "-" }}</td>
+      </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..153d0f92999c72c16d97ef8b4e7d628cfe00f02e
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,43 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{{ title or "Sandbox Shop" }}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('index') }}">Sandbox Shop</a>
+      <nav>
+        <a href="{{ url_for('index') }}">Products</a>
+        {% if g.user %}
+          <a href="{{ url_for('cart') }}">Cart</a>
+          <a href="{{ url_for('orders') }}">Orders</a>
+          {% if g.user.is_admin %}
+            <a href="{{ url_for('admin_orders') }}">Admin</a>
+          {% endif %}
+          <form method="post" action="{{ url_for('logout') }}" class="inline">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="link-button">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Sign in</a>
+          <a href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </nav>
+    </header>
+    <main class="page">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/cart.html b/templates/cart.html
new file mode 100644
index 0000000000000000000000000000000000000000..2e615279b02131630e4d472965a9aaa81e9759a7
--- /dev/null
+++ b/templates/cart.html
@@ -0,0 +1,38 @@
+{% extends "base.html" %}
+{% block content %}
+<section class="heading">
+  <h1>Your cart</h1>
+</section>
+{% if items %}
+  <table>
+    <thead><tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th><th></th></tr></thead>
+    <tbody>
+      {% for item in items %}
+        <tr>
+          <td>{{ item.name }}</td>
+          <td>{{ item.price_cents|money }}</td>
+          <td>
+            <form method="post" action="{{ url_for('update_cart') }}" class="row-form">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <input type="hidden" name="item_id" value="{{ item.id }}">
+              <input type="number" name="quantity" min="0" max="25" value="{{ item.quantity }}" required>
+              <button type="submit">Update</button>
+            </form>
+          </td>
+          <td>{{ item.line_total|money }}</td>
+          <td class="muted">{{ item.stock }} available</td>
+        </tr>
+      {% endfor %}
+    </tbody>
+  </table>
+  <div class="checkout">
+    <strong>Total: {{ total|money }}</strong>
+    <form method="post" action="{{ url_for('checkout') }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <button type="submit">Checkout</button>
+    </form>
+  </div>
+{% else %}
+  <p>Your cart is empty.</p>
+{% endif %}
+{% endblock %}
