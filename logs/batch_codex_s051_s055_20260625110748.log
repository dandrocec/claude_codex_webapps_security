+<%- include('partials/header', { title: 'Register' }) %>
+<section class="panel narrow">
+  <h1>Create account</h1>
+  <form method="post" action="/register" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Email
+      <input name="email" type="email" autocomplete="email" maxlength="254" required>
+    </label>
+    <label>Password
+      <input name="password" type="password" autocomplete="new-password" minlength="12" maxlength="128" required>
+    </label>
+    <button type="submit">Register</button>
+  </form>
+  <p>Already registered? <a href="/login">Log in</a>.</p>
+</section>
+<%- include('partials/footer') %>
diff --git a/src/views/responses.ejs b/src/views/responses.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..0c11d704db41b44f5085f42f00f11267be39ed28
--- /dev/null
+++ b/src/views/responses.ejs
@@ -0,0 +1,33 @@
+<%- include('partials/header', { title: 'Responses' }) %>
+<section class="panel">
+  <div class="heading-row">
+    <div>
+      <h1>Responses for <%= survey.title %></h1>
+      <p class="muted"><%= responses.length %> collected responses</p>
+    </div>
+    <a class="button secondary" href="/surveys/<%= survey.id %>">Back to survey</a>
+  </div>
+  <div class="table-wrap">
+    <table>
+      <thead>
+        <tr>
+          <th>Submitted</th>
+          <% questions.forEach((question) => { %>
+            <th><%= question.prompt %></th>
+          <% }) %>
+        </tr>
+      </thead>
+      <tbody>
+        <% responses.forEach((response) => { %>
+          <tr>
+            <td><%= response.created_at %></td>
+            <% questions.forEach((question) => { %>
+              <td><%= answerMap.get(`${response.id}:${question.id}`) || '' %></td>
+            <% }) %>
+          </tr>
+        <% }) %>
+      </tbody>
+    </table>
+  </div>
+</section>
+<%- include('partials/footer') %>
diff --git a/src/views/survey_new.ejs b/src/views/survey_new.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..72955ab76f331131f711eb8675a0e130b92cc390
--- /dev/null
+++ b/src/views/survey_new.ejs
@@ -0,0 +1,23 @@
+<%- include('partials/header', { title: 'New survey' }) %>
+<section class="panel">
+  <h1>New survey</h1>
+  <form method="post" action="/surveys" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Title
+      <input name="title" maxlength="120" required>
+    </label>
+    <label>Description
+      <textarea name="description" maxlength="800" rows="3"></textarea>
+    </label>
+    <fieldset>
+      <legend>Questions</legend>
+      <% for (let i = 0; i < 5; i += 1) { %>
+        <label>Question <%= i + 1 %>
+          <input name="questions" maxlength="240" <%= i === 0 ? 'required' : '' %>>
+        </label>
+      <% } %>
+    </fieldset>
+    <button type="submit">Create survey</button>
+  </form>
+</section>
+<%- include('partials/footer') %>
diff --git a/src/views/survey_show.ejs b/src/views/survey_show.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2dd952b9666e6bc02c645a0b2bb4b7c4c49cf83f
--- /dev/null
+++ b/src/views/survey_show.ejs
@@ -0,0 +1,19 @@
+<%- include('partials/header', { title: survey.title }) %>
+<section class="panel">
+  <div class="heading-row">
+    <div>
+      <h1><%= survey.title %></h1>
+      <p class="muted"><%= survey.description || 'No description' %></p>
+    </div>
+    <a class="button" href="/surveys/<%= survey.id %>/responses">View responses</a>
+  </div>
+  <h2>Public response link</h2>
+  <p><a href="<%= shareUrl %>"><%= shareUrl %></a></p>
+  <h2>Questions</h2>
+  <ol>
+    <% questions.forEach((question) => { %>
+      <li><%= question.prompt %></li>
+    <% }) %>
+  </ol>
+</section>
+<%- include('partials/footer') %>
