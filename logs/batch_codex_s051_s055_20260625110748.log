+  padding: clamp(22px, 4vw, 38px);
+  box-shadow: var(--shadow);
+}
+
+.panel.narrow h1,
+.login-panel h1 {
+  margin-bottom: 22px;
+  font-size: clamp(2rem, 5vw, 3rem);
+}
+
+.stacked-form {
+  display: grid;
+  gap: 18px;
+}
+
+label {
