+<%- include('partials/header', { title: 'Log in' }) %>
+<section class="panel narrow">
+  <h1>Log in</h1>
+  <form method="post" action="/login" class="stack">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
