diff --git a/views/project-form.ejs b/views/project-form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..afc55c8bf7a438fc03663c90a0dfbcf796b65c41
--- /dev/null
+++ b/views/project-form.ejs
@@ -0,0 +1,37 @@
+<%- include('partials/header', { title: heading }) %>
+
+<section class="panel">
+  <h1><%= heading %></h1>
+  <% if (errors.length) { %>
+    <div class="alert">
+      <% errors.forEach((error) => { %>
+        <p><%= error %></p>
+      <% }) %>
+    </div>
+  <% } %>
