diff --git a/src/views/public_survey.ejs b/src/views/public_survey.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..075e0fddcf93716012ee5a888fa862a27dae3a11
--- /dev/null
+++ b/src/views/public_survey.ejs
@@ -0,0 +1,24 @@
+<%- include("partials/start", { title: survey.title }) %>
+<section class="public-form">
+  <div class="page-heading">
+    <div>
+      <p class="eyebrow">Survey</p>
+      <h1><%= survey.title %></h1>
+      <% if (survey.description) { %><p><%= survey.description %></p><% } %>
+    </div>
+  </div>
+
+  <form method="post" action="/s/<%= survey.slug %>" class="stack panel">
+    <% questions.forEach((question) => { %>
+      <label><%= question.prompt %><% if (question.required) { %> <span class="required">*</span><% } %>
+        <% if (question.question_type === "textarea") { %>
+          <textarea name="q_<%= question.id %>" rows="4" <%= question.required ? "required" : "" %>><%= values[`q_${question.id}`] || "" %></textarea>
+        <% } else { %>
+          <input type="text" name="q_<%= question.id %>" value="<%= values[`q_${question.id}`] || "" %>" <%= question.required ? "required" : "" %>>
+        <% } %>
+      </label>
+    <% }) %>
+    <button class="button" type="submit">Submit response</button>
+  </form>
+</section>
+<%- include("partials/end") %>
diff --git a/src/views/register.ejs b/src/views/register.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..99b17f3ec1c94c19399292d36a893b3b57656095
--- /dev/null
+++ b/src/views/register.ejs
@@ -0,0 +1,14 @@
+<%- include("partials/start", { title: "Register" }) %>
+<section class="auth-panel">
+  <h1>Create account</h1>
+  <form method="post" action="/register" class="stack">
+    <label>Email
+      <input type="email" name="email" required autocomplete="email">
+    </label>
+    <label>Password
+      <input type="password" name="password" minlength="6" required autocomplete="new-password">
+    </label>
+    <button class="button" type="submit">Register</button>
+  </form>
+</section>
+<%- include("partials/end") %>
diff --git a/src/views/survey_detail.ejs b/src/views/survey_detail.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..da8f3c429d74affb9e454a1aa2c2cfd74148f39f
--- /dev/null
+++ b/src/views/survey_detail.ejs
@@ -0,0 +1,50 @@
+<%- include("partials/start", { title: survey.title }) %>
+<div class="page-heading">
+  <div>
+    <p class="eyebrow">Survey</p>
+    <h1><%= survey.title %></h1>
+    <% if (survey.description) { %><p><%= survey.description %></p><% } %>
+  </div>
+  <a class="button secondary" href="/dashboard">Back</a>
+</div>
+
+<section class="panel share-panel">
+  <div>
+    <h2>Public response link</h2>
+    <p><a href="/s/<%= survey.slug %>" target="_blank" rel="noreferrer">/s/<%= survey.slug %></a></p>
+  </div>
+</section>
+
+<section class="panel">
+  <div class="section-heading">
+    <h2>Responses</h2>
+    <span><%= responses.length %> total</span>
+  </div>
+  <% if (responses.length === 0) { %>
+    <p class="muted">No responses have been submitted yet.</p>
+  <% } else { %>
+    <div class="table-wrap">
+      <table>
+        <thead>
+          <tr>
+            <th>Submitted</th>
+            <% questions.forEach((question) => { %>
+              <th><%= question.prompt %></th>
+            <% }) %>
+          </tr>
+        </thead>
+        <tbody>
+          <% responses.forEach((response) => { %>
+            <tr>
+              <td><%= response.submitted_at %></td>
+              <% questions.forEach((question) => { %>
+                <td><%= answerMap.get(`${response.id}:${question.id}`) || "" %></td>
+              <% }) %>
+            </tr>
+          <% }) %>
+        </tbody>
+      </table>
+    </div>
+  <% } %>
+</section>
+<%- include("partials/end") %>
diff --git a/src/views/survey_form.ejs b/src/views/survey_form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..d6c0bedc010d647fee5619e5c4b04593f9f89882
--- /dev/null
+++ b/src/views/survey_form.ejs
@@ -0,0 +1,71 @@
+<%- include("partials/start", { title: "New Survey" }) %>
+<div class="page-heading">
+  <div>
+    <p class="eyebrow">Builder</p>
+    <h1>New survey</h1>
+  </div>
+</div>
+
+<form method="post" action="/surveys" class="builder">
+  <section class="panel stack">
+    <label>Survey title
+      <input type="text" name="title" value="<%= form.title || "" %>" required>
+    </label>
+    <label>Description
+      <textarea name="description" rows="3"><%= form.description || "" %></textarea>
+    </label>
+  </section>
+
+  <section class="panel">
+    <div class="section-heading">
+      <h2>Questions</h2>
+      <button class="button secondary small" type="button" id="add-question">Add question</button>
+    </div>
+    <div id="questions" class="question-list">
+      <% questions.forEach((question, index) => { %>
+        <div class="question-row">
+          <label>Prompt
+            <input type="text" name="prompt" value="<%= question.prompt %>" required>
+          </label>
+          <label>Type
+            <select name="question_type">
+              <option value="text" <%= question.question_type === "text" ? "selected" : "" %>>Short text</option>
+              <option value="textarea" <%= question.question_type === "textarea" ? "selected" : "" %>>Long text</option>
+            </select>
+          </label>
+          <label class="check">
+            <input type="checkbox" name="required" value="<%= index %>" <%= question.required ? "checked" : "" %>>
+            Required
+          </label>
+          <button class="remove" type="button" aria-label="Remove question">Remove</button>
+        </div>
+      <% }) %>
+    </div>
+  </section>
+
+  <div class="actions">
+    <button class="button" type="submit">Create survey</button>
+    <a class="button secondary" href="/dashboard">Cancel</a>
+  </div>
+</form>
+
+<template id="question-template">
+  <div class="question-row">
+    <label>Prompt
+      <input type="text" name="prompt" required>
+    </label>
+    <label>Type
+      <select name="question_type">
+        <option value="text">Short text</option>
+        <option value="textarea">Long text</option>
+      </select>
+    </label>
+    <label class="check">
+      <input type="checkbox" name="required" value="0" checked>
+      Required
+    </label>
+    <button class="remove" type="button" aria-label="Remove question">Remove</button>
+  </div>
+</template>
+<script src="/builder.js"></script>
+<%- include("partials/end") %>
