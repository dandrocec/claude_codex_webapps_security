+  text-decoration: none;
+}
+
+.ticket-row h2 {
+  margin-bottom: 4px;
+}
+
+.meta {
+  color: var(--muted);
+  font-size: 0.9rem;
+}
+
+.ticket-badges {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  justify-content: flex-end;
+}
+
+.badge {
+  border-radius: 999px;
+  display: inline-flex;
+  font-size: 0.85rem;
+  font-weight: 700;
+  padding: 5px 10px;
+}
+
+.status {
+  background: #e8f0fe;
+  color: #174ea6;
+}
+
+.priority-low {
+  background: #e6f4ea;
+  color: var(--success);
+}
+
+.priority-medium {
+  background: #fef7e0;
+  color: var(--warning);
+}
+
+.priority-high,
+.priority-urgent {
+  background: #fce8e6;
+  color: var(--danger);
+}
+
+.back-link {
+  display: inline-block;
+  margin-bottom: 16px;
+}
+
+.description {
+  border-top: 1px solid var(--border);
+  padding-top: 20px;
+  white-space: pre-wrap;
+}
+
+@media (max-width: 680px) {
+  .site-header,
+  .page-header,
+  .detail-header,
+  .ticket-row {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .nav,
+  .actions,
+  .ticket-badges {
+    justify-content: flex-start;
+  }
+}
