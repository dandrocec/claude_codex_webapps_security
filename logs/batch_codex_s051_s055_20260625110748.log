+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button class="danger" type="submit">Delete</button>
+        </form>
+      </div>
+    </article>
+  <% }) %>
+</section>
+
+<%- include('partials/footer') %>
