+}
+
+.message-success {
+  background: #e6f4ea;
+  color: var(--success);
+}
+
+.message-error {
+  background: #fce8e6;
+  color: var(--danger);
+}
+
+.message-warning {
+  background: #fef7e0;
+  color: var(--warning);
+}
+
+.ticket-list {
+  display: grid;
+  gap: 12px;
+}
+
+.ticket-row {
+  align-items: center;
+  background: var(--panel);
+  border: 1px solid var(--border);
