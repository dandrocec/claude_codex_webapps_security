+{% extends "base.html" %}
+{% block title %}Error | Support Tickets{% endblock %}
+{% block content %}
+  <section class="panel narrow">
+    <h1>{{ message }}</h1>
+    <p>The request could not be completed.</p>
+    <a class="button" href="{{ url_for('index') }}">Go back</a>
+  </section>
+{% endblock %}
