diff --git a/src/views/partials/header.ejs b/src/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..6edf92db7796d3060100b7ae76786daa715f0f94
--- /dev/null
+++ b/src/views/partials/header.ejs
@@ -0,0 +1,28 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= title || 'Survey Builder' %></title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="<%= currentUser ? '/dashboard' : '/login' %>">Survey Builder</a>
+    <nav>
+      <% if (currentUser) { %>
+        <span><%= currentUser.email %></span>
+        <form method="post" action="/logout" class="inline">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Log out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Log in</a>
+        <a href="/register">Register</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="page">
+    <% if (typeof flash !== 'undefined' && flash) { %>
+      <div class="flash <%= flash.type %>"><%= flash.message %></div>
+    <% } %>
diff --git a/src/views/public_survey.ejs b/src/views/public_survey.ejs
new file mode 100644
