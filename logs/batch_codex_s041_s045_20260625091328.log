+  padding-top: 0.8rem;
+}
+
+.comment p {
+  margin: 0.25rem 0;
+}
+
+@media (max-width: 680px) {
+  .site-header,
+  .headline {
+    align-items: flex-start;
+    flex-direction: column;
+  }
