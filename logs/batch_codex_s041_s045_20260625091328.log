+:root {
+  color-scheme: light;
+  --bg: #f4f1eb;
+  --surface: #ffffff;
+  --ink: #1b1f24;
+  --muted: #667085;
+  --line: #d9dee7;
+  --accent: #146c5f;
+  --accent-strong: #0e5147;
+  --warning: #895800;
+  --error: #aa2e25;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--bg);
+  color: var(--ink);
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 20px;
+  padding: 18px clamp(18px, 4vw, 56px);
+  border-bottom: 1px solid var(--line);
+  background: rgba(255, 255, 255, 0.86);
+}
+
+.brand {
+  color: var(--ink);
+  font-weight: 800;
+  text-decoration: none;
+}
+
+nav {
+  display: flex;
+  gap: 18px;
+}
+
+nav a {
+  color: var(--muted);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+main {
+  width: min(100%, 1040px);
+  margin: 0 auto;
+  padding: clamp(28px, 5vw, 64px) 18px;
+}
+
+.panel,
+.wide-panel {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: clamp(22px, 4vw, 42px);
+  box-shadow: 0 18px 50px rgba(27, 31, 36, 0.08);
+}
+
+.panel {
+  max-width: 720px;
+  margin: 0 auto;
+}
+
+.centered {
+  text-align: center;
+}
+
+.intro {
+  margin-bottom: 24px;
+}
+
+.eyebrow {
+  margin: 0 0 8px;
+  color: var(--accent);
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  margin-bottom: 0;
+  font-size: clamp(2rem, 5vw, 3.5rem);
+  line-height: 1.03;
+}
+
+.contact-form {
+  display: grid;
+  gap: 18px;
+}
+
+label {
+  display: grid;
+  gap: 7px;
+  font-weight: 750;
+}
+
+small {
+  color: var(--muted);
+  font-weight: 650;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 7px;
+  padding: 12px 13px;
+  color: var(--ink);
+  font: inherit;
+  background: #fff;
+}
+
+input:focus,
+textarea:focus {
+  border-color: var(--accent);
+  box-shadow: 0 0 0 3px rgba(20, 108, 95, 0.16);
+  outline: none;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button-link {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 46px;
+  border: 0;
+  border-radius: 7px;
+  padding: 0 18px;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 800;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+button:hover,
+.button-link:hover {
+  background: var(--accent-strong);
+}
+
+.notice {
+  border-radius: 7px;
+  margin-bottom: 18px;
+  padding: 12px 14px;
+}
+
+.notice p {
+  margin: 0;
+}
+
+.error {
+  border: 1px solid rgba(170, 46, 37, 0.3);
+  background: rgba(170, 46, 37, 0.08);
+  color: var(--error);
+}
+
+.warning {
+  border: 1px solid rgba(137, 88, 0, 0.3);
+  background: rgba(137, 88, 0, 0.08);
+  color: var(--warning);
+}
+
+.preview {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 16px;
+  background: #f7faf9;
+}
+
+.preview h2,
+.preview h3 {
+  margin-bottom: 10px;
+}
+
+pre {
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+  margin: 0;
+  color: var(--muted);
+  font: inherit;
+  line-height: 1.5;
+}
+
+.submission-list {
+  display: grid;
+  gap: 16px;
+}
+
+.submission {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 18px;
+  background: #fff;
+}
+
+.submission header {
+  display: flex;
+  align-items: start;
+  justify-content: space-between;
+  gap: 18px;
+  margin-bottom: 14px;
+}
+
+.submission h2 {
+  margin-bottom: 4px;
+}
+
+time,
+.muted,
+.empty {
+  color: var(--muted);
+}
+
+.message {
+  white-space: pre-wrap;
+}
+
+.compact {
+  margin-top: 14px;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .submission header {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  h1 {
+    font-size: 2.25rem;
+  }
+}
diff --git a/templates/admin.html b/templates/admin.html
new file mode 100644
index 0000000000000000000000000000000000000000..a722584cde107f5b493ae3a579cc99b0040a2bc9
--- /dev/null
+++ b/templates/admin.html
@@ -0,0 +1,41 @@
+{% extends "base.html" %}
+{% set title = "Admin" %}
+
+{% block content %}
+<section class="wide-panel">
+  <div class="intro">
+    <p class="eyebrow">Admin</p>
+    <h1>Submitted messages</h1>
+  </div>
+
+  {% if submissions %}
+    <div class="submission-list">
+      {% for item in submissions %}
+        <article class="submission">
+          <header>
+            <div>
+              <h2>{{ item.name }}</h2>
+              <a href="mailto:{{ item.email }}">{{ item.email }}</a>
+            </div>
+            <time>{{ item.created_at }}</time>
+          </header>
+          <p class="message">{{ item.message }}</p>
+          {% if item.website_url %}
+            <div class="preview compact">
+              <a href="{{ item.website_url }}" rel="noreferrer" target="_blank">{{ item.website_url }}</a>
+              {% if item.preview_title %}
+                <h3>{{ item.preview_title }}</h3>
+                <pre>{{ item.preview_text }}</pre>
+              {% elif item.fetch_error %}
+                <p class="muted">{{ item.fetch_error }}</p>
+              {% endif %}
+            </div>
+          {% endif %}
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty">No messages have been submitted yet.</p>
+  {% endif %}
+</section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..8b8fe7880ba8b5b1a7df746610f7d01a2de72efb
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,21 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{{ title or "Contact Form" }}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Contact Desk</a>
+    <nav>
+      <a href="{{ url_for('index') }}">Form</a>
+      <a href="{{ url_for('admin') }}">Admin</a>
+    </nav>
+  </header>
+  <main>
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/index.html b/templates/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..0339a2abae439c28dd4dc0141f31f4717a9666a1
--- /dev/null
+++ b/templates/index.html
@@ -0,0 +1,55 @@
+{% extends "base.html" %}
+{% set title = "Contact Form" %}
+
+{% block content %}
+<section class="panel">
+  <div class="intro">
+    <p class="eyebrow">Contact</p>
+    <h1>Send a message</h1>
+  </div>
+
+  {% if errors %}
+    <div class="notice error">
+      {% for error in errors %}
+        <p>{{ error }}</p>
+      {% endfor %}
+    </div>
+  {% endif %}
+
+  <form method="post" class="contact-form">
+    <label>
+      <span>Name</span>
+      <input name="name" value="{{ form.name }}" required maxlength="120" autocomplete="name">
+    </label>
+
+    <label>
+      <span>Email</span>
+      <input name="email" type="email" value="{{ form.email }}" required maxlength="180" autocomplete="email">
+    </label>
+
+    <label>
+      <span>Website URL <small>optional</small></span>
+      <input name="website_url" type="url" value="{{ form.website_url }}" maxlength="500" placeholder="https://example.com">
+    </label>
+
+    <label>
+      <span>Message</span>
+      <textarea name="message" required rows="7" maxlength="3000">{{ form.message }}</textarea>
+    </label>
+
+    {% if preview %}
+      <aside class="preview">
+        <p class="eyebrow">Website preview</p>
+        <h2>{{ preview.title }}</h2>
+        <pre>{{ preview.text }}</pre>
+      </aside>
+    {% elif fetch_error %}
+      <div class="notice warning">
+        <p>{{ fetch_error }}</p>
+      </div>
+    {% endif %}
+
+    <button type="submit">Submit message</button>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/thanks.html b/templates/thanks.html
new file mode 100644
index 0000000000000000000000000000000000000000..004f48819f039e80d00aa1638d93bc5571a6a45a
--- /dev/null
+++ b/templates/thanks.html
@@ -0,0 +1,11 @@
+{% extends "base.html" %}
+{% set title = "Message Sent" %}
+
+{% block content %}
+<section class="panel centered">
+  <p class="eyebrow">Received</p>
+  <h1>Thanks for the message.</h1>
+  <p class="muted">Your submission has been saved.</p>
+  <a class="button-link" href="{{ url_for('index') }}">Send another</a>
+</section>
+{% endblock %}

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..b92fe108794c284a201c7be5e3ffbf777fab6bee
--- /dev/null
+++ b/README.md
@@ -0,0 +1,18 @@
+# Contact Form Preview App
+
+A small Flask web app with a public contact form and an admin page for reviewing submitted messages.
+
+## Run locally
+
+```bash
+python -m venv .venv
+.venv\Scripts\activate
+pip install -r requirements.txt
+python app.py
+```
+
+Open http://localhost:5044 in your browser.
+
+The admin page is available at http://localhost:5044/admin.
+
+Submissions are stored in a local SQLite database file named `contacts.db`, created automatically on first run.
