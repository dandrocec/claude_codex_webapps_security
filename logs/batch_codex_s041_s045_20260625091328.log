+  padding: 0 16px;
+  background: var(--accent);
+  color: #ffffff;
+  font-weight: 800;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+.button.secondary {
+  background: var(--surface);
+  color: var(--accent-dark);
+}
+
+.faq-group {
+  margin: 32px 0;
+}
+
+.faq-group h2,
+.panel h2,
+.empty-state h2 {
+  margin: 0 0 16px;
+  font-size: 1.35rem;
+}
+
+.faq-list {
+  display: grid;
+  gap: 14px;
+}
+
+.faq-item {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.faq-item h3 {
+  margin: 0 0 8px;
+  font-size: 1.05rem;
+}
+
+.faq-item p,
+.empty-state p {
+  margin: 0;
+  color: var(--muted);
