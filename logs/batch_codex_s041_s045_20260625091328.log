diff --git a/src/views/partials/start.ejs b/src/views/partials/start.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..db441357843474a49c2c4696b15f74a211f1f431
--- /dev/null
+++ b/src/views/partials/start.ejs
@@ -0,0 +1,23 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= title %></title>
+  <link rel="stylesheet" href="/static/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="/">File Share</a>
+    <% if (currentUser) { %>
+      <form method="post" action="/logout" class="inline">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <span class="user"><%= currentUser.username %></span>
+        <button type="submit">Sign out</button>
+      </form>
+    <% } %>
+  </header>
+  <main class="container">
+    <% for (const message of messages) { %>
+      <div class="flash <%= message.type %>"><%= message.text %></div>
+    <% } %>
diff --git a/src/views/register.ejs b/src/views/register.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..5ce2a3bc375492e1b7cddfe22dea0e8c3edda681
--- /dev/null
+++ b/src/views/register.ejs
@@ -0,0 +1,25 @@
+<%- include('partials/start', { title: 'Register' }) %>
+<section class="panel auth">
+  <h1>Create account</h1>
+  <% if (errors.length) { %>
+    <div class="errors">
+      <% for (const error of errors) { %>
+        <p><%= error.msg %></p>
+      <% } %>
+    </div>
+  <% } %>
+  <form method="post" action="/register" novalidate>
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>
+      Username
+      <input name="username" value="<%= form.username || '' %>" autocomplete="username" required minlength="3" maxlength="32" pattern="[A-Za-z0-9_-]+">
+    </label>
+    <label>
+      Password
+      <input name="password" type="password" autocomplete="new-password" required minlength="12" maxlength="128">
+    </label>
+    <button type="submit">Create account</button>
+  </form>
+  <p class="muted">Already have an account? <a href="/login">Sign in</a>.</p>
+</section>
+<%- include('partials/end') %>
diff --git a/src/views/uploads.ejs b/src/views/uploads.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..8712b357ce6d971dc2f1008438064ec45335c3f9
--- /dev/null
+++ b/src/views/uploads.ejs
@@ -0,0 +1,59 @@
+<%- include('partials/start', { title: 'Your uploads' }) %>
+<section class="panel">
+  <h1>Your uploads</h1>
+  <% if (errors.length) { %>
+    <div class="errors">
+      <% for (const error of errors) { %>
+        <p><%= error.msg %></p>
+      <% } %>
+    </div>
+  <% } %>
+  <form method="post" action="/uploads" enctype="multipart/form-data" class="upload-form">
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>
+      File
+      <input name="file" type="file" required accept=".png,.jpg,.jpeg,.pdf,.txt,image/png,image/jpeg,application/pdf,text/plain">
+    </label>
+    <p class="muted">Allowed: PNG, JPEG, PDF, TXT. Maximum size: <%= maxUploadMb %> MB.</p>
+    <button type="submit">Upload</button>
+  </form>
+</section>
+
+<section class="panel">
+  <h2>Files</h2>
+  <% if (!uploads.length) { %>
+    <p class="muted">No uploads yet.</p>
+  <% } else { %>
+    <div class="table-wrap">
+      <table>
+        <thead>
+          <tr>
+            <th>Name</th>
+            <th>Type</th>
+            <th>Size</th>
+            <th>Uploaded</th>
+            <th>Actions</th>
+          </tr>
+        </thead>
+        <tbody>
+          <% for (const file of uploads) { %>
+            <tr>
+              <td><%= file.original_name %></td>
+              <td><%= file.mime_type %></td>
+              <td><%= Math.ceil(file.byte_size / 1024) %> KB</td>
+              <td><%= file.created_at %></td>
+              <td class="actions">
+                <a href="/uploads/<%= file.id %>/download">Download</a>
+                <form method="post" action="/uploads/<%= file.id %>/delete" class="inline">
+                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+                  <button type="submit">Delete</button>
+                </form>
+              </td>
+            </tr>
+          <% } %>
+        </tbody>
+      </table>
+    </div>
+  <% } %>
+</section>
+<%- include('partials/end') %>

