diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..dc7cc297ce5faf3f813799d47a7c4df3c4f46b5e
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,258 @@
+:root {
+  color-scheme: light;
+  --bg: #f4f1eb;
+  --surface: #ffffff;
+  --ink: #1b1f24;
+  --muted: #667085;
+  --line: #d9dee7;
+  --accent: #146c5f;
+  --accent-strong: #0e5147;
+  --warning: #895800;
+  --error: #aa2e25;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--bg);
+  color: var(--ink);
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 20px;
+  padding: 18px clamp(18px, 4vw, 56px);
+  border-bottom: 1px solid var(--line);
+  background: rgba(255, 255, 255, 0.86);
+}
+
+.brand {
+  color: var(--ink);
+  font-weight: 800;
+  text-decoration: none;
+}
+
+nav {
+  display: flex;
+  gap: 18px;
+}
+
+nav a {
+  color: var(--muted);
+  font-weight: 700;
+  text-decoration: none;
+}
+
+main {
+  width: min(100%, 1040px);
+  margin: 0 auto;
+  padding: clamp(28px, 5vw, 64px) 18px;
+}
+
+.panel,
+.wide-panel {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: clamp(22px, 4vw, 42px);
+  box-shadow: 0 18px 50px rgba(27, 31, 36, 0.08);
+}
+
+.panel {
+  max-width: 720px;
+  margin: 0 auto;
+}
+
+.centered {
+  text-align: center;
+}
+
+.intro {
+  margin-bottom: 24px;
+}
+
+.eyebrow {
+  margin: 0 0 8px;
+  color: var(--accent);
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  margin-bottom: 0;
+  font-size: clamp(2rem, 5vw, 3.5rem);
+  line-height: 1.03;
+}
+
+.contact-form {
+  display: grid;
+  gap: 18px;
+}
+
+label {
+  display: grid;
+  gap: 7px;
+  font-weight: 750;
+}
+
+small {
+  color: var(--muted);
+  font-weight: 650;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 7px;
+  padding: 12px 13px;
+  color: var(--ink);
+  font: inherit;
+  background: #fff;
+}
+
+input:focus,
+textarea:focus {
+  border-color: var(--accent);
+  box-shadow: 0 0 0 3px rgba(20, 108, 95, 0.16);
+  outline: none;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button,
+.button-link {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 46px;
+  border: 0;
+  border-radius: 7px;
+  padding: 0 18px;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 800;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+button:hover,
+.button-link:hover {
+  background: var(--accent-strong);
+}
+
+.notice {
+  border-radius: 7px;
+  margin-bottom: 18px;
+  padding: 12px 14px;
+}
+
+.notice p {
+  margin: 0;
+}
+
+.error {
+  border: 1px solid rgba(170, 46, 37, 0.3);
+  background: rgba(170, 46, 37, 0.08);
+  color: var(--error);
+}
+
+.warning {
+  border: 1px solid rgba(137, 88, 0, 0.3);
+  background: rgba(137, 88, 0, 0.08);
+  color: var(--warning);
+}
+
+.preview {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 16px;
+  background: #f7faf9;
+}
+
+.preview h2,
+.preview h3 {
+  margin-bottom: 10px;
+}
+
+pre {
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+  margin: 0;
+  color: var(--muted);
+  font: inherit;
+  line-height: 1.5;
+}
+
+.submission-list {
+  display: grid;
+  gap: 16px;
+}
+
+.submission {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 18px;
+  background: #fff;
+}
+
+.submission header {
+  display: flex;
+  align-items: start;
+  justify-content: space-between;
+  gap: 18px;
+  margin-bottom: 14px;
+}
+
+.submission h2 {
+  margin-bottom: 4px;
+}
+
+time,
+.muted,
+.empty {
+  color: var(--muted);
+}
+
+.message {
+  white-space: pre-wrap;
+}
+
+.compact {
+  margin-top: 14px;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .submission header {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  h1 {
+    font-size: 2.25rem;
+  }
+}
diff --git a/templates/admin.html b/templates/admin.html
new file mode 100644
