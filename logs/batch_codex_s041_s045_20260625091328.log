diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..f58684a2c01b861d233ce46c8d84d0d35ee03f64
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,187 @@
+:root {
+    color-scheme: light;
+    --bg: #f7f7f4;
+    --text: #202124;
+    --muted: #626b73;
+    --line: #d8ddd7;
+    --panel: #ffffff;
+    --accent: #1b6f68;
+    --danger: #a83232;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--bg);
+    color: var(--text);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.55;
+}
+
+a {
+    color: var(--accent);
+    text-decoration: none;
+}
+
+a:hover {
+    text-decoration: underline;
+}
+
+.site-header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 1rem;
+    padding: 1rem clamp(1rem, 3vw, 2rem);
+    border-bottom: 1px solid var(--line);
+    background: var(--panel);
+}
+
+.brand {
+    color: var(--text);
+    font-size: 1.35rem;
+    font-weight: 700;
+}
+
+.nav {
+    display: flex;
+    align-items: center;
+    gap: 1rem;
+    flex-wrap: wrap;
+}
+
+.nav form,
+.actions form {
+    display: inline;
+}
+
+.container {
+    width: min(920px, calc(100% - 2rem));
+    margin: 2rem auto;
+}
+
+.page-title,
+.article-full,
+.form-panel,
+.error {
+    margin-bottom: 1.5rem;
+}
+
+.article-card,
+.comment {
+    padding: 1rem 0;
+    border-bottom: 1px solid var(--line);
+}
+
+.article-card h2,
+.article-full h1,
+.form-panel h1 {
+    margin-top: 0;
+}
+
+.meta {
+    color: var(--muted);
+    font-size: 0.94rem;
+}
+
+.article-body {
+    margin-top: 1.5rem;
+    font-size: 1.06rem;
+}
+
+.actions {
+    display: flex;
+    gap: 0.75rem;
+    align-items: center;
+    margin-top: 1.5rem;
+}
+
+.comments,
+.comment-form {
+    margin-top: 2rem;
+    padding-top: 1rem;
+    border-top: 1px solid var(--line);
+}
+
+form {
+    display: grid;
+    gap: 0.65rem;
+}
+
+label {
+    font-weight: 700;
+}
+
+input,
+textarea {
+    width: 100%;
+    padding: 0.75rem;
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    background: var(--panel);
+    color: var(--text);
+    font: inherit;
+}
+
+textarea {
+    min-height: 180px;
+    resize: vertical;
+}
+
+button,
+.button {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    width: fit-content;
+    min-height: 42px;
+    padding: 0.62rem 0.95rem;
+    border: 0;
+    border-radius: 6px;
+    background: var(--accent);
+    color: #ffffff;
+    font: inherit;
+    font-weight: 700;
+    cursor: pointer;
+}
+
+.button:hover {
+    text-decoration: none;
+}
+
+.danger {
+    background: var(--danger);
+}
+
+.link-button {
+    min-height: auto;
+    padding: 0;
+    background: transparent;
+    color: var(--accent);
+    font-weight: 400;
+}
+
+.flash {
+    padding: 0.75rem 1rem;
+    border: 1px solid #d6b85f;
+    border-radius: 6px;
+    background: #fff8df;
+}
+
+.flash p {
+    margin: 0.25rem 0;
+}
+
+.empty {
+    color: var(--muted);
+}
+
+@media (max-width: 640px) {
+    .site-header {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+}
diff --git a/templates/article_detail.html b/templates/article_detail.html
new file mode 100644
