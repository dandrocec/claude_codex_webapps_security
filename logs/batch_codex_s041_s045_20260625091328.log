+:root {
+  color-scheme: light;
+  --bg: #f4f7f6;
+  --panel: #ffffff;
+  --text: #17211f;
+  --muted: #62706d;
+  --line: #d9e2df;
+  --accent: #0b6b57;
+  --accent-dark: #084e40;
+  --danger: #9f1d35;
+  --ok: #116a3a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent-dark);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 3rem);
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  font-weight: 700;
+  text-decoration: none;
+  color: var(--text);
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+}
+
+.shell {
+  width: min(960px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.panel,
+.message-card {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: clamp(1rem, 3vw, 2rem);
+  box-shadow: 0 8px 24px rgba(23, 33, 31, 0.06);
+}
+
+.narrow {
+  max-width: 460px;
+  margin-inline: auto;
+}
+
+h1,
+h2,
+p {
+  overflow-wrap: anywhere;
+}
+
+h1 {
+  margin: 0 0 1.25rem;
+  font-size: 1.75rem;
+}
+
+h2 {
+  margin: 0;
+  font-size: 1.05rem;
+}
+
+form {
+  display: grid;
+  gap: 1rem;
+}
+
+label {
+  display: grid;
+  gap: 0.35rem;
+  font-weight: 700;
+}
+
+label span {
+  color: var(--muted);
+  font-weight: 400;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 0.75rem;
+  color: var(--text);
+  font: inherit;
+  background: #fff;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button {
+  justify-self: start;
+  border: 0;
+  border-radius: 6px;
+  padding: 0.75rem 1rem;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+button:hover {
+  background: var(--accent-dark);
+}
+
+.inline {
+  display: inline;
+}
+
+.link-button {
+  padding: 0;
+  background: transparent;
+  color: var(--accent-dark);
+  font-weight: 400;
+}
+
+.link-button:hover {
+  background: transparent;
+  text-decoration: underline;
+}
+
+.alerts {
+  display: grid;
+  gap: 0.5rem;
+  margin-bottom: 1rem;
+}
+
+.alert {
+  margin: 0;
+  padding: 0.75rem 1rem;
+  border-radius: 6px;
+  background: #fff;
+  border: 1px solid var(--line);
+}
+
+.alert.error {
+  color: var(--danger);
+  border-color: #e8b4bd;
+}
+
+.alert.success {
+  color: var(--ok);
+  border-color: #adddc1;
+}
+
+.admin-head {
+  margin-bottom: 1rem;
+}
+
+.message-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.message-card header {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  border-bottom: 1px solid var(--line);
+  padding-bottom: 0.75rem;
+}
+
+time,
+.preview-url,
+.empty {
+  color: var(--muted);
+}
+
+.preview {
+  margin-top: 1rem;
+  padding: 1rem;
+  border-radius: 6px;
+  background: #eef5f3;
+  border: 1px solid var(--line);
+}
+
+.preview p {
+  margin-bottom: 0;
+}
+
+@media (max-width: 640px) {
+  .message-card header,
+  .topbar {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
