diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..356fdbb359290675ac6c32c2abfa1ab236941784
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,215 @@
+:root {
+  color-scheme: light;
+  --bg: #f4f7f6;
+  --panel: #ffffff;
+  --text: #17211f;
+  --muted: #62706d;
+  --line: #d9e2df;
+  --accent: #0b6b57;
+  --accent-dark: #084e40;
+  --danger: #9f1d35;
+  --ok: #116a3a;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent-dark);
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 3rem);
+  background: #ffffff;
+  border-bottom: 1px solid var(--line);
+}
+
+.brand {
+  font-weight: 700;
+  text-decoration: none;
+  color: var(--text);
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+}
+
+.shell {
+  width: min(960px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.panel,
+.message-card {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: clamp(1rem, 3vw, 2rem);
+  box-shadow: 0 8px 24px rgba(23, 33, 31, 0.06);
+}
+
+.narrow {
+  max-width: 460px;
+  margin-inline: auto;
+}
+
+h1,
+h2,
+p {
+  overflow-wrap: anywhere;
+}
+
+h1 {
+  margin: 0 0 1.25rem;
+  font-size: 1.75rem;
+}
+
+h2 {
+  margin: 0;
+  font-size: 1.05rem;
+}
+
+form {
+  display: grid;
+  gap: 1rem;
+}
+
+label {
+  display: grid;
+  gap: 0.35rem;
+  font-weight: 700;
+}
+
+label span {
+  color: var(--muted);
+  font-weight: 400;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 0.75rem;
+  color: var(--text);
+  font: inherit;
+  background: #fff;
+}
+
+textarea {
+  resize: vertical;
+}
+
+button {
+  justify-self: start;
+  border: 0;
+  border-radius: 6px;
+  padding: 0.75rem 1rem;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+button:hover {
+  background: var(--accent-dark);
+}
+
+.inline {
+  display: inline;
+}
+
+.link-button {
+  padding: 0;
+  background: transparent;
+  color: var(--accent-dark);
+  font-weight: 400;
+}
+
+.link-button:hover {
+  background: transparent;
+  text-decoration: underline;
+}
+
+.alerts {
+  display: grid;
+  gap: 0.5rem;
+  margin-bottom: 1rem;
+}
+
+.alert {
+  margin: 0;
+  padding: 0.75rem 1rem;
+  border-radius: 6px;
+  background: #fff;
+  border: 1px solid var(--line);
+}
+
+.alert.error {
+  color: var(--danger);
+  border-color: #e8b4bd;
+}
+
+.alert.success {
+  color: var(--ok);
+  border-color: #adddc1;
+}
+
+.admin-head {
+  margin-bottom: 1rem;
+}
+
+.message-list {
+  display: grid;
+  gap: 1rem;
+}
+
+.message-card header {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  border-bottom: 1px solid var(--line);
+  padding-bottom: 0.75rem;
+}
+
+time,
+.preview-url,
+.empty {
+  color: var(--muted);
+}
+
+.preview {
+  margin-top: 1rem;
+  padding: 1rem;
+  border-radius: 6px;
+  background: #eef5f3;
+  border: 1px solid var(--line);
+}
+
+.preview p {
+  margin-bottom: 0;
+}
+
+@media (max-width: 640px) {
+  .message-card header,
+  .topbar {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
diff --git a/templates/admin.html b/templates/admin.html
new file mode 100644
index 0000000000000000000000000000000000000000..4676e18dc74b04ff15b746ca30115668ba1bc86a
--- /dev/null
+++ b/templates/admin.html
@@ -0,0 +1,34 @@
+{% extends "base.html" %}
+{% set title = "Messages" %}
+{% block content %}
+  <section class="admin-head">
+    <h1>Submitted messages</h1>
+  </section>
+  <section class="message-list">
+    {% for item in messages %}
+      <article class="message-card">
+        <header>
+          <div>
+            <h2>{{ item.name }}</h2>
+            <a href="mailto:{{ item.email }}">{{ item.email }}</a>
+          </div>
+          <time datetime="{{ item.created_at }}">{{ item.created_at }}</time>
+        </header>
+        <p>{{ item.message | nl2br }}</p>
+        {% if item.website %}
+          <div class="preview">
+            <p class="preview-url">{{ item.website }}</p>
+            {% if item.preview_title %}
+              <strong>{{ item.preview_title }}</strong>
+              <p>{{ item.preview_excerpt | nl2br }}</p>
+            {% else %}
+              <p>No preview available.</p>
+            {% endif %}
+          </div>
+        {% endif %}
+      </article>
+    {% else %}
+      <p class="empty">No messages yet.</p>
+    {% endfor %}
+  </section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..8e5cf5464b9f91fd1efb49714b5914e4176bf5e5
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,37 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{{ title or "Contact Form" }}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('contact_form') }}">Contact Desk</a>
+      <nav>
+        {% if session.get("admin_id") %}
+          <a href="{{ url_for('admin_messages') }}">Admin</a>
+          <form method="post" action="{{ url_for('logout') }}" class="inline">
+            <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
+            <button type="submit" class="link-button">Sign out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login_form') }}">Admin</a>
+        {% endif %}
+      </nav>
+    </header>
+    <main class="shell">
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <section class="alerts" aria-live="polite">
+            {% for category, message in messages %}
+              <p class="alert {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </section>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/contact.html b/templates/contact.html
new file mode 100644
index 0000000000000000000000000000000000000000..f9ef5dfddec5a723545c8ae11d7660953b84451c
--- /dev/null
+++ b/templates/contact.html
@@ -0,0 +1,27 @@
+{% extends "base.html" %}
+{% set title = "Contact" %}
+{% block content %}
+  <section class="panel">
+    <h1>Contact us</h1>
+    <form method="post" action="{{ url_for('submit_contact') }}" novalidate>
+      <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
+      <label>
+        Name
+        <input name="name" maxlength="120" required value="{{ (form.name if form else '') }}">
+      </label>
+      <label>
+        Email
+        <input name="email" type="email" maxlength="254" required value="{{ (form.email if form else '') }}">
+      </label>
+      <label>
+        Website URL <span>optional</span>
+        <input name="website" type="url" maxlength="2048" placeholder="https://example.com" value="{{ (form.website if form else '') }}">
+      </label>
+      <label>
+        Message
+        <textarea name="message" maxlength="4000" rows="8" required>{{ (form.message if form else '') }}</textarea>
+      </label>
+      <button type="submit">Send message</button>
+    </form>
+  </section>
+{% endblock %}
