+  border-bottom: 1px solid var(--line);
+  display: flex;
+  gap: 24px;
+  justify-content: space-between;
+  padding: 16px max(18px, calc((100vw - 980px) / 2));
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+}
+
+.nav {
+  align-items: center;
+  display: flex;
+  gap: 14px;
+  flex-wrap: wrap;
+}
+
+.nav form {
+  margin: 0;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 980px;
+  padding: 28px 18px 56px;
+}
+
+.page-head {
+  align-items: flex-start;
+  display: flex;
+  gap: 18px;
+  justify-content: space-between;
+  margin-bottom: 22px;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+  margin: 0 0 10px;
+}
+
+p {
+  margin: 0 0 12px;
+}
+
+.poll-list {
+  display: grid;
+  gap: 14px;
+}
+
+.poll-card,
+.auth,
+.form-page,
+.poll-detail,
+.error-page {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 20px;
+}
+
+.poll-card h2 {
+  font-size: 1.15rem;
+}
+
+.meta,
+.empty,
+.total {
+  color: var(--muted);
+  font-size: 0.95rem;
+}
+
+.stack {
+  display: grid;
+  gap: 14px;
+  max-width: 620px;
+}
+
+label,
+fieldset {
+  display: grid;
+  gap: 7px;
+}
+
+fieldset {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  margin: 0;
+  padding: 14px;
+}
+
+legend {
+  color: var(--muted);
+  padding: 0 6px;
+}
+
+input,
+textarea {
+  border: 1px solid #b8c1cc;
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 10px 11px;
+  width: 100%;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: white;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 14px;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.danger {
+  background: var(--danger);
+}
+
+.errors,
+.flash,
+.notice {
+  border-radius: 8px;
+  margin: 0 0 16px;
+  padding: 12px 14px;
+}
+
+.errors {
+  background: #fff1f2;
+  border: 1px solid #fecdd3;
+  color: #9f1239;
+}
+
+.errors p {
+  margin: 0;
+}
+
+.flash,
+.notice {
+  background: #ecfeff;
+  border: 1px solid #a5f3fc;
+  color: #155e75;
+}
+
+.vote-form {
+  display: grid;
+  gap: 10px;
+  margin: 24px 0;
+  max-width: 640px;
+}
+
+.option-row {
+  align-items: center;
+  border: 1px solid var(--line);
