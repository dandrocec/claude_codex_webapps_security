+{% extends "base.html" %}
+
+{% block title %}Articles - Daily Ledger{% endblock %}
+
+{% block content %}
+  <section class="headline">
+    <div>
+      <p class="eyebrow">Latest reporting</p>
+      <h1>Articles from our authors</h1>
+    </div>
+    {% if g.user %}
+      <a class="button" href="{{ url_for('publish') }}">Publish article</a>
+    {% endif %}
+  </section>
+
+  {% if articles %}
+    <section class="article-list">
+      {% for article in articles %}
+        <article class="article-card">
+          <div class="meta">
+            By {{ article.author_name }} · {{ article.created_at }} ·
+            {{ article.comment_count }} comment{% if article.comment_count != 1 %}s{% endif %}
+          </div>
+          <h2><a href="{{ url_for('article', article_id=article.id) }}">{{ article.title }}</a></h2>
+          <p>{{ article.body[:220] }}{% if article.body|length > 220 %}...{% endif %}</p>
+          <a class="read-more" href="{{ url_for('article', article_id=article.id) }}">Read article</a>
+        </article>
+      {% endfor %}
+    </section>
+  {% else %}
+    <div class="empty-state">
+      <h2>No articles yet</h2>
+      <p>Registered authors can publish the first story.</p>
+    </div>
+  {% endif %}
+{% endblock %}
