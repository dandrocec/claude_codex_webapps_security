@@ -0,0 +1,46 @@
+{% extends "base.html" %}
+{% block title %}{{ article.title }} · Newsroom{% endblock %}
+{% block content %}
+<article class="article-full">
+    <h1>{{ article.title }}</h1>
+    <p class="meta">By {{ article.author_name }} on {{ article.created_at[:10] }}</p>
+    <div class="article-body">{{ nl2br(article.body) }}</div>
+
+    {% if g.user and g.user.id == article.author_id %}
+        <div class="actions">
+            <a class="button" href="{{ url_for('edit_article', article_id=article.id) }}">Edit</a>
+            <form method="post" action="{{ url_for('delete_article', article_id=article.id) }}">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <button type="submit" class="danger">Delete</button>
+            </form>
+        </div>
+    {% endif %}
+</article>
+
+<section class="comments">
+    <h2>Comments</h2>
+    {% if comments %}
+        {% for comment in comments %}
+            <article class="comment">
+                <h3>{{ comment.commenter_name }}</h3>
+                <p class="meta">{{ comment.created_at[:10] }}</p>
+                <div>{{ nl2br(comment.body) }}</div>
+            </article>
+        {% endfor %}
+    {% else %}
+        <p class="empty">No comments yet.</p>
+    {% endif %}
+</section>
+
+<section class="comment-form">
+    <h2>Post a Comment</h2>
+    <form method="post" action="{{ url_for('add_comment', article_id=article.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <label for="commenter_name">Name</label>
+        <input id="commenter_name" name="commenter_name" required minlength="2" maxlength="80">
+        <label for="body">Comment</label>
+        <textarea id="body" name="body" required maxlength="5000"></textarea>
+        <button type="submit">Publish comment</button>
+    </form>
+</section>
+{% endblock %}
diff --git a/templates/article_form.html b/templates/article_form.html
new file mode 100644
