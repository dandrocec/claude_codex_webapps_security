@@ -0,0 +1,29 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= title %> - Secure Polls</title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="/">Secure Polls</a>
+    <nav class="nav">
+      <% if (currentUser) { %>
+        <a href="/polls/new">New poll</a>
+        <span><%= currentUser.username %></span>
+        <form method="post" action="/logout">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Sign out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Sign in</a>
+        <a href="/register">Register</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="container">
+    <% if (flash) { %>
+      <div class="flash <%= flash.type %>"><%= flash.message %></div>
+    <% } %>
diff --git a/views/poll.ejs b/views/poll.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..d2c75ebf8cc6b94f8a1612d4ebe4bdf5acc37698
--- /dev/null
+++ b/views/poll.ejs
@@ -0,0 +1,47 @@
+<%- include("partials/header", { title }) %>
+<section class="poll-detail">
+  <div class="page-head">
+    <div>
+      <h1><%= poll.title %></h1>
+      <% if (poll.description) { %><p><%= poll.description %></p><% } %>
+      <div class="meta">Created by <%= poll.owner_name %></div>
+    </div>
+    <% if (isOwner) { %>
+      <form method="post" action="/polls/<%= poll.id %>/delete" onsubmit="return confirm('Delete this poll?');">
+        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+        <button class="danger" type="submit">Delete</button>
+      </form>
+    <% } %>
+  </div>
+
+  <% if (existingVote) { %>
+    <p class="notice">You have voted in this poll.</p>
+  <% } else { %>
+    <form method="post" action="/polls/<%= poll.id %>/vote" class="vote-form">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <% poll.options.forEach((option) => { %>
+        <label class="option-row">
+          <input type="radio" name="option_id" value="<%= option.id %>" required>
+          <span><%= option.label %></span>
+        </label>
+      <% }) %>
+      <button type="submit">Vote</button>
+    </form>
+  <% } %>
+
+  <section class="results" data-poll-id="<%= poll.id %>">
+    <h2>Live results</h2>
+    <div class="total"><span data-total><%= totalVotes %></span> total votes</div>
+    <div class="chart" data-chart>
+      <% results.forEach((row) => { %>
+        <% const percent = totalVotes ? Math.round((row.votes / totalVotes) * 100) : 0; %>
+        <div class="bar-row" data-option-id="<%= row.id %>">
+          <div class="bar-label"><span><%= row.label %></span><strong data-votes><%= row.votes %></strong></div>
+          <div class="bar-track"><div class="bar-fill" data-fill style="width:<%= percent %>%"></div></div>
+        </div>
+      <% }) %>
+    </div>
+  </section>
+</section>
+<script src="/poll-results.js" defer></script>
+<%- include("partials/footer") %>
