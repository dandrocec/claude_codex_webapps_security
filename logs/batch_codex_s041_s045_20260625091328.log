diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..f58684a2c01b861d233ce46c8d84d0d35ee03f64
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,187 @@
+:root {
+    color-scheme: light;
+    --bg: #f7f7f4;
+    --text: #202124;
+    --muted: #626b73;
+    --line: #d8ddd7;
+    --panel: #ffffff;
+    --accent: #1b6f68;
+    --danger: #a83232;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--bg);
+    color: var(--text);
+    font-family: Arial, Helvetica, sans-serif;
+    line-height: 1.55;
+}
+
+a {
+    color: var(--accent);
+    text-decoration: none;
+}
+
+a:hover {
+    text-decoration: underline;
+}
+
+.site-header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 1rem;
+    padding: 1rem clamp(1rem, 3vw, 2rem);
+    border-bottom: 1px solid var(--line);
+    background: var(--panel);
+}
+
+.brand {
+    color: var(--text);
+    font-size: 1.35rem;
+    font-weight: 700;
+}
+
+.nav {
+    display: flex;
+    align-items: center;
+    gap: 1rem;
+    flex-wrap: wrap;
+}
+
+.nav form,
+.actions form {
+    display: inline;
+}
+
+.container {
+    width: min(920px, calc(100% - 2rem));
+    margin: 2rem auto;
+}
+
+.page-title,
+.article-full,
+.form-panel,
+.error {
+    margin-bottom: 1.5rem;
+}
+
+.article-card,
+.comment {
+    padding: 1rem 0;
+    border-bottom: 1px solid var(--line);
+}
+
+.article-card h2,
+.article-full h1,
+.form-panel h1 {
+    margin-top: 0;
+}
+
+.meta {
+    color: var(--muted);
+    font-size: 0.94rem;
+}
+
+.article-body {
+    margin-top: 1.5rem;
+    font-size: 1.06rem;
+}
+
+.actions {
+    display: flex;
+    gap: 0.75rem;
+    align-items: center;
+    margin-top: 1.5rem;
+}
+
+.comments,
+.comment-form {
+    margin-top: 2rem;
+    padding-top: 1rem;
+    border-top: 1px solid var(--line);
+}
+
+form {
+    display: grid;
+    gap: 0.65rem;
+}
+
+label {
+    font-weight: 700;
+}
+
+input,
+textarea {
+    width: 100%;
+    padding: 0.75rem;
+    border: 1px solid var(--line);
+    border-radius: 6px;
+    background: var(--panel);
+    color: var(--text);
+    font: inherit;
+}
+
+textarea {
+    min-height: 180px;
+    resize: vertical;
+}
+
+button,
+.button {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    width: fit-content;
+    min-height: 42px;
+    padding: 0.62rem 0.95rem;
+    border: 0;
+    border-radius: 6px;
+    background: var(--accent);
+    color: #ffffff;
+    font: inherit;
+    font-weight: 700;
+    cursor: pointer;
+}
+
+.button:hover {
+    text-decoration: none;
+}
+
+.danger {
+    background: var(--danger);
+}
+
+.link-button {
+    min-height: auto;
+    padding: 0;
+    background: transparent;
+    color: var(--accent);
+    font-weight: 400;
+}
+
+.flash {
+    padding: 0.75rem 1rem;
+    border: 1px solid #d6b85f;
+    border-radius: 6px;
+    background: #fff8df;
+}
+
+.flash p {
+    margin: 0.25rem 0;
+}
+
+.empty {
+    color: var(--muted);
+}
+
+@media (max-width: 640px) {
+    .site-header {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+}
diff --git a/templates/article_detail.html b/templates/article_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..1a001683ee5a65afff72d6e74d4b1189cf41a4d0
--- /dev/null
+++ b/templates/article_detail.html
@@ -0,0 +1,46 @@
+{% extends "base.html" %}
+{% block title %}{{ article.title }} · Newsroom{% endblock %}
+{% block content %}
+<article class="article-full">
+    <h1>{{ article.title }}</h1>
+    <p class="meta">By {{ article.author_name }} on {{ article.created_at[:10] }}</p>
+    <div class="article-body">{{ nl2br(article.body) }}</div>
+
+    {% if g.user and g.user.id == article.author_id %}
+        <div class="actions">
+            <a class="button" href="{{ url_for('edit_article', article_id=article.id) }}">Edit</a>
+            <form method="post" action="{{ url_for('delete_article', article_id=article.id) }}">
+                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                <button type="submit" class="danger">Delete</button>
+            </form>
+        </div>
+    {% endif %}
+</article>
+
+<section class="comments">
+    <h2>Comments</h2>
+    {% if comments %}
+        {% for comment in comments %}
+            <article class="comment">
+                <h3>{{ comment.commenter_name }}</h3>
+                <p class="meta">{{ comment.created_at[:10] }}</p>
+                <div>{{ nl2br(comment.body) }}</div>
+            </article>
+        {% endfor %}
+    {% else %}
+        <p class="empty">No comments yet.</p>
+    {% endif %}
+</section>
+
+<section class="comment-form">
+    <h2>Post a Comment</h2>
+    <form method="post" action="{{ url_for('add_comment', article_id=article.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <label for="commenter_name">Name</label>
+        <input id="commenter_name" name="commenter_name" required minlength="2" maxlength="80">
+        <label for="body">Comment</label>
+        <textarea id="body" name="body" required maxlength="5000"></textarea>
+        <button type="submit">Publish comment</button>
+    </form>
+</section>
+{% endblock %}
diff --git a/templates/article_form.html b/templates/article_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..f71d8bfd86338c2859c899f19dbefdbb0dffdbe3
--- /dev/null
+++ b/templates/article_form.html
@@ -0,0 +1,15 @@
+{% extends "base.html" %}
+{% block title %}{% if article %}Edit Article{% else %}New Article{% endif %} · Newsroom{% endblock %}
+{% block content %}
+<section class="form-panel">
+    <h1>{% if article %}Edit Article{% else %}New Article{% endif %}</h1>
+    <form method="post">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <label for="title">Title</label>
+        <input id="title" name="title" required minlength="5" maxlength="160" value="{{ article.title if article else '' }}">
+        <label for="body">Body</label>
+        <textarea id="body" name="body" required minlength="20" maxlength="20000">{{ article.body if article else '' }}</textarea>
+        <button type="submit">{% if article %}Save changes{% else %}Publish article{% endif %}</button>
+    </form>
+</section>
+{% endblock %}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..fa6adcce024ccf87068337458e9b222c301ca157
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,40 @@
+<!doctype html>
+<html lang="en">
+<head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Newsroom{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+    <header class="site-header">
+        <a class="brand" href="{{ url_for('index') }}">Newsroom</a>
+        <nav class="nav">
+            {% if g.user %}
+                <a href="{{ url_for('new_article') }}">New article</a>
+                <span>{{ g.user.username }}</span>
+                <form method="post" action="{{ url_for('logout') }}">
+                    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+                    <button type="submit" class="link-button">Log out</button>
+                </form>
+            {% else %}
+                <a href="{{ url_for('login') }}">Log in</a>
+                <a href="{{ url_for('register') }}">Register</a>
+            {% endif %}
+        </nav>
+    </header>
+
+    <main class="container">
+        {% with messages = get_flashed_messages() %}
+            {% if messages %}
+                <div class="flash" role="alert">
+                    {% for message in messages %}
+                        <p>{{ message }}</p>
+                    {% endfor %}
+                </div>
+            {% endif %}
+        {% endwith %}
+        {% block content %}{% endblock %}
+    </main>
+</body>
+</html>
