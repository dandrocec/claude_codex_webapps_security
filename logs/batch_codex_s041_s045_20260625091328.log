+<%- include('partials/start', { title: 'Not found' }) %>
+<section class="panel auth">
+  <h1>Not found</h1>
+  <p class="muted">The requested resource could not be found.</p>
+  <p><a href="/">Return home</a></p>
+</section>
+<%- include('partials/end') %>
diff --git a/src/views/partials/end.ejs b/src/views/partials/end.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..8f0b997cf27cd319fccfc51d64ea2ce6551cb675
