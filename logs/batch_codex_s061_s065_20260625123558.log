diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..cd46819d097219fbb47ac20ab4b77671c98fef57
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,238 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1e252e;
+  --muted: #697586;
+  --line: #d9dee7;
+  --accent: #176b87;
+  --accent-dark: #0f4d61;
+  --danger: #b42318;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+  text-decoration: none;
+}
+
+.topbar {
+  align-items: center;
+  background: var(--panel);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  padding: 14px 24px;
+}
+
+.brand {
+  color: var(--text);
+  font-weight: 700;
+}
+
+nav,
+.actions,
+.page-title,
+.task-form,
+.toolbar {
+  align-items: center;
+  display: flex;
+  gap: 12px;
+}
+
+.container {
+  margin: 0 auto;
+  max-width: 1180px;
+  padding: 28px 20px;
+}
+
+.panel,
+.project-card,
+.column,
+.task,
+.toolbar {
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+}
+
+.panel,
+.toolbar {
+  padding: 20px;
+}
+
+.narrow {
+  max-width: 460px;
+}
+
+.hero {
+  max-width: 680px;
+}
+
+.messages {
+  background: #fff7df;
+  border: 1px solid #e8c96a;
+  border-radius: 8px;
+  margin-bottom: 18px;
+  padding: 10px 14px;
+}
+
+.messages p {
+  margin: 0;
+}
+
+.page-title {
+  justify-content: space-between;
+  margin-bottom: 18px;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+form {
+  display: grid;
+  gap: 12px;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  color: var(--muted);
+  display: grid;
+  font-size: 0.9rem;
+  gap: 5px;
+}
+
+input,
+textarea,
+select {
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  color: var(--text);
+  font: inherit;
+  padding: 9px 10px;
+  width: 100%;
+}
+
+textarea {
+  min-height: 110px;
+  resize: vertical;
+}
+
+button,
+.button {
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  color: #ffffff;
+  cursor: pointer;
+  display: inline-block;
+  font: inherit;
+  font-weight: 700;
+  padding: 10px 14px;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+}
+
+.secondary {
+  background: #e7edf2;
+  color: var(--text);
+}
+
+.danger {
+  background: var(--danger);
+}
+
+.grid {
+  display: grid;
+  gap: 14px;
+  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
+}
+
+.project-card {
+  color: var(--text);
+  display: grid;
+  gap: 8px;
+  padding: 16px;
+}
+
+.project-card span,
+small,
+.empty {
+  color: var(--muted);
+}
+
+.toolbar {
+  justify-content: space-between;
+  margin-bottom: 18px;
+}
+
+.members {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+
+.members span {
+  background: #edf7f8;
+  border-radius: 999px;
+  padding: 6px 10px;
+}
+
+.board {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  margin-top: 18px;
+}
+
+.column {
+  min-height: 260px;
+  padding: 14px;
+}
+
+.task {
+  display: grid;
+  gap: 10px;
+  margin-bottom: 12px;
+  padding: 14px;
+}
+
+.task h3,
+.task p {
+  overflow-wrap: anywhere;
+}
+
+@media (max-width: 780px) {
+  .topbar,
+  .page-title,
+  .toolbar,
+  .task-form {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .board {
+    grid-template-columns: 1fr;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..43c22254e6dc1db71c65c1fb25c5411bfdbcf7c6
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Project Board{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Project Board</a>
+    <nav>
+      {% if g.user %}
+        <a href="{{ url_for('projects') }}">Projects</a>
+        <span>{{ g.user.username }}</span>
+        <form method="post" action="{{ url_for('logout') }}" class="inline">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages() %}
+      {% if messages %}
+        <div class="messages">
+          {% for message in messages %}
+            <p>{{ message }}</p>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/board.html b/templates/board.html
new file mode 100644
index 0000000000000000000000000000000000000000..705329ebdf131fcd04ffc793b5b1464eb0e620b0
--- /dev/null
+++ b/templates/board.html
@@ -0,0 +1,87 @@
+{% extends "base.html" %}
+{% block title %}{{ project.name }}{% endblock %}
+{% block content %}
+<div class="page-title">
+  <div>
+    <h1>{{ project.name }}</h1>
+    <p>{{ project.description }}</p>
+  </div>
+</div>
+
+<section class="toolbar">
+  <form method="post" action="{{ url_for('invite_member', project_id=project.id) }}">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label>Invite by username
+      <input name="username" required minlength="3" maxlength="32" pattern="[A-Za-z0-9_.-]{3,32}">
+    </label>
+    <button type="submit">Invite</button>
+  </form>
+  <div class="members">
+    {% for member in members %}
+      <span>{{ member.username }} · {{ member.role }}</span>
+    {% endfor %}
+  </div>
+</section>
+
+<section class="panel">
+  <h2>Add task</h2>
+  <form method="post" action="{{ url_for('add_task', project_id=project.id) }}" class="task-form">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label>Title
+      <input name="title" required maxlength="120">
+    </label>
+    <label>Description
+      <input name="description" maxlength="500">
+    </label>
+    <label>Assignee
+      <select name="assignee_id">
+        <option value="">Unassigned</option>
+        {% for member in members %}
+          <option value="{{ member.id }}">{{ member.username }}</option>
+        {% endfor %}
+      </select>
+    </label>
+    <button type="submit">Add task</button>
+  </form>
+</section>
+
+<section class="board">
+  {% for status in statuses %}
+    <div class="column">
+      <h2>{{ status }}</h2>
+      {% for task in tasks[status] %}
+        <article class="task">
+          <h3>{{ task.title }}</h3>
+          {% if task.description %}<p>{{ task.description }}</p>{% endif %}
+          <small>Assigned to {{ task.assignee_name or "nobody" }}</small>
+          <form method="post" action="{{ url_for('update_task', project_id=project.id, task_id=task.id) }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <label>Status
+              <select name="status">
+                {% for option in statuses %}
+                  <option value="{{ option }}" {% if option == task.status %}selected{% endif %}>{{ option }}</option>
+                {% endfor %}
+              </select>
+            </label>
+            <label>Assignee
+              <select name="assignee_id">
+                <option value="">Unassigned</option>
+                {% for member in members %}
+                  <option value="{{ member.id }}" {% if member.id == task.assignee_id %}selected{% endif %}>{{ member.username }}</option>
+                {% endfor %}
+              </select>
+            </label>
+            <button type="submit">Update</button>
+          </form>
+          <form method="post" action="{{ url_for('delete_task', project_id=project.id, task_id=task.id) }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="danger">Delete</button>
+          </form>
+        </article>
+      {% else %}
+        <p class="empty">No tasks.</p>
+      {% endfor %}
+    </div>
+  {% endfor %}
+</section>
+{% endblock %}
