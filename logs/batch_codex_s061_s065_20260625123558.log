+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1f2937;
+  --muted: #667085;
+  --border: #d0d5dd;
+  --accent: #0f766e;
+  --accent-dark: #115e59;
+  --danger-bg: #fff1f2;
+  --danger: #be123c;
+  --ok-bg: #ecfdf3;
+  --ok: #027a48;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: Arial, Helvetica, sans-serif;
+  background: var(--bg);
+  color: var(--text);
+  line-height: 1.55;
+}
+
+a {
+  color: var(--accent-dark);
+  text-decoration: none;
+}
+
+a:hover {
+  text-decoration: underline;
+}
+
+.topbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  padding: 14px 24px;
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+}
+
+.brand {
+  font-weight: 700;
+  color: var(--text);
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 14px;
+  flex-wrap: wrap;
+}
+
+.container {
+  width: min(980px, calc(100% - 32px));
+  margin: 28px auto 56px;
+}
+
+.page-head {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+}
+
+h1,
+h2 {
+  line-height: 1.2;
+}
+
+.question-list,
+.answers {
+  display: grid;
+  gap: 14px;
+}
+
+.list-item,
+.question-detail,
+.answer,
+.answer-form,
+.form,
+.error-page {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.list-item {
+  display: grid;
+  grid-template-columns: 82px 1fr;
+  gap: 18px;
+}
+
+.stats,
+.vote-box {
+  display: grid;
+  justify-items: center;
+  align-content: start;
+  color: var(--muted);
+}
+
+.stats strong,
+.vote-box strong {
+  font-size: 1.35rem;
+  color: var(--text);
+}
+
+.meta,
+.empty {
+  color: var(--muted);
+}
+
+.body {
+  white-space: pre-wrap;
+}
+
+.form {
+  display: grid;
+  gap: 16px;
+  max-width: 720px;
+}
+
+label {
+  display: grid;
+  gap: 6px;
+  font-weight: 700;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  padding: 10px 12px;
+  font: inherit;
+  color: var(--text);
+  background: #fff;
+}
+
+button,
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 38px;
+  border: 0;
+  border-radius: 6px;
+  padding: 8px 13px;
+  background: var(--accent);
+  color: #fff;
+  font: inherit;
+  font-weight: 700;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-dark);
+  text-decoration: none;
+}
+
+.inline {
+  display: inline;
+}
+
+.inline button {
+  min-height: 0;
+  padding: 0;
+  background: transparent;
+  color: var(--accent-dark);
+}
+
+.answer {
+  display: grid;
+  grid-template-columns: 56px 1fr;
+  gap: 18px;
+}
+
+.answer.accepted {
+  border-color: #32d583;
+  background: var(--ok-bg);
+}
+
+.accepted-label {
+  display: inline-block;
+  margin-bottom: 8px;
+  color: var(--ok);
+  font-weight: 700;
+}
+
+.vote-box form {
+  margin: 0;
+}
+
+.vote-box button {
+  width: 34px;
+  height: 34px;
+  min-height: 34px;
+  padding: 0;
+  background: transparent;
+  color: var(--muted);
+}
+
+.vote-box button.selected,
+.vote-box button:hover {
+  color: #fff;
+  background: var(--accent);
+}
+
+.errors {
+  max-width: 720px;
+  margin: 0 0 16px;
+  padding: 12px 14px;
+  border: 1px solid #fecdd3;
+  border-radius: 8px;
+  background: var(--danger-bg);
+  color: var(--danger);
+}
+
+.errors p {
+  margin: 0;
+}
+
+.errors p + p {
+  margin-top: 6px;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .page-head {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .list-item,
+  .answer {
+    grid-template-columns: 1fr;
+  }
+
+  .stats,
+  .vote-box {
+    display: flex;
+    gap: 10px;
+    align-items: center;
+    justify-content: flex-start;
+  }
+}
