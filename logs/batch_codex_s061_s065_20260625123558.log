+
+    @app.post("/logout")
+    @login_required
+    def logout():
+        session.clear()
+        return redirect(url_for("login"))
+
+    @app.route("/tickets", methods=["GET", "POST"])
+    @login_required
+    def tickets():
+        if request.method == "POST":
+            title = clean_text(request.form.get("title"), 120)
