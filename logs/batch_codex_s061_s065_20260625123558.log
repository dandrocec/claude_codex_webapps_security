@@ -0,0 +1,10 @@
+<%- include('partials/header') %>
+<section class="panel">
+  <h1>Follow people. Share short updates.</h1>
+  <p>Register to create a profile, follow other users, and see their posts in your feed.</p>
+  <div class="actions">
+    <a class="button" href="/register">Create account</a>
+    <a class="button secondary" href="/login">Log in</a>
+  </div>
+</section>
+<%- include('partials/footer') %>
diff --git a/src/views/login.ejs b/src/views/login.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..a45ec553d66106ec1098f7e74c3164d5d5ab2470
--- /dev/null
