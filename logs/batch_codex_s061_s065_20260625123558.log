+    }
+    .reply { margin-top: 12px; }
+    .reply.agent { border-left: 4px solid var(--accent); }
+    .reply.customer { border-left: 4px solid var(--brand); }
+    .description { white-space: pre-wrap; }
+    @media (max-width: 760px) {
