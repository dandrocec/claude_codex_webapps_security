diff --git a/src/views/edit-profile.ejs b/src/views/edit-profile.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..ca7ed38ed66699d154b49f18d84ee5d62bd5b379
--- /dev/null
+++ b/src/views/edit-profile.ejs
@@ -0,0 +1,15 @@
+<%- include('partials/header') %>
+<section class="panel narrow">
+  <h1>Edit profile</h1>
+  <form method="post" action="/profile/edit" novalidate>
+    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+    <label>Display name
+      <input name="display_name" value="<%= form.display_name || '' %>" maxlength="60" required>
+    </label>
+    <label>Bio
+      <textarea name="bio" maxlength="240"><%= form.bio || '' %></textarea>
+    </label>
+    <button type="submit">Save profile</button>
+  </form>
+</section>
+<%- include('partials/footer') %>
