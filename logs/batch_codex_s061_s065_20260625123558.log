diff --git a/views/student-dashboard.ejs b/views/student-dashboard.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..2e2b8601ace366077053eba49be8e76e3780b96b
--- /dev/null
+++ b/views/student-dashboard.ejs
@@ -0,0 +1,30 @@
+<%- include('partials/header') %>
+
+<div class="row">
+  <div>
+    <h1 class="page-title">Student Dashboard</h1>
+    <p class="lead">Continue your enrolled courses and mark lessons complete.</p>
+  </div>
+  <a class="button" href="/courses">Find courses</a>
+</div>
+
+<% if (courses.length === 0) { %>
+  <div class="empty">You have not enrolled in any courses yet.</div>
+<% } else { %>
+  <div class="grid">
+    <% courses.forEach((course) => { %>
+      <% const percent = course.lesson_count ? Math.round((course.completed_count / course.lesson_count) * 100) : 0; %>
+      <article class="course-card">
+        <div>
+          <h3><%= course.title %></h3>
+          <p class="muted">By <%= course.instructor_name %></p>
+          <p><%= course.completed_count %> of <%= course.lesson_count %> lessons complete</p>
+          <div class="progress"><span style="width: <%= percent %>%"></span></div>
+        </div>
+        <a class="button secondary" href="/courses/<%= course.id %>">Continue</a>
+      </article>
+    <% }) %>
+  </div>
+<% } %>
+
+<%- include('partials/footer') %>

diff --git a/README.md b/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..597dbc1d13cb04f6a148942add69e49a1b1f8212
--- /dev/null
+++ b/README.md
@@ -0,0 +1,14 @@
+# LearnDeck
+
+A Node.js/Express e-learning app with instructor and student roles. Instructors create courses and lessons, students enrol in published courses, and lesson content is visible only to enrolled students.
+
+## Run locally
+
+```bash
+npm install
+npm start
+```
+
+The app runs on `http://localhost:5061` by default. Set `PORT=5061` explicitly if your environment requires it.
+
+SQLite database files are created automatically in the `data/` directory.
