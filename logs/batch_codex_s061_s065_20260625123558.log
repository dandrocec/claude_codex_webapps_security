+{% extends "base.html" %}
+{% block title %}Projects{% endblock %}
+{% block content %}
+<section class="section-heading">
+  <div>
+    <h1>Projects</h1>
+    <p>Your private project spaces.</p>
+  </div>
+  <a class="button" href="{{ url_for('new_project') }}">New project</a>
+</section>
+
+<section class="project-grid">
+  {% for membership in memberships %}
+    {% set project = membership.project %}
+    <a class="project-card" href="{{ url_for('project_detail', project_id=project.id) }}">
+      <h2>{{ project.name }}</h2>
+      <p>{{ project.description or "No description yet." }}</p>
+      <span>{{ project.tasks|length }} tasks</span>
+    </a>
+  {% else %}
+    <div class="empty">
+      <h2>No projects yet</h2>
+      <p>Create your first project to start adding members and tasks.</p>
+    </div>
+  {% endfor %}
+</section>
+{% endblock %}
