diff --git a/src/views/partials/header.ejs b/src/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..8dfcf69f08c0fd11ed68a34462dc0de9234afb98
--- /dev/null
+++ b/src/views/partials/header.ejs
@@ -0,0 +1,34 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>Secure Social</title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="<%= currentUser ? '/feed' : '/' %>">Secure Social</a>
+    <nav>
+      <% if (currentUser) { %>
+        <a href="/feed">Feed</a>
+        <a href="/users">People</a>
+        <a href="/users/<%= currentUser.id %>">Profile</a>
+        <form method="post" action="/logout" class="inline">
+          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+          <button type="submit">Log out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Log in</a>
+        <a href="/register">Register</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="container">
+    <% if (errors && errors.length) { %>
+      <div class="alert">
+        <% errors.forEach(function(error) { %>
+          <p><%= error %></p>
+        <% }) %>
+      </div>
+    <% } %>
diff --git a/src/views/profile.ejs b/src/views/profile.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..81bebda23a32416f7302a5686f106cafba9cef4c
--- /dev/null
+++ b/src/views/profile.ejs
@@ -0,0 +1,32 @@
+<%- include('partials/header') %>
+<section class="panel">
+  <h1><%= profile.display_name %></h1>
+  <p>@<%= profile.username %></p>
+  <p><%= profile.bio %></p>
+  <% if (currentUser.id === profile.id) { %>
+    <a class="button secondary" href="/profile/edit">Edit profile</a>
+  <% } else if (isFollowing) { %>
+    <form method="post" action="/users/<%= profile.id %>/unfollow">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <button type="submit">Unfollow</button>
+    </form>
+  <% } else { %>
+    <form method="post" action="/users/<%= profile.id %>/follow">
+      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
+      <button type="submit">Follow</button>
+    </form>
+  <% } %>
+</section>
+
+<section class="stream">
+  <% posts.forEach(function(post) { %>
+    <article class="post">
+      <div class="post-head">
+        <strong><%= profile.display_name %></strong>
+        <time><%= post.created_at %></time>
+      </div>
+      <p><%= post.body %></p>
+    </article>
+  <% }) %>
+</section>
+<%- include('partials/footer') %>
