+{
+  "name": "express-social-status-app",
+  "version": "1.0.0",
+  "description": "A small Node.js/Express social app with profiles, follows, posts, and a following feed.",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js",
+    "dev": "node server.js"
+  },
+  "dependencies": {
+    "bcryptjs": "^2.4.3",
+    "connect-flash": "^0.1.1",
+    "ejs": "^3.1.10",
+    "express": "^4.19.2",
+    "express-session": "^1.18.0",
+    "method-override": "^3.0.0",
+    "sql.js": "^1.10.3"
+  },
+  "engines": {
+    "node": ">=18"
+  }
+}
