diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..7a73e6f98df2ffc9ff38d7022e374856febd8610
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,166 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Helpdesk{% endblock %}</title>
+    <style>
+      :root {
+        color-scheme: light;
+        --bg: #f7f7f4;
+        --panel: #ffffff;
+        --line: #d9ded6;
+        --text: #1d2520;
+        --muted: #637066;
+        --accent: #0b6b58;
+        --danger: #a33232;
+      }
+      * { box-sizing: border-box; }
+      body {
+        margin: 0;
+        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+        background: var(--bg);
+        color: var(--text);
+      }
+      header {
+        border-bottom: 1px solid var(--line);
+        background: var(--panel);
+      }
+      nav {
+        max-width: 1040px;
+        margin: 0 auto;
+        padding: 14px 18px;
+        display: flex;
+        gap: 14px;
+        align-items: center;
+        justify-content: space-between;
+      }
+      nav a, .link-button {
+        color: var(--accent);
+        font-weight: 650;
+        text-decoration: none;
+      }
+      .link-button {
+        border: 0;
+        background: transparent;
+        padding: 0;
+        cursor: pointer;
+        font: inherit;
+      }
+      main {
+        max-width: 1040px;
+        margin: 0 auto;
+        padding: 24px 18px 56px;
+      }
+      .auth, .panel {
+        background: var(--panel);
+        border: 1px solid var(--line);
+        border-radius: 8px;
+        padding: 20px;
+      }
+      .auth { max-width: 460px; }
+      h1 { font-size: 1.65rem; margin: 0 0 18px; }
+      h2 { font-size: 1.15rem; margin: 0 0 12px; }
+      label { display: block; font-weight: 650; margin: 14px 0 6px; }
+      input, textarea, select {
+        width: 100%;
+        border: 1px solid var(--line);
+        border-radius: 6px;
+        padding: 10px 11px;
+        font: inherit;
+        background: #fff;
+        color: var(--text);
+      }
+      textarea { min-height: 140px; resize: vertical; }
+      button, .button {
+        display: inline-flex;
+        align-items: center;
+        justify-content: center;
+        min-height: 40px;
+        border: 0;
+        border-radius: 6px;
+        padding: 9px 14px;
+        background: var(--accent);
+        color: #fff;
+        font: inherit;
+        font-weight: 700;
+        text-decoration: none;
+        cursor: pointer;
+      }
+      .button.secondary { background: #4f5f57; }
+      .actions { display: flex; flex-wrap: wrap; gap: 10px; align-items: end; margin-top: 16px; }
+      .grid { display: grid; gap: 14px; }
+      .ticket-list { display: grid; gap: 10px; }
+      .ticket-row {
+        display: grid;
+        gap: 6px;
+        padding: 14px;
+        background: var(--panel);
+        border: 1px solid var(--line);
+        border-radius: 8px;
+      }
+      .meta { color: var(--muted); font-size: .92rem; }
+      .status {
+        display: inline-block;
+        width: fit-content;
+        border: 1px solid var(--line);
+        border-radius: 999px;
+        padding: 3px 9px;
+        background: #eef4f0;
+        color: #29463b;
+        font-size: .86rem;
+        font-weight: 700;
+      }
+      .body-text { white-space: pre-wrap; overflow-wrap: anywhere; line-height: 1.5; }
+      .reply {
+        border-top: 1px solid var(--line);
+        padding-top: 14px;
+      }
+      .flash {
+        border-radius: 6px;
+        padding: 10px 12px;
+        margin-bottom: 14px;
+        background: #eaf5ef;
+        border: 1px solid #bcd7c9;
+      }
+      .flash.error {
+        background: #fff0f0;
+        border-color: #e4b8b8;
+        color: var(--danger);
+      }
+      @media (min-width: 760px) {
+        .agent-tools {
+          display: grid;
+          grid-template-columns: 1fr 1fr;
+          gap: 14px;
+        }
+      }
+    </style>
+  </head>
+  <body>
+    <header>
+      <nav>
+        <a href="{{ url_for('tickets') }}">Helpdesk</a>
+        <div>
+          {% if g.user %}
+            <span class="meta">{{ g.user.name }} · {{ g.user.role }}</span>
+            <form action="{{ url_for('logout') }}" method="post" style="display:inline; margin-left: 12px;">
+              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+              <button class="link-button" type="submit">Sign out</button>
+            </form>
+          {% else %}
+            <a href="{{ url_for('login') }}">Sign in</a>
+          {% endif %}
+        </div>
+      </nav>
+    </header>
+    <main>
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% for category, message in messages %}
+          <div class="flash {{ category }}">{{ message }}</div>
+        {% endfor %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/error.html b/templates/error.html
new file mode 100644
index 0000000000000000000000000000000000000000..dab332bbabddb66af753688dc64e50d240f73489
--- /dev/null
+++ b/templates/error.html
@@ -0,0 +1,9 @@
+{% extends "base.html" %}
+{% block title %}Error · Helpdesk{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Request could not be completed</h1>
+  <p>{{ message }}</p>
+  <a class="button" href="{{ url_for('tickets') }}">Back to tickets</a>
+</section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..0e1b14dd1474da001777a2ec9944a0862775f5e6
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,18 @@
+{% extends "base.html" %}
+{% block title %}Sign in · Helpdesk{% endblock %}
+{% block content %}
+<section class="auth">
+  <h1>Sign in</h1>
+  <form method="post">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label for="email">Email</label>
+    <input id="email" name="email" type="email" autocomplete="email" maxlength="254" required>
+    <label for="password">Password</label>
+    <input id="password" name="password" type="password" autocomplete="current-password" required>
+    <div class="actions">
+      <button type="submit">Sign in</button>
+      <a href="{{ url_for('register') }}">Create customer account</a>
+    </div>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/new_ticket.html b/templates/new_ticket.html
new file mode 100644
index 0000000000000000000000000000000000000000..0658f0009251f8feb5f78caaad5729b7310c3cc7
--- /dev/null
+++ b/templates/new_ticket.html
@@ -0,0 +1,18 @@
+{% extends "base.html" %}
+{% block title %}Open ticket · Helpdesk{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>Open ticket</h1>
+  <form method="post" action="{{ url_for('tickets') }}">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label for="title">Title</label>
+    <input id="title" name="title" maxlength="120" required>
+    <label for="body">Message</label>
+    <textarea id="body" name="body" maxlength="4000" required></textarea>
+    <div class="actions">
+      <button type="submit">Create ticket</button>
+      <a class="button secondary" href="{{ url_for('tickets') }}">Cancel</a>
+    </div>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/register.html b/templates/register.html
new file mode 100644
index 0000000000000000000000000000000000000000..0bc9469b8a602e5ce8d0a4008d01402e8b6a07af
--- /dev/null
+++ b/templates/register.html
@@ -0,0 +1,20 @@
+{% extends "base.html" %}
+{% block title %}Register · Helpdesk{% endblock %}
+{% block content %}
+<section class="auth">
+  <h1>Create customer account</h1>
+  <form method="post">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label for="name">Name</label>
+    <input id="name" name="name" autocomplete="name" maxlength="80" required>
+    <label for="email">Email</label>
+    <input id="email" name="email" type="email" autocomplete="email" maxlength="254" required>
+    <label for="password">Password</label>
+    <input id="password" name="password" type="password" autocomplete="new-password" minlength="12" required>
+    <div class="actions">
+      <button type="submit">Create account</button>
+      <a href="{{ url_for('login') }}">Sign in</a>
+    </div>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/ticket_detail.html b/templates/ticket_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..f00423d848a40592a98467b058e48d25c64b0a36
--- /dev/null
+++ b/templates/ticket_detail.html
@@ -0,0 +1,68 @@
+{% extends "base.html" %}
+{% block title %}{{ ticket.title }} · Helpdesk{% endblock %}
+{% block content %}
+<div class="grid">
+  <section class="panel">
+    <div class="actions" style="justify-content: space-between; margin-top: 0;">
+      <h1>{{ ticket.title }}</h1>
+      <span class="status">{{ ticket.status }}</span>
+    </div>
+    <p class="meta">
+      Customer: {{ ticket.customer_name }} · Agent: {{ ticket.agent_name or "Unassigned" }} · Updated: {{ ticket.updated_at }}
+    </p>
+    <div class="body-text">{{ ticket.body }}</div>
+  </section>
+
+  {% if g.user.role == "agent" %}
+    <section class="agent-tools">
+      <form class="panel" method="post" action="{{ url_for('assign_ticket', ticket_id=ticket.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <h2>Assignment</h2>
+        <label for="agent_id">Agent</label>
+        <select id="agent_id" name="agent_id">
+          <option value="">Unassigned</option>
+          {% for agent in agents %}
+            <option value="{{ agent.id }}" {% if ticket.agent_id == agent.id %}selected{% endif %}>{{ agent.name }} ({{ agent.email }})</option>
+          {% endfor %}
+        </select>
+        <div class="actions"><button type="submit">Update assignment</button></div>
+      </form>
+      <form class="panel" method="post" action="{{ url_for('change_status', ticket_id=ticket.id) }}">
+        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+        <h2>Status</h2>
+        <label for="status">Status</label>
+        <select id="status" name="status">
+          {% for status in statuses %}
+            <option value="{{ status }}" {% if ticket.status == status %}selected{% endif %}>{{ status }}</option>
+          {% endfor %}
+        </select>
+        <div class="actions"><button type="submit">Update status</button></div>
+      </form>
+    </section>
+  {% endif %}
+
+  <section class="panel">
+    <h2>Replies</h2>
+    <div class="grid">
+      {% for reply in replies %}
+        <article class="reply">
+          <p class="meta">{{ reply.name }} · {{ reply.role }} · {{ reply.created_at }}</p>
+          <div class="body-text">{{ reply.body }}</div>
+        </article>
+      {% else %}
+        <p class="meta">No replies yet.</p>
+      {% endfor %}
+    </div>
+  </section>
+
+  <section class="panel">
+    <h2>Add reply</h2>
+    <form method="post">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label for="message">Message</label>
+      <textarea id="message" name="message" maxlength="4000" required></textarea>
+      <div class="actions"><button type="submit">Send reply</button></div>
+    </form>
+  </section>
+</div>
+{% endblock %}
