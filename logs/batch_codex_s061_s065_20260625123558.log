+{% extends "base.html" %}
+{% block title %}Project Board{% endblock %}
+{% block content %}
+<section class="hero">
+  <div>
+    <h1>Project Board</h1>
+    <p>Create private team projects, invite members, and move tasks from todo to done.</p>
+    <div class="actions">
+      <a class="button" href="{{ url_for('register') }}">Create account</a>
+      <a class="button secondary" href="{{ url_for('login') }}">Log in</a>
+    </div>
+  </div>
+</section>
+{% endblock %}
diff --git a/templates/login.html b/templates/login.html
new file mode 100644
index 0000000000000000000000000000000000000000..93edad03df4e9190e617e3059503279fc16a5d7f
--- /dev/null
+++ b/templates/login.html
@@ -0,0 +1,16 @@
+{% extends "base.html" %}
+{% block title %}Log in{% endblock %}
+{% block content %}
+<section class="panel narrow">
+  <h1>Log in</h1>
+  <form method="post" class="stack">
+    <label>Username
+      <input name="username" required autocomplete="username">
+    </label>
+    <label>Password
+      <input name="password" type="password" required autocomplete="current-password">
+    </label>
+    <button type="submit" class="button">Log in</button>
+  </form>
+</section>
+{% endblock %}
diff --git a/templates/project_detail.html b/templates/project_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..b64ee199c421ab0e9db7c63dba3f88eb69843c87
--- /dev/null
+++ b/templates/project_detail.html
@@ -0,0 +1,72 @@
+{% extends "base.html" %}
+{% block title %}{{ project.name }}{% endblock %}
+{% block content %}
+<section class="project-header">
+  <div>
+    <a class="back-link" href="{{ url_for('projects') }}">Back to projects</a>
+    <h1>{{ project.name }}</h1>
+    <p>{{ project.description or "No description yet." }}</p>
+  </div>
+  <form method="post" action="{{ url_for('invite_member', project_id=project.id) }}" class="invite-form">
+    <input name="username" placeholder="Invite by username" required>
+    <button type="submit" class="button">Invite</button>
+  </form>
+</section>
+
+<section class="members">
+  <strong>Members</strong>
+  {% for member in members %}
+    <span class="user-chip">{{ member.username }}</span>
+  {% endfor %}
+</section>
+
+<section class="task-composer panel">
+  <h2>Add task</h2>
+  <form method="post" action="{{ url_for('create_task', project_id=project.id) }}" class="task-form">
+    <input name="title" placeholder="Task title" required maxlength="180">
+    <select name="assignee_id">
+      <option value="">Unassigned</option>
+      {% for member in members %}
+        <option value="{{ member.id }}">{{ member.username }}</option>
+      {% endfor %}
+    </select>
+    <textarea name="details" rows="2" placeholder="Details"></textarea>
+    <button type="submit" class="button">Add task</button>
+  </form>
+</section>
+
+<section class="board">
+  {% for status in statuses %}
+    <div class="column">
+      <h2>{{ status|capitalize }}</h2>
+      {% for task in columns[status] %}
+        <article class="task">
+          <h3>{{ task.title }}</h3>
+          {% if task.details %}
+            <p>{{ task.details }}</p>
+          {% endif %}
+          <form method="post" action="{{ url_for('update_task', project_id=project.id, task_id=task.id) }}" class="task-controls">
+            <select name="status">
+              {% for option in statuses %}
+                <option value="{{ option }}" {% if task.status == option %}selected{% endif %}>{{ option|capitalize }}</option>
+              {% endfor %}
+            </select>
+            <select name="assignee_id">
+              <option value="">Unassigned</option>
+              {% for member in members %}
+                <option value="{{ member.id }}" {% if task.assignee_id == member.id %}selected{% endif %}>{{ member.username }}</option>
+              {% endfor %}
+            </select>
+            <button type="submit" class="button small">Save</button>
+          </form>
+          <form method="post" action="{{ url_for('delete_task', project_id=project.id, task_id=task.id) }}">
+            <button type="submit" class="danger-link">Delete</button>
+          </form>
+        </article>
+      {% else %}
+        <div class="empty-column">No {{ status }} tasks.</div>
+      {% endfor %}
+    </div>
+  {% endfor %}
+</section>
+{% endblock %}
diff --git a/templates/project_form.html b/templates/project_form.html
new file mode 100644
index 0000000000000000000000000000000000000000..0fe5fa9815771218eed657b819159a9cd4f2d30d
--- /dev/null
+++ b/templates/project_form.html
@@ -0,0 +1,16 @@
+{% extends "base.html" %}
+{% block title %}New Project{% endblock %}
+{% block content %}
+<section class="panel">
+  <h1>New project</h1>
+  <form method="post" class="stack">
+    <label>Name
+      <input name="name" required maxlength="140">
+    </label>
+    <label>Description
+      <textarea name="description" rows="4"></textarea>
+    </label>
+    <button type="submit" class="button">Create project</button>
+  </form>
+</section>
+{% endblock %}
