+{% extends "base.html" %}
+{% block title %}Tickets · Helpdesk{% endblock %}
+{% block content %}
+<div class="actions" style="justify-content: space-between; margin-top: 0;">
+  <h1>Tickets</h1>
+  {% if g.user.role == "customer" %}
+    <a class="button" href="{{ url_for('new_ticket') }}">Open ticket</a>
+  {% endif %}
+</div>
+<section class="ticket-list">
+  {% for ticket in tickets %}
+    <article class="ticket-row">
+      <a href="{{ url_for('ticket_detail', ticket_id=ticket.id) }}"><strong>{{ ticket.title }}</strong></a>
+      <span class="status">{{ ticket.status }}</span>
+      <div class="meta">
+        {% if g.user.role == "agent" %}Customer: {{ ticket.customer_name }} · {% endif %}
+        Agent: {{ ticket.agent_name or "Unassigned" }} · Updated: {{ ticket.updated_at }}
+      </div>
+    </article>
+  {% else %}
+    <div class="panel">No tickets yet.</div>
+  {% endfor %}
+</section>
+{% endblock %}

