@@ -0,0 +1,22 @@
+{
+  "name": "express-social-status-app",
+  "version": "1.0.0",
+  "description": "A small Node.js/Express social app with profiles, follows, posts, and a following feed.",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js",
+    "dev": "node server.js"
+  },
+  "dependencies": {
+    "bcryptjs": "^2.4.3",
+    "connect-flash": "^0.1.1",
+    "ejs": "^3.1.10",
+    "express": "^4.19.2",
+    "express-session": "^1.18.0",
+    "method-override": "^3.0.0",
+    "sql.js": "^1.10.3"
+  },
+  "engines": {
+    "node": ">=18"
+  }
+}
diff --git a/public/styles.css b/public/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..0045c9a2ed8edbeaadf58542595933ab61c3ed94
--- /dev/null
+++ b/public/styles.css
@@ -0,0 +1,350 @@
+:root {
+  --bg: #f5f7f8;
+  --surface: #ffffff;
+  --text: #172026;
+  --muted: #68727c;
+  --line: #d8dee4;
+  --primary: #0f766e;
+  --primary-dark: #115e59;
+  --accent: #b45309;
+  --danger: #b42318;
+  --shadow: 0 10px 30px rgba(23, 32, 38, 0.08);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+input,
+textarea,
+button {
+  font: inherit;
+}
+
+textarea {
+  resize: vertical;
+}
+
+.site-header {
+  position: sticky;
+  top: 0;
+  z-index: 5;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+  padding: 16px clamp(16px, 5vw, 64px);
+  background: rgba(255, 255, 255, 0.92);
+  border-bottom: 1px solid var(--line);
+  backdrop-filter: blur(12px);
+}
+
+.brand {
+  font-size: 1.25rem;
+  font-weight: 800;
+  color: var(--primary-dark);
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  justify-content: flex-end;
+  gap: 14px;
+  color: var(--muted);
+}
+
+.nav a:hover,
+.link-button:hover {
+  color: var(--primary-dark);
+}
+
+.container {
+  width: min(1100px, calc(100% - 32px));
+  margin: 0 auto;
+  padding: 32px 0 56px;
+}
+
+.hero {
+  min-height: 62vh;
+  display: grid;
+  align-items: center;
+}
+
+.hero > div {
+  max-width: 720px;
+}
+
+.eyebrow {
+  margin: 0 0 12px;
+  color: var(--accent);
+  font-weight: 800;
+  text-transform: uppercase;
+  font-size: 0.78rem;
+}
+
+h1,
+h2 {
+  line-height: 1.12;
+  margin: 0 0 16px;
+}
+
+h1 {
+  font-size: clamp(2rem, 6vw, 4.5rem);
+}
+
+.panel h1,
+.timeline h1 {
+  font-size: 2rem;
+}
+
+.lede {
+  max-width: 600px;
+  color: var(--muted);
+  font-size: 1.2rem;
+}
+
+.actions,
+.form-row,
+.section-heading,
+.profile-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+}
+
+.actions {
+  justify-content: flex-start;
+  margin-top: 28px;
+}
+
+.button,
+.secondary,
+button {
+  border: 0;
+  border-radius: 8px;
+  cursor: pointer;
+}
+
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 42px;
+  padding: 0 18px;
+  background: var(--primary);
+  color: #fff;
+  font-weight: 800;
+}
+
+.button:hover {
+  background: var(--primary-dark);
+}
+
+.button.small,
+.secondary.compact {
+  min-height: 34px;
+  padding: 0 12px;
+  font-size: 0.92rem;
+}
+
+.secondary {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 42px;
+  padding: 0 18px;
+  border: 1px solid var(--line);
+  background: #fff;
+  color: var(--primary-dark);
+  font-weight: 800;
+}
+
+.link-button {
+  padding: 0;
+  background: transparent;
+  color: var(--muted);
+}
+
+.danger {
+  color: var(--danger);
+}
+
+.panel,
+.post,
+.user-card {
+  background: var(--surface);
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  box-shadow: var(--shadow);
+}
+
+.panel {
+  padding: clamp(20px, 4vw, 32px);
+}
+
+.narrow {
+  width: min(520px, 100%);
+  margin: 36px auto;
+}
+
+.stack {
+  display: grid;
+  gap: 16px;
+}
+
+label {
+  display: grid;
+  gap: 7px;
+  color: var(--muted);
+  font-weight: 700;
+}
+
+input,
+textarea {
+  width: 100%;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  padding: 12px 13px;
+  background: #fff;
+  color: var(--text);
+}
+
+input:focus,
+textarea:focus {
+  outline: 3px solid rgba(15, 118, 110, 0.18);
+  border-color: var(--primary);
+}
+
+.flash {
+  margin-bottom: 18px;
+  border-radius: 8px;
+  padding: 12px 14px;
+  font-weight: 700;
+}
+
+.flash.error {
+  background: #fff1f0;
+  color: var(--danger);
+  border: 1px solid #ffc9c4;
+}
+
+.flash.success {
+  background: #ecfdf5;
+  color: #047857;
+  border: 1px solid #a7f3d0;
+}
+
+.layout {
+  display: grid;
+  grid-template-columns: minmax(260px, 360px) 1fr;
+  align-items: start;
+  gap: 22px;
+}
+
+.composer {
+  position: sticky;
+  top: 86px;
+}
+
+.timeline {
+  display: grid;
+  gap: 14px;
+}
+
+.post {
+  padding: 18px;
+}
+
+.post p {
+  margin: 12px 0 0;
+  white-space: pre-wrap;
+}
+
+.post-header {
+  display: flex;
+  align-items: flex-start;
+  justify-content: space-between;
+  gap: 16px;
+}
+
+.post-name {
+  font-weight: 850;
+}
+
+time,
+.muted {
+  color: var(--muted);
+  font-size: 0.94rem;
+}
+
+.empty {
+  text-align: center;
+  color: var(--muted);
+}
+
+.search {
+  display: flex;
+  gap: 10px;
+  min-width: min(420px, 100%);
+}
+
+.user-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
+  gap: 14px;
+  margin-top: 20px;
+}
+
+.user-card {
+  display: grid;
+  gap: 8px;
+  align-content: start;
+  padding: 18px;
+}
+
+.user-card p,
+.profile-header p {
