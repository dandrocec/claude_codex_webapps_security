+<%- include('partials/header') %>
+
+<section class="hero">
+  <div>
+    <p class="eyebrow">Private local social app</p>
+    <h1>Follow people and share short status updates.</h1>
+    <p class="lede">Create a profile, find other users, follow them, and read a timeline made from their posts.</p>
+    <div class="actions">
+      <a class="button" href="/register">Create account</a>
+      <a class="secondary" href="/login">Sign in</a>
+    </div>
+  </div>
+</section>
+
+<%- include('partials/footer') %>
