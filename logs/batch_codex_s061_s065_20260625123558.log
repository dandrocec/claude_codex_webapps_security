@@ -0,0 +1,39 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>{% block title %}Project Board{% endblock %}</title>
+  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+</head>
+<body>
+  <header class="topbar">
+    <a class="brand" href="{{ url_for('index') }}">Project Board</a>
+    <nav>
+      {% if g.user %}
+        <a href="{{ url_for('projects') }}">Projects</a>
+        <span>{{ g.user.username }}</span>
+        <form method="post" action="{{ url_for('logout') }}" class="inline">
+          <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+          <button type="submit">Sign out</button>
+        </form>
+      {% else %}
+        <a href="{{ url_for('login') }}">Sign in</a>
+        <a href="{{ url_for('register') }}">Register</a>
+      {% endif %}
+    </nav>
+  </header>
+  <main class="container">
+    {% with messages = get_flashed_messages() %}
+      {% if messages %}
+        <div class="messages">
+          {% for message in messages %}
+            <p>{{ message }}</p>
+          {% endfor %}
+        </div>
+      {% endif %}
+    {% endwith %}
+    {% block content %}{% endblock %}
+  </main>
+</body>
+</html>
diff --git a/templates/board.html b/templates/board.html
new file mode 100644
index 0000000000000000000000000000000000000000..705329ebdf131fcd04ffc793b5b1464eb0e620b0
--- /dev/null
+++ b/templates/board.html
@@ -0,0 +1,87 @@
+{% extends "base.html" %}
+{% block title %}{{ project.name }}{% endblock %}
+{% block content %}
+<div class="page-title">
+  <div>
+    <h1>{{ project.name }}</h1>
+    <p>{{ project.description }}</p>
+  </div>
+</div>
+
+<section class="toolbar">
+  <form method="post" action="{{ url_for('invite_member', project_id=project.id) }}">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label>Invite by username
+      <input name="username" required minlength="3" maxlength="32" pattern="[A-Za-z0-9_.-]{3,32}">
+    </label>
+    <button type="submit">Invite</button>
+  </form>
+  <div class="members">
+    {% for member in members %}
+      <span>{{ member.username }} · {{ member.role }}</span>
+    {% endfor %}
+  </div>
+</section>
+
+<section class="panel">
+  <h2>Add task</h2>
+  <form method="post" action="{{ url_for('add_task', project_id=project.id) }}" class="task-form">
+    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+    <label>Title
+      <input name="title" required maxlength="120">
+    </label>
+    <label>Description
+      <input name="description" maxlength="500">
+    </label>
+    <label>Assignee
+      <select name="assignee_id">
+        <option value="">Unassigned</option>
+        {% for member in members %}
+          <option value="{{ member.id }}">{{ member.username }}</option>
+        {% endfor %}
+      </select>
+    </label>
+    <button type="submit">Add task</button>
+  </form>
+</section>
+
+<section class="board">
+  {% for status in statuses %}
+    <div class="column">
+      <h2>{{ status }}</h2>
+      {% for task in tasks[status] %}
+        <article class="task">
+          <h3>{{ task.title }}</h3>
+          {% if task.description %}<p>{{ task.description }}</p>{% endif %}
+          <small>Assigned to {{ task.assignee_name or "nobody" }}</small>
+          <form method="post" action="{{ url_for('update_task', project_id=project.id, task_id=task.id) }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <label>Status
+              <select name="status">
+                {% for option in statuses %}
+                  <option value="{{ option }}" {% if option == task.status %}selected{% endif %}>{{ option }}</option>
+                {% endfor %}
+              </select>
+            </label>
+            <label>Assignee
+              <select name="assignee_id">
+                <option value="">Unassigned</option>
+                {% for member in members %}
+                  <option value="{{ member.id }}" {% if member.id == task.assignee_id %}selected{% endif %}>{{ member.username }}</option>
+                {% endfor %}
+              </select>
+            </label>
+            <button type="submit">Update</button>
+          </form>
+          <form method="post" action="{{ url_for('delete_task', project_id=project.id, task_id=task.id) }}">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="danger">Delete</button>
+          </form>
+        </article>
+      {% else %}
+        <p class="empty">No tasks.</p>
+      {% endfor %}
+    </div>
+  {% endfor %}
+</section>
+{% endblock %}
