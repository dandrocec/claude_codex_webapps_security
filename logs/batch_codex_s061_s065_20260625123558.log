diff --git a/views/partials/header.ejs b/views/partials/header.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..b0ef51b5567989c32b8003d3d310968054e198ba
--- /dev/null
+++ b/views/partials/header.ejs
@@ -0,0 +1,33 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title><%= title %> | StatusHub</title>
+  <link rel="stylesheet" href="/styles.css">
+</head>
+<body>
+  <header class="site-header">
+    <a class="brand" href="<%= currentUser ? '/feed' : '/' %>">StatusHub</a>
+    <nav class="nav">
+      <% if (currentUser) { %>
+        <a href="/feed">Feed</a>
+        <a href="/discover">Discover</a>
+        <a href="/users/<%= currentUser.username %>">Profile</a>
+        <a href="/profile/edit">Settings</a>
+        <form action="/logout" method="post">
+          <button class="link-button" type="submit">Sign out</button>
+        </form>
+      <% } else { %>
+        <a href="/login">Sign in</a>
+        <a class="button small" href="/register">Create account</a>
+      <% } %>
+    </nav>
+  </header>
+  <main class="container">
+    <% if (messages.error.length) { %>
+      <div class="flash error"><%= messages.error[0] %></div>
+    <% } %>
+    <% if (messages.success.length) { %>
+      <div class="flash success"><%= messages.success[0] %></div>
+    <% } %>
diff --git a/views/profile.ejs b/views/profile.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..be384a69f6761a677ff96cf112b89bcc37c4016f
--- /dev/null
+++ b/views/profile.ejs
@@ -0,0 +1,42 @@
+<%- include('partials/header') %>
+
+<section class="profile-header panel">
+  <div>
+    <h1><%= profile.display_name %></h1>
+    <p class="muted">@<%= profile.username %></p>
+    <% if (profile.location) { %><p><%= profile.location %></p><% } %>
+    <% if (profile.bio) { %><p><%= profile.bio %></p><% } %>
+    <p class="muted"><%= profile.posts_count %> posts · <%= profile.followers_count %> followers · <%= profile.following_count %> following</p>
+  </div>
+  <% if (currentUser && currentUser.id !== profile.id) { %>
+    <% if (profile.is_following) { %>
+      <form method="post" action="/users/<%= profile.username %>/follow?_method=DELETE">
+        <button class="secondary" type="submit">Unfollow</button>
+      </form>
+    <% } else { %>
+      <form method="post" action="/users/<%= profile.username %>/follow">
+        <button class="button" type="submit">Follow</button>
+      </form>
+    <% } %>
+  <% } %>
+</section>
+
+<section class="timeline">
+  <% posts.forEach((post) => { %>
+    <article class="post">
+      <div class="post-header">
+        <strong><%= post.display_name %></strong>
+        <time><%= post.created_label %></time>
+      </div>
+      <p><%= post.body %></p>
+    </article>
+  <% }) %>
+  <% if (!posts.length) { %>
+    <article class="empty panel">
+      <h2>No posts yet</h2>
+      <p>This profile has not posted any status updates.</p>
+    </article>
+  <% } %>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/register.ejs b/views/register.ejs
new file mode 100644
