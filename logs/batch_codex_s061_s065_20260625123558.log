diff --git a/views/course-content.ejs b/views/course-content.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..f9c43b378b3395a9eadfcb5b759eec204ad377e2
--- /dev/null
+++ b/views/course-content.ejs
@@ -0,0 +1,31 @@
+<%- include('partials/header') %>
+
+<section class="stack">
+  <div>
+    <h1 class="page-title"><%= course.title %></h1>
+    <p class="lead"><%= course.description %></p>
+    <p class="muted">Instructor: <%= course.instructor_name %></p>
+  </div>
+
+  <% if (lessons.length === 0) { %>
+    <div class="empty">This course has no lessons yet.</div>
+  <% } else { %>
+    <% lessons.forEach((lesson) => { %>
+      <article class="lesson">
+        <div class="row">
+          <h3><%= lesson.position %>. <%= lesson.title %></h3>
+          <% if (lesson.completed) { %>
+            <span class="badge">Complete</span>
+          <% } else { %>
+            <form action="/lessons/<%= lesson.id %>/complete" method="post">
+              <button type="submit">Mark complete</button>
+            </form>
+          <% } %>
+        </div>
+        <p class="lesson-content"><%= lesson.content %></p>
+      </article>
+    <% }) %>
+  <% } %>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/course-form.ejs b/views/course-form.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..afa90ab64b2ecf77dcb41a3242360632cbf9df48
--- /dev/null
+++ b/views/course-form.ejs
@@ -0,0 +1,20 @@
+<%- include('partials/header') %>
+
+<h1 class="page-title"><%= course.id ? 'Edit Course' : 'New Course' %></h1>
+<form class="form-panel" action="<%= action %>" method="post">
+  <label>
+    Title
+    <input name="title" value="<%= course.title || '' %>" required>
+  </label>
+  <label>
+    Description
+    <textarea name="description" required><%= course.description || '' %></textarea>
+  </label>
+  <label class="checkbox">
+    <input type="checkbox" name="published" <%= course.published ? 'checked' : '' %>>
+    Publish course
+  </label>
+  <button type="submit">Save course</button>
+</form>
+
+<%- include('partials/footer') %>
diff --git a/views/course-public.ejs b/views/course-public.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..5e540ba77c7a8d74e7b26444e3617db706b1ce52
--- /dev/null
+++ b/views/course-public.ejs
@@ -0,0 +1,13 @@
+<%- include('partials/header') %>
+
+<section class="panel">
+  <h1 class="page-title"><%= course.title %></h1>
+  <p class="lead"><%= course.description %></p>
+  <p class="muted">Instructor: <%= course.instructor_name %></p>
+  <p>Enrol to access lessons and track completion.</p>
+  <form action="/courses/<%= course.id %>/enrol" method="post">
+    <button type="submit">Enrol in course</button>
+  </form>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/courses.ejs b/views/courses.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..70fbff8c70b6d3a560152ccdf1ca900560a2621a
--- /dev/null
+++ b/views/courses.ejs
@@ -0,0 +1,24 @@
+<%- include('partials/header') %>
+
+<h1 class="page-title">Courses</h1>
+<p class="lead">Students can enrol in published courses. Lesson content stays hidden until enrolment.</p>
+
+<% if (courses.length === 0) { %>
+  <div class="empty">No published courses are available.</div>
+<% } else { %>
+  <div class="grid">
+    <% courses.forEach((course) => { %>
+      <article class="course-card">
+        <div>
+          <span class="badge"><%= course.lesson_count %> lessons</span>
+          <h3><%= course.title %></h3>
+          <p class="muted">By <%= course.instructor_name %></p>
+          <p><%= course.description %></p>
+        </div>
+        <a class="button secondary" href="/courses/<%= course.id %>">View</a>
+      </article>
+    <% }) %>
+  </div>
+<% } %>
+
+<%- include('partials/footer') %>
diff --git a/views/home.ejs b/views/home.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..7ec5fcfe2a0ed12cf5367272f14ba4014d172742
--- /dev/null
+++ b/views/home.ejs
@@ -0,0 +1,44 @@
+<%- include('partials/header') %>
+
+<section class="hero">
+  <div>
+    <h1>LearnDeck</h1>
+    <p class="lead">A focused e-learning workspace where instructors publish structured courses and enrolled students track lesson progress.</p>
+    <div class="actions">
+      <a class="button" href="/courses">Browse courses</a>
+      <% if (!user) { %>
+        <a class="button secondary" href="/register">Create account</a>
+      <% } %>
+    </div>
+  </div>
+  <div class="panel">
+    <h2>Role-based learning</h2>
+    <p class="muted">Instructor accounts create courses and lessons. Student accounts enrol before course content is revealed.</p>
+  </div>
+</section>
+
+<section class="stack">
+  <div class="row">
+    <h2>Published courses</h2>
+    <a href="/courses">View all</a>
+  </div>
+  <% if (featuredCourses.length === 0) { %>
+    <div class="empty">No published courses yet.</div>
+  <% } else { %>
+    <div class="grid">
+      <% featuredCourses.forEach((course) => { %>
+        <article class="course-card">
+          <div>
+            <span class="badge"><%= course.lesson_count %> lessons</span>
+            <h3><%= course.title %></h3>
+            <p class="muted">By <%= course.instructor_name %></p>
+            <p><%= course.description %></p>
+          </div>
+          <a class="button secondary" href="/courses/<%= course.id %>">Open course</a>
+        </article>
+      <% }) %>
+    </div>
+  <% } %>
+</section>
+
+<%- include('partials/footer') %>
diff --git a/views/instructor-course.ejs b/views/instructor-course.ejs
new file mode 100644
index 0000000000000000000000000000000000000000..3ac8045862384011d1f8c240ab8d4bbc65e0cc3a
--- /dev/null
+++ b/views/instructor-course.ejs
@@ -0,0 +1,46 @@
+<%- include('partials/header') %>
+
+<div class="row">
+  <div>
+    <h1 class="page-title"><%= course.title %></h1>
+    <p class="lead"><%= course.description %></p>
+    <span class="badge"><%= course.published ? 'Published' : 'Draft' %></span>
+  </div>
+  <a class="button secondary" href="/instructor/courses/<%= course.id %>/edit">Edit course</a>
+</div>
+
+<section class="panel">
+  <h2>Add lesson</h2>
+  <form action="/instructor/courses/<%= course.id %>/lessons" method="post">
+    <label>
+      Lesson title
+      <input name="title" required>
+    </label>
+    <label>
+      Content
+      <textarea name="content" required></textarea>
+    </label>
+    <button type="submit">Add lesson</button>
+  </form>
+</section>
+
+<section class="stack">
+  <h2>Lessons</h2>
+  <% if (lessons.length === 0) { %>
+    <div class="empty">No lessons have been added.</div>
+  <% } else { %>
+    <% lessons.forEach((lesson) => { %>
+      <article class="lesson">
+        <div class="row">
+          <h3><%= lesson.position %>. <%= lesson.title %></h3>
+          <form action="/instructor/lessons/<%= lesson.id %>/delete" method="post">
+            <button class="danger" type="submit">Delete</button>
+          </form>
+        </div>
+        <p class="lesson-content"><%= lesson.content %></p>
+      </article>
+    <% }) %>
+  <% } %>
+</section>
+
+<%- include('partials/footer') %>
