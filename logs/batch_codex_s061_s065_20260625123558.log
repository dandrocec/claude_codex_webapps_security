+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Not found - Q&A Board</title>
+    <link rel="stylesheet" href="/styles.css">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="/">Q&A Board</a>
+    </header>
+    <main class="shell">
+      <section class="panel">
+        <h1>Not found</h1>
+        <p class="muted">That page does not exist.</p>
+        <a href="/">Return to questions</a>
+      </section>
+    </main>
