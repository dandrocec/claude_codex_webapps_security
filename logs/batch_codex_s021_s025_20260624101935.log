+                  <th>Destination</th>
+                  <th>Test</th>
+                </tr>
+              </thead>
+              <tbody>${rows}</tbody>
+            </table>`
+          : `<div class="empty">No redirects have been registered yet.</div>`
+      }
+    </section>
+  </main>
+</body>
+</html>`;
+}
