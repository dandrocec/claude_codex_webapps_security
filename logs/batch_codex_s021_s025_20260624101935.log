+      border-radius: 6px;
+      background: #ffffff;
+    }
+
+    input:focus {
+      outline: 3px solid rgba(37, 99, 235, 0.22);
+      border-color: #2563eb;
+    }
+
+    button,
+    .button {
+      display: inline-flex;
+      align-items: center;
+      justify-content: center;
+      min-height: 42px;
+      padding: 10px 14px;
+      border: 0;
