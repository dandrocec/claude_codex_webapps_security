+            border-radius: 6px;
+            padding: 12px 14px;
+            font: inherit;
+        }
+
+        button,
+        .link-button {
+            border: 0;
+            border-radius: 6px;
+            background: var(--primary);
+            color: #ffffff;
+            font: inherit;
+            font-weight: 700;
+            padding: 12px 16px;
