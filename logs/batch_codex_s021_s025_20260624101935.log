diff --git a/static/styles.css b/static/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..9c800fa840d98332015bd497667f2c3e4437cf31
--- /dev/null
+++ b/static/styles.css
@@ -0,0 +1,225 @@
+:root {
+  color-scheme: light;
+  --bg: #f6f7f9;
+  --panel: #ffffff;
+  --text: #1d232a;
+  --muted: #5f6b7a;
+  --border: #d8dee6;
+  --accent: #116149;
+  --accent-strong: #0b4b38;
+  --danger: #9e2630;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: Arial, Helvetica, sans-serif;
+  line-height: 1.5;
+}
+
+a {
+  color: var(--accent);
+}
+
+.topbar {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 2rem);
+  background: var(--panel);
+  border-bottom: 1px solid var(--border);
+}
+
+.brand {
+  color: var(--text);
+  font-size: 1.15rem;
+  font-weight: 700;
+  text-decoration: none;
+}
+
+nav {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+}
+
+main {
+  width: min(960px, calc(100% - 2rem));
+  margin: 2rem auto;
+}
+
+.panel {
+  margin-bottom: 1.25rem;
+  padding: 1.5rem;
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+}
+
+.narrow {
+  max-width: 520px;
+  margin-left: auto;
+  margin-right: auto;
+}
+
+h1,
+h2 {
+  margin: 0 0 1rem;
+  line-height: 1.2;
+}
+
+p {
+  color: var(--muted);
+}
+
+form {
+  display: grid;
+  gap: 0.75rem;
+}
+
+.inline {
+  display: inline;
+}
+
+label {
+  font-weight: 700;
+}
+
+input,
+textarea {
+  width: 100%;
+  padding: 0.75rem;
+  color: var(--text);
+  background: #fff;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  font: inherit;
+}
+
+textarea,
+pre {
+  font-family: Consolas, "Liberation Mono", monospace;
+}
+
+button,
+.button {
+  display: inline-block;
+  width: fit-content;
+  padding: 0.7rem 1rem;
+  color: #fff;
+  background: var(--accent);
+  border: 0;
+  border-radius: 6px;
+  font: inherit;
+  font-weight: 700;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+button:hover,
+.button:hover {
+  background: var(--accent-strong);
+}
+
+.secondary {
+  color: var(--accent);
+  background: #e6f3ef;
+}
+
+.secondary:hover {
+  color: #fff;
+}
+
+.danger {
+  background: var(--danger);
+}
+
+.link-button {
+  padding: 0;
+  color: var(--accent);
+  background: transparent;
+  font-weight: 400;
+}
+
+.link-button:hover {
+  color: var(--accent-strong);
+  background: transparent;
+}
+
+.actions {
+  display: flex;
+  gap: 0.75rem;
+  flex-wrap: wrap;
+}
+
+.messages {
+  margin-bottom: 1rem;
+}
+
+.message {
+  padding: 0.75rem 1rem;
+  background: #fff7df;
+  border: 1px solid #edd486;
+  border-radius: 6px;
+}
+
+.message.success {
+  background: #e8f7ee;
+  border-color: #9ed4b2;
+}
+
+.paste-list {
+  padding: 0;
+  list-style: none;
+}
+
+.paste-list li {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 0.75rem 0;
+  border-bottom: 1px solid var(--border);
+}
+
+time,
+.user {
+  color: var(--muted);
+}
+
+.paste-header {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  align-items: flex-start;
+}
+
+pre {
+  min-height: 16rem;
+  margin: 1rem 0 0;
+  padding: 1rem;
+  overflow: auto;
+  white-space: pre-wrap;
+  word-break: break-word;
+  background: #f0f3f6;
+  border: 1px solid var(--border);
+  border-radius: 6px;
+}
+
+@media (max-width: 640px) {
+  .topbar,
+  .paste-header,
+  .paste-list li {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  nav {
+    flex-wrap: wrap;
+  }
+}
diff --git a/templates/base.html b/templates/base.html
new file mode 100644
index 0000000000000000000000000000000000000000..3195e96a1d84a60454ad667e12364d134e6994d1
--- /dev/null
+++ b/templates/base.html
@@ -0,0 +1,38 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}Secure Pastebin{% endblock %}</title>
+    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
+  </head>
+  <body>
+    <header class="topbar">
+      <a class="brand" href="{{ url_for('index') }}">Secure Pastebin</a>
+      <nav>
+        {% if g.user %}
+          <span class="user">{{ g.user["username"] }}</span>
+          <form method="post" action="{{ url_for('logout') }}" class="inline">
+            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+            <button type="submit" class="link-button">Log out</button>
+          </form>
+        {% else %}
+          <a href="{{ url_for('login') }}">Log in</a>
+          <a href="{{ url_for('register') }}">Register</a>
+        {% endif %}
+      </nav>
+    </header>
+    <main>
+      {% with messages = get_flashed_messages(with_categories=true) %}
+        {% if messages %}
+          <div class="messages">
+            {% for category, message in messages %}
+              <p class="message {{ category }}">{{ message }}</p>
+            {% endfor %}
+          </div>
+        {% endif %}
+      {% endwith %}
+      {% block content %}{% endblock %}
+    </main>
+  </body>
+</html>
diff --git a/templates/dashboard.html b/templates/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..4030427a8203abae53183bba0a713dce954217ed
--- /dev/null
+++ b/templates/dashboard.html
@@ -0,0 +1,29 @@
+{% extends "base.html" %}
+{% block title %}New paste{% endblock %}
+{% block content %}
+  <section class="panel">
+    <h1>New paste</h1>
+    <form method="post" action="{{ url_for('create_paste') }}">
+      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
+      <label for="body">Text</label>
+      <textarea id="body" name="body" maxlength="20000" required rows="14"></textarea>
+      <button type="submit">Create unique URL</button>
+    </form>
+  </section>
+
+  <section class="panel">
+    <h2>Your recent pastes</h2>
+    {% if pastes %}
+      <ul class="paste-list">
+        {% for paste in pastes %}
+          <li>
+            <a href="{{ url_for('view_paste', token=paste['token']) }}">{{ paste["preview"] or "Untitled paste" }}</a>
+            <time>{{ paste["created_at"] }}</time>
+          </li>
+        {% endfor %}
+      </ul>
+    {% else %}
+      <p>No pastes yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
