+  "name": "redirect-registry",
+  "version": "1.0.0",
+  "description": "A small Express app for registering named redirects.",
+  "main": "server.js",
+  "scripts": {
+    "start": "node server.js"
+  },
+  "dependencies": {
+    "express": "^4.19.2"
+  },
+  "engines": {
+    "node": ">=18"
+  }
+}
