+:root {
+    color-scheme: light;
+    --background: #f6f8fb;
+    --panel: #ffffff;
+    --text: #152033;
+    --muted: #58677d;
+    --border: #d9e0ea;
+    --accent: #166b62;
+    --accent-dark: #0d5049;
+    --danger-bg: #fff0f0;
+    --danger: #9d1c1c;
+    --success-bg: #ebf8f1;
+    --success: #17613d;
+}
+
+* {
+    box-sizing: border-box;
+}
+
+body {
+    margin: 0;
+    background: var(--background);
+    color: var(--text);
+    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+    line-height: 1.5;
+}
+
+.page {
+    min-height: 100vh;
+    display: grid;
+    place-items: center;
+    padding: 32px 16px;
+}
+
+.page.wide {
+    align-items: start;
+}
+
+.panel {
+    width: min(100%, 520px);
+    background: var(--panel);
+    border: 1px solid var(--border);
+    border-radius: 8px;
+    padding: 28px;
+    box-shadow: 0 18px 45px rgba(21, 32, 51, 0.08);
+}
+
+.wide .panel {
+    width: min(100%, 900px);
+}
+
+h1 {
+    margin: 0 0 8px;
+    font-size: 1.75rem;
+    line-height: 1.2;
+}
+
+.lede {
+    margin: 0 0 24px;
+    color: var(--muted);
+}
+
+form {
+    display: grid;
+    gap: 10px;
+}
+
+label {
+    font-weight: 700;
+}
+
+input {
+    width: 100%;
+    min-height: 44px;
+    border: 1px solid var(--border);
+    border-radius: 6px;
+    padding: 10px 12px;
+    color: var(--text);
+    font: inherit;
+}
+
+input:focus {
+    border-color: var(--accent);
+    outline: 3px solid rgba(22, 107, 98, 0.18);
+}
+
+button {
+    min-height: 44px;
+    border: 0;
+    border-radius: 6px;
+    padding: 10px 16px;
+    background: var(--accent);
+    color: #ffffff;
+    cursor: pointer;
+    font: inherit;
+    font-weight: 700;
+}
+
+button:hover,
+button:focus {
+    background: var(--accent-dark);
+}
+
+.notice {
+    border-radius: 6px;
+    margin: 0 0 18px;
+    padding: 12px 14px;
+}
+
+.notice p {
+    margin: 0;
+}
+
+.notice.error {
+    background: var(--danger-bg);
+    color: var(--danger);
+}
+
+.notice.success {
+    background: var(--success-bg);
+    color: var(--success);
+}
+
+.admin-link {
+    margin: 20px 0 0;
+}
+
+a {
+    color: var(--accent-dark);
+}
+
+.topbar {
+    display: flex;
+    gap: 16px;
+    justify-content: space-between;
+    align-items: start;
+    margin-bottom: 18px;
+}
+
+.inline-form {
+    display: block;
+}
+
+.table-wrap {
+    overflow-x: auto;
+}
+
+table {
+    width: 100%;
+    border-collapse: collapse;
+}
+
+th,
+td {
+    border-bottom: 1px solid var(--border);
+    padding: 12px 10px;
+    text-align: left;
+}
+
+th {
+    color: var(--muted);
+    font-size: 0.9rem;
+}
+
+@media (max-width: 640px) {
+    .panel {
+        padding: 22px;
+    }
+
+    .topbar {
+        display: grid;
+    }
+}
