# Copy to ".env" and adjust as needed. The app also reads these from the real
# process environment; .env is just a convenience for local development.
# (.env is git-ignored — never commit real secrets.)

# Force the Secure flag on the session cookie. Leave unset for plain-HTTP
# localhost (otherwise the browser won't send the cookie and sessions break).
# Set to 1 in production where the app is served over HTTPS.
#COOKIE_SECURE=0

# Session cookie name.
#SESSION_NAME=CONTACTSESSID

# Absolute path to the submissions file. Defaults to ./data/submissions.jsonl
#DATA_FILE=/var/lib/contact-app/submissions.jsonl
