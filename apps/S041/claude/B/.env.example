# Copy this file to ".env" and fill in real values. NEVER commit your real .env.

# Port the server listens on.
PORT=5041

# Node environment. Use "production" when deploying behind HTTPS.
NODE_ENV=development

# Secret used to sign the session cookie. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Set to "true" ONLY when the app is served over HTTPS (sets the Secure cookie flag).
# Leave "false" for local plain-HTTP development on http://localhost.
COOKIE_SECURE=false

# Seed editor account. On first run, if no users exist, this account is created.
# Choose a strong password. If SEED_ADMIN_PASSWORD is omitted, a random one is
# generated and printed to the console exactly once at startup.
SEED_ADMIN_USERNAME=editor
SEED_ADMIN_PASSWORD=

# Path to the SQLite database file (created automatically if missing).
DATABASE_FILE=./data/faq.db
