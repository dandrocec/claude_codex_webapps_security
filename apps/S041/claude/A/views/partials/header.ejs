<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'FAQ' %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">❓ FAQ</a>
    <nav>
      <% if (currentUser) { %>
        <a href="/admin">Admin</a>
        <span class="who">Signed in as <strong><%= currentUser %></strong></span>
        <form action="/logout" method="post" class="inline">
          <button type="submit" class="link-btn">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Editor login</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
