# Copy this file to ".env" and adjust as needed.

# Port the server listens on.
PORT=5041

# Secret used to sign session cookies. Change this to a long random string.
SESSION_SECRET=please-change-me-to-a-long-random-string

# Editor account seeded on first run (only created if it doesn't exist yet).
EDITOR_USERNAME=editor
EDITOR_PASSWORD=changeme
