# Copy to .env (or export these in your shell) before running in production.
# NEVER commit real secrets.

# Signs the session cookie. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
# If unset, an ephemeral secret is generated on startup (sessions drop on restart).
SESSION_SECRET=

# Database (SQLAlchemy URL). Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./idp.db

# Public issuer URL used in tokens / discovery document.
ISSUER=http://localhost:5099

# Send the session cookie only over HTTPS. Set to "true" in production (behind TLS).
# Left false for local http://localhost development so login works without TLS.
COOKIE_SECURE=false

# Token lifetimes (seconds).
ACCESS_TOKEN_TTL=3600
ID_TOKEN_TTL=3600
AUTH_CODE_TTL=300

# RSA signing key. If PRIVATE_KEY_PEM is unset, a key is loaded from KEYS_DIR/private.pem
# (generated automatically on first run).
PRIVATE_KEY_PEM=
KEYS_DIR=./keys

# Optional: seed an initial admin user on startup (skipped if already present).
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@example.com
