# Copy to .env (or export these in your shell) before running in anything
# other than a throwaway local session.

# Required in production. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Port the app listens on.
PORT=5017

# Set to "false" ONLY for local plain-HTTP testing. A Secure cookie is not sent
# over http://, which would break CSRF locally. Keep "true" behind HTTPS.
SESSION_COOKIE_SECURE=true
