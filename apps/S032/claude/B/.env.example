# Copy this file to ".env" and adjust the values before running.

# Port the server listens on.
PORT=5032

# Secret used to sign the session ID cookie.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Set to "production" when deploying behind HTTPS so the Secure cookie flag is enforced.
# Leave as "development" for local plain-HTTP testing.
NODE_ENV=development
