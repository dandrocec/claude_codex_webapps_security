<%- include('partials/header') %>

<div class="card narrow">
  <h1>Edit expense</h1>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <form action="/expenses/<%= expense.id %>" method="post" class="expense-form">
    <label>Amount
      <input type="number" name="amount" step="0.01" min="0.01"
             value="<%= expense.amount %>" required />
    </label>
    <label>Category
      <input type="text" name="category" value="<%= expense.category %>" required />
    </label>
    <label>Date
      <input type="date" name="spent_on" value="<%= expense.spent_on %>" required />
    </label>
    <label>Note
      <input type="text" name="note" value="<%= expense.note %>" placeholder="optional" />
    </label>
    <div class="row">
      <button type="submit" class="primary">Save</button>
      <a class="link-btn" href="/expenses">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
