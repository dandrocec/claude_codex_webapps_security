<%- include('partials/header') %>

<div class="grid">
  <section class="card">
    <h2>Add expense</h2>
    <% if (error) { %><p class="error"><%= error %></p><% } %>
    <form action="/expenses" method="post" class="expense-form">
      <label>Amount
        <input type="number" name="amount" step="0.01" min="0.01"
               value="<%= form.amount || '' %>" required />
      </label>
      <label>Category
        <input type="text" name="category" list="categories"
               value="<%= form.category || '' %>" placeholder="e.g. Groceries" required />
        <datalist id="categories">
          <option value="Groceries"></option>
          <option value="Rent"></option>
          <option value="Transport"></option>
          <option value="Dining"></option>
          <option value="Utilities"></option>
          <option value="Entertainment"></option>
          <option value="Health"></option>
          <option value="Other"></option>
        </datalist>
      </label>
      <label>Date
        <input type="date" name="spent_on" value="<%= form.spent_on || '' %>" required />
      </label>
      <label>Note
        <input type="text" name="note" value="<%= form.note || '' %>" placeholder="optional" />
      </label>
      <button type="submit" class="primary">Add</button>
    </form>
  </section>

  <section class="card">
    <div class="month-header">
      <h2>Expenses</h2>
      <form method="get" action="/expenses" class="inline">
        <input type="month" name="month" value="<%= month %>" onchange="this.form.submit()" />
      </form>
    </div>

    <div class="total">
      Monthly total: <strong>$<%= total.toFixed(2) %></strong>
    </div>

    <% if (expenses.length === 0) { %>
      <p class="muted">No expenses recorded for this month yet.</p>
    <% } else { %>
      <table class="expenses">
        <thead>
          <tr>
            <th>Date</th><th>Category</th><th>Note</th>
            <th class="right">Amount</th><th></th>
          </tr>
        </thead>
        <tbody>
          <% expenses.forEach(function (e) { %>
            <tr>
              <td><%= e.spent_on %></td>
              <td><span class="tag"><%= e.category %></span></td>
              <td class="note"><%= e.note %></td>
              <td class="right">$<%= e.amount.toFixed(2) %></td>
              <td class="actions">
                <a class="link-btn" href="/expenses/<%= e.id %>/edit">Edit</a>
                <form action="/expenses/<%= e.id %>/delete" method="post" class="inline"
                      onsubmit="return confirm('Delete this expense?');">
                  <button type="submit" class="link-btn danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>
