<%- include('../partials/header') %>

<section class="auth-panel wide-panel">
  <h1>Edit expense</h1>
  <% if (errors.length) { %>
    <div class="alert error">
      <% errors.forEach((error) => { %><p><%= error %></p><% }) %>
    </div>
  <% } %>
  <form method="post" action="/expenses/<%= expense.id %>/edit" class="expense-form">
    <label>
      Amount
      <input name="amount" type="number" min="0.01" step="0.01" value="<%= expense.amount %>" required>
    </label>
    <label>
      Category
      <input name="category" value="<%= expense.category %>" required>
    </label>
    <label>
      Date
      <input name="expenseDate" type="date" value="<%= expense.expense_date || expense.expenseDate %>" required>
    </label>
    <label class="wide">
      Note
      <textarea name="note" rows="4"><%= expense.note || '' %></textarea>
    </label>
    <button type="submit">Save changes</button>
    <a class="button-secondary" href="/expenses?month=<%= (expense.expense_date || expense.expenseDate).slice(0, 7) %>">Cancel</a>
  </form>
</section>

<%- include('../partials/footer') %>
