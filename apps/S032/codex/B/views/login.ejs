<%- include("partials/header", { title: "Log in", user, csrfToken }) %>
  <section class="auth-panel">
    <h1>Log in</h1>
    <%- include("partials/errors", { errors }) %>
    <form method="post" action="/login" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        Email
        <input name="email" type="email" maxlength="254" required autocomplete="email" value="<%= values.email || "" %>">
      </label>
      <label>
        Password
        <input name="password" type="password" maxlength="128" required autocomplete="current-password">
      </label>
      <button type="submit">Log in</button>
    </form>
    <p class="muted">Need an account? <a href="/register">Register</a></p>
  </section>
<%- include("partials/footer") %>
