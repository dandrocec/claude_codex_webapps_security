# Copy to .env (or export these in your shell) before running in production.

# Required in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "false" ONLY for local HTTP testing. Leave unset/true behind HTTPS so
# the session cookie carries the Secure flag.
SECURE_COOKIES=true

# Optional: override the SQLite database file location.
# LEDGER_DB=/absolute/path/to/ledger.db
