{
    "name": "demo/base64-tool",
    "description": "A small, security-hardened PHP web tool to Base64-encode and decode text.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5021 -t public"
    },
    "config": {
        "sort-packages": true
    }
}
