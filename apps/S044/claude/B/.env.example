# Copy to .env (or export these in your shell) before running in production.

# Flask session signing key. REQUIRED in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin account, created on first run if it does not already exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-passphrase

# Set to true ONLY when serving over HTTPS (adds Secure cookie + HSTS).
# Leave false for local plain-HTTP testing or the session cookie won't be sent.
COOKIE_SECURE=false

# Optional outbound-fetch tuning (defaults shown).
# FETCH_CONNECT_TIMEOUT=5
# FETCH_READ_TIMEOUT=5
# FETCH_MAX_BYTES=524288
# FETCH_MAX_REDIRECTS=3

# Optional: override the SQLite location.
# DATABASE_PATH=contact.db
