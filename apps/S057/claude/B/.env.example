# Copy to ".env" and adjust. Never commit your real .env file.

# Secret used to sign session cookies and CSRF tokens.
# Generate a strong value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 only when the app is served over HTTPS so the session cookie
# gets the Secure flag. Leave 0 for local plain-HTTP development.
SESSION_COOKIE_SECURE=0

# Port the app listens on.
PORT=5057

# Optional: override the SQLite database file location.
# DATABASE_PATH=shop.db
