# Copy to .env (or export these in your shell) before running.

# Required in production: a long random secret for signing session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Initial editor account, created on first run if no users exist.
# If ADMIN_PASSWORD is left blank, a random password is generated and printed
# once to the server console.
ADMIN_USERNAME=editor
ADMIN_PASSWORD=

# Set to 0 ONLY for plain-HTTP local testing. Leave unset/1 in production so
# the session cookie is sent over HTTPS only.
SESSION_COOKIE_SECURE=0

# Optional overrides
# PORT=5049
# DATABASE_PATH=newsletter.db
