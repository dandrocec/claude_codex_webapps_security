<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sign in</title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <main class="shell">
      <section class="panel">
        <p class="eyebrow">OAuth profile demo</p>
        <h1>Sign in with GitHub</h1>
        <p class="lede">
          Connect your GitHub account to store a local profile and view account data fetched through the GitHub API.
        </p>

        <% if (missingConfig) { %>
          <div class="notice">
            Add <code>GITHUB_CLIENT_ID</code> and <code>GITHUB_CLIENT_SECRET</code> to your <code>.env</code> file before signing in.
          </div>
        <% } %>

        <a class="button" href="/auth/github">Continue with GitHub</a>
      </section>
    </main>
  </body>
</html>
