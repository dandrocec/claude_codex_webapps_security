# Copy this file to ".env" and fill in the values from your GitHub OAuth App.
#
# Register an OAuth App at: https://github.com/settings/developers
#   - Application name:        anything (e.g. "Local OAuth Demo")
#   - Homepage URL:            http://localhost:5090
#   - Authorization callback:  http://localhost:5090/auth/github/callback

GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Secret used to sign the session cookie. Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Port the app listens on.
PORT=5090

# Base URL of this app (used to build the OAuth callback URL).
BASE_URL=http://localhost:5090
