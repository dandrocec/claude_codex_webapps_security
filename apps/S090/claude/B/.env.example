# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values. NEVER commit your real .env.
# ---------------------------------------------------------------------------

# App
PORT=5090
NODE_ENV=development

# Set to "true" only when the app is served over HTTPS (e.g. behind a TLS proxy).
# When true, session cookies get the Secure flag. Leave false for plain http://localhost.
COOKIE_SECURE=false

# GitHub OAuth application credentials.
# Create one at: https://github.com/settings/developers  ->  "New OAuth App"
#   Homepage URL:               http://localhost:5090
#   Authorization callback URL: http://localhost:5090/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
OAUTH_CALLBACK_URL=http://localhost:5090/auth/github/callback

# Secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_a_long_random_value

# 32-byte (64 hex chars) key used to encrypt provider access tokens at rest (AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_me_with_64_hex_characters
