# Copy to .env (or export these in your shell) before running.
# Generate a strong key, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-value

# Set to false ONLY for local plain-HTTP testing, so the session cookie is
# sent over http://. Leave unset / true in any real deployment (HTTPS).
SECURE_COOKIES=false

# Port the app listens on.
PORT=5023
