# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Secret used to sign the session cookie. Use a long, random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Port the server listens on.
PORT=5015

# Set to "true" only when serving over HTTPS (e.g. behind a TLS-terminating proxy).
# When true, session cookies are marked Secure and will NOT be sent over plain HTTP.
COOKIE_SECURE=false

# Node environment: "development" or "production".
# In production, internal errors and stack traces are never sent to clients.
NODE_ENV=development
