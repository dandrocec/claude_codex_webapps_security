# Copy this file to ".env" and adjust as needed.
# Never commit your real .env file. Do not hardcode secrets in source.

# Application environment: "production" or "development".
# In production, internal errors are never shown to clients.
APP_ENV=development

# Absolute or relative path (from project root) to the SQLite database file.
DB_PATH=storage/database.sqlite

# Directory (from project root) where uploaded images are stored.
# This MUST be outside the public/ web root so files are never executed.
UPLOAD_DIR=storage/uploads

# Maximum accepted upload size in bytes (default 5 MiB).
MAX_UPLOAD_BYTES=5242880

# Force the "Secure" flag on session cookies (1) or auto-detect from HTTPS (0).
# Leave 0 for local HTTP on port 5050; set 1 when serving over HTTPS.
SESSION_SECURE=0
