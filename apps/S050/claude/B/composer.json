{
    "name": "example/photoblog",
    "description": "A small, security-hardened PHP photo blog (image + caption posts, public feed).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*"
    },
    "autoload": {
        "files": [
            "src/config.php",
            "src/db.php",
            "src/helpers.php"
        ]
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5050 -t public public/index.php"
    }
}
