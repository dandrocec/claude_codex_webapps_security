# Copy this file to ".env" and adjust the values before running.
# Never commit your real .env file.

# Port the server listens on
PORT=5080

# Set to "production" when deploying behind HTTPS so that the
# session cookie is sent with the Secure flag.
NODE_ENV=development

# Session signing secret. Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-please

# Location of the SQLite database file (created automatically).
DB_PATH=./data/warehouse.db

# Credentials used ONLY when seeding the initial demo accounts.
# Change these before running `npm run seed`.
SEED_MANAGER_USERNAME=manager
SEED_MANAGER_PASSWORD=ManagerPass123!
SEED_CLERK_USERNAME=clerk
SEED_CLERK_PASSWORD=ClerkPass123!
