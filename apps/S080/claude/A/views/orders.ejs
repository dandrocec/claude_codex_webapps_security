<%- include('partials/header') %>

<div class="row-between">
  <h1>Orders</h1>
  <a class="button" href="/orders/new">+ Process order</a>
</div>

<table>
  <thead>
    <tr>
      <th>#</th>
      <th>Customer</th>
      <th>Status</th>
      <th>Processed by</th>
      <th>Date</th>
    </tr>
  </thead>
  <tbody>
    <% orders.forEach(function (o) { %>
      <tr>
        <td><a href="/orders/<%= o.id %>">#<%= o.id %></a></td>
        <td><%= o.customer %></td>
        <td><span class="badge ok"><%= o.status %></span></td>
        <td><%= o.created_by %></td>
        <td><%= o.created_at %></td>
      </tr>
    <% }); %>
    <% if (orders.length === 0) { %>
      <tr><td colspan="5" class="empty">No orders yet.</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('partials/footer') %>
