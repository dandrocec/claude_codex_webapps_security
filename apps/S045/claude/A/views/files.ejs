<%- include('partials/header') %>

<div class="card">
  <h2 style="margin-top:0">Upload a file</h2>
  <form method="post" action="/upload" enctype="multipart/form-data">
    <input type="file" name="file" required />
    <p><button type="submit">Upload</button></p>
  </form>
  <p class="muted">Max 50 MB per file.</p>
</div>

<h2>Your files</h2>
<% if (files.length === 0) { %>
  <p class="muted">You haven't uploaded anything yet.</p>
<% } else { %>
  <table>
    <thead>
      <tr><th>Name</th><th>Size</th><th>Uploaded</th><th></th></tr>
    </thead>
    <tbody>
      <% files.forEach(function (f) { %>
        <tr>
          <td><a href="/download/<%= f.id %>"><%= f.original_name %></a></td>
          <td><%= f.size_human %></td>
          <td class="muted"><%= f.created_at %> UTC</td>
          <td>
            <form class="inline" method="post" action="/delete/<%= f.id %>"
                  onsubmit="return confirm('Delete this file?');">
              <button class="danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<%- include('partials/footer') %>
