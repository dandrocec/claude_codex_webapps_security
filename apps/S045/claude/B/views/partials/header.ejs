<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Secure File Share</title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/files">Secure File Share</a>
      <nav>
        <% var _user = (typeof currentUser !== 'undefined') ? currentUser : null; %>
        <% var _csrf = (typeof csrfToken !== 'undefined') ? csrfToken : ''; %>
        <% if (_user) { %>
          <span class="who">Signed in as <strong><%= _user.username %></strong></span>
          <form class="inline" method="post" action="/logout">
            <input type="hidden" name="_csrf" value="<%= _csrf %>" />
            <button type="submit" class="link">Sign out</button>
          </form>
        <% } else { %>
          <a href="/login">Sign in</a>
          <a href="/register">Create account</a>
        <% } %>
      </nav>
    </header>
    <main class="container">
