<%- include('partials/header') %>

<% if (flash) { %>
  <p class="alert <%= flash.type === 'success' ? 'success' : 'error' %>"><%= flash.message %></p>
<% } %>

<section class="card">
  <h1>Upload a file</h1>
  <p class="muted">Allowed: <%= allowed %>. Maximum size: <%= maxSize %>.</p>
  <form method="post" action="/files?_csrf=<%= encodeURIComponent(csrfToken) %>"
        enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="file" name="file" required />
    <button type="submit" class="primary">Upload</button>
  </form>
</section>

<section class="card">
  <h1>My files</h1>
  <% if (files.length === 0) { %>
    <p class="muted">You haven't uploaded anything yet.</p>
  <% } else { %>
    <table class="files">
      <thead>
        <tr><th>Name</th><th>Type</th><th>Size</th><th>Uploaded</th><th></th></tr>
      </thead>
      <tbody>
        <% files.forEach(function (f) { %>
          <tr>
            <td class="name"><%= f.original_name %></td>
            <td><%= f.mime_type %></td>
            <td><%= f.size_human %></td>
            <td><%= f.created_at %></td>
            <td class="actions">
              <a class="button" href="/files/<%= f.id %>/download">Download</a>
              <form class="inline" method="post" action="/files/<%= f.id %>/delete">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/footer') %>
