# Copy this file to ".env" and adjust the values.
# NEVER commit your real .env file.

# Port the server listens on.
PORT=5045

# Secret used to sign the session cookie.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED in production. In development a random ephemeral secret is generated
# if this is left unset (sessions then reset on every restart).
SESSION_SECRET=

# "development" or "production".
# In production the session cookie is marked Secure (requires HTTPS).
NODE_ENV=development

# Maximum accepted upload size, in bytes (default: 10 MiB).
MAX_UPLOAD_BYTES=10485760

# Directory for the SQLite database file and uploaded blobs.
# Created automatically if it does not exist. Keep it OUTSIDE any
# directory that is served as static/executable content.
DATA_DIR=./data
