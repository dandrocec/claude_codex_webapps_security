{
    "name": "example/realestate",
    "description": "Secure PHP real-estate listings site (agents post properties, visitors search and contact).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-fileinfo": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5066 -t public public/index.php"
    }
}
