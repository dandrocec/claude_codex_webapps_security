# Copy this file to ".env" and adjust values. Never commit your real .env.
# All application secrets/config are read from the environment (see src/Config.php).

# Environment: "local" (HTTP, dev) or "production" (HTTPS required)
APP_ENV=local

# Show detailed errors on screen? Keep "false" in any shared/production environment.
APP_DEBUG=false

# 32+ byte random string. Generate one with:  php -r "echo bin2hex(random_bytes(32));"
# Used as an optional password "pepper" and for misc keyed hashing.
APP_KEY=change-me-to-a-long-random-value

# Force the "Secure" flag on session cookies. Leave empty to auto-detect:
#   - auto: Secure is ON when the request is HTTPS, OFF on plain-HTTP localhost.
# Set to "true" to force it on (recommended in production behind HTTPS).
SESSION_SECURE=

# Absolute or project-relative paths. Defaults are fine for local use.
# The SQLite database file (created automatically on first run).
DB_PATH=storage/app.sqlite

# Directory where uploaded photos are stored. MUST be OUTSIDE the public/ web root.
UPLOAD_DIR=storage/uploads

# Max upload size per photo, in bytes (default 5 MiB).
MAX_UPLOAD_BYTES=5242880
