# Copy this file to ".env" and adjust. NEVER commit your real .env.

# Mandatory in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Where the SQLite file lives (optional; defaults to ./blog.db)
# DATABASE_PATH=./blog.db

# Secure cookies require HTTPS. Local testing runs on plain HTTP, so set this
# to False locally; keep it True (or unset) behind HTTPS in production.
SESSION_COOKIE_SECURE=False
