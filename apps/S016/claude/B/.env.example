# Copy this file to ".env" and adjust as needed. Never commit your real .env.

# "production" hides internal errors from clients; "development" shows them.
APP_ENV=development

# Application secret. REQUIRED in production. Generate a fresh value with:
#   php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_SECRET=

# Force the Secure cookie flag on/off. Leave unset to auto-detect HTTPS.
# Keep it unset (or false) for plain-HTTP local development on port 5016.
# COOKIE_SECURE=false

# Optional: override where the vote tally is stored.
# STORAGE_FILE=/absolute/path/to/votes.json
