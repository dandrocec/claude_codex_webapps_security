{
    "name": "example/php-poll",
    "description": "A small, security-hardened single-question poll application in plain PHP.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-json": "*"
    },
    "autoload": {
