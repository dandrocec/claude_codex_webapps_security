# Copy this file to ".env" and adjust the values.
# NEVER commit your real .env file.

# Port the server listens on
PORT=5067

# Secret used to sign the session cookie. Use a long, random value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value

# Set to "production" when deploying behind HTTPS so the Secure cookie flag is enforced.
NODE_ENV=development

# Set to "true" to force Secure cookies even in development (only works over HTTPS).
COOKIE_SECURE=false

# Credentials for the seeded staff account (created on first run if it does not exist).
STAFF_USERNAME=staff
STAFF_PASSWORD=ChangeMe!Staff123
