<%- include('partials/header') %>

<h1>Incoming orders</h1>

<nav class="filters">
  <a href="/staff/orders" class="<%= filter ? '' : 'active' %>">All</a>
  <% statuses.forEach(function (s) { %>
    <a href="/staff/orders?status=<%= s %>" class="<%= filter === s ? 'active' : '' %>"><%= s %></a>
  <% }); %>
</nav>

<% if (orders.length === 0) { %>
  <p>No orders<%= filter ? ' with status "' + filter + '"' : '' %>.</p>
<% } else { %>
  <table class="table">
    <thead>
      <tr><th>Order</th><th>Customer</th><th>Placed</th><th>Status</th><th>Total</th><th></th></tr>
    </thead>
    <tbody>
      <% orders.forEach(function (o) { %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.username %></td>
          <td><%= o.created_at %></td>
          <td><span class="badge status-<%= o.status %>"><%= o.status %></span></td>
          <td><%= formatPrice(o.total_cents) %></td>
          <td><a href="/staff/orders/<%= o.id %>">Manage</a></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<%- include('partials/footer') %>
