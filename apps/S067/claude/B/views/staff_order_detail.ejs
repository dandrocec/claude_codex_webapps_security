<%- include('partials/header') %>

<h1>Order #<%= order.id %></h1>
<p>Customer: <%= order.username %></p>
<p>Placed: <%= order.created_at %></p>
<p>Current status: <span class="badge status-<%= order.status %>"><%= order.status %></span></p>

<table class="table">
  <thead><tr><th>Item</th><th>Unit</th><th>Qty</th><th>Line total</th></tr></thead>
  <tbody>
    <% items.forEach(function (it) { %>
      <tr>
        <td><%= it.name %></td>
        <td><%= formatPrice(it.unit_price_cents) %></td>
        <td><%= it.quantity %></td>
        <td><%= formatPrice(it.unit_price_cents * it.quantity) %></td>
      </tr>
    <% }); %>
  </tbody>
  <tfoot>
    <tr><th colspan="3">Total</th><th><%= formatPrice(order.total_cents) %></th></tr>
  </tfoot>
</table>

<form method="post" action="/staff/orders/<%= order.id %>/status" class="stack">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Update status
    <select name="status">
      <% statuses.forEach(function (s) { %>
        <option value="<%= s %>" <%= s === order.status ? 'selected' : '' %>><%= s %></option>
      <% }); %>
    </select>
  </label>
  <button type="submit" class="primary">Save status</button>
</form>

<p><a href="/staff/orders">← Back to queue</a></p>

<%- include('partials/footer') %>
