<%- include('partials/header') %>

<section class="section-head">
  <h1>Incoming Orders</h1>
</section>

<% if (orders.length === 0) { %>
  <p class="notice">No incoming orders.</p>
<% } else { %>
  <table>
    <thead><tr><th>Order</th><th>Customer</th><th>Status</th><th>Total</th><th>Placed</th><th>Update</th></tr></thead>
    <tbody>
      <% orders.forEach((order) => { %>
        <tr>
          <td><a href="/staff/orders/<%= order.id %>">#<%= order.id %></a></td>
          <td><%= order.email %></td>
          <td><span class="status"><%= order.status %></span></td>
          <td><%= money(order.total_cents) %></td>
          <td><%= order.created_at %></td>
          <td>
            <form method="post" action="/staff/orders/<%= order.id %>/status" class="status-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <select name="status" required>
                <% statuses.forEach((status) => { %>
                  <option value="<%= status %>" <%= status === order.status ? 'selected' : '' %>><%= status %></option>
                <% }) %>
              </select>
              <button type="submit">Save</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('partials/footer') %>
