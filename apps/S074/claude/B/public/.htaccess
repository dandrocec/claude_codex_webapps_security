# Only needed if you serve the app through Apache instead of `php -S`.
# Routes every request that is not a real file to the front controller.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    RewriteRule ^ index.php [L]
</IfModule>

# Defence in depth: never serve dotfiles.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
