{
    "name": "marketplace/multivendor",
    "description": "A secure multi-vendor PHP marketplace (vendors manage products & see own orders; buyers shop across vendors with one cart).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5074 -t public",
        "init-db": "php bin/init-db.php"
    }
}
