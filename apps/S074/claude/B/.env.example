# Copy this file to ".env" and adjust values. Never commit your real .env.
#
# APP_ENV: "local" (developer-friendly errors logged to file) or "production".
APP_ENV=local

# APP_DEBUG: when "false" no internal errors/stack traces are shown to clients.
# Keep this "false" unless you are actively debugging locally.
APP_DEBUG=false

# Secret used to harden session handling. MUST be a long random string.
# Generate one with:  php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_SECRET=change-me-to-a-long-random-value

# Absolute or relative path (relative to project root) to the SQLite database file.
DB_PATH=storage/marketplace.sqlite

# Force the "Secure" flag on session cookies even over plain HTTP.
# Leave as "false" for local http://127.0.0.1 development (otherwise the browser
# will drop the cookie and login will appear to "not work"). Set "true" in any
# environment served over HTTPS.
SESSION_SECURE=false
