<%- include('partials/header', { title: 'Register' }) %>

<h1>Create an account</h1>

<% if (errors && errors.length) { %>
  <ul class="form-errors">
    <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }); %>
  </ul>
<% } %>

<form method="POST" action="/register" class="auth-form" novalidate>
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>
    Username
    <input type="text" name="username" autocomplete="username" required
           minlength="3" maxlength="30" value="<%= values.username || '' %>">
  </label>
  <label>
    Password
    <input type="password" name="password" autocomplete="new-password"
           required minlength="8">
  </label>
  <p class="muted">At least 8 characters.</p>
  <button type="submit" class="button">Register</button>
</form>

<p class="muted">Already have an account? <a href="/login">Log in</a>.</p>

<%- include('partials/footer') %>
