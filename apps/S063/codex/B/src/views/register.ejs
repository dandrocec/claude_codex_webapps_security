<%- include('partials/header') %>
<section class="panel narrow">
  <h1>Create account</h1>
  <form method="post" action="/register" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Username
      <input name="username" value="<%= form.username || '' %>" maxlength="24" autocomplete="username" required>
    </label>
    <label>Display name
      <input name="display_name" value="<%= form.display_name || '' %>" maxlength="60" autocomplete="name" required>
    </label>
    <label>Password
      <input name="password" type="password" minlength="12" maxlength="128" autocomplete="new-password" required>
    </label>
    <button type="submit">Register</button>
  </form>
</section>
<%- include('partials/footer') %>
