<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>mini-social</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">mini-social</a>
    <nav>
      <% if (currentUser) { %>
        <a href="/feed">Feed</a>
        <a href="/people">People</a>
        <a href="/profile/<%= currentUser.username %>">My profile</a>
        <form action="/logout" method="post" class="inline">
          <button type="submit" class="linkbtn">Log out (@<%= currentUser.username %>)</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>
  <main>
