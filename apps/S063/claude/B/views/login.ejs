<%- include('partials/header') %>
<section class="card narrow">
  <h1>Log in</h1>
  <% if (errors && errors.length) { %>
    <ul class="errors">
      <% errors.forEach(function(e){ %><li><%= e.msg %></li><% }) %>
    </ul>
  <% } %>
  <form method="post" action="/login" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Username
      <input type="text" name="username" value="<%= values.username || '' %>" maxlength="30" required>
    </label>
    <label>Password
      <input type="password" name="password" maxlength="200" required>
    </label>
    <button type="submit" class="btn">Log in</button>
  </form>
  <p class="muted">New here? <a href="/register">Create an account</a>.</p>
</section>
<%- include('partials/footer') %>
