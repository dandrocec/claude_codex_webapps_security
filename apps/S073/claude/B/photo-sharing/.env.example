# Copy this file to ".env" and adjust as needed.
# NEVER commit your real .env file.

# Port the server listens on.
PORT=5073

# Set to "production" when deploying behind HTTPS (enables the Secure cookie flag).
NODE_ENV=development

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-value

# Absolute or relative path where uploaded image files are stored (kept OUTSIDE the
# web-served static directory). Defaults to ./var/uploads
UPLOAD_DIR=./var/uploads

# SQLite database file location. Defaults to ./var/app.db
DATABASE_FILE=./var/app.db

# Maximum upload size in bytes (default 5 MB).
MAX_UPLOAD_BYTES=5242880
