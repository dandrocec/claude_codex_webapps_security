<%- include('partials/header') %>
<h1>Create an account</h1>
<% if (errors && errors.length) { %>
  <ul class="errors">
    <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }); %>
  </ul>
<% } %>
<form action="/register" method="post" class="card form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Username
    <input type="text" name="username" value="<%= values.username || '' %>" required
           minlength="3" maxlength="30" pattern="[A-Za-z0-9_]+" autocomplete="username">
  </label>
  <label>Password
    <input type="password" name="password" required minlength="8" maxlength="200" autocomplete="new-password">
  </label>
  <button type="submit">Register</button>
</form>
<p>Already have an account? <a href="/login">Log in</a>.</p>
<%- include('partials/footer') %>
