# Copy this file to .env and fill in real values. NEVER commit your real .env.

# REQUIRED: random secret used to sign session cookies / CSRF tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Shared secret used to sign/verify payment webhook signatures.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# Payment provider: "sandbox" (built-in, no account needed) or "stripe".
PAYMENT_PROVIDER=sandbox

# Public base URL the app is reachable at (used to build payment redirect URLs).
BASE_URL=http://localhost:5089

# Set to 1 only when serving over HTTPS so the Secure cookie flag is enabled.
SESSION_COOKIE_SECURE=0

# Enable Flask debug ONLY for local development. Never in production.
FLASK_DEBUG=0

# Seed admin account (used by `flask --app app seed`). If ADMIN_PASSWORD is left
# blank a strong random password is generated and printed once.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ---- Stripe (only needed when PAYMENT_PROVIDER=stripe) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
