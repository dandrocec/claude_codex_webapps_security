<%- include('partials/header') %>
<h1>Create an account</h1>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<form action="/register" method="post" class="card form">
  <label>Name
    <input type="text" name="name" value="<%= form.name || '' %>" required />
  </label>
  <label>Email
    <input type="email" name="email" value="<%= form.email || '' %>" required />
  </label>
  <label>Password
    <input type="password" name="password" minlength="6" required />
  </label>
  <fieldset class="roles">
    <legend>I am a…</legend>
    <label class="radio"><input type="radio" name="role" value="student" <%= form.role !== 'instructor' ? 'checked' : '' %> /> Student</label>
    <label class="radio"><input type="radio" name="role" value="instructor" <%= form.role === 'instructor' ? 'checked' : '' %> /> Instructor</label>
  </fieldset>
  <button type="submit" class="btn">Register</button>
</form>
<p>Already have an account? <a href="/login">Log in</a>.</p>
<%- include('partials/footer') %>
