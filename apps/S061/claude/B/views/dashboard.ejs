<%- include('partials/header') %>

<% if (currentUser.role === 'instructor') { %>
  <div class="page-head">
    <h1>Your courses</h1>
    <a class="btn" href="/courses/new">+ New course</a>
  </div>

  <% if (!myCourses.length) { %>
    <p class="muted">You haven't created any courses yet.</p>
  <% } else { %>
    <ul class="course-list">
      <% myCourses.forEach(function (c) { %>
        <li class="card">
          <h3><a href="/courses/<%= c.id %>"><%= c.title %></a></h3>
          <p class="muted"><%= c.student_count %> enrolled</p>
        </li>
      <% }); %>
    </ul>
  <% } %>
<% } else { %>
  <div class="page-head">
    <h1>My learning</h1>
    <a class="btn btn-secondary" href="/courses">Browse courses</a>
  </div>

  <% if (!enrolled.length) { %>
    <p class="muted">You're not enrolled in any courses yet. <a href="/courses">Browse the catalog</a>.</p>
  <% } else { %>
    <ul class="course-list">
      <% enrolled.forEach(function (c) { %>
        <li class="card">
          <h3><a href="/courses/<%= c.id %>"><%= c.title %></a></h3>
          <p class="muted">by <%= c.instructor_name %></p>
        </li>
      <% }); %>
    </ul>
  <% } %>
<% } %>

<%- include('partials/footer') %>
