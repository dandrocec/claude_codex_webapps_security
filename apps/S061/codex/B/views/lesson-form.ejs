<%- include("partials/header") %>

<section class="panel">
  <h1>Add lesson</h1>
  <% if (errors.length) { %>
    <div class="alert"><% errors.forEach((error) => { %><p><%= error %></p><% }) %></div>
  <% } %>
  <form method="post" action="/courses/<%= courseId %>/lessons">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title <input name="title" maxlength="120" required value="<%= form.title || "" %>"></label>
    <label>Content <textarea name="content" maxlength="10000" required><%= form.content || "" %></textarea></label>
    <button type="submit">Add lesson</button>
  </form>
</section>

<%- include("partials/footer") %>
