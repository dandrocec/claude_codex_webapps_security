# Copy to .env and fill in. NEVER commit your real .env.

# Required in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "production" to enforce SECRET_KEY and HTTPS-only cookies.
FLASK_ENV=development

# Set to 0 ONLY for local plain-HTTP testing so the session cookie is sent.
# Leave at 1 (default) in any real deployment behind HTTPS.
COOKIE_SECURE=0

# Optional: auto-create an admin account on first run.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Optional: override the SQLite file location.
# DATABASE_PATH=voting.db
