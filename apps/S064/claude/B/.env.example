# Copy this file to ".env" and fill in real values. Never commit ".env".

# Required in production. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Optional. Defaults to a local SQLite file at instance/app.db
# DATABASE_URL=sqlite:///instance/app.db

# Set to true ONLY when serving over HTTPS (enables Secure cookies + HSTS).
SESSION_COOKIE_SECURE=false

# Set to 1 to enable Flask debug locally (never in production).
FLASK_DEBUG=0
