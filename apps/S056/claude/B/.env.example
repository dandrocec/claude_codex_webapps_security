# Copy this file to .env and adjust the values.
# NEVER commit your real .env file.

# Port the API listens on.
PORT=5056

# Secret used to sign JWTs. MUST be long and random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long an access token is valid (e.g. 15m, 1h, 7d).
JWT_EXPIRES_IN=1h

# Set to "production" when deploying behind HTTPS so cookies get the Secure flag.
NODE_ENV=development
