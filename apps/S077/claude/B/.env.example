# Copy to .env and adjust. Never commit your real .env.

# Required in production: a long random string used to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 only when serving over HTTPS (adds Secure flag + HSTS).
# Leave 0 for local http on port 5077.
SECURE_COOKIES=0

# Optional overrides.
PORT=5077
# WIKI_DB_PATH=wiki.db
