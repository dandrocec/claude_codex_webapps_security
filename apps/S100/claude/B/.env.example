# Copy this file to ".env" and fill in real values. Never commit your real .env.
# All secrets are read from the environment — nothing sensitive is hardcoded.

# Port the server listens on.
PORT=5100

# Set to "production" when deploying behind HTTPS. In production the app
# refuses to start unless SESSION_SECRET and SECRETS_KEY are provided, and
# session cookies are marked Secure (HTTPS only).
NODE_ENV=development

# Secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# 32-byte key (hex = 64 chars) used to encrypt service secrets at rest
# with AES-256-GCM. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_KEY=replace-with-64-hex-characters

# Force the Secure flag on cookies even in development (e.g. if you terminate
# TLS in front of the app). Defaults to true in production, false otherwise.
# COOKIE_SECURE=false

# If you run behind a reverse proxy (nginx, etc.) that terminates TLS,
# set this to 1 so secure cookies and rate limiting work correctly.
# TRUST_PROXY=0
