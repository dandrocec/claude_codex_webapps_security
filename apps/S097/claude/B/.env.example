# Copy this file to ".env" and adjust the values before running.
# NEVER commit your real .env file.

# Mandatory: a long, random secret used to sign session cookies & CSRF tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Set to "1" only when serving over HTTPS. Leave at "0" for local HTTP dev,
# otherwise the browser will refuse to send the (Secure) session cookie.
SECURE_COOKIES=0

# Seed admin account (created on first run if it does not exist).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# SQLite database file location (relative paths are fine).
DATABASE=shop.sqlite3
