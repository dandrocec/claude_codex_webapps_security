<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>DocMan</title>
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">📁 DocMan</a>
    <nav>
      <% if (currentUser) { %>
        <a href="/">My Folders</a>
        <a href="/groups">Groups</a>
        <span class="who">Signed in as <strong><%= currentUser.username %></strong></span>
        <form method="post" action="/logout" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="link-btn">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
    <% if (flash && flash.length) { %>
      <ul class="flash">
        <% flash.forEach(function (f) { %>
          <li class="flash-<%= f.type %>"><%= f.message %></li>
        <% }); %>
      </ul>
    <% } %>
