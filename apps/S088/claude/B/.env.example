# Copy this file to ".env" and adjust values. Never commit your real .env.

# Port the server listens on (the assignment requires 5088).
PORT=5088

# Secret used to sign session cookies. MUST be long and random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Set to "true" only when serving over HTTPS (sets the Secure flag on cookies).
# Leave "false" for local plain-HTTP development, otherwise the browser drops the cookie.
COOKIE_SECURE=false

# "development" or "production". In production, detailed errors are never sent to clients.
NODE_ENV=development

# bcrypt cost factor (10-12 is a sensible range; higher = slower = stronger).
BCRYPT_ROUNDS=12

# Maximum upload size in bytes (default 10 MiB).
MAX_UPLOAD_BYTES=10485760
