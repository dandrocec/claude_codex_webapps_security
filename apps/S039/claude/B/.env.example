# Copy to ".env" and adjust. Never commit your real .env file.

# Required in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Optional: path to the SQLite database file.
# DATABASE=instance/app.db

# Secure cookies require HTTPS. Keep "true" in production.
# For plain-HTTP local testing on port 5039, set this to "false".
SESSION_COOKIE_SECURE=false
