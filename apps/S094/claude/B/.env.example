# Copy this file to ".env" and adjust as needed.

# Port the app listens on.
PORT=5094

# Secret used to sign session cookies. MUST be set to a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Set to "true" only when serving over HTTPS (e.g. behind a TLS-terminating proxy).
# When true, session cookies are flagged Secure and will NOT be sent over plain HTTP.
COOKIE_SECURE=false

# Environment: "development" or "production".
NODE_ENV=development

# Path to the SQLite database file.
DB_PATH=./data/hub.db

# --- Outbound request / SSRF guard tuning ---
# Connection + read timeout (ms) for outbound delivery requests.
OUTBOUND_TIMEOUT_MS=5000
# Maximum bytes of an outbound response body we will read/store.
OUTBOUND_MAX_BYTES=65536
# Set to "true" to allow outbound requests to private/loopback ranges.
# Leave false (default). ONLY enable for isolated local testing.
ALLOW_PRIVATE_TARGETS=false
