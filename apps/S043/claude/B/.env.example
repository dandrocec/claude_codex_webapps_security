# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# Port the app listens on
PORT=5043

# Set to "production" when deploying behind HTTPS (enables Secure cookies).
# Leave as "development" for local HTTP testing.
NODE_ENV=development

# Secret used to sign the session cookie. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# When NODE_ENV=production this MUST be true and the app MUST be served over HTTPS.
# For local HTTP testing keep it false so the browser will send the cookie.
COOKIE_SECURE=false
