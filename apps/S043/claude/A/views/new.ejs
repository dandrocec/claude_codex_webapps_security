<%- include('partials/header') %>

<h1>Create a poll</h1>
<form method="post" action="/polls" class="card form" id="poll-form">
  <label>Question
    <input name="question" placeholder="What should we have for lunch?" required>
  </label>

  <fieldset>
    <legend>Options</legend>
    <div id="options">
      <input name="options" placeholder="Option 1" required>
      <input name="options" placeholder="Option 2" required>
    </div>
    <button type="button" class="link-btn" id="add-option">+ Add another option</button>
  </fieldset>

  <button type="submit">Create poll</button>
</form>

<script>
  document.getElementById('add-option').addEventListener('click', function () {
    const wrap = document.getElementById('options');
    const input = document.createElement('input');
    input.name = 'options';
    input.placeholder = 'Option ' + (wrap.children.length + 1);
    wrap.appendChild(input);
    input.focus();
  });
</script>

<%- include('partials/footer') %>
