# Copy to .env and adjust. NEVER commit your real .env.

# REQUIRED in production. A strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# If unset, an ephemeral key is generated at startup (tokens won't survive a restart).
SECRET_KEY=

# Database connection string (parameterised queries via SQLAlchemy ORM).
# Default is a local SQLite file. For Postgres:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/blog
DATABASE_URL=sqlite:///./blog.db

# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Send the "Secure" flag on cookies. MUST be true in production (HTTPS).
# Set to false ONLY for local testing of cookie auth over plain http.
COOKIE_SECURE=true

# Comma-separated list of allowed CORS origins (no wildcard with credentials).
CORS_ORIGINS=http://localhost:5083

# Seed an initial admin account on first run (optional; for local dev).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
