<%- include('partials/header', { title: 'Auction House' }) %>

<section class="intro">
  <div>
    <p class="eyebrow">Live marketplace</p>
    <h1>Bid on active listings or create a timed auction.</h1>
  </div>
  <a class="button" href="/auctions/new">List an item</a>
</section>

<section class="auction-grid" aria-label="Auction listings">
  <% auctions.forEach((auction) => { %>
    <article class="auction-card">
      <div class="card-head">
        <span class="status <%= auction.is_ended ? 'ended' : 'live' %>"><%= auction.status_label %></span>
        <span><%= auction.bid_count %> <%= auction.bid_count === 1 ? 'bid' : 'bids' %></span>
      </div>
      <h2><a href="/auctions/<%= auction.id %>"><%= auction.title %></a></h2>
      <p><%= auction.description %></p>
      <dl class="facts">
        <div>
          <dt>Current price</dt>
          <dd><%= formatMoney(auction.current_price_cents) %></dd>
        </div>
        <div>
          <dt>Ends</dt>
          <dd><%= formatDate(auction.end_time) %></dd>
        </div>
        <div>
          <dt>Seller</dt>
          <dd><%= auction.seller_name %></dd>
        </div>
      </dl>
      <% if (auction.is_ended && auction.high_bidder_name) { %>
        <p class="winner">Winner: <strong><%= auction.high_bidder_name %></strong></p>
      <% } else if (auction.is_ended) { %>
        <p class="winner">Ended with no bids.</p>
      <% } %>
      <a class="text-link" href="/auctions/<%= auction.id %>">View auction</a>
    </article>
  <% }) %>
</section>

<% if (!auctions.length) { %>
  <section class="empty">
    <h2>No auctions yet</h2>
    <p>Create the first listing to start accepting bids.</p>
  </section>
<% } %>

<%- include('partials/footer') %>
