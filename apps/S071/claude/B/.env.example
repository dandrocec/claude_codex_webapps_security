# Copy this file to ".env" and adjust values. Never commit the real .env.

# Port the server listens on.
PORT=5071

# Secret used to sign session cookies. MUST be a long, random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Set to "production" when deploying behind HTTPS.
NODE_ENV=development

# Set to "true" to mark session cookies as Secure (HTTPS-only).
# Leave unset/false for plain-HTTP local development, otherwise the cookie
# will not be sent over http://localhost and you will not stay logged in.
# In production this is forced on automatically.
COOKIE_SECURE=false

# Path to the SQLite database file.
DATABASE_FILE=./data/auction.db
