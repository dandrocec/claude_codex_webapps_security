<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'Auction Site' %></title>
  <link rel="stylesheet" href="/static/style.css" />
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">🛎️ Auction Site</a>
    <nav>
      <% if (currentUser) { %>
        <span class="user">Signed in as <strong><%= currentUser.username %></strong></span>
        <a href="/items/new">Sell an item</a>
        <form method="post" action="/logout" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="link-btn">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
