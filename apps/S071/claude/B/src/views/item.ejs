<%- include('partials/header', { title: item.title }) %>

<article class="item-detail">
  <h1><%= item.title %></h1>
  <p class="meta">Seller: <strong><%= sellerName %></strong></p>
  <% if (item.description) { %>
    <p class="description"><%= item.description %></p>
  <% } %>

  <p>Starting price: <strong><%= item.starting_price.toFixed(2) %></strong></p>

  <% if (highest) { %>
    <p>Current highest bid: <strong><%= highest.amount.toFixed(2) %></strong>
       by <%= highest.bidder_name %></p>
  <% } else { %>
    <p>No bids yet.</p>
  <% } %>

  <% if (ended) { %>
    <p class="status ended-banner">
      This auction ended on <%= item.end_time %> UTC.
      <% if (winner) { %>
        Winner: <strong><%= winner.bidder_name %></strong>
        at <strong><%= winner.amount.toFixed(2) %></strong>.
      <% } else { %>
        No bids were placed.
      <% } %>
    </p>
  <% } else { %>
    <p class="status">Auction ends <%= item.end_time %> UTC.</p>
  <% } %>

  <%- include('partials/errors', { errors: errors }) %>

  <% if (!ended) { %>
    <% if (!currentUser) { %>
      <p><a href="/login">Log in</a> to place a bid.</p>
    <% } else if (isSeller) { %>
      <p><em>You are the seller of this item.</em></p>
    <% } else { %>
      <form method="post" action="/items/<%= item.id %>/bids" class="bid-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>
          Your bid (must exceed <%= minBid.toFixed(2) %>)
          <input type="number" name="amount" min="0.01" step="0.01" required />
        </label>
        <button type="submit">Place bid</button>
      </form>
    <% } %>
  <% } %>

  <% if (canDelete) { %>
    <form method="post" action="/items/<%= item.id %>/delete" class="delete-form"
          onsubmit="return confirm('Delete this listing?');">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="danger">Delete listing</button>
    </form>
  <% } %>

  <% if (history.length) { %>
    <h2>Bid history</h2>
    <table class="bid-history">
      <thead><tr><th>Bidder</th><th>Amount</th><th>Time (UTC)</th></tr></thead>
      <tbody>
        <% history.forEach(function (b) { %>
          <tr>
            <td><%= b.bidder_name %></td>
            <td><%= b.amount.toFixed(2) %></td>
            <td><%= b.created_at %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>

  <p><a href="/">&larr; Back to all auctions</a></p>
</article>

<%- include('partials/footer') %>
