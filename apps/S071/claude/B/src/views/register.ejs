<%- include('partials/header', { title: 'Register' }) %>

<h1>Create an account</h1>
<%- include('partials/errors', { errors: errors }) %>

<form method="post" action="/register" class="card-form" autocomplete="off">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <label>
    Username
    <input type="text" name="username" value="<%= values.username || '' %>"
           required minlength="3" maxlength="32" pattern="[A-Za-z0-9_]+" />
  </label>
  <label>
    Password
    <input type="password" name="password" required minlength="8" maxlength="200" />
  </label>
  <button type="submit">Register</button>
</form>
<p>Already have an account? <a href="/login">Log in</a>.</p>

<%- include('partials/footer') %>
