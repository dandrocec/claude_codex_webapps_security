# Copy this file to ".env" and fill in real values. NEVER commit your real .env.
#
# Application
APP_DEBUG=false

# Set to "true" only when serving over HTTPS (e.g. behind TLS in production).
# When true, session cookies get the Secure flag and HSTS is sent.
FORCE_HTTPS=false

# Absolute or relative (to project root) path to the SQLite database file.
DATABASE_PATH=data/app.sqlite

# Admin credentials for the subscribers list page.
# ADMIN_PASSWORD_HASH must be a bcrypt/argon2 hash, NOT a plaintext password.
# Generate one with:  php bin/generate-admin-hash.php "your-strong-password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
