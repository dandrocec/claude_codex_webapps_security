# Copy this file to ".env" and adjust the values.
# NEVER commit your real .env file.

# Port the gateway listens on
PORT=5096

# Set to "production" when deploying. In production SESSION_SECRET is mandatory
# and secure cookies are enabled by default.
NODE_ENV=development

# Secret used to sign session cookies. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Force the "Secure" flag on cookies. Leave false for local http development,
# set to true behind HTTPS / a TLS-terminating proxy.
COOKIE_SECURE=false

# The backend that valid API requests are proxied to.
# httpbin is handy for trying things out; point this at your own service.
BACKEND_URL=https://httpbin.org

# Default per-key rate limit (requests per minute) applied to newly created keys.
DEFAULT_RATE_LIMIT=60

# Where the SQLite database file lives.
DB_PATH=./data/gateway.db
