# Copy to .env (optional). All values have working defaults.

# Port the gateway listens on.
PORT=5096

# Backend that valid /gateway/* requests are proxied to.
# Defaults to a public test API so things work with no setup.
BACKEND_URL=https://jsonplaceholder.typicode.com

# Path to the SQLite database file (defaults to ./data/gateway.db).
# DB_PATH=./data/gateway.db
