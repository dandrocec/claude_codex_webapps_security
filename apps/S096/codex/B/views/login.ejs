<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login | Secure API Gateway</title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body class="auth-page">
    <main class="auth-panel">
      <h1>API Gateway</h1>
      <p class="muted">Sign in to manage keys and usage.</p>
      <% if (typeof error !== 'undefined') { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="post" action="/login" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          Email
          <input type="email" name="email" autocomplete="email" maxlength="254" required>
        </label>
        <label>
          Password
          <input type="password" name="password" autocomplete="current-password" maxlength="128" required>
        </label>
        <button type="submit">Sign in</button>
      </form>
      <p class="switch-link">New developer? <a href="/register">Create an account</a></p>
    </main>
  </body>
</html>
