# Copy this file to .env and adjust values. Never commit your real .env.

# Secret used to derive session-related values. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-value

# Database connection string (SQLAlchemy URL). Default is local SQLite.
DATABASE_URL=sqlite:///./jobrunner.db

# Set to false ONLY for local plain-HTTP testing, so the session cookie is sent
# over http://127.0.0.1. Keep true in any real/HTTPS deployment.
COOKIE_SECURE=false

# Per-job wall-clock timeout (seconds).
JOB_TIMEOUT_SECONDS=300

# Max captured output stored per job (bytes).
MAX_OUTPUT_BYTES=262144

# Bind address / port.
HOST=127.0.0.1
PORT=5095
