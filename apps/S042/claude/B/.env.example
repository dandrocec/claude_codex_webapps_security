# Copy this file to ".env" and adjust as needed.
# Never commit your real .env file.

# Secret used to sign session cookies and CSRF tokens.
# Generate a strong value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Path to the SQLite database file.
DATABASE=news.db

# Set to "true" ONLY when serving over HTTPS (production).
# For local plain-HTTP development on http://localhost:5042 keep this "false",
# otherwise the browser will refuse to send the session cookie and login won't work.
COOKIE_SECURE=false
