# Copy to .env and adjust. Never commit your real .env.

# Required in production; if unset in development a temporary key is generated.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# "development" (default) or "production".
# In production, secure cookies (Secure flag) and HSTS are enabled, which
# require serving over HTTPS.
PORTAL_ENV=development

# Optional overrides (sensible defaults live under the instance/ directory):
# DATABASE=instance/portal.sqlite3
# UPLOAD_DIR=instance/uploads
