# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Secret used to sign session cookies. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Port the server listens on.
PORT=5024

# Set to "production" when deploying behind HTTPS so cookies get the Secure flag.
# Leave as "development" for local http://localhost testing.
NODE_ENV=development

# Optional: where the SQLite database file lives (defaults to ./data/app.db).
# DATABASE_FILE=./data/app.db
