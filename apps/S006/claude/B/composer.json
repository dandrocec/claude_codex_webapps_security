{
    "name": "example/text-analyzer",
    "description": "A small, security-hardened PHP web app that counts characters, words, and lines in submitted text.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5006 -t public"
    },
    "config": {
        "sort-packages": true
    }
}
