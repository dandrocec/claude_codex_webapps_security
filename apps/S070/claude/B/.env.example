# Copy to .env and adjust. Never commit the real .env.
# A strong random secret used to sign session cookies and CSRF tokens.
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-value

# Port the app listens on (default 5070).
PORT=5070

# Set to true ONLY when serving over HTTPS (enables Secure cookies + HSTS).
SESSION_COOKIE_SECURE=false

# Optional overrides:
# DATABASE_PATH=./recruiting.sqlite3
# UPLOAD_DIR=./uploads
# MAX_UPLOAD_BYTES=5242880
