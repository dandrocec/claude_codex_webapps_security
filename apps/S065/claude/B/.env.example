# Copy this file to ".env" and adjust the values.

# Port the server listens on
PORT=5065

# Node environment: "development" or "production"
NODE_ENV=development

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value

# Set to "true" only when serving over HTTPS so the session cookie gets the Secure flag.
# Leave "false" for local plain-HTTP development.
COOKIE_SECURE=false
