<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'Q&A' %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">Q&amp;A</a>
    <nav>
      <% if (currentUser) { %>
        <span class="muted">Hi, <strong><%= currentUser.username %></strong></span>
        <a class="btn" href="/questions/new">Ask Question</a>
        <form method="post" action="/logout" class="inline">
          <button class="link" type="submit">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a class="btn" href="/register">Register</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="alert"><%= error %></p>
    <% } %>
