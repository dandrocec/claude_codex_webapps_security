<%- include('../partials/header') %>
  <div class="page-head">
    <h1>My Surveys</h1>
    <a class="btn" href="/surveys/new">+ New survey</a>
  </div>

  <% if (surveys.length === 0) { %>
    <p class="muted">You have no surveys yet. Create your first one.</p>
  <% } else { %>
    <table class="data">
      <thead>
        <tr><th>Title</th><th>Created</th><th>Responses</th><th></th></tr>
      </thead>
      <tbody>
        <% surveys.forEach(function (s) { %>
          <tr>
            <td><a href="/surveys/<%= s.id %>"><%= s.title %></a></td>
            <td><%= s.created_at %></td>
            <td><%= s.response_count %></td>
            <td><a href="/surveys/<%= s.id %>/responses">View responses</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
<%- include('../partials/footer') %>
