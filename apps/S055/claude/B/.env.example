# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file.

# Port the app listens on
PORT=5055

# Set to "production" when deploying behind HTTPS so Secure cookies are enforced.
NODE_ENV=development

# Secret used to sign the session cookie. MUST be long and random.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Where the SQLite database file lives.
DB_FILE=./data/survey.db
