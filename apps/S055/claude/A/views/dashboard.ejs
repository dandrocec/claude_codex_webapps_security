<%- include('partials/head', { pageTitle: 'My surveys' }) %>
<div class="page-head">
  <h1>My surveys</h1>
  <a class="btn" href="/surveys/new">+ New survey</a>
</div>

<% if (surveys.length === 0) { %>
  <div class="card empty">
    <p>You haven't created any surveys yet.</p>
    <a class="btn" href="/surveys/new">Create your first survey</a>
  </div>
<% } else { %>
  <div class="grid">
    <% surveys.forEach(function (s) { %>
      <div class="card">
        <h3><a href="/surveys/<%= s.id %>"><%= s.title %></a></h3>
        <% if (s.description) { %><p class="muted"><%= s.description %></p><% } %>
        <p class="meta">
          <span class="pill"><%= s.response_count %> response<%= s.response_count === 1 ? '' : 's' %></span>
          <span class="muted">created <%= s.created_at %></span>
        </p>
        <a href="/surveys/<%= s.id %>">View &amp; share →</a>
      </div>
    <% }); %>
  </div>
<% } %>
<%- include('partials/foot') %>
