# Copy to .env (or export these in your shell) before running.
#
# Required. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-value

# Optional. Set to 1 ONLY for local http development. This disables the
# Secure cookie flag and enables Flask's debugger. Leave unset/0 in production.
FLASK_DEBUG=0

# Optional. Port the dev server listens on (defaults to 5026).
PORT=5026

# Optional. Path to the SQLite database file (defaults to ./blog.db).
# DATABASE_PATH=/var/data/blog.db
