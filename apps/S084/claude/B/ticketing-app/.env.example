# Copy this file to ".env" and adjust the values.

# Port the server listens on.
PORT=5084

# Secret used to sign the session cookie. MUST be set in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value

# Set to "production" when deploying behind HTTPS.
NODE_ENV=development

# Set to "true" ONLY when the app is served over HTTPS (e.g. behind a TLS proxy).
# When true, session cookies get the Secure flag and will NOT be sent over plain HTTP.
COOKIE_SECURE=false

# Path to the SQLite database file.
DB_FILE=./data/ticketing.db
