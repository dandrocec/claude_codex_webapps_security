<%- include('layout/header') %>

<section class="panel auth-panel">
  <h1>Sign in</h1>
  <% if (error) { %><p class="alert"><%= error %></p><% } %>
  <form method="post" action="/login" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="username">Username</label>
    <input id="username" name="username" maxlength="40" autocomplete="username" required>

    <label for="password">Password</label>
    <input id="password" name="password" type="password" maxlength="128" autocomplete="current-password" required>

    <button type="submit">Sign in</button>
  </form>
  <p class="muted">Need an account? <a href="/register">Create one</a>.</p>
</section>

<%- include('layout/footer') %>
