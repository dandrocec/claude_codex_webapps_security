# Copy this file to ".env" and fill in real values. NEVER commit your real .env.

# Port the server listens on.
PORT=5018

# Set to "production" when deploying. In production, secure cookies are enforced
# and the app refuses to start without a strong SESSION_SECRET.
NODE_ENV=development

# Secret used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED in production. In development a random ephemeral secret is generated
# if this is left unset (sessions will not survive a restart).
SESSION_SECRET=

# Path to the SQLite database file.
DATABASE_FILE=./data/app.db
