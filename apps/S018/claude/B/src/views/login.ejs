<%- include('partials/header') %>

<h1>Log in</h1>
<%- include('partials/errors') %>

<form action="/login" method="post" class="card" autocomplete="off">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <label for="username">Username</label>
  <input type="text" id="username" name="username" value="<%= values.username || '' %>"
         required maxlength="32" autofocus>

  <label for="password">Password</label>
  <input type="password" id="password" name="password" required maxlength="200">

  <button type="submit">Log in</button>
</form>

<p>No account? <a href="/register">Register here</a>.</p>

<%- include('partials/footer') %>
