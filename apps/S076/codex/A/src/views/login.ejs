<%- include("partials/head", { title: "Log in" }) %>
<section class="auth-panel">
  <h1>Log in</h1>
  <% if (typeof error !== "undefined" && error) { %>
    <p class="alert"><%= error %></p>
  <% } %>
  <form method="post" action="/login" class="stack">
    <label>
      Username
      <input name="username" autocomplete="username" required minlength="3" maxlength="30">
    </label>
    <label>
      Password
      <input type="password" name="password" autocomplete="current-password" required minlength="6">
    </label>
    <button type="submit">Log in</button>
  </form>
  <p class="swap">Need an account? <a href="/register">Register</a></p>
</section>
<%- include("partials/foot") %>
