# Copy this file to ".env" and adjust the values before running.

# Port the server listens on (assignment requires 5076)
PORT=5076

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Set to "true" only when serving over HTTPS (sets the Secure flag on cookies).
# Leave "false" for local http://localhost development.
COOKIE_SECURE=false

# Node environment: "development" or "production"
NODE_ENV=development
