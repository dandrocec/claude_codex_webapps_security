<%- include('partials/header') %>

<section class="card narrow">
  <h1>Log in</h1>
  <% if (error) { %><p class="alert"><%= error %></p><% } %>
  <form action="/login" method="post" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      Username
      <input type="text" name="username" value="<%= values.username || '' %>"
             required minlength="3" maxlength="32" autofocus>
    </label>
    <label>
      Password
      <input type="password" name="password" required minlength="8" maxlength="200">
    </label>
    <button type="submit">Log in</button>
  </form>
  <p class="muted">No account? <a href="/register">Register here</a>.</p>
</section>

<%- include('partials/footer') %>
