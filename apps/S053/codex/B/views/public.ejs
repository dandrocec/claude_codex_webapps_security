<%- include('partials/header', { title: 'Portfolio' }) %>

<section class="intro">
  <h1>Selected projects</h1>
  <p>A public portfolio of recent work.</p>
</section>

<section class="grid" aria-label="Projects">
  <% if (projects.length === 0) { %>
    <p class="empty">No projects have been published yet.</p>
  <% } %>

  <% projects.forEach((project) => { %>
    <article class="project-card">
      <% if (project.image) { %>
        <img src="<%= project.image %>" alt="">
      <% } %>
      <div class="project-body">
        <h2><%= project.title %></h2>
        <p><%= project.description %></p>
        <% if (project.link) { %>
          <a class="button" href="<%= project.link %>" rel="noopener noreferrer" target="_blank">View project</a>
        <% } %>
      </div>
    </article>
  <% }) %>
</section>

<%- include('partials/footer') %>
