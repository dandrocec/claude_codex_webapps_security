# Copy this file to ".env" and fill in real values. NEVER commit your real .env.

# Port the server listens on.
PORT=5053

# Node environment. Use "production" when deployed behind HTTPS.
NODE_ENV=development

# Session signing secret. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Set to "true" only when the app is served over HTTPS (enables Secure cookies).
# In local HTTP development leave this false, otherwise the cookie won't be sent.
COOKIE_SECURE=false

# Absolute or relative path to the SQLite database file.
DATABASE_PATH=./data/portfolio.db
