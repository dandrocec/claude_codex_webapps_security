<%- include('../partials/head') %>

  <div class="page-head">
    <h1>Your projects</h1>
    <a class="btn" href="/admin/new">+ New project</a>
  </div>

  <% if (projects.length === 0) { %>
    <p class="muted">You haven't added any projects yet.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr><th>Title</th><th>Link</th><th>Created</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% projects.forEach(function (p) { %>
          <tr>
            <td><%= p.title %></td>
            <td>
              <% if (p.link) { %>
                <a href="<%= p.link %>" target="_blank" rel="noopener noreferrer nofollow"><%= p.link %></a>
              <% } else { %><span class="muted">—</span><% } %>
            </td>
            <td><%= p.created_at %></td>
            <td class="actions">
              <a href="/admin/projects/<%= p.id %>/edit">Edit</a>
              <form class="inline" method="post" action="/admin/projects/<%= p.id %>/delete"
                    data-confirm="Delete this project?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="link-btn danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

<%- include('../partials/foot') %>
