<%- include('partials/head') %>

  <h1>Owner login</h1>

  <% if (errors && errors.length) { %>
    <ul class="errors">
      <% errors.forEach(function (e) { %><li><%= e %></li><% }) %>
    </ul>
  <% } %>

  <form class="form" method="post" action="/login" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      Username
      <input type="text" name="username" value="<%= values && values.username ? values.username : '' %>"
             required minlength="3" maxlength="32" autofocus>
    </label>
    <label>
      Password
      <input type="password" name="password" required minlength="10" maxlength="128">
    </label>
    <button type="submit">Log in</button>
  </form>

<%- include('partials/foot') %>
