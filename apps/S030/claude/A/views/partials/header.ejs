<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bookmark Manager</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">🔖 Bookmarks</a>
    <nav>
      <% if (currentUser) { %>
        <span class="who">Signed in as <strong><%= currentUser.username %></strong></span>
        <a class="btn btn-sm" href="/bookmarks/new">+ New</a>
        <form action="/logout" method="POST" class="inline">
          <button class="btn btn-sm btn-ghost" type="submit">Log out</button>
        </form>
      <% } else { %>
        <a class="btn btn-sm" href="/login">Log in</a>
        <a class="btn btn-sm btn-ghost" href="/register">Register</a>
      <% } %>
    </nav>
  </header>

  <main class="container">
    <% (success || []).forEach(function (msg) { %>
      <div class="flash flash-success"><%= msg %></div>
    <% }); %>
    <% (error || []).forEach(function (msg) { %>
      <div class="flash flash-error"><%= msg %></div>
    <% }); %>
