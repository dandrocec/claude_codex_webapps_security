<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="referrer" content="no-referrer">
  <title><%= typeof title !== 'undefined' ? title : 'Bookmark Manager' %></title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/bookmarks">🔖 Bookmarks</a>
    <nav>
      <% if (currentUser) { %>
        <span class="who">Signed in as <strong><%= currentUser.username %></strong></span>
        <a href="/bookmarks/new">New</a>
        <form class="inline" method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="linklike">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
