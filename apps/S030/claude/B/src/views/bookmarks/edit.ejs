<%- include('../partials/header', { title: 'Edit bookmark' }) %>

<h1>Edit bookmark</h1>
<%- include('../partials/errors', { errors: errors }) %>

<form method="post" action="/bookmarks/<%= bookmark.id %>" class="card form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <label for="title">Title</label>
  <input id="title" name="title" type="text" maxlength="200" required
         value="<%= values.title || '' %>">

  <label for="url">URL</label>
  <input id="url" name="url" type="url" maxlength="2048" required
         value="<%= values.url || '' %>">

  <label for="tags">Tags</label>
  <input id="tags" name="tags" type="text" maxlength="500"
         placeholder="comma, separated, tags" value="<%= values.tags || '' %>">
  <small>Separate tags with commas.</small>

  <div class="form-actions">
    <button type="submit">Update</button>
    <a class="button ghost" href="/bookmarks">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
