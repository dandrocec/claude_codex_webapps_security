# Copy this file to ".env" and adjust the values.
# Never commit your real .env file.

# Port the server listens on.
PORT=5030

# Set to "production" when deploying behind HTTPS so that the
# Secure flag is enforced on session cookies.
NODE_ENV=development

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value
