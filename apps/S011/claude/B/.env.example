# Copy to ".env" (or export these in your shell) before running.

# Required for stable sessions. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Port the app listens on.
PORT=5011

# Session cookies are marked Secure by default, which means browsers will only
# send them over HTTPS. For plain-HTTP localhost testing, set this to false so
# login works; leave it true (or unset) for any HTTPS deployment.
SECURE_COOKIES=false
