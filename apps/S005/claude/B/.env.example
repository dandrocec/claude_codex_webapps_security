# Copy to ".env" and adjust, or export these in your shell before running.
# Never commit your real .env file.

# Port the server listens on.
PORT=5005

# "development" or "production". In production, SESSION_SECRET is mandatory
# and session cookies are flagged Secure (requires HTTPS).
NODE_ENV=development

# Strong random secret used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Set to the number of trusted proxy hops if running behind a reverse proxy
# (e.g. nginx, a load balancer). Leave unset for direct local runs.
# TRUST_PROXY=1
