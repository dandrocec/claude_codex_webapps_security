# Copy this file to ".env" and adjust the values.

# Port the HTTP server listens on.
PORT=5098

# REQUIRED in production. A long, random, secret string used to sign session
# cookies. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If left unset, the app generates an ephemeral secret on each start (sessions
# will not survive a restart) and logs a warning.
SESSION_SECRET=

# "development" or "production".
NODE_ENV=development

# Set to "true" only when the app is served over HTTPS (production / behind a
# TLS-terminating proxy). When true, session cookies get the Secure flag and
# will NOT be sent over plain HTTP.
SECURE_COOKIES=false

# Optional: path to the SQLite database file. Defaults to ./data.db
# DB_PATH=./data.db
