# Copy this file to ".env" and fill in real values. Never commit ".env".

# Secret used to sign session cookies and CSRF tokens. REQUIRED.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Set to False for plain-HTTP local development so the session cookie is sent
# over http://127.0.0.1. Set to True (the default) behind HTTPS in production.
SESSION_COOKIE_SECURE=False

# Optional overrides
# DATABASE_PATH=instance/recipes.db
# FLASK_DEBUG=False
