# Copy to ".env" for local development. Real environment variables override these.
# NEVER commit your actual .env file.

# "development" enables on-screen error messages. Use "production" otherwise.
APP_ENV=development

# Path to the SQLite database file (created automatically on first run).
DB_PATH=./data/forum.sqlite

# Session cookie name.
SESSION_NAME=forum_sid

# Set to "true" ONLY when serving over HTTPS so the Secure cookie flag is sent.
SECURE_COOKIE=false
