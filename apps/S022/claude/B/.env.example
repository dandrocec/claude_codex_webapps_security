# Copy to ".env" and adjust, or export these in your shell.
# Secrets are read from the environment and never hardcoded.

# Port the server listens on.
PORT=5022

# Set to "production" to enforce Secure cookies and require COOKIE_SECRET.
NODE_ENV=development

# Secret used to sign the CSRF cookie. REQUIRED in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=
