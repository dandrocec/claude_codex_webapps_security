<%- include('partials/header', { title: 'Log in' }) %>

<h1>Log in</h1>

<% if (errors && errors.length) { %>
  <ul class="errors">
    <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }); %>
  </ul>
<% } %>

<form method="post" action="/login" class="stacked">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <label for="email">Email</label>
  <input id="email" name="email" type="email" autocomplete="username" value="<%= values.email || '' %>" required>

  <label for="password">Password</label>
  <input id="password" name="password" type="password" autocomplete="current-password" required>

  <button type="submit">Log in</button>
</form>

<p>No account? <a href="/register">Sign up</a>.</p>

<%- include('partials/footer') %>
