<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Crowdfund' %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">Crowdfund</a>
    <nav>
      <% if (currentUser) { %>
        <span class="greeting">Hi, <%= currentUser.display_name %></span>
        <a href="/campaigns/new">Start a campaign</a>
        <form class="inline" method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="linkbtn">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register">Sign up</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
