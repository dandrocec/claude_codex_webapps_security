<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">Crowdfund</a>
    <nav class="nav" aria-label="Main navigation">
      <% if (currentUser) { %>
        <span class="muted"><%= currentUser.name %></span>
        <a class="button" href="/campaigns/new">Launch campaign</a>
        <form class="inline-form" action="/logout" method="post">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button class="secondary" type="submit">Sign out</button>
        </form>
      <% } else { %>
        <a href="/login">Sign in</a>
        <a class="button" href="/register">Create account</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>
