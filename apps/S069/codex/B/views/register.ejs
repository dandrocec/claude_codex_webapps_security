<%- include('partials/header') %>
<section class="panel">
  <h1>Create account</h1>
  <%- include('partials/errors') %>
  <form action="/register" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="name">Name</label>
    <input id="name" name="name" value="<%= values.name || '' %>" autocomplete="name" maxlength="80" required>

    <label for="email">Email</label>
    <input id="email" name="email" value="<%= values.email || '' %>" autocomplete="email" maxlength="254" required>

    <label for="password">Password</label>
    <input id="password" name="password" type="password" autocomplete="new-password" minlength="12" maxlength="128" required>

    <p><button type="submit">Create account</button></p>
  </form>
</section>
<%- include('partials/footer') %>
