# Copy to ".env" and fill in. Never commit your real .env.

# REQUIRED: secret used to sign sessions & CSRF tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Where the SQLite file lives (optional; defaults to ./timetracker.db)
# DATABASE_PATH=timetracker.db

# Cookie Secure flag. Leave unset (defaults to true) in production over HTTPS.
# For local plain-HTTP testing on http://localhost:5054 set this to false,
# otherwise the browser will not send the session cookie.
SESSION_COOKIE_SECURE=false

# Port (optional; defaults to 5054)
# PORT=5054
