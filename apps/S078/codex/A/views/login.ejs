<%- include("partials/start", { title }) %>
<section class="login-panel">
  <h1>Pipeline CRM</h1>
  <p>Sign in to manage contacts and move deals through the sales pipeline.</p>
  <% if (typeof error !== "undefined") { %><div class="error"><%= error %></div><% } %>
  <form method="post" action="/login" class="stack">
    <label>Email <input name="email" type="email" required autofocus value="manager@example.com"></label>
    <label>Password <input name="password" type="password" required value="password123"></label>
    <button type="submit">Sign in</button>
  </form>
  <div class="demo-users">
    Demo users: manager@example.com, sam@example.com, riley@example.com<br>
    Password: password123
  </div>
</section>
<%- include("partials/end") %>
