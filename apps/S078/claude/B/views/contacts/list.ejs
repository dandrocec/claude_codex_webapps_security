<%- include('../partials/header') %>
  <div class="page-head">
    <h1>Contacts</h1>
    <a class="btn" href="/contacts/new">+ New contact</a>
  </div>

  <% if (!contacts.length) { %>
    <p class="muted">No contacts yet.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Name</th><th>Company</th><th>Email</th><th>Phone</th>
          <% if (currentUser.role === 'manager') { %><th>Owner</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach(function(c){ %>
          <tr>
            <td><a href="/contacts/<%= c.id %>"><%= c.name %></a></td>
            <td><%= c.company || '—' %></td>
            <td><%= c.email || '—' %></td>
            <td><%= c.phone || '—' %></td>
            <% if (currentUser.role === 'manager') { %><td><%= c.owner_name %></td><% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
<%- include('../partials/footer') %>
