<%- include('partials/head', { pageTitle: 'Sign in' }) %>
  <div class="auth-card">
    <h1>Sign in</h1>
    <% if (error) { %><p class="alert"><%= error %></p><% } %>
    <form method="POST" action="/login">
      <label>Email
        <input type="email" name="email" required autofocus value="alice@example.com" />
      </label>
      <label>Password
        <input type="password" name="password" required value="password" />
      </label>
      <button type="submit" class="btn btn-primary">Sign in</button>
    </form>
    <div class="hint">
      <strong>Demo accounts</strong> (password: <code>password</code>)
      <ul>
        <li><code>manager@example.com</code> — manager, sees the whole team</li>
        <li><code>alice@example.com</code> — sales</li>
        <li><code>bob@example.com</code> — sales</li>
      </ul>
    </div>
  </div>
<%- include('partials/foot') %>
