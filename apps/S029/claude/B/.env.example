# Copy this file to ".env" and adjust the values. Never commit your real .env.

# Used to derive a per-session value and general app secret. Generate a random one:
#   php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_KEY=change-me-to-a-long-random-string

# "production" hides errors from clients (recommended). "development" shows them.
APP_ENV=production

# Absolute or relative path to the SQLite database file.
DB_PATH=data/guestbook.sqlite

# Set to "true" only when serving over HTTPS so the session cookie gets the Secure flag.
# For plain local http://127.0.0.1:5029 testing, keep this "false".
SESSION_SECURE=false

# Optional: create an initial admin account on first boot (admins can delete any message).
# Leave blank to skip. Use a strong password; it is hashed, never stored in plaintext.
ADMIN_USERNAME=
ADMIN_PASSWORD=
