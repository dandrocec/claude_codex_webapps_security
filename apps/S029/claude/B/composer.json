{
    "name": "example/php-guestbook",
    "description": "A secure PHP guestbook: visitors leave a name and message, stored in SQLite and shown newest-first.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5029 -t public public/index.php"
    }
}
