# Copy this file to ".env" and fill in real values. Never commit ".env".

# Required: a long random secret used to sign sessions and CSRF tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Where the SQLite database file lives (optional; defaults to ./app.db)
# DATABASE_PATH=app.db

# Port the dev server listens on.
PORT=5086

# Cookie hardening. Keep TRUE in production (HTTPS). Set to "false" ONLY for
# plain-HTTP local testing, otherwise the browser will refuse to send the
# session cookie over http and login will appear to fail.
SESSION_COOKIE_SECURE=false
