# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Required: a long, random secret used to sign session cookies and CSRF tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# "development" or "production". In production the app refuses to start
# without a SECRET_KEY and enables stricter cookie settings.
FLASK_ENV=development

# Set to "1" only when serving over HTTPS (adds the Secure flag to cookies).
# Leave as "0" for plain-HTTP local development on http://localhost:5008.
SESSION_COOKIE_SECURE=0

# SQLAlchemy database URL. Defaults to a local SQLite file if omitted.
DATABASE_URL=sqlite:///qrapp.db

# Port the development server listens on.
PORT=5008
