# Copy this file to ".env" and adjust as needed. Never commit your real .env.

# Application environment: "production" or "development".
# In production, internal errors are never shown to the client.
APP_ENV=development

# Secret used to harden the session. MUST be set to a long random string.
# Generate one with: php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
APP_KEY=

# Database driver: "sqlite" (default, zero-config) or "mysql".
DB_DRIVER=sqlite

# --- SQLite settings (used when DB_DRIVER=sqlite) ---
# Path to the SQLite file. Relative paths are resolved from the project root.
DB_SQLITE_PATH=storage/database.sqlite

# --- MySQL settings (used when DB_DRIVER=mysql) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=address_book
DB_USER=root
DB_PASS=

# Set to "true" only when serving the app over HTTPS so the session
# cookie is marked Secure. Leave "false" for local http://127.0.0.1.
SESSION_SECURE=false
