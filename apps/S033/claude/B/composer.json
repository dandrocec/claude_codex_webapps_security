{
    "name": "example/php-address-book",
    "description": "A secure PHP address book with user accounts, contacts CRUD, and search.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5033 -t public"
    }
}
