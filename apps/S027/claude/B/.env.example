# Copy this file to ".env" and fill in real values. Never commit your .env.

# Port the server listens on.
PORT=5027

# Set to "production" when deploying behind HTTPS (enables Secure cookies).
NODE_ENV=development

# REQUIRED: a long, random secret used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Optional: override the SQLite database file location.
# DB_PATH=./data/todo.db
