<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>To-Do</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/tasks">✓ To-Do</a>
    <% if (currentUser) { %>
      <div class="user-area">
        <span class="who">Hi, <%= currentUser %></span>
        <form method="POST" action="/logout">
          <button class="btn btn-ghost" type="submit">Log out</button>
        </form>
      </div>
    <% } %>
  </header>
  <main class="container">
