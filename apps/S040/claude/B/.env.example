# Copy this file to ".env" and adjust values. NEVER commit your real .env.

# Application environment: "production" or "development".
# In "development" you see detailed errors; in "production" errors are generic.
APP_ENV=development

# Set to "true" only when serving over HTTPS so the Secure cookie flag is set.
# On plain http://localhost leave this false or the session cookie won't be sent.
APP_HTTPS=false

# Secret used for hashing/signing helpers. Generate a fresh one, e.g.:
#   php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
APP_SECRET=change-me-to-a-long-random-string

# ---- Database ----------------------------------------------------------
# Driver: "sqlite" (default, zero-config) or "mysql".
DB_DRIVER=sqlite

# For sqlite: path to the database file (relative paths are resolved from project root).
DB_SQLITE_PATH=storage/classifieds.sqlite

# For mysql (only used when DB_DRIVER=mysql):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=classifieds
DB_USER=classifieds
DB_PASSWORD=
