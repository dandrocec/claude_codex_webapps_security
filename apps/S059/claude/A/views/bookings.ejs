<%- include('partials/head') %>

<h1>My Bookings</h1>

<% if (flash) { %><p class="flash <%= flash.type %>"><%= flash.msg %></p><% } %>

<% if (bookings.length === 0) { %>
  <p class="muted">You have no bookings yet. <a href="/availability">Find a room →</a></p>
<% } else { %>
  <table class="list">
    <thead>
      <tr><th>Date</th><th>Slot</th><th>Room</th><th></th></tr>
    </thead>
    <tbody>
      <% bookings.forEach(function (b) { %>
        <tr>
          <td><%= b.date %></td>
          <td><%= b.slot %></td>
          <td><%= b.room_name %></td>
          <td class="right">
            <form action="/bookings/<%= b.id %>/cancel" method="post"
                  onsubmit="return confirm('Cancel this booking?');">
              <button type="submit" class="danger">Cancel</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<%- include('partials/foot') %>
