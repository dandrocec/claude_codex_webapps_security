# Copy this file to ".env" and adjust the values.
# NEVER commit your real .env file.

# Port the server listens on
PORT=5059

# Set to "production" when deploying behind HTTPS (enables Secure cookies + HSTS)
NODE_ENV=development

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-secret

# Path to the SQLite database file (created automatically on first run)
DATABASE_FILE=./data/reservations.db
