<%- include('partials/header') %>

<h1>Create an account</h1>

<% if (typeof formErrors !== 'undefined') { %>
  <ul class="errors">
    <% formErrors.forEach(function (e) { %><li><%= e.msg %></li><% }); %>
  </ul>
<% } %>

<form action="/register" method="post" class="card form" autocomplete="off">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>
    Username
    <input type="text" name="username" value="<%= formData.username || '' %>" required minlength="3" maxlength="32">
    <small>3–32 characters: letters, numbers, and . _ -</small>
  </label>
  <label>
    Password
    <input type="password" name="password" required minlength="8" maxlength="72">
    <small>At least 8 characters.</small>
  </label>
  <button type="submit">Register</button>
</form>

<p>Already have an account? <a href="/login">Log in</a>.</p>

<%- include('partials/footer') %>
