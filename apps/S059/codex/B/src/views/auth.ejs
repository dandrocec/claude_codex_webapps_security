<%- include("partials/open", { title }) %>
<section class="panel narrow">
  <h1><%= title %></h1>
  <form method="post" action="<%= action %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      Email
      <input name="email" type="email" maxlength="254" required autocomplete="email">
    </label>
    <label>
      Password
      <input name="password" type="password" minlength="<%= action === '/register' ? 12 : 1 %>" maxlength="128" required autocomplete="<%= action === '/register' ? 'new-password' : 'current-password' %>">
    </label>
    <button type="submit"><%= submitLabel %></button>
  </form>
  <% if (action === "/login") { %>
    <p class="muted">No account yet? <a href="/register">Create one</a>.</p>
  <% } else { %>
    <p class="muted">Already registered? <a href="/login">Sign in</a>.</p>
  <% } %>
</section>
<%- include("partials/close") %>
