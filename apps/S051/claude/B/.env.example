# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file.

# Port the app listens on
PORT=5051

# Secret used to sign the session cookie.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Set to "production" when deploying behind HTTPS.
# In production the session cookie is marked Secure (HTTPS-only).
NODE_ENV=development

# Force Secure cookies even outside production (only works over HTTPS).
# Leave as false for plain-HTTP local development.
COOKIE_SECURE=false
