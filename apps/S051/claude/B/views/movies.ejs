<%- include('partials/header', { title: 'My Watchlist' }) %>

<div class="card">
  <h1>Add a movie</h1>
  <%- include('partials/errors') %>
  <form action="/movies" method="post" class="movie-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="grid">
      <label>
        Title
        <input type="text" name="title" value="<%= values.title || '' %>"
               required maxlength="200" />
      </label>
      <label>
        Year
        <input type="number" name="year" value="<%= values.year || '' %>"
               required min="1888" max="<%= new Date().getFullYear() + 5 %>" />
      </label>
      <label>
        Status
        <select name="status" required>
          <% validStatuses.forEach(function (s) { %>
            <option value="<%= s %>" <%= values.status === s ? 'selected' : '' %>>
              <%= statusLabels[s] %>
            </option>
          <% }); %>
        </select>
      </label>
      <label>
        Rating (1-10, optional)
        <input type="number" name="rating" value="<%= values.rating || '' %>"
               min="1" max="10" />
      </label>
    </div>
    <button type="submit" class="primary">Add movie</button>
  </form>
</div>

<div class="card">
  <div class="list-head">
    <h1>My movies</h1>
    <nav class="filters">
      <a class="<%= activeFilter === 'all' ? 'active' : '' %>" href="/movies">All</a>
      <% validStatuses.forEach(function (s) { %>
        <a class="<%= activeFilter === s ? 'active' : '' %>"
           href="/movies?status=<%= s %>"><%= statusLabels[s] %></a>
      <% }); %>
    </nav>
  </div>

  <% if (!movies.length) { %>
    <p class="muted">No movies yet. Add your first one above.</p>
  <% } else { %>
    <table class="movies">
      <thead>
        <tr>
          <th>Title</th><th>Year</th><th>Status</th><th>Rating</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% movies.forEach(function (m) { %>
          <tr>
            <td><%= m.title %></td>
            <td><%= m.year %></td>
            <td><span class="badge badge-<%= m.status %>"><%= statusLabels[m.status] %></span></td>
            <td><%= m.rating ? m.rating + '/10' : '—' %></td>
            <td>
              <form action="/movies/<%= m.id %>/delete" method="post"
                    class="inline js-confirm" data-confirm="Delete this movie?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="link-btn danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('partials/footer') %>
