<%- include('partials/header', { title: 'Log in' }) %>

<div class="card narrow">
  <h1>Log in</h1>
  <%- include('partials/errors') %>
  <form action="/login" method="post" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>
      Username
      <input type="text" name="username" value="<%= values.username || '' %>"
             required maxlength="32" autofocus />
    </label>
    <label>
      Password
      <input type="password" name="password" required maxlength="128" />
    </label>
    <button type="submit" class="primary">Log in</button>
  </form>
  <p class="muted">No account? <a href="/register">Register</a></p>
</div>

<%- include('partials/footer') %>
