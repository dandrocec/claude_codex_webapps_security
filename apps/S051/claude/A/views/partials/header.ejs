<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Movie Watchlist</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">🎬 Watchlist</a>
    <% if (currentUser) { %>
      <div class="user-box">
        <span>Hi, <strong><%= currentUser %></strong></span>
        <form method="POST" action="/logout">
          <button class="link-btn" type="submit">Log out</button>
        </form>
      </div>
    <% } %>
  </header>
  <main class="container">
