<%- include('partials/header') %>

<section class="card">
  <h2>Add a movie</h2>
  <form class="add-form" method="POST" action="/movies">
    <input type="text" name="title" placeholder="Title" required />
    <input type="number" name="year" placeholder="Year" min="1888" max="2100" />
    <select name="status">
      <% statuses.forEach(function (s) { %>
        <option value="<%= s %>"><%= statusLabels[s] %></option>
      <% }); %>
    </select>
    <input type="number" name="rating" placeholder="Rating 1-10" min="1" max="10" />
    <button type="submit">Add</button>
  </form>
</section>

<section>
  <div class="filters">
    <a class="chip <%= activeFilter === 'all' ? 'active' : '' %>" href="/">All</a>
    <% statuses.forEach(function (s) { %>
      <a class="chip <%= activeFilter === s ? 'active' : '' %>"
         href="/?status=<%= s %>"><%= statusLabels[s] %></a>
    <% }); %>
  </div>

  <% if (movies.length === 0) { %>
    <p class="empty">No movies here yet. Add one above!</p>
  <% } else { %>
    <table class="movies">
      <thead>
        <tr>
          <th>Title</th><th>Year</th><th>Status</th><th>Rating</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% movies.forEach(function (m) { %>
          <tr>
            <td><%= m.title %></td>
            <td><%= m.year || '—' %></td>
            <td><span class="badge badge-<%= m.status %>"><%= statusLabels[m.status] %></span></td>
            <td><%= m.rating != null ? m.rating + '/10' : '—' %></td>
            <td>
              <form method="POST" action="/movies/<%= m.id %>/delete"
                    onsubmit="return confirm('Remove this movie?');">
                <button class="link-btn danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/footer') %>
