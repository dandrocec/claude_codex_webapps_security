# Copy to .env (or export these in your shell) and adjust.
# NEVER commit real secrets.

# Required in production. A long random string used to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Set to true when serving over HTTPS so the session cookie gets the Secure flag
# (and HSTS is sent). Leave false for local plain-HTTP testing on port 5010.
COOKIE_SECURE=false

# Network binding
HOST=127.0.0.1
PORT=5010

# Upload policy
MAX_UPLOAD_BYTES=5242880

# Storage locations (defaults are fine for local use)
# UPLOAD_DIR=./uploads
# DB_PATH=./data/app.db
