<%- include('partials/header') %>
<h1>Create an account</h1>
<% if (error) { %><p class="alert error"><%= error %></p><% } %>
<form method="post" action="/register" class="card">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Username
    <input type="text" name="username" autocomplete="username"
           value="<%= values.username || '' %>" required
           pattern="[A-Za-z0-9_.\-]{3,32}">
    <small>3-32 characters: letters, digits, dot, underscore, hyphen.</small>
  </label>
  <label>Password
    <input type="password" name="password" autocomplete="new-password" required minlength="10">
    <small>At least 10 characters.</small>
  </label>
  <button type="submit">Register</button>
</form>
<p>Already have an account? <a href="/login">Log in</a></p>
<%- include('partials/footer') %>
