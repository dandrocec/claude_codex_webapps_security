# Copy this file to ".env" and fill in real values before running.

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Port the server listens on.
PORT=5082

# Set to "true" only when serving over HTTPS (enables the Secure cookie flag).
# Leave unset/false for plain-HTTP local development.
COOKIE_SECURE=false

# Maximum upload size in bytes (default 10 MiB).
MAX_UPLOAD_BYTES=10485760
