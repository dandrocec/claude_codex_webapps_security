<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>File Vault</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">📁 File Vault</a>
    <nav>
      <% if (currentUser) { %>
        <a href="/">My Files</a>
        <a href="/shares">Share Links</a>
        <span class="who">@<%= currentUser.username %></span>
        <form method="post" action="/logout" class="inline">
          <button type="submit" class="link-btn">Log out</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>

  <main>
    <% if (messages.error && messages.error.length) { %>
      <% messages.error.forEach(function (m) { %>
        <div class="flash flash-error"><%= m %></div>
      <% }) %>
    <% } %>
    <% if (messages.success && messages.success.length) { %>
      <% messages.success.forEach(function (m) { %>
        <div class="flash flash-success"><%= m %></div>
      <% }) %>
    <% } %>
