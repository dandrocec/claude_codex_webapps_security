<%- include('partials/header') %>
<%
  function fmtSize(n) {
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
    return (n / 1024 / 1024).toFixed(1) + ' MB';
  }
%>

<section class="card">
  <h1>My Files</h1>
  <form method="post" action="/files" enctype="multipart/form-data" class="upload-form">
    <input type="file" name="file" required />
    <button type="submit">Upload</button>
  </form>
</section>

<section class="card">
  <% if (files.length === 0) { %>
    <p class="muted">No files yet. Upload one above to get started.</p>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Name</th><th>Size</th><th>Uploaded</th><th>Shares</th><th></th></tr>
      </thead>
      <tbody>
        <% files.forEach(function (f) { %>
          <tr>
            <td class="name"><%= f.original_name %></td>
            <td><%= fmtSize(f.size_bytes) %></td>
            <td class="muted"><%= f.created_at %> UTC</td>
            <td>
              <% if (f.active_shares > 0) { %>
                <span class="badge"><%= f.active_shares %> active</span>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>
            <td class="actions">
              <a class="btn-sm" href="/files/<%= f.id %>/download">Download</a>
              <form method="post" action="/files/<%= f.id %>/shares" class="inline">
                <button type="submit" class="btn-sm">Create share link</button>
              </form>
              <form method="post" action="/files/<%= f.id %>/delete" class="inline"
                    onsubmit="return confirm('Delete this file and all its share links?');">
                <button type="submit" class="btn-sm danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/footer') %>
