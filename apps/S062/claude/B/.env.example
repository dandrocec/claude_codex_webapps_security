# Copy to `.env` and adjust. NEVER commit your real .env.

# Required in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Optional. Defaults to ./helpdesk.db
# DATABASE_PATH=helpdesk.db

# Set to true ONLY for local development (enables the debugger, disables
# Secure-cookie enforcement so login works over plain HTTP).
FLASK_DEBUG=false

# Force-disable Secure cookies if you run the prod build over plain HTTP.
# SESSION_COOKIE_SECURE=false
