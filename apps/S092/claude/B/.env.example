# Copy this file to ".env" and adjust values. Never commit your real .env.

# Port the app listens on (assignment requires 5092)
PORT=5092

# Node environment: "development" or "production"
NODE_ENV=development

# Secret used to sign the session cookie. MUST be a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value

# Set to "true" ONLY when serving over HTTPS (production). Over plain http on
# localhost this must remain "false", otherwise the browser drops the cookie.
COOKIE_SECURE=false

# Filesystem path to the SQLite database file.
DB_PATH=./data/clinic.db
