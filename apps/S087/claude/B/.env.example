# Copy this file to `.env` and adjust values. NEVER commit your real .env.

# Mandatory. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The value below is for LOCAL DEVELOPMENT ONLY — replace it for any real use.
SECRET_KEY=dev-only-change-me-0123456789abcdef0123456789abcdef

# Database. Defaults to a local SQLite file if omitted.
# Postgres example: postgresql+psycopg://user:pass@localhost:5432/saas
DATABASE_URL=sqlite:///./app.db

# Set to "true" when served over HTTPS so the session cookie gets the Secure
# flag. For plain-HTTP local testing on http://localhost set it to "false".
SESSION_COOKIE_SECURE=false

# "development" or "production". Affects HSTS / logging behaviour.
ENVIRONMENT=development
