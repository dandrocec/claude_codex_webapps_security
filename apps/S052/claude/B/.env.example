# Copy to .env and adjust. NEVER commit a real .env.

# Required: signs session cookies & CSRF tokens. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to true ONLY for local HTTP testing. Leave true/unset behind HTTPS so the
# session cookie carries the Secure flag.
SESSION_COOKIE_SECURE=false

# Optional overrides
PORT=5052
# DATABASE=instance/tickets.sqlite3
# FLASK_DEBUG=false
