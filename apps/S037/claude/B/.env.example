# Copy this file to ".env" and adjust the values. Never commit your real .env.
#
# The app reads configuration from environment variables and contains no
# hardcoded secrets. The bootstrap will load a local ".env" file if present
# (simple KEY=VALUE lines), but in a real deployment you should set these in
# the process environment instead. Values already in the environment win.

# "production" or "development". Controls whether detailed errors are shown.
# Defaults to "production" (no stack traces leaked to clients).
APP_ENV=development

# Absolute or relative path to the SQLite database file.
# Defaults to storage/database.sqlite
# DB_PATH=storage/database.sqlite

# Directory where uploaded files are stored. MUST be outside the web root.
# Defaults to storage/uploads
# UPLOAD_DIR=storage/uploads

# Maximum accepted upload size in bytes. Defaults to 5242880 (5 MB).
# MAX_UPLOAD_BYTES=5242880

# Force the "Secure" flag on session cookies even over plain HTTP.
# Leave empty for local HTTP development; set to "1" behind HTTPS.
# By default the flag is enabled automatically when the request is HTTPS.
# FORCE_SECURE_COOKIE=0
