# Copy this file to .env and fill in real values. Never commit .env.

# Required. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Session/CSRF cookies are sent only over HTTPS when true.
# Keep "true" in production. Set to "false" ONLY for local plain-HTTP testing.
SESSION_COOKIE_SECURE=false

# Optional overrides
# PORT=5047
# HOST=127.0.0.1
# DATABASE_PATH=instance/inventory.sqlite3
