# Copy to .env and adjust. Never commit your real .env.

# Required in production; auto-generated for local dev if unset.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "production" to require SECRET_KEY and harden defaults.
FLASK_ENV=development

# Secure cookies need HTTPS. For plain-HTTP localhost testing, set to 0.
SESSION_COOKIE_SECURE=0

# Optional: override the SQLite file location.
# DATABASE_PATH=wiki.db
