# Copy this file to ".env" and adjust the values before running.

# Port the server listens on.
PORT=5048

# Set to "production" when deploying behind HTTPS so secure cookies are enforced.
NODE_ENV=development

# Secret used to sign the session cookie. MUST be long and random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Seed reviewer account. These are used by `npm run seed` to create the login.
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=ChangeMe!2026
