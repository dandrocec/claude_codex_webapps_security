{
    "name": "quotes/app",
    "description": "A small, secure PHP quotes application (submit, approve, list, filter, edit).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "scripts": {
        "start": "php -S 127.0.0.1:5046 -t public",
        "init-db": "php bin/init-db.php"
    },
    "config": {
        "sort-packages": true
    }
}
