# Copy this file to ".env" and adjust the values.
# NEVER commit your real .env file.

# Application environment: "production" or "development".
# In production, internal errors are never shown to the client.
APP_ENV=development

# Secret used to derive/secure session and CSRF state.
# Generate a strong random value, e.g.:  php -r "echo bin2hex(random_bytes(32));"
APP_KEY=change-me-to-a-long-random-string

# Database (SQLite by default — no server required).
# Path is relative to the project root unless absolute.
DB_DSN=sqlite:data/quotes.sqlite

# Set to "true" only when serving the app over HTTPS so the
# session cookie gets the Secure flag. Leave "false" for plain
# http://localhost during local development.
SESSION_SECURE=false
