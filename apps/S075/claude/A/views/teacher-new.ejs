<%- include('partials/head', { title: 'Create a quiz' }) %>

<h1>Create a quiz</h1>
<p class="muted">Add questions, fill in the options, and mark the one correct answer per question.</p>

<form id="quiz-form">
  <label class="field">
    <span>Quiz title</span>
    <input type="text" id="quiz-title" placeholder="e.g. Geography Basics" required />
  </label>

  <div id="questions"></div>

  <div class="actions">
    <button type="button" class="btn" id="add-question">+ Add question</button>
    <button type="submit" class="btn btn-primary">Save quiz</button>
  </div>

  <div id="form-errors" class="errors" hidden></div>
</form>

<!-- Template for one question block -->
<template id="question-template">
  <fieldset class="card question">
    <legend>Question <span class="q-index"></span></legend>
    <button type="button" class="btn btn-ghost remove-question">Remove</button>
    <label class="field">
      <span>Question text</span>
      <input type="text" class="q-text" placeholder="Type the question" required />
    </label>
    <p class="muted small">Select the radio button next to the correct answer.</p>
    <div class="options"></div>
    <button type="button" class="btn btn-ghost add-option">+ Add option</button>
  </fieldset>
</template>

<!-- Template for one option row -->
<template id="option-template">
  <div class="option-row">
    <input type="radio" class="o-correct" title="Mark as correct answer" />
    <input type="text" class="o-text" placeholder="Answer option" required />
    <button type="button" class="btn btn-ghost remove-option" title="Remove option">×</button>
  </div>
</template>

<script src="/teacher-new.js"></script>

<%- include('partials/foot') %>
