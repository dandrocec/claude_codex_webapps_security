<%- include('partials/head', { title: quiz.title }) %>

<h1><%= quiz.title %></h1>

<% if (questions.length === 0) { %>
  <p class="muted">This quiz has no questions yet.</p>
<% } else { %>
  <form method="POST" action="/quiz/<%= quiz.id %>/submit">
    <% questions.forEach(function (q, qi) { %>
      <fieldset class="card question">
        <legend><span class="q-num"><%= qi + 1 %>.</span> <%= q.text %></legend>
        <% q.options.forEach(function (o) { %>
          <label class="option">
            <input type="radio" name="question_<%= q.id %>" value="<%= o.id %>" required />
            <span><%= o.text %></span>
          </label>
        <% }) %>
      </fieldset>
    <% }) %>
    <button type="submit" class="btn btn-primary">Submit answers</button>
  </form>
<% } %>

<%- include('partials/foot') %>
