<%- include('partials/header') %>
<section class="card narrow">
  <h1>Register</h1>
  <%- include('partials/errors') %>
  <form method="post" action="/register" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      Username
      <input type="text" name="username" value="<%= values.username || '' %>" required minlength="3" maxlength="32">
    </label>
    <label>
      Password
      <input type="password" name="password" required minlength="8" maxlength="128">
      <small>At least 8 characters.</small>
    </label>
    <fieldset>
      <legend>I am a…</legend>
      <label class="radio">
        <input type="radio" name="role" value="student" <%= values.role !== 'teacher' ? 'checked' : '' %>>
        Student
      </label>
      <label class="radio">
        <input type="radio" name="role" value="teacher" <%= values.role === 'teacher' ? 'checked' : '' %>>
        Teacher
      </label>
    </fieldset>
    <button type="submit">Create account</button>
  </form>
  <p>Already registered? <a href="/login">Log in</a></p>
</section>
<%- include('partials/footer') %>
