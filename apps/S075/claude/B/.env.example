# Copy this file to ".env" and adjust values. Never commit your real .env.

# Port the app listens on (the assignment requires 5075).
PORT=5075

# Session secret — MUST be a long, random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value

# Set to "production" behind HTTPS so cookies get the Secure flag.
# In "development" the Secure flag is relaxed so the app works over plain http://localhost.
NODE_ENV=development

# Path to the SQLite database file.
DATABASE_FILE=./data/quiz.db
