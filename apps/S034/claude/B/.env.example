# Copy to .env and fill in. Never commit the real .env.

# Required in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to "production" to require SECRET_KEY and enable strict behaviour.
FLASK_ENV=development

# Optional. Defaults to OFF in development and ON in production.
# Force with 1 (HTTPS-only) or 0 (allow plain HTTP, local testing only).
# SESSION_COOKIE_SECURE=1

# Optional: override the SQLite file location.
# DATABASE=instance/reading_list.sqlite3
