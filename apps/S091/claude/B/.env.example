# Copy to .env and adjust. NEVER commit a real .env.
# A strong random secret is required in production. If unset, a random one is
# generated at startup (sessions will not survive a restart).
SECRET_KEY=change-me-to-a-long-random-string

# SQLAlchemy database URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./microblog.db

# Bind address / port for the web server.
HOST=127.0.0.1
PORT=5091

# Cookie hardening.
#   COOKIE_SECURE must be "true" in production (HTTPS). It is "false" here so the
#   app works over plain http://localhost during local development.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_TTL_HOURS=24

# Run the background worker as an in-process thread. Set to "false" if you prefer
# to run a dedicated worker process via `python worker.py`.
WORKER_ENABLED=true

# Link-preview fetcher (SSRF-hardened) limits.
LINK_PREVIEW_TIMEOUT=5
LINK_PREVIEW_MAX_BYTES=524288

# Never enable in production: exposes detailed errors.
DEBUG=false
